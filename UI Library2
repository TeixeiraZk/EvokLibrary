    local SavedList = Evok.ConfigManager:GetConfigs()
    if #SavedList == 0 then
        table.insert(SavedList, "Nenhuma")
    end

    ConfigBox:Dropdown({
        Name = "Saved Configs",
        Options = SavedList,
        Default = SavedList[1],
        Flag = "Config_SavedList",
        Callback = function(val)
            if val ~= "Nenhuma" then
                SelectedConfig = val
                
                if Evok.Flags["Config_InputName"] then
                    Evok.Flags["Config_InputName"]:Set(val)
                end
            end
        end
    })
    
    ConfigBox:Button({
        Name = "Refresh Config List",
        Callback = function()
            local newList = Evok.ConfigManager:GetConfigs()
            
            if #newList == 0 then
                table.insert(newList, "Nenhuma")
            end
            
            if Evok.Flags["Config_SavedList"] then
                Evok.Flags["Config_SavedList"]:Set(newList)
            end
            
            Evok:Notify({
                Title = "Config Manager",
                Content = "Lista de configurações atualizada.",
                Duration = 2,
                Type = "Info"
            })
        end
    })
    
    ConfigBox:Button({
        Name = "Delete Config",
        Callback = function()
            if SelectedConfig ~= "" and SelectedConfig ~= "Nenhuma" then
                Evok.ConfigManager:Delete(SelectedConfig)
                
                local newList = Evok.ConfigManager:GetConfigs()
                if #newList == 0 then
                    table.insert(newList, "Nenhuma")
                end
                
                if Evok.Flags["Config_SavedList"] then
                    Evok.Flags["Config_SavedList"]:Set(newList)
                end
                
                if Evok.Flags["Config_InputName"] then
                    Evok.Flags["Config_InputName"]:Set("")
                end
            end
        end
    })

    -- ==========================================
    -- CONFIGURAÇÕES VISUAIS GERAIS
    -- ==========================================
    VisualsBox:Toggle({
        Name = "Show Watermark",
        Default = false,
        Flag = "UI_Watermark",
        Callback = function(val)
            if Evok.Registry.WatermarkFrame then
                Evok.Registry.WatermarkFrame.Visible = val
            end
        end
    })
    
    VisualsBox:Keybind({
        Name = "Menu Toggle Key",
        Default = Enum.KeyCode.RightShift,
        Flag = "UI_MenuKey",
        Callback = function()
            Evok.MenuOpen = not Evok.MenuOpen
            
            -- Puxando o MainFrame da UI Global
            local MainFrame = EvokGui:FindFirstChild("Evok_Main")
            if MainFrame then
                MainFrame.Visible = Evok.MenuOpen
            end
        end
    })
    
    VisualsBox:Button({
        Name = "Unload UI",
        Callback = function()
            if EvokGui then
                EvokGui:Destroy()
            end
            
            -- Limpando conexões de memória
            for _, conn in pairs(Evok.Connections) do
                if typeof(conn) == "RBXScriptConnection" then
                    conn:Disconnect()
                end
            end
            
            -- Limpando o ESP se estiver ativo
            for _, drawings in pairs(Evok.ESP.Cache) do
                for _, drawing in pairs(drawings) do
                    if drawing.Remove then
                        drawing:Remove()
                    end
                end
            end
        end
    })
end

-- ========================================================================
-- 27. ESP ENGINE WRAPPER (SISTEMA DE DRAWING API / WALLHACK)
-- ========================================================================
Evok.ESP = {
    Enabled = false,
    
    Boxes = false,
    BoxColor = Color3.fromRGB(255, 255, 255),
    
    Names = false,
    NameColor = Color3.fromRGB(255, 255, 255),
    
    Distances = false,
    DistanceColor = Color3.fromRGB(150, 150, 150),
    
    HealthBars = false,
    
    Tracers = false,
    TracerColor = Color3.fromRGB(255, 255, 255),
    TracerOrigin = "Bottom", -- Top, Mouse, Bottom
    
    TeamCheck = false,
    MaxDistance = 2500,
    TextSize = 13,
    
    Cache = {},
    Camera = workspace.CurrentCamera
}

local function GetDrawings()
    -- Verificação de segurança caso o executor não tenha Drawing API
    local hasDrawing = type(Drawing) == "table" and type(Drawing.new) == "function"
    
    if not hasDrawing then return nil end
    
    return {
        Box = Drawing.new("Square"),
        BoxOutline = Drawing.new("Square"),
        
        HealthBar = Drawing.new("Square"),
        HealthBarOutline = Drawing.new("Square"),
        
        Name = Drawing.new("Text"),
        Distance = Drawing.new("Text"),
        Tracer = Drawing.new("Line")
    }
end

function Evok.ESP:Init()
    local hasDrawing = type(Drawing) == "table" and type(Drawing.new) == "function"
    
    if not hasDrawing then
        warn("[Evok V5 Ultimate] O seu executor não suporta Drawing API. O módulo de ESP foi desativado por segurança.")
        return
    end

    local function CreatePlayerCache(player)
        if player == LocalPlayer then 
            return 
        end
        
        local drawings = GetDrawings()
        if not drawings then return end
        
        self.Cache[player] = drawings
        
        -- Configuração Padrão Box Outline
        self.Cache[player].BoxOutline.Thickness = 3
        self.Cache[player].BoxOutline.Filled = false
        self.Cache[player].BoxOutline.Transparency = 1
        self.Cache[player].BoxOutline.Color = Color3.new(0, 0, 0)
        self.Cache[player].BoxOutline.Visible = false
        
        -- Configuração Padrão Box
        self.Cache[player].Box.Thickness = 1
        self.Cache[player].Box.Filled = false
        self.Cache[player].Box.Transparency = 1
        self.Cache[player].Box.Color = self.BoxColor
        self.Cache[player].Box.Visible = false
        
        -- Configuração HealthBar Outline
        self.Cache[player].HealthBarOutline.Thickness = 1
        self.Cache[player].HealthBarOutline.Filled = true
        self.Cache[player].HealthBarOutline.Transparency = 1
        self.Cache[player].HealthBarOutline.Color = Color3.new(0, 0, 0)
        self.Cache[player].HealthBarOutline.Visible = false
        
        -- Configuração HealthBar Fill
        self.Cache[player].HealthBar.Thickness = 1
        self.Cache[player].HealthBar.Filled = true
        self.Cache[player].HealthBar.Transparency = 1
        self.Cache[player].HealthBar.Color = Color3.new(0, 1, 0)
        self.Cache[player].HealthBar.Visible = false
        
        -- Configuração Name
        self.Cache[player].Name.Size = self.TextSize
        self.Cache[player].Name.Center = true
        self.Cache[player].Name.Outline = true
        self.Cache[player].Name.Color = self.NameColor
        self.Cache[player].Name.Visible = false
        
        -- Configuração Distance
        self.Cache[player].Distance.Size = self.TextSize - 1
        self.Cache[player].Distance.Center = true
        self.Cache[player].Distance.Outline = true
        self.Cache[player].Distance.Color = self.DistanceColor
        self.Cache[player].Distance.Visible = false
        
        -- Configuração Tracer
        self.Cache[player].Tracer.Thickness = 1
        self.Cache[player].Tracer.Transparency = 1
        self.Cache[player].Tracer.Color = self.TracerColor
        self.Cache[player].Tracer.Visible = false
    end

    local function RemovePlayerCache(player)
        if self.Cache[player] then
            for _, drawing in pairs(self.Cache[player]) do
                drawing:Remove()
            end
            self.Cache[player] = nil
        end
    end

    for _, player in ipairs(Players:GetPlayers()) do
        CreatePlayerCache(player)
    end

    table.insert(Evok.Connections, Players.PlayerAdded:Connect(function(player)
        CreatePlayerCache(player)
    end))

    table.insert(Evok.Connections, Players.PlayerRemoving:Connect(function(player)
        RemovePlayerCache(player)
    end))

    -- Render Loop Principal do ESP
    table.insert(Evok.Connections, RunService.RenderStepped:Connect(function()
        for player, drawings in pairs(self.Cache) do
            local character = player.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            local humanoid = character and character:FindFirstChild("Humanoid")
            
            if self.Enabled and character and rootPart and humanoid and humanoid.Health > 0 then
                
                if self.TeamCheck and player.Team == LocalPlayer.Team then
                    drawings.Box.Visible = false
                    drawings.BoxOutline.Visible = false
                    drawings.HealthBar.Visible = false
                    drawings.HealthBarOutline.Visible = false
                    drawings.Name.Visible = false
                    drawings.Distance.Visible = false
                    drawings.Tracer.Visible = false
                    continue
                end

                local distRaw = (self.Camera.CFrame.Position - rootPart.Position).Magnitude
                
                if distRaw > self.MaxDistance then
                    drawings.Box.Visible = false
                    drawings.BoxOutline.Visible = false
                    drawings.HealthBar.Visible = false
                    drawings.HealthBarOutline.Visible = false
                    drawings.Name.Visible = false
                    drawings.Distance.Visible = false
                    drawings.Tracer.Visible = false
                    continue
                end

                local screenPos, onScreen = self.Camera:WorldToViewportPoint(rootPart.Position)
                
                if onScreen then
                    local head = character:FindFirstChild("Head")
                    local headPos = head and self.Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0)) or screenPos
                    local legPos = self.Camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0))
                    
                    local height = math.abs(headPos.Y - legPos.Y)
                    local width = height / 2
                    
                    local boxSize = Vector2.new(width, height)
                    local boxPos = Vector2.new(screenPos.X - width / 2, screenPos.Y - height / 2)

                    if self.Boxes then
                        drawings.BoxOutline.Size = boxSize
                        drawings.BoxOutline.Position = boxPos
                        drawings.BoxOutline.Visible = true
                        
                        drawings.Box.Size = boxSize
                        drawings.Box.Position = boxPos
                        drawings.Box.Color = self.BoxColor
                        drawings.Box.Visible = true
                    else
                        drawings.Box.Visible = false
                        drawings.BoxOutline.Visible = false
                    end

                    if self.HealthBars then
                        local hpPct = humanoid.Health / humanoid.MaxHealth
                        local hpColor = Color3.fromHSV(math.clamp(hpPct, 0, 1) * 0.3, 1, 1)
                        
                        local hpBarWidth = 2
                        local hpBarHeight = height * hpPct
                        
                        local hpOutlinePos = Vector2.new(boxPos.X - 5, boxPos.Y - 1)
                        local hpOutlineSize = Vector2.new(hpBarWidth + 2, height + 2)
                        
                        local hpFillPos = Vector2.new(boxPos.X - 4, boxPos.Y + height - hpBarHeight)
                        local hpFillSize = Vector2.new(hpBarWidth, hpBarHeight)
                        
                        drawings.HealthBarOutline.Size = hpOutlineSize
                        drawings.HealthBarOutline.Position = hpOutlinePos
                        drawings.HealthBarOutline.Visible = true
                        
                        drawings.HealthBar.Size = hpFillSize
                        drawings.HealthBar.Position = hpFillPos
                        drawings.HealthBar.Color = hpColor
                        drawings.HealthBar.Visible = true
                    else
                        drawings.HealthBar.Visible = false
                        drawings.HealthBarOutline.Visible = false
                    end

                    if self.Names then
                        drawings.Name.Text = player.Name
                        drawings.Name.Position = Vector2.new(screenPos.X, boxPos.Y - 15 - self.TextSize)
                        drawings.Name.Color = self.NameColor
                        drawings.Name.Visible = true
                    else
                        drawings.Name.Visible = false
                    end
                    
                    if self.Distances then
                        local mathDist = math.floor(distRaw)
                        drawings.Distance.Text = "[" .. tostring(mathDist) .. " studs]"
                        drawings.Distance.Position = Vector2.new(screenPos.X, boxPos.Y + height + 5)
                        drawings.Distance.Color = self.DistanceColor
                        drawings.Distance.Visible = true
                    else
                        drawings.Distance.Visible = false
                    end

                    if self.Tracers then
                        local originPos = Vector2.new(self.Camera.ViewportSize.X / 2, self.Camera.ViewportSize.Y)
                        
                        if self.TracerOrigin == "Top" then
                            originPos = Vector2.new(self.Camera.ViewportSize.X / 2, 0)
                        elseif self.TracerOrigin == "Mouse" then
                            local mouse = UserInputService:GetMouseLocation()
                            originPos = mouse
                        end
                        
                        drawings.Tracer.From = originPos
                        drawings.Tracer.To = Vector2.new(screenPos.X, boxPos.Y + height)
                        drawings.Tracer.Color = self.TracerColor
                        drawings.Tracer.Visible = true
                    else
                        drawings.Tracer.Visible = false
                    end
                else
                    drawings.Box.Visible = false
                    drawings.BoxOutline.Visible = false
                    drawings.HealthBar.Visible = false
                    drawings.HealthBarOutline.Visible = false
                    drawings.Name.Visible = false
                    drawings.Distance.Visible = false
                    drawings.Tracer.Visible = false
                end
            else
                drawings.Box.Visible = false
                drawings.BoxOutline.Visible = false
                drawings.HealthBar.Visible = false
                drawings.HealthBarOutline.Visible = false
                drawings.Name.Visible = false
                drawings.Distance.Visible = false
                drawings.Tracer.Visible = false
            end
        end
    end))
end

return Evok

