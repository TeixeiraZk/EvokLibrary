function Evok:SetWatermark(config)
    local wmText = config.Text or "Evok V5 Ultimate"
    local wmVisible = config.Visible or false
    
    if not self.Registry.WatermarkFrame then
        local WMFrame = Utility:Create("Frame", {
            Name = "Evok_Watermark",
            Size = UDim2.new(0, 200, 0, 28),
            Position = UDim2.new(0, 15, 0, 15),
            BackgroundColor3 = self:GetTheme("Background"),
            BorderColor3 = self:GetTheme("Border"),
            BorderSizePixel = 1,
            Visible = false,
            ZIndex = 100,
            Parent = EvokGui
        })
        
        Utility:Create("UICorner", {
            CornerRadius = UDim.new(0, 6),
            Parent = WMFrame
        })
        
        local WMInnerBorder = Utility:Create("UIStroke", {
            Color = self:GetTheme("Border"),
            Thickness = 1,
            LineJoinMode = Enum.LineJoinMode.Miter,
            Parent = WMFrame
        })

        local WMLabel = Utility:Create("TextLabel", {
            Name = "Label",
            Size = UDim2.new(1, -20, 1, 0),
            Position = UDim2.new(0, 10, 0, 0),
            BackgroundTransparency = 1,
            Text = "",
            TextColor3 = self:GetTheme("Text"),
            Font = Enum.Font.Code,
            TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left,
            RichText = true,
            ZIndex = 101,
            Parent = WMFrame
        })
        
        self.Registry.WatermarkFrame = WMFrame
        self.Registry.WatermarkLabel = WMLabel
        
        table.insert(self.Connections, RunService.RenderStepped:Connect(function(deltaTime)
            if not self.Registry.WatermarkFrame.Visible then 
                return 
            end
            
            local fps = math.floor(1 / deltaTime)
            local ping = "0"
            
            local success, stats = pcall(function() 
                return game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValueString() 
            end)
            
            if success and stats then
                ping = string.match(stats, "%d+") or "0"
            end
            
            local memory = math.floor(game:GetService("Stats"):GetTotalMemoryUsageMb())
            local timeStr = os.date("%X")
            
            local hexAccent = Evok.ColorSpace:RGBToHEX(self:GetTheme("Accent")):gsub("#", "")
            
            local finalString = string.format(
                "<font color='#%s'>%s</font> | %s fps | %s ms | %s MB | %s", 
                hexAccent, 
                wmText, 
                tostring(fps), 
                ping, 
                tostring(memory),
                timeStr
            )
            
            self.Registry.WatermarkLabel.Text = finalString
            
            local plainText = string.format("%s | %s fps | %s ms | %s MB | %s", wmText, fps, ping, memory, timeStr)
            
            local TextWidth = TextService:GetTextSize(
                plainText, 
                12, 
                Enum.Font.Code, 
                Vector2.new(1000, 25)
            ).X
            
            self.Registry.WatermarkFrame.Size = UDim2.new(0, TextWidth + 20, 0, 28)
        end))
    end
    
    self.Registry.WatermarkFrame.Visible = wmVisible
end

return Evok

