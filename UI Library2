                        HueIndicator.Position = UDim2.new(0, -2, Hue, -1)
                        UpdateColor()
                    end
                end)

                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        MapDragging = false
                        HueDragging = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseMovement then
                        if MapDragging then
                            local pctX = math.clamp((input.Position.X - SatValMap.AbsolutePosition.X) / SatValMap.AbsoluteSize.X, 0, 1)
                            local pctY = math.clamp((input.Position.Y - SatValMap.AbsolutePosition.Y) / SatValMap.AbsoluteSize.Y, 0, 1)
                            Sat = pctX
                            Val = 1 - pctY
                            MapIndicator.Position = UDim2.new(Sat, -2, 1 - Val, -2)
                            UpdateColor()
                        elseif HueDragging then
                            local pctY = math.clamp((input.Position.Y - HueSlider.AbsolutePosition.Y) / HueSlider.AbsoluteSize.Y, 0, 1)
                            Hue = pctY
                            HueIndicator.Position = UDim2.new(0, -2, Hue, -1)
                            UpdateColor()
                        end
                    end
                end)

                HexInput.FocusLost:Connect(function()
                    local success, result = pcall(function()
                        return Evok.ColorSpace:HEXToRGB(HexInput.Text)
                    end)
                    
                    if success and result then
                        Hue, Sat, Val = Evok.ColorSpace:RGBToHSV(result)
                        MapIndicator.Position = UDim2.new(Sat, -2, 1 - Val, -2)
                        HueIndicator.Position = UDim2.new(0, -2, Hue, -1)
                        UpdateColor()
                    else
                        HexInput.Text = Evok.ColorSpace:RGBToHEX(CPButton.BackgroundColor3)
                    end
                end)

                CPButton.MouseButton1Click:Connect(function()
                    IsOpen = not IsOpen
                    CPopup.Visible = IsOpen
                end)

                Evok.Flags[CPFlag] = {
                    Value = CPDefault,
                    Set = function(self, val)
                        Hue, Sat, Val = Evok.ColorSpace:RGBToHSV(val)
                        MapIndicator.Position = UDim2.new(Sat, -2, 1 - Val, -2)
                        HueIndicator.Position = UDim2.new(0, -2, Hue, -1)
                        UpdateColor()
                    end
                }
            end

            -- ========================================================================
            -- 22. ELEMENTO: MULTI-DROPDOWN (CORREÇÃO DO TAMANHO DA CAIXA VAZIA)
            -- ========================================================================
            function Elements:MultiDropdown(multiConfig)
                local DropName = multiConfig.Name or "Multi Dropdown"
                local DropOptions = multiConfig.Options or {}
                local DropDefault = multiConfig.Default or {}
                local DropFlag = multiConfig.Flag or DropName
                local DropCallback = multiConfig.Callback or function() end
                
                local SelectedOptions = {}
                for _, v in ipairs(DropDefault) do
                    SelectedOptions[v] = true
                end
                
                local IsOpen = false

                local DropFrame = Utility:Create("Frame", {
                    Name = DropName .. "_MultiDropdown",
                    Size = UDim2.new(1, 0, 0, 40),
                    BackgroundTransparency = 1,
                    ClipsDescendants = true,
                    Parent = GroupContainer
                })

                local DropTitle = Utility:Create("TextLabel", {
                    Name = "Title",
                    Size = UDim2.new(1, 0, 0, 16),
                    BackgroundTransparency = 1,
                    Text = DropName,
                    TextColor3 = Evok:GetTheme("Text"),
                    Font = Enum.Font.Code,
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = DropFrame
                })

                local function GetSelectedString()
                    local str = ""
                    local count = 0
                    
                    for k, v in pairs(SelectedOptions) do
                        if v then
                            str = str .. k .. ", "
                            count = count + 1
                        end
                    end
                    
                    if count == 0 then 
                        return "None" 
                    end
                    
                    return string.sub(str, 1, -3)
                end

                local DropButton = Utility:Create("TextButton", {
                    Name = "MainButton",
                    Size = UDim2.new(1, 0, 0, 22),
                    Position = UDim2.new(0, 0, 0, 18),
                    BackgroundColor3 = Evok:GetTheme("ElementBg"),
                    BorderColor3 = Evok:GetTheme("Border"),
                    BorderSizePixel = 1,
                    Text = "  " .. GetSelectedString(),
                    TextColor3 = Evok:GetTheme("TextMuted"),
                    Font = Enum.Font.Code,
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextTruncate = Enum.TextTruncate.AtEnd,
                    AutoButtonColor = false,
                    Parent = DropFrame
                })
                
                Utility:Create("UICorner", {
                    CornerRadius = UDim.new(0, 4),
                    Parent = DropButton
                })

                local DropArrow = Utility:Create("TextLabel", {
                    Name = "Arrow",
                    Size = UDim2.new(0, 20, 1, 0),
                    Position = UDim2.new(1, -20, 0, 0),
                    BackgroundTransparency = 1,
                    Text = "▼",
                    TextColor3 = Evok:GetTheme("TextMuted"),
                    Font = Enum.Font.Code,
                    TextSize = 10,
                    Parent = DropButton
                })

                local DropScroll = Utility:Create("ScrollingFrame", {
                    Name = "OptionsScroll",
                    Size = UDim2.new(1, -4, 0, 0),
                    Position = UDim2.new(0, 2, 0, 45),
                    BackgroundTransparency = 1,
                    ScrollBarThickness = 2,
                    BorderSizePixel = 0,
                    Parent = DropFrame
                })

                local DropListLayout = Utility:Create("UIListLayout", {
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    Padding = UDim.new(0, 2),
                    Parent = DropScroll
                })

                local OptionButtons = {}

                local function BuildOptions()
                    for _, child in pairs(DropScroll:GetChildren()) do
                        if child:IsA("TextButton") then 
                            child:Destroy() 
                        end
                    end
                    
                    table.clear(OptionButtons)
                    local TotalY = 0

                    for _, option in ipairs(DropOptions) do
                        local IsSelected = SelectedOptions[option] or false

                        local OptBtn = Utility:Create("TextButton", {
                            Name = "Option_" .. option,
                            Size = UDim2.new(1, 0, 0, 22),
                            BackgroundColor3 = IsSelected and Evok:GetTheme("Accent") or Evok:GetTheme("GroupboxBg"),
                            BorderSizePixel = 0,
                            Text = "  " .. option,
                            TextColor3 = IsSelected and Evok:GetTheme("Background") or Evok:GetTheme("TextMuted"),
                            Font = Enum.Font.Code,
                            TextSize = 11,
                            TextXAlignment = Enum.TextXAlignment.Left,
                            Parent = DropScroll
                        })
                        
                        Utility:Create("UICorner", {
                            CornerRadius = UDim.new(0, 4),
                            Parent = OptBtn
                        })
                        
                        TotalY = TotalY + 24
                        table.insert(OptionButtons, OptBtn)

                        OptBtn.MouseButton1Click:Connect(function()
                            SelectedOptions[option] = not SelectedOptions[option]
                            local active = SelectedOptions[option]
                            
                            Evok.Tween(OptBtn, {
                                BackgroundColor3 = active and Evok:GetTheme("Accent") or Evok:GetTheme("GroupboxBg"),
                                TextColor3 = active and Evok:GetTheme("Background") or Evok:GetTheme("TextMuted")
                            }, 0.15)

                            DropButton.Text = "  " .. GetSelectedString()
                            
                            local ActiveTable = {}
                            for k, v in pairs(SelectedOptions) do
                                if v then 
                                    table.insert(ActiveTable, k) 
                                end
                            end

                            if Evok.Flags[DropFlag] then
                                Evok.Flags[DropFlag].Value = ActiveTable
                            end
                            
                            DropCallback(ActiveTable)
                        end)
                    end
                    
                    DropScroll.CanvasSize = UDim2.new(0, 0, 0, TotalY)
                    return TotalY
                end

                DropButton.MouseButton1Click:Connect(function()
                    IsOpen = not IsOpen
                    if IsOpen then
                        local listHeight = BuildOptions()
                        
                        -- CÁLCULO EXATO PARA NÃO SOBRAR ESPAÇO VAZIO
                        local finalSize = math.clamp(listHeight, 40, 150)
                        
                        Evok.Tween(DropFrame, {
                            Size = UDim2.new(1, 0, 0, finalSize + 45)
                        }, 0.2)
                        
                        Evok.Tween(DropScroll, {
                            Size = UDim2.new(1, -4, 0, finalSize)
                        }, 0.2)
                        
                        DropArrow.Text = "▲"
                    else
                        Evok.Tween(DropFrame, {
                            Size = UDim2.new(1, 0, 0, 40)
                        }, 0.2)
                        
                        Evok.Tween(DropScroll, {
                            Size = UDim2.new(1, -4, 0, 0)
                        }, 0.2)
                        
                        DropArrow.Text = "▼"
                    end
                end)

                Evok.Flags[DropFlag] = {
                    Value = DropDefault,
                    Set = function(self, valTable)
                        SelectedOptions = {}
                        for _, v in ipairs(valTable) do
                            SelectedOptions[v] = true
                        end
                        DropButton.Text = "  " .. GetSelectedString()
                        BuildOptions()
                        DropCallback(valTable)
                    end
                }
            end

            return Elements
        end

        return TabLogic
    end

    return WindowLogic
end

