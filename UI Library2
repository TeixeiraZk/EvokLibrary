function Evok:Notify(config)
    local notifTitle = config.Title or "Evok Ultimate"
    local notifText = config.Content or ""
    local notifDur = config.Duration or 3
    local notifType = config.Type or "Info" 
    
    if not self.Registry.NotifyContainer then
        local NContainer = Utility:Create("Frame", {
            Name = "Evok_NotifyContainer",
            Size = UDim2.new(0, 300, 1, -40),
            Position = UDim2.new(1, -320, 0, 20),
            BackgroundTransparency = 1,
            ZIndex = 100,
            Parent = EvokGui
        })
        
        Utility:Create("UIListLayout", {
            SortOrder = Enum.SortOrder.LayoutOrder,
            VerticalAlignment = Enum.VerticalAlignment.Bottom,
            Padding = UDim.new(0, 10),
            Parent = NContainer
        })
        
        self.Registry.NotifyContainer = NContainer
    end
    
    local TypeColor = self:GetTheme("Accent")
    if notifType == "Warning" then
        TypeColor = Color3.fromRGB(255, 170, 0)
    elseif notifType == "Error" then
        TypeColor = self:GetTheme("Warning")
    end

    local NotifFrame = Utility:Create("Frame", {
        Name = "Notification_" .. HttpService:GenerateGUID(false),
        Size = UDim2.new(1, 50, 0, 75), 
        BackgroundColor3 = self:GetTheme("GroupboxBg"),
        BorderColor3 = self:GetTheme("Border"),
        BorderSizePixel = 1,
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        Parent = self.Registry.NotifyContainer
    })
    
    Utility:Create("UICorner", {
        CornerRadius = UDim.new(0, 6),
        Parent = NotifFrame
    })

    local NTitle = Utility:Create("TextLabel", {
        Name = "Title",
        Size = UDim2.new(1, -20, 0, 20),
        Position = UDim2.new(0, 10, 0, 5),
        BackgroundTransparency = 1,
        Text = notifTitle,
        TextColor3 = TypeColor,
        Font = Enum.Font.Code,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTransparency = 1,
        Parent = NotifFrame
    })

    local NDesc = Utility:Create("TextLabel", {
        Name = "Description",
        Size = UDim2.new(1, -20, 0, 40),
        Position = UDim2.new(0, 10, 0, 25),
        BackgroundTransparency = 1,
        Text = notifText,
        TextColor3 = self:GetTheme("TextMuted"),
        Font = Enum.Font.Code,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        TextTransparency = 1,
        Parent = NotifFrame
    })

    -- Barra de Progresso
    local ProgressBarBG = Utility:Create("Frame", {
        Name = "ProgressBG",
        Size = UDim2.new(1, 0, 0, 3),
        Position = UDim2.new(0, 0, 1, -3),
        BackgroundColor3 = self:GetTheme("Background"),
        BorderSizePixel = 0,
        BackgroundTransparency = 1,
        Parent = NotifFrame
    })

    local ProgressBarFill = Utility:Create("Frame", {
        Name = "ProgressFill",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = TypeColor,
        BorderSizePixel = 0,
        BackgroundTransparency = 1,
        Parent = ProgressBarBG
    })

    -- Animação de Entrada
    Evok.Tween(NotifFrame, {
        Size = UDim2.new(1, 0, 0, 75),
        BackgroundTransparency = 0
    }, 0.3)
    
    Evok.Tween(NTitle, {TextTransparency = 0}, 0.3)
    Evok.Tween(NDesc, {TextTransparency = 0}, 0.3)
    Evok.Tween(ProgressBarBG, {BackgroundTransparency = 0}, 0.3)
    Evok.Tween(ProgressBarFill, {BackgroundTransparency = 0}, 0.3)

    -- Anima a barra de progresso encolhendo ao longo do tempo
    local ProgressTween = TweenService:Create(
        ProgressBarFill,
        TweenInfo.new(notifDur, Enum.EasingStyle.Linear, Enum.EasingDirection.Out),
        {Size = UDim2.new(0, 0, 1, 0)}
    )
    
    ProgressTween:Play()

    -- Timer de Destruição
    task.delay(notifDur, function()
        Evok.Tween(NotifFrame, {
            Size = UDim2.new(1, 50, 0, 75),
            BackgroundTransparency = 1
        }, 0.3)
        
        Evok.Tween(NTitle, {TextTransparency = 1}, 0.3)
        Evok.Tween(ProgressBarBG, {BackgroundTransparency = 1}, 0.3)
        Evok.Tween(ProgressBarFill, {BackgroundTransparency = 1}, 0.3)
        
        local fadeOut = Evok.Tween(NDesc, {TextTransparency = 1}, 0.3)
        
        fadeOut.Completed:Connect(function()
            NotifFrame:Destroy()
        end)
    end)
end

