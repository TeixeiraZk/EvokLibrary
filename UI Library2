                    ScrollBarThickness = 2,
                    BorderSizePixel = 0,
                    Parent = DropFrame
                })

                local DropListLayout = Utility:Create("UIListLayout", {
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    Padding = UDim.new(0, 2),
                    Parent = DropScroll
                })

                local function BuildOptions()
                    for _, child in pairs(DropScroll:GetChildren()) do
                        if child:IsA("TextButton") then child:Destroy() end
                    end

                    local TotalY = 0

                    for _, option in ipairs(DropOptions) do
                        local OptBtn = Utility:Create("TextButton", {
                            Name = option,
                            Size = UDim2.new(1, 0, 0, 22),
                            BackgroundColor3 = DropValue == option and Evok:GetTheme("Accent") or Evok:GetTheme("GroupboxBg"),
                            BorderSizePixel = 0,
                            Text = "  " .. option,
                            TextColor3 = DropValue == option and Evok:GetTheme("Background") or Evok:GetTheme("TextMuted"),
                            Font = Enum.Font.Code,
                            TextSize = 11,
                            TextXAlignment = Enum.TextXAlignment.Left,
                            Parent = DropScroll
                        })
                        
                        Utility:Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = OptBtn })
                        
                        TotalY = TotalY + 24

                        OptBtn.MouseButton1Click:Connect(function()
                            DropValue = option
                            DropButton.Text = "  " .. option
                            Evok.Flags[DropFlag] = { Value = DropValue }
                            DropCallback(DropValue)
                            
                            IsOpen = false
                            Evok.Tween(DropFrame, { Size = UDim2.new(1, 0, 0, 40) }, 0.2)
                            Evok.Tween(DropScroll, { Size = UDim2.new(1, -4, 0, 0) }, 0.2)
                            DropArrow.Text = "▼"
                        end)
                    end
                    
                    DropScroll.CanvasSize = UDim2.new(0, 0, 0, TotalY)
                    return TotalY
                end

                DropButton.MouseButton1Click:Connect(function()
                    IsOpen = not IsOpen
                    if IsOpen then
                        local listHeight = BuildOptions()
                        -- CORREÇÃO: CALCULA O TAMANHO REAL (SEM BURACO PRETO)
                        local finalSize = math.clamp(listHeight, 40, 150)
                        
                        Evok.Tween(DropFrame, { Size = UDim2.new(1, 0, 0, finalSize + 45) }, 0.2)
                        Evok.Tween(DropScroll, { Size = UDim2.new(1, -4, 0, finalSize) }, 0.2)
                        DropArrow.Text = "▲"
                    else
                        Evok.Tween(DropFrame, { Size = UDim2.new(1, 0, 0, 40) }, 0.2)
                        Evok.Tween(DropScroll, { Size = UDim2.new(1, -4, 0, 0) }, 0.2)
                        DropArrow.Text = "▼"
                    end
                end)

                Evok.Flags[DropFlag] = {
                    Value = DropValue,
                    Set = function(self, val)
                        DropValue = val
                        DropButton.Text = "  " .. val
                        DropCallback(val)
                    end
                }
            end

