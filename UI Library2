-- 3. COLOR SPACE ENGINE (HSV, RGB, HEX, HSL, CMYK)
-- ========================================================================
function Evok.ColorSpace:RGBToHSV(color)
    local r = color.R
    local g = color.G
    local b = color.B
    
    local max = math.max(r, g, b)
    local min = math.min(r, g, b)
    local h, s, v
    
    v = max
    local d = max - min
    
    if max == 0 then 
        s = 0 
    else 
        s = d / max 
    end
    
    if max == min then 
        h = 0 
    else
        if max == r then 
            h = (g - b) / d + (g < b and 6 or 0)
        elseif max == g then 
            h = (b - r) / d + 2
        elseif max == b then 
            h = (r - g) / d + 4 
        end
        h = h / 6
    end
    
    return h, s, v
end

function Evok.ColorSpace:HSVToRGB(h, s, v)
    local r, g, b
    local i = math.floor(h * 6)
    local f = h * 6 - i
    local p = v * (1 - s)
    local q = v * (1 - f * s)
    local t = v * (1 - (1 - f) * s)
    
    i = i % 6
    
    if i == 0 then 
        r, g, b = v, t, p
    elseif i == 1 then 
        r, g, b = q, v, p
    elseif i == 2 then 
        r, g, b = p, v, t
    elseif i == 3 then 
        r, g, b = p, q, v
    elseif i == 4 then 
        r, g, b = t, p, v
    elseif i == 5 then 
        r, g, b = v, p, q 
    end
    
    return Color3.new(r, g, b)
end

function Evok.ColorSpace:HEXToRGB(hex)
    hex = hex:gsub("#", "")
    local r = tonumber("0x"..hex:sub(1,2))
    local g = tonumber("0x"..hex:sub(3,4))
    local b = tonumber("0x"..hex:sub(5,6))
    
    return Color3.fromRGB(r, g, b)
end

function Evok.ColorSpace:RGBToHEX(color)
    local r = math.floor(color.R * 255)
    local g = math.floor(color.G * 255)
    local b = math.floor(color.B * 255)
    
    return string.format("#%02X%02X%02X", r, g, b)
end

function Evok.ColorSpace:RGBToHSL(color)
    local r = color.R
    local g = color.G
    local b = color.B
    local max = math.max(r, g, b)
    local min = math.min(r, g, b)
    local h, s, l
    l = (max + min) / 2
    if max == min then
        h = 0
        s = 0
    else
        local d = max - min
        s = l > 0.5 and d / (2 - max - min) or d / (max + min)
        if max == r then
            h = (g - b) / d + (g < b and 6 or 0)
        elseif max == g then
            h = (b - r) / d + 2
        elseif max == b then
            h = (r - g) / d + 4
        end
        h = h / 6
    end
    return h, s, l
end

function Evok.ColorSpace:RGBToCMYK(color)
    local r = color.R
    local g = color.G
    local b = color.B
    
    if r == 0 and g == 0 and b == 0 then
        return 0, 0, 0, 1
    end
    
    local c = 1 - r
    local m = 1 - g
    local y = 1 - b
    
    local k = math.min(c, math.min(m, y))
    
    c = (c - k) / (1 - k)
    m = (m - k) / (1 - k)
    y = (y - k) / (1 - k)
    
    return c, m, y, k
end

-- ========================================================================
-- 4. EASING ENGINE (TWEENS CUSTOMIZADOS)
-- ========================================================================
local PI = math.pi
local HALF_PI = math.pi / 2

function Evok.Easing.Linear(t, b, c, d) 
    return c * t / d + b 
end

function Evok.Easing.InQuad(t, b, c, d) 
    t = t / d
    return c * math.pow(t, 2) + b 
end

function Evok.Easing.OutQuad(t, b, c, d) 
    t = t / d
    return -c * t * (t - 2) + b 
end

function Evok.Easing.InOutQuad(t, b, c, d) 
    t = t / (d / 2)
    if t < 1 then 
        return c / 2 * math.pow(t, 2) + b 
    end
    t = t - 1
    return -c / 2 * (t * (t - 2) - 1) + b 
end

function Evok.Easing.InCubic(t, b, c, d) 
    t = t / d
    return c * math.pow(t, 3) + b 
end

function Evok.Easing.OutCubic(t, b, c, d) 
    t = t / d - 1
    return c * (math.pow(t, 3) + 1) + b 
end

function Evok.Easing.InOutCubic(t, b, c, d) 
    t = t / (d / 2)
    if t < 1 then 
        return c / 2 * math.pow(t, 3) + b 
    end
    t = t - 2
    return c / 2 * (math.pow(t, 3) + 2) + b 
end

function Evok.Easing.InQuart(t, b, c, d) 
    t = t / d
    return c * math.pow(t, 4) + b 
end

function Evok.Easing.OutQuart(t, b, c, d) 
    t = t / d - 1
    return -c * (math.pow(t, 4) - 1) + b 
end

function Evok.Easing.InOutQuart(t, b, c, d) 
    t = t / (d / 2)
    if t < 1 then 
        return c / 2 * math.pow(t, 4) + b 
    end
    t = t - 2
    return -c / 2 * (math.pow(t, 4) - 2) + b 
end

function Evok.Easing.InQuint(t, b, c, d) 
    t = t / d
    return c * math.pow(t, 5) + b 
end

function Evok.Easing.OutQuint(t, b, c, d) 
    t = t / d - 1
    return c * (math.pow(t, 5) + 1) + b 
end

function Evok.Easing.InOutQuint(t, b, c, d) 
    t = t / (d / 2)
    if t < 1 then 
        return c / 2 * math.pow(t, 5) + b 
    end
    t = t - 2
    return c / 2 * (math.pow(t, 5) + 2) + b 
end

function Evok.Easing.InSine(t, b, c, d) 
    return -c * math.cos(t / d * HALF_PI) + c + b 
end

function Evok.Easing.OutSine(t, b, c, d) 
    return c * math.sin(t / d * HALF_PI) + b 
end

function Evok.Easing.InOutSine(t, b, c, d) 
    return -c / 2 * (math.cos(PI * t / d) - 1) + b 
end

function Evok.Easing.InExpo(t, b, c, d) 
    if t == 0 then 
        return b 
    end
    return c * math.pow(2, 10 * (t / d - 1)) + b - c * 0.001 
end

function Evok.Easing.OutExpo(t, b, c, d) 
    if t == d then 
        return b + c 
    end
    return c * 1.001 * (-math.pow(2, -10 * t / d) + 1) + b 
end

function Evok.Easing.InCirc(t, b, c, d)
    t = t / d
    return -c * (math.sqrt(1 - math.pow(t, 2)) - 1) + b
end

function Evok.Easing.OutCirc(t, b, c, d)
    t = t / d - 1
    return c * math.sqrt(1 - math.pow(t, 2)) + b
end

function Evok.Easing.OutBounce(t, b, c, d)
    t = t / d
    if t < (1 / 2.75) then
        return c * (7.5625 * t * t) + b
    elseif t < (2 / 2.75) then
        t = t - (1.5 / 2.75)
        return c * (7.5625 * t * t + 0.75) + b
    elseif t < (2.5 / 2.75) then
        t = t - (2.25 / 2.75)
        return c * (7.5625 * t * t + 0.9375) + b
    else
        t = t - (2.625 / 2.75)
        return c * (7.5625 * t * t + 0.984375) + b
    end
end

