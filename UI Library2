                    Text = "",
                    AutoButtonColor = false,
                    Parent = SldFrame
                })
                    Utility:Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = Track })
                -- CORREÇÃO: ARREDONDAR TRACK DO SLIDER
                Utility:Create("UICorner", {
                    CornerRadius = UDim.new(0, 4),
                    Parent = SldTrack
                })

                local SldFillPct = math.clamp((SldValue - SldMin) / (SldMax - SldMin), 0, 1)

                local SldFill = Utility:Create("Frame", {
                    Name = "Fill",
                    Size = UDim2.new(SldFillPct, 0, 1, 0),
                    BackgroundColor3 = Evok:GetTheme("Accent"),
                    BorderSizePixel = 0,
                    Parent = SldTrack
                })
                    Utility:Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = Fill })

                -- CORREÇÃO: ARREDONDAR FILL DO SLIDER
                Utility:Create("UICorner", {
                    CornerRadius = UDim.new(0, 4),
                    Parent = SldFill
                })

                local SldThumb = Utility:Create("Frame", {
                    Name = "Thumb",
                    Size = UDim2.new(0, 16, 0, 16),
                    Position = UDim2.new(1, -8, 0.5, -8),
                    BackgroundColor3 = Evok:GetTheme("Thumb"),
                    BorderSizePixel = 0,
                    Parent = SldFill
                })
                
                Utility:Create("UICorner", {
                    CornerRadius = UDim.new(1, 0),
                    Parent = SldThumb
                })

                local SldDisplay = Utility:Create("TextLabel", {
                    Name = "ValueDisplay",
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text = tostring(SldValue) .. "/" .. tostring(SldMax),
                    TextColor3 = Evok:GetTheme("Text"),
                    Font = Enum.Font.Code,
                    TextSize = 11,
                    Parent = SldTrack
                })

                local dragging = false
                
                local function UpdateSlider(input)
                    local trackAbsPos = SldTrack.AbsolutePosition.X
                    local trackAbsSize = SldTrack.AbsoluteSize.X
                    
                    local percent = math.clamp((input.Position.X - trackAbsPos) / trackAbsSize, 0, 1)
                    local rawValue = SldMin + ((SldMax - SldMin) * percent)
                    
                    SldValue = math.floor(rawValue)
                    SldDisplay.Text = tostring(SldValue) .. "/" .. tostring(SldMax)
                    
                    Evok.Tween(SldFill, {
                        Size = UDim2.new(percent, 0, 1, 0)
                    }, 0.1)
                    
                    Evok.Flags[SldFlag] = { Value = SldValue }
                    SldCallback(SldValue)
                end

                SldTrack.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                        UpdateSlider(input)
                    end
                end)

                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        UpdateSlider(input)
                    end
                end)

                Evok.Flags[SldFlag] = {
                    Value = SldValue,
                    Set = function(self, newVal)
                        SldValue = math.clamp(newVal, SldMin, SldMax)
                        local newPct = (SldValue - SldMin) / (SldMax - SldMin)
                        SldDisplay.Text = tostring(SldValue) .. "/" .. tostring(SldMax)
                        Evok.Tween(SldFill, { Size = UDim2.new(newPct, 0, 1, 0) }, 0.1)
                        SldCallback(SldValue)
                    end
                }
            end

