-- 25. CONFIG MANAGER (SISTEMA DE SAVE E LOAD VIA EXECUTOR)
-- ========================================================================
Evok.ConfigManager = {
    Folder = "Evok_Ultimate_Configs",
    Extension = ".evok"
}

-- Bypasses e proteções para as funções do sistema de arquivos do executor
local function MakeFolder(path)
    if makefolder then
        if not isfolder(path) then
            makefolder(path)
        end
    end
end

local function WriteFile(path, content)
    if writefile then
        writefile(path, content)
    end
end

local function ReadFile(path)
    if readfile then
        if isfile(path) then
            return readfile(path)
        end
    end
    return nil
end

local function ListFiles(path)
    if listfiles then
        if isfolder(path) then
            return listfiles(path)
        end
    end
    return {}
end

local function DeleteFile(path)
    if delfile then
        if isfile(path) then
            delfile(path)
        end
    end
end

function Evok.ConfigManager:Initialize()
    local success, err = pcall(function()
        MakeFolder(self.Folder)
    end)
    
    if not success then
        warn("[Evok V5] Erro fatal ao criar pasta de configurações: " .. tostring(err))
    end
end

function Evok.ConfigManager:Save(configName)
    self:Initialize()
    
    local path = self.Folder .. "/" .. configName .. self.Extension
    local dataToSave = {}
    
    for flagName, flagData in pairs(Evok.Flags) do
        local val = flagData.Value
        local valType = typeof(val)
        
        if valType == "boolean" or valType == "number" or valType == "string" or valType == "table" then
            dataToSave[flagName] = {
                ["Type"] = "Standard",
                ["Data"] = val
            }
        elseif valType == "Color3" then
            dataToSave[flagName] = {
                ["Type"] = "Color3",
                ["Hex"] = Evok.ColorSpace:RGBToHEX(val)
            }
        elseif valType == "EnumItem" then
            dataToSave[flagName] = {
                ["Type"] = "Keybind",
                ["Key"] = val.Name
            }
        end
    end
    
    local success, encoded = pcall(function()
        return HttpService:JSONEncode(dataToSave)
    end)
    
    if success and encoded then
        WriteFile(path, encoded)
        
        Evok:Notify({
            Title = "Config Manager",
            Content = "A configuração '" .. configName .. "' foi salva com sucesso no executor.",
            Duration = 3,
            Type = "Info"
        })
    else
        Evok:Notify({
            Title = "Erro ao Salvar",
            Content = "Falha ao compilar o JSON da configuração.",
            Duration = 4,
            Type = "Error"
        })
    end
end

function Evok.ConfigManager:Load(configName)
    self:Initialize()
    
    local path = self.Folder .. "/" .. configName .. self.Extension
    local rawData = ReadFile(path)
    
    if not rawData then
        Evok:Notify({
            Title = "Erro de Arquivo",
            Content = "A configuração '" .. configName .. "' não foi encontrada na pasta.",
            Duration = 3,
            Type = "Warning"
        })
        return false
    end
    
    local success, decoded = pcall(function()
        return HttpService:JSONDecode(rawData)
    end)
    
    if success and decoded then
        for flagName, flagData in pairs(decoded) do
            if Evok.Flags[flagName] then
                if flagData.Type == "Standard" then
                    Evok.Flags[flagName]:Set(flagData.Data)
                    
                elseif flagData.Type == "Color3" then
                    local restoredColor = Evok.ColorSpace:HEXToRGB(flagData.Hex)
                    Evok.Flags[flagName]:Set(restoredColor)
                    
                elseif flagData.Type == "Keybind" then
                    local restoredKey = Enum.KeyCode[flagData.Key]
                    if restoredKey then
                        Evok.Flags[flagName]:Set(restoredKey)
                    end
                end
            end
        end
        
        Evok:Notify({
            Title = "Config Manager",
            Content = "Configuração '" .. configName .. "' carregada com sucesso!",
            Duration = 3,
            Type = "Info"
        })
        
        return true
    end
    
    return false
end

function Evok.ConfigManager:GetConfigs()
    self:Initialize()
    
    local files = ListFiles(self.Folder)
    local formattedNames = {}
    
    for _, file in ipairs(files) do
        if file:match(self.Extension .. "$") then
            local cleanName = file:match("([^/\\]+)$"):gsub(self.Extension, "")
            table.insert(formattedNames, cleanName)
        end
    end
    
    return formattedNames
end

function Evok.ConfigManager:Delete(configName)
    self:Initialize()
    
    local path = self.Folder .. "/" .. configName .. self.Extension
    
    if isfile and isfile(path) then
        DeleteFile(path)
        Evok:Notify({
            Title = "Config Manager",
            Content = "A configuração '" .. configName .. "' foi deletada.",
            Duration = 3,
            Type = "Info"
        })
    end
end

