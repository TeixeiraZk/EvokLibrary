                local SldMax = sldConfig.Max or 100
                local SldValue = sldConfig.Default or SldMin
                local SldFlag = sldConfig.Flag or SldName
                local SldCallback = sldConfig.Callback or function() end

                local SldFrame = Utility:Create("Frame", {
                    Name = SldName .. "_Slider",
