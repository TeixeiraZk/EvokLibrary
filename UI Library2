                    KBtn.TextColor3 = Evok:GetTheme("Warning")
                end)

                UserInputService.InputBegan:Connect(function(input, gp)
                    if not gp then
                        if IsBinding and input.UserInputType == Enum.UserInputType.Keyboard then
                            CurrentKey = (input.KeyCode == Enum.KeyCode.Escape) and Enum.KeyCode.Unknown or input.KeyCode
                            KBtn.Text = Evok.Keymap[CurrentKey] or CurrentKey.Name
                            KBtn.TextColor3 = Evok:GetTheme("Accent")
                            IsBinding = false
                            Evok.Flags[KeyFlag] = { Value = CurrentKey }
                        elseif not IsBinding and input.KeyCode == CurrentKey and CurrentKey ~= Enum.KeyCode.Unknown then
                            KeyCallback()
                        end
                    end
                end)
            end

            return Elements
