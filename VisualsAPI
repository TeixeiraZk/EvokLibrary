-- 📜 SYSTEM 6: ULTIMATE LUAU LEXER (Syntax Highlighting)
-- ==============================================================================
local Lexer = {
    Keywords = {"and", "break", "do", "else", "elseif", "end", "false", "for", "function", "if", "in", "local", "nil", "not", "or", "repeat", "return", "then", "true", "until", "while", "continue", "export", "type", "self"},
    Globals = {"game", "workspace", "script", "math", "string", "table", "coroutine", "task", "debug", "os", "tick", "Enum", "Color3", "Vector3", "Vector2", "UDim2", "UDim", "CFrame", "Instance", "TweenInfo", "RaycastParams", "ColorSequence", "NumberSequence", "require", "pcall", "xpcall", "assert", "error", "print", "warn", "setmetatable", "getmetatable", "typeof", "type", "pairs", "ipairs", "next", "unpack", "select"},
    Methods = {"Connect", "Wait", "Destroy", "Clone", "FindFirstChild", "WaitForChild", "GetService", "GetChildren", "GetDescendants", "Lerp", "Play", "Pause", "Cancel", "IsA", "GetPropertyChangedSignal", "Disconnect"},
    Operators = {"+", "-", "*", "/", "%", "^", "#", "==", "~=", "<=", ">=", "<", ">", "=", ":", "%."},
    
    Colors = {
        Keyword = "#FF7B72",   
        Global = "#79C0FF",    
        Method = "#D2A8FF",    
        String = "#A5D6FF",    
        Number = "#79C0FF",    
        Comment = "#8B949E",   
        Operator = "#C9D1D9",  
        Type = "#FFA657",
        Default = "#C9D1D9",
        LineNum = "#484F58"
    }
}

local function ParseSyntax(code)
    code = code:gsub("&", "&amp;"):gsub("<", "&lt;"):gsub(">", "&gt;")
    
    -- Multiline Comments
    code = code:gsub("(%-%-%[%[.-%]%])", "<font color='" .. Lexer.Colors.Comment .. "'>%1</font>")
    -- Single line comments
    code = code:gsub("(%-%-[^\n]*)", "<font color='" .. Lexer.Colors.Comment .. "'>%1</font>")
    
    -- Multiline Strings
    code = code:gsub("(%[%[.-%]%])", "<font color='" .. Lexer.Colors.String .. "'>%1</font>")
    -- Single line Strings
    code = code:gsub("(\"[^\"]*\")", "<font color='" .. Lexer.Colors.String .. "'>%1</font>")
    code = code:gsub("('[^']*')", "<font color='" .. Lexer.Colors.String .. "'>%1</font>")
    
    -- Numbers
    code = code:gsub("([^%a%w_])(%d+%.?%d*)", "%1<font color='" .. Lexer.Colors.Number .. "'>%2</font>")
    if tonumber(code:sub(1, 1)) then 
        code = code:gsub("^(%d+%.?%d*)", "<font color='" .. Lexer.Colors.Number .. "'>%1</font>")
    end

    -- Operators
    for _, op in ipairs(Lexer.Operators) do
        local escapedOp = op:gsub("([%^%$%(%)%%%.%[%]%*%+%-%?])", "%%%1")
        code = code:gsub("(" .. escapedOp .. ")", "<font color='" .. Lexer.Colors.Operator .. "'>%1</font>")
    end

    -- Keywords
    for _, word in ipairs(Lexer.Keywords) do
        code = code:gsub("([^%a%w_])(" .. word .. ")([^%a%w_])", "%1<font color='" .. Lexer.Colors.Keyword .. "'>%2</font>%3")
        code = code:gsub("^(" .. word .. ")([^%a%w_])", "<font color='" .. Lexer.Colors.Keyword .. "'>%1</font>%2")
        code = code:gsub("([^%a%w_])(" .. word .. ")$", "%1<font color='" .. Lexer.Colors.Keyword .. "'>%2</font>")
    end

    -- Globals
    for _, word in ipairs(Lexer.Globals) do
        code = code:gsub("([^%a%w_])(" .. word .. ")([^%a%w_])", "%1<font color='" .. Lexer.Colors.Global .. "'>%2</font>%3")
        code = code:gsub("^(" .. word .. ")([^%a%w_])", "<font color='" .. Lexer.Colors.Global .. "'>%1</font>%2")
    end

    -- Methods
    for _, word in ipairs(Lexer.Methods) do
        code = code:gsub(":%s*(" .. word .. ")([^%a%w_])", ":<font color='" .. Lexer.Colors.Method .. "'>%1</font>%2")
        code = code:gsub("%.%s*(" .. word .. ")([^%a%w_])", ".<font color='" .. Lexer.Colors.Method .. "'>%1</font>%2")
    end

    return code
end

local function CountLines(str)
    local _, count = string.gsub(str, "\n", "")
    return count + 1
end

