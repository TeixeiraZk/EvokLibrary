-- 🎬 SYSTEM 3: POST-PROCESSING ENGINE (Smooth Lighting Interpolator Frame-Loop)
-- ==============================================================================
function VisualsModule:InitPostProcessing()
    if self.FXInstances["Blur"] then return end

    local dof = Instance.new("DepthOfFieldEffect")
    dof.Name = "EvokRender_DOF"
    dof.Parent = Lighting

    local cc = Instance.new("ColorCorrectionEffect")
    cc.Name = "EvokRender_CC"
    cc.Parent = Lighting

    local bloom = Instance.new("BloomEffect")
    bloom.Name = "EvokRender_Bloom"
    bloom.Parent = Lighting

    self.FXInstances["Blur"] = dof
    self.FXInstances["CC"] = cc
    self.FXInstances["Bloom"] = bloom

    -- Estado padrão zerado
    self.CurrentFXState = {
        DOF_FarIntensity = 0, DOF_FocusDistance = 0.05, DOF_InFocusRadius = 0, DOF_NearIntensity = 0,
        CC_Brightness = 0, CC_Contrast = 0, CC_Saturation = 0, CC_TintColor = Color3.new(1,1,1),
        Bloom_Intensity = 0, Bloom_Size = 0, Bloom_Threshold = 2
    }
    self.TargetFXState = table.clone(self.CurrentFXState)

    -- Loop de transição via interpolação linear delta (Sem travamentos bruscos)
    local lerpLoop = RunService.Heartbeat:Connect(function(dt)
        local curr = self.CurrentFXState
        local targ = self.TargetFXState
        if not curr or not targ then return end

        local factor = math.clamp(dt * self.FXTransitionSpeed, 0, 1)

        curr.DOF_FarIntensity = curr.DOF_FarIntensity + (targ.DOF_FarIntensity - curr.DOF_FarIntensity) * factor
        curr.DOF_FocusDistance = curr.DOF_FocusDistance + (targ.DOF_FocusDistance - curr.DOF_FocusDistance) * factor
        curr.DOF_InFocusRadius = curr.DOF_InFocusRadius + (targ.DOF_InFocusRadius - curr.DOF_InFocusRadius) * factor
        curr.DOF_NearIntensity = curr.DOF_NearIntensity + (targ.DOF_NearIntensity - curr.DOF_NearIntensity) * factor
        
        curr.CC_Brightness = curr.CC_Brightness + (targ.CC_Brightness - curr.CC_Brightness) * factor
        curr.CC_Contrast = curr.CC_Contrast + (targ.CC_Contrast - curr.CC_Contrast) * factor
        curr.CC_Saturation = curr.CC_Saturation + (targ.CC_Saturation - curr.CC_Saturation) * factor
        curr.CC_TintColor = curr.CC_TintColor:Lerp(targ.CC_TintColor, factor)

        curr.Bloom_Intensity = curr.Bloom_Intensity + (targ.Bloom_Intensity - curr.Bloom_Intensity) * factor
        curr.Bloom_Size = curr.Bloom_Size + (targ.Bloom_Size - curr.Bloom_Size) * factor
        curr.Bloom_Threshold = curr.Bloom_Threshold + (targ.Bloom_Threshold - curr.Bloom_Threshold) * factor

        -- Aplicação direta nos objetos do Lighting
        dof.FarIntensity = curr.DOF_FarIntensity
        dof.FocusDistance = curr.DOF_FocusDistance
        dof.InFocusRadius = curr.DOF_InFocusRadius
        dof.NearIntensity = curr.DOF_NearIntensity

        cc.Brightness = curr.CC_Brightness
        cc.Contrast = curr.CC_Contrast
        cc.Saturation = curr.CC_Saturation
        cc.TintColor = curr.CC_TintColor

        bloom.Intensity = curr.Bloom_Intensity
        bloom.Size = curr.Bloom_Size
        bloom.Threshold = curr.Bloom_Threshold
    end)
    table.insert(self.Connections, lerpLoop)
end

function VisualsModule:ApplyPostProcessingProfile(profile: string, themeAccent: Color3)
    if not self.CurrentFXState then self:InitPostProcessing() end
    local targ = self.TargetFXState
    if not targ then return end

    if profile == "VibrantAcrylic" then
        targ.DOF_FarIntensity = 0; targ.DOF_FocusDistance = 0.05; targ.DOF_InFocusRadius = 0; targ.DOF_NearIntensity = 1
        targ.CC_Brightness = 0.02; targ.CC_Contrast = 0.14; targ.CC_Saturation = 0.2
        targ.CC_TintColor = Color3.new(1,1,1):Lerp(themeAccent, 0.06)
        targ.Bloom_Intensity = 0.45; targ.Bloom_Size = 22; targ.Bloom_Threshold = 0.9
    elseif profile == "MinimalistDark" then
        targ.DOF_FarIntensity = 0; targ.DOF_FocusDistance = 0.05; targ.DOF_InFocusRadius = 0; targ.DOF_NearIntensity = 0.6
        targ.CC_Brightness = -0.05; targ.CC_Contrast = 0.06; targ.CC_Saturation = -0.1
        targ.CC_TintColor = Color3.fromRGB(245, 245, 255)
        targ.Bloom_Intensity = 0.15; targ.Bloom_Size = 10; targ.Bloom_Threshold = 1.6
    else
        targ.DOF_FarIntensity = 0; targ.DOF_FocusDistance = 0.05; targ.DOF_InFocusRadius = 0; targ.DOF_NearIntensity = 0
        targ.CC_Brightness = 0; targ.CC_Contrast = 0; targ.CC_Saturation = 0
        targ.CC_TintColor = Color3.new(1,1,1)
        targ.Bloom_Intensity = 0; targ.Bloom_Size = 0; targ.Bloom_Threshold = 2
    end
end

function VisualsModule:ClearPostProcessing()
    self.TargetFXState = {
        DOF_FarIntensity = 0, DOF_FocusDistance = 0.05, DOF_InFocusRadius = 0, DOF_NearIntensity = 0,
        CC_Brightness = 0, CC_Contrast = 0, CC_Saturation = 0, CC_TintColor = Color3.new(1,1,1),
        Bloom_Intensity = 0, Bloom_Size = 0, Bloom_Threshold = 2
    }
    task.wait(0.2)
    for k, inst in pairs(self.FXInstances) do
        if inst and inst.Parent then pcall(function() inst:Destroy() end) end
    end
    table.clear(self.FXInstances)
    self.CurrentFXState = nil
    self.TargetFXState = nil
end

