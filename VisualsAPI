        SearchInput.Font = Enum.Font.Gotham
        SearchInput.TextSize = 10
        SearchInput.TextXAlignment = Enum.TextXAlignment.Left

        local LineNumbers = Instance.new("Frame")
        LineNumbers.Size = UDim2.new(0, 28, 1, -28)
        LineNumbers.Position = UDim2.new(0, 0, 0, 28)
        LineNumbers.BackgroundColor3 = Core.Themes.Container
        LineNumbers.BorderSizePixel = 0
        LineNumbers.Parent = ScopeFrame

        local Gutter = Instance.new("Frame")
        Gutter.Size = UDim2.new(0, 1, 1, 0)
        Gutter.Position = UDim2.new(1, 0, 0, 0)
        Gutter.BackgroundColor3 = Core.Themes.Border
        Gutter.BorderSizePixel = 0
        Gutter.Parent = LineNumbers

        local CodeScroll = Instance.new("ScrollingFrame")
        CodeScroll.Size = UDim2.new(1, -28, 1, -28)
        CodeScroll.Position = UDim2.new(0, 28, 0, 28)
        CodeScroll.BackgroundTransparency = 1
        CodeScroll.ScrollBarThickness = 2
        CodeScroll.ScrollBarImageColor3 = Core.Themes.Border
        CodeScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
        CodeScroll.Parent = ScopeFrame

        local Padding = Instance.new("UIPadding", CodeScroll)
        Padding.PaddingTop = UDim.new(0, 6)
        Padding.PaddingBottom = UDim.new(0, 6)
        Padding.PaddingLeft = UDim.new(0, 8)

        local TextDisplay = Instance.new("TextLabel")
        TextDisplay.Size = UDim2.new(1, 0, 1, 0)
        TextDisplay.AutomaticSize = Enum.AutomaticSize.XY
        TextDisplay.BackgroundTransparency = 1
        TextDisplay.TextColor3 = Core.Themes.Text
        TextDisplay.Font = Enum.Font.Code
        TextDisplay.TextSize = 11
        TextDisplay.TextXAlignment = Enum.TextXAlignment.Left
        TextDisplay.TextYAlignment = Enum.TextYAlignment.Top
        TextDisplay.RichText = true
        TextDisplay.Parent = CodeScroll

        local NumbersScroll = Instance.new("ScrollingFrame")
        NumbersScroll.Size = UDim2.new(1, 0, 1, 0)
        NumbersScroll.BackgroundTransparency = 1
        NumbersScroll.ScrollBarThickness = 0
        NumbersScroll.ScrollingEnabled = false
        NumbersScroll.Parent = LineNumbers

        local NumPadding = Instance.new("UIPadding", NumbersScroll)
        NumPadding.PaddingTop = UDim.new(0, 6)

        local NumbersDisplay = Instance.new("TextLabel")
        NumbersDisplay.Size = UDim2.new(1, -4, 1, 0)
        NumbersDisplay.AutomaticSize = Enum.AutomaticSize.Y
        NumbersDisplay.BackgroundTransparency = 1
        NumbersDisplay.TextColor3 = Core.Themes.TextMuted
        NumbersDisplay.Font = Enum.Font.Code
        NumbersDisplay.TextSize = 11
        NumbersDisplay.TextXAlignment = Enum.TextXAlignment.Right
        NumbersDisplay.TextYAlignment = Enum.TextYAlignment.Top
        NumbersDisplay.Parent = NumbersScroll

        CodeScroll:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
            NumbersScroll.CanvasPosition = Vector2.new(0, CodeScroll.CanvasPosition.Y)
        end)

        local function RenderSource(targetText, highlightQuery)
            local formattedText = targetText
            
            -- Se houver busca ativa, envelopa o termo correspondente em marcações RichText
            if highlightQuery and highlightQuery ~= "" then
                formattedText = formattedText:gsub(highlightQuery, "<font color='#FFFF00'><b>" .. highlightQuery .. "</b></font>")
            end

            TextDisplay.Text = formattedText
            local _, lines = string.gsub(targetText, "\n", "")
            lines = lines + 1
            
            local numStr = ""
            for k = 1, lines do numStr = numStr .. tostring(k) .. "\n" end
            NumbersDisplay.Text = numStr
            
            CodeScroll.CanvasSize = UDim2.new(0, TextDisplay.TextBounds.X + 30, 0, TextDisplay.TextBounds.Y + 20)
        end

        SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
            RenderSource(sourceCode, SearchInput.Text)
        end)

        RenderSource(sourceCode, "")

        Core:SubscribeToTheme(function(theme)
            ScopeFrame.BackgroundColor3 = Core.Math.Color.Darken(theme.Background, 0.06)
            Stroke.Color = theme.Border
            ViewerTop.BackgroundColor3 = theme.Container
            SearchBarBg.BackgroundColor3 = theme.Background
            SBS.Color = theme.Border
            LineNumbers.BackgroundColor3 = theme.Container
            Gutter.BackgroundColor3 = theme.Border
            CodeScroll.ScrollBarImageColor3 = theme.Border
            TextDisplay.TextColor3 = theme.Text
            NumbersDisplay.TextColor3 = theme.TextMuted
        end)

        return {
            UpdateCode = function(c) sourceCode = c; RenderSource(c, SearchInput.Text) end,
            GetCode = function() return sourceCode end
        }
    end
end

-- ==============================================================================
-- 💣 SYSTEM 7: DETAILED GARBAGE COLLECTION ENGINE (Zero Leak Execution Block)
-- ==============================================================================
function VisualsModule:InjectUnloader(WindowInstance)
    local Core = WindowInstance.Core

    function WindowInstance:Unload()
        Core.Logger:Log("Evoking Deep Eviction Routine...")

        -- 1. Destruição de Elementos Ambientais e Efeitos do Lighting
        VisualsModule:ClearPostProcessing()
        VisualsModule.ChromaActive = false

        -- 2. Limpeza Absoluta de Viewports e Telas Secundárias
        if VisualsModule.ParticleEngine.Container then
            VisualsModule.ParticleEngine.Container:Destroy()
            VisualsModule.ParticleEngine.Active = false
        end
        
        if VisualsModule.HitmarkerLayer then VisualsModule.HitmarkerLayer:Destroy() end
        if VisualsModule.DamageTextLayer then VisualsModule.DamageTextLayer:Destroy() end
        if VisualsModule.CrosshairLayer then VisualsModule.CrosshairLayer:Destroy() end

        -- 3. Restauração do Ponteiro do Mouse Original do Sistema
        if Core.Cursor.Instance then
            Core.Cursor.Instance:Destroy()
            Core.Cursor.Enabled = false
            UserInputService.MouseIconEnabled = true
        end

        -- 4. Quebra de Conexões em Pipeline Ativo (Prevenção Absoluta de Memory Leaks)
        for idx = #VisualsModule.Connections, 1, -1 do
            local signal = VisualsModule.Connections[idx]
            if signal and signal.Connected then 
                pcall(function() signal:Disconnect() end) 
            end
            table.remove(VisualsModule.Connections, idx)
        end

        if Core.Connections then
            for idx = #Core.Connections, 1, -1 do
                local signal = Core.Connections[idx]
                if signal and signal.Connected then 
                    pcall(function() signal:Disconnect() end) 
                end
                table.remove(Core.Connections, idx)
            end
        end

        -- 5. Retorno Seguro do Foco de Câmera do Player Local
        pcall(function()
            local currentChar = LocalPlayer.Character
            if currentChar then
                local humanoid = currentChar:FindFirstChildOfClass("Humanoid")
                if humanoid then Workspace.CurrentCamera.CameraSubject = humanoid end
            end
        end)

        -- 6. Colapso de Geometria e Destruição das Instâncias CoreGui
        if WindowInstance.GUI then
            local mainFrame = WindowInstance.MainFrame
            local closeAnimation = TweenService:Create(mainFrame, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                Size = UDim2.new(0, 0, 0, 0)
            })
            closeAnimation:Play()
            closeAnimation.Completed:Wait()
            
            WindowInstance.GUI:Destroy()
            WindowInstance.GUI = nil
        end
        
        if getgenv then getgenv().EvokAPI = nil end
        Core.Logger:Log("Eviction protocol finished. Cache cleaned.")
    end
end

-- ==============================================================================
-- 🔗 SYSTEM 8: API DE EXPORTAÇÃO EXTERNA (Sandboxed Injection Binding)
-- ==============================================================================
function VisualsModule.Inject(WindowInstance)
    -- Inicialização do Pipeline Gráfico Integrado
    VisualsModule.ParticleEngine:Init(WindowInstance.GUI)
    VisualsModule:InitOverlays(WindowInstance.GUI)
    VisualsModule:InitDamageTextLayer(WindowInstance.GUI)
    
    -- Inicialização de Loops Estendidos por Injeção Subalterna
    VisualsModule:InjectScriptViewer(WindowInstance)
    VisualsModule:InjectUnloader(WindowInstance)

    -- Consolidação e Distribuição da Sandbox API Externa
    local SandboxedAPI = {
        EmitParticles = function(configTable) VisualsModule.ParticleEngine:Emit(configTable) end,
        DrawHitmarker = function(themeColor) VisualsModule:DrawHitmarker(themeColor) end,
        ProjectDamage = function(v, p, c) VisualsModule:ProjectDamageNumber(v, p, c) end,
        SetCrosshair = function(state, color) VisualsModule:CreateEngineCrosshair(state, color) end,
        SetChroma = function(inst, prop, speed, offset) VisualsModule:RegisterChromaElement(inst, prop, speed, offset) end,
        SetFXProfile = function(profileName) VisualsModule:ApplyPostProcessingProfile(profileName, WindowInstance.Core.Themes.Accent) end,
        Notify = function(configTable) WindowInstance.Core:Notify(configTable) end,
        Unload = function() WindowInstance:Unload() end
    }

    if getgenv then getgenv().EvokAPI = SandboxedAPI end
    WindowInstance.Core.Logger:Log("VisualsAPI Module Injected & Sandboxed.")
    
    return SandboxedAPI
end

return VisualsModule
