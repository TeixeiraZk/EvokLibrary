function Visuals.DamageNumbers:Show(amount, worldPosition, isCrit)
    if not Visuals.DamageNumGUI then return end
    
    local screenPos, onScreen = Camera:WorldToViewportPoint(worldPosition)
    if not onScreen then return end

    local Label = Instance.new("TextLabel")
    Label.BackgroundTransparency = 1
    Label.Text = tostring(math.floor(amount))
    Label.TextColor3 = isCrit and Color3.fromRGB(255, 215, 0) or Color3.fromRGB(255, 255, 255)
    Label.Font = isCrit and Enum.Font.GothamBlack or Enum.Font.GothamBold
    Label.TextSize = isCrit and 24 or 18
    Label.TextStrokeTransparency = 0
    Label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    
    -- Random spread for numbers
    local offsetX = math.random(-30, 30)
    local offsetY = math.random(-10, 10)
    
    Label.Position = UDim2.new(0, screenPos.X + offsetX, 0, screenPos.Y + offsetY)
    Label.Size = UDim2.new(0, 50, 0, 50)
    Label.AnchorPoint = Vector2.new(0.5, 0.5)
    Label.Parent = Visuals.DamageNumGUI

    -- Physics arc animation
    local targetY = screenPos.Y - math.random(50, 100)
    local targetX = screenPos.X + (offsetX * 1.5)
    
    local tweenInfo1 = TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    local tween1 = TweenService:Create(Label, tweenInfo1, {
        Position = UDim2.new(0, targetX, 0, targetY),
        TextSize = isCrit and 28 or 22
    })
    
    local tweenInfo2 = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
    local tween2 = TweenService:Create(Label, tweenInfo2, {
        Position = UDim2.new(0, targetX, 0, targetY + 30),
        TextTransparency = 1,
        TextStrokeTransparency = 1
    })

    tween1:Play()
    tween1.Completed:Connect(function()
        tween2:Play()
        tween2.Completed:Connect(function()
            Label:Destroy()
        end)
    end)
end

