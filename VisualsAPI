-- ==============================================================================
-- 🧮 UTILITY MATHEMATICS ENGINE (Vectors, Curves & Pseudo-Noise)
-- ==============================================================================
local MathExt = {}

function MathExt.BezierQuadratic(p0: Vector2, p1: Vector2, p2: Vector2, t: number): Vector2
    local l1 = p0:Lerp(p1, t)
    local l2 = p1:Lerp(p2, t)
    return l1:Lerp(l2, t)
end

function MathExt.BezierCubic(p0: Vector2, p1: Vector2, p2: Vector2, p3: Vector2, t: number): Vector2
    local l1 = p0:Lerp(p1, t)
    local l2 = p1:Lerp(p2, t)
    local l3 = p2:Lerp(p3, t)
    local a = l1:Lerp(l2, t)
    local b = l2:Lerp(l3, t)
    return a:Lerp(b, t)
end

function MathExt.PseudoNoise(x: number): number
    return math.sin(x) * math.cos(x * 2.5) * math.sin(x * 0.15)
end

function MathExt.ClampVector2(vec: Vector2, min: Vector2, max: Vector2): Vector2
    return Vector2.new(math.clamp(vec.X, min.X, max.X), math.clamp(vec.Y, min.Y, max.Y))
end

function MathExt.LerpColor(c1: Color3, c2: Color3, t: number): Color3
    return c1:Lerp(c2, math.clamp(t, 0, 1))
end

function MathExt.CalculateVelocityMagnitude(vel: Vector2): number
    return math.sqrt(vel.X * vel.X + vel.Y * vel.Y)
end

