    Evok.ParticleEngine = {
        Enabled = false,
        Mode = "Snow", -- "Snow" ou "Matrix"
        Container = nil,
        ParticleCount = 50,
        Connection = nil
    }

    function Evok.ParticleEngine:Initialize(TargetGui)
        if self.Container then return end
        self.Container = Evok.Utility.Instance:Create("Frame", {
            Name = "Evok_Particle_Layer",
            Parent = TargetGui,
            Size = UDim2.new(1, 0, 1, 0),
            Position = UDim2.new(0, 0, 0, 0),
            BackgroundTransparency = 1,
            ClipsDescendants = true,
            ZIndex = 0 -- Atrás dos botões, na frente do fundo
        })
    end

    function Evok.ParticleEngine:CreateParticle()
        if not self.Container then return end
        
        local isMatrix = (self.Mode == "Matrix")
        
        local Particle = Evok.Utility.Instance:Create("TextLabel", {
            Parent = self.Container,
            BackgroundTransparency = 1,
            Text = isMatrix and string.char(math.random(33, 126)) or "•",
            TextColor3 = isMatrix and Evok.ThemeManager:GetColor("Success") or Color3.fromRGB(255, 255, 255),
            Font = isMatrix and Evok.Fonts.Code or Evok.Fonts.Main,
            TextSize = isMatrix and math.random(10, 16) or math.random(8, 20),
            TextTransparency = math.random(20, 80) / 100,
            Position = UDim2.new(math.random(0, 100)/100, 0, -0.1, 0),
            Size = UDim2.new(0, 20, 0, 20),
            ZIndex = 0
        })

        local duration = math.random(3, 8)
        local targetY = 1.1

        -- Tween linear caindo
        local fallTween = TweenService:Create(Particle, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
            Position = UDim2.new(Particle.Position.X.Scale, 0, targetY, 0)
        })

        -- Se for Matrix, roda as letras
        if isMatrix then
            task.spawn(function()
                while Particle and Particle.Parent do
                    Particle.Text = string.char(math.random(33, 126))
                    task.wait(0.1)
                end
            end)
        end

        fallTween:Play()
        fallTween.Completed:Connect(function()
            Particle:Destroy()
        end)
    end

    function Evok.ParticleEngine:Toggle(State, Mode)
        self.Enabled = State
        if Mode then self.Mode = Mode end

        if State then
            if not self.Connection then
                self.Connection = RunService.RenderStepped:Connect(function()
                    if math.random(1, 10) > 8 then -- Controla a densidade
                        self:CreateParticle()
                    end
                end)
                table.insert(Evok.Visuals.Connections, self.Connection)
            end
        else
            if self.Connection then
                self.Connection:Disconnect()
                self.Connection = nil
            end
            -- Limpa as partículas ativas
            if self.Container then
                for _, child in ipairs(self.Container:GetChildren()) do
                    child:Destroy()
                end
            end
        end
    end

    -- ============================================================================
    -- MÓDULO 6: CUSTOM CURSOR ENGINE (Software Rendering)
    -- ============================================================================

    Evok.CursorEngine = {
        Enabled = false,
        Gui = nil,
        Cursor = nil,
        TrailContainer = nil,
        Connection = nil
    }

    function Evok.CursorEngine:Initialize()
        if self.Gui then return end

        self.Gui = Evok.Utility.Instance:Create("ScreenGui", {
            Name = "Evok_Custom_Cursor",
            Parent = CoreGui,
            ZIndexBehavior = Enum.ZIndexBehavior.Global,
            DisplayOrder = 9999 -- Sempre no topo
        })

        self.TrailContainer = Evok.Utility.Instance:Create("Frame", {
            Parent = self.Gui,
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1
        })

        self.Cursor = Evok.Utility.Instance:Create("ImageLabel", {
            Name = "Pointer",
            Parent = self.Gui,
            Size = UDim2.new(0, 16, 0, 16),
            BackgroundTransparency = 1,
            Image = "rbxassetid://10057378285", -- Ícone genérico, ajustar conforme tema
            ImageColor3 = Evok.ThemeManager:GetColor("Accent"),
            AnchorPoint = Vector2.new(0, 0),
            ZIndex = 100
        })

        -- Esconde o mouse padrão do Roblox
        UserInputService.MouseIconEnabled = false
    end

    function Evok.CursorEngine:CreateRipple(Position)
        local Ripple = Evok.Utility.Instance:Create("Frame", {
            Parent = self.TrailContainer,
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0, Position.X, 0, Position.Y),
            AnchorPoint = Vector2.new(0.5, 0.5),
            BackgroundColor3 = Evok.ThemeManager:GetColor("Accent"),
            BackgroundTransparency = 0.5,
            ZIndex = 99
        })
        Evok.Utility.Instance:CreateRound(100).Parent = Ripple
        Evok.Utility.Instance:CreateStroke(Evok.ThemeManager:GetColor("Accent"), 1).Parent = Ripple

        local tw = TweenService:Create(Ripple, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 30, 0, 30),
            BackgroundTransparency = 1
        })
        tw:Play()
        tw.Completed:Connect(function() Ripple:Destroy() end)
    end

    function Evok.CursorEngine:Toggle(State)
        self.Enabled = State
        
        if State then
            self:Initialize()
            UserInputService.MouseIconEnabled = false
            
            if not self.Connection then
                self.Connection = RunService.RenderStepped:Connect(function()
                    local mousePos = UserInputService:GetMouseLocation()
                    -- Lerp para movimento suave
                    self.Cursor.Position = UDim2.new(0, mousePos.X, 0, mousePos.Y)
                end)
                table.insert(Evok.Visuals.Connections, self.Connection)

                -- Evento de clique
                local clickConn = UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        local pos = UserInputService:GetMouseLocation()
                        self:CreateRipple(pos)
                    end
                end)
                table.insert(Evok.Visuals.Connections, clickConn)
            end
        else
            UserInputService.MouseIconEnabled = true
            if self.Connection then
                self.Connection:Disconnect()
                self.Connection = nil
            end
            if self.Gui then
                self.Gui:Destroy()
                self.Gui = nil
            end
        end
    end

    -- ============================================================================
    -- MÓDULO 7: DEVELOPER EXTERNAL API (Global Control)
    -- ============================================================================
    
    function Evok.API:GetFlag(FlagName)
        return Evok.Flags[FlagName]
    end

    function Evok.API:SetFlag(FlagName, Value)
        if Evok.Flags[FlagName] ~= nil then
            Evok.Flags[FlagName] = Value
            return true
        end
        return false
    end

    function Evok.API:SetTheme(ThemeName)
        if Evok.ThemeManager.Themes[ThemeName] then
            Evok.ThemeManager:SetTheme(ThemeName)
            return true
        end
        return false
    end

    function Evok.API:ToggleAcrylic(State)
        Evok.AcrylicEngine:Toggle(State)
    end

    function Evok.API:ToggleParticles(State, Mode)
        Evok.ParticleEngine:Toggle(State, Mode)
    end

    -- ============================================================================
    -- MÓDULO 8: GLOBAL UNLOAD MANAGER (Autodestruição Limpa)
    -- ============================================================================
    
    function Evok:Unload()
        Evok.API:Notify({Title = "Evok", Content = "Commencing Unload Protocol...", Type = "Warning", Duration = 2})
        task.wait(0.5)
        
        -- Restaura configurações do Roblox
        UserInputService.MouseIconEnabled = true
        
        -- 1. Limpeza de Conexões do Core
        for _, conn in pairs(self.Connections) do
            if typeof(conn) == "RBXScriptConnection" and conn.Connected then conn:Disconnect() end
        end
        self.Connections = {}

        -- 2. Limpeza de Conexões Visuais
        for _, conn in pairs(Evok.Visuals.Connections) do
            if typeof(conn) == "RBXScriptConnection" and conn.Connected then conn:Disconnect() end
        end
        Evok.Visuals.Connections = {}

        -- 3. Limpeza de Conexões do System (Parte 4)
        if Evok.System and Evok.System.Connections then
            for _, conn in pairs(Evok.System.Connections) do
                if typeof(conn) == "RBXScriptConnection" and conn.Connected then conn:Disconnect() end
            end
        end

        if Evok.PlayerListAPI and Evok.PlayerListAPI.Connections then
            for _, conn in pairs(Evok.PlayerListAPI.Connections) do
                if typeof(conn) == "RBXScriptConnection" and conn.Connected then conn:Disconnect() end
            end
        end

        -- 4. Destruição de Interfaces
        for _, inst in pairs(self.Instances) do
            if typeof(inst) == "Instance" and inst.Parent then inst:Destroy() end
        end
        self.Instances = {}

        -- 5. Limpeza de Containers Globais Extras
        if Evok.NotificationEngine and Evok.NotificationEngine.Container then
            Evok.NotificationEngine.Container.Parent:Destroy()
        end

        if Evok.CursorEngine and Evok.CursorEngine.Gui then
            Evok.CursorEngine.Gui:Destroy()
        end

        -- 6. Liberação de Memória
        Evok.Flags = {}
        if Evok.PlayerListAPI then
            Evok.PlayerListAPI.AvatarCache.Headshots = {}
            Evok.PlayerListAPI.AvatarCache.Busts = {}
            Evok.PlayerListAPI.AvatarCache.FullBody = {}
        end

        self.IsRunning = false
        print("[EVOK] Unload Complete. Memory cleared.")
    end

