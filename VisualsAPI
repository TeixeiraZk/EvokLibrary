function VisualsModule:ProjectDamageNumber(value: number, worldPos: Vector3, critical: boolean)
    if not self.DamageTextLayer then return end
    
    local screenPos, visible = Camera:WorldToViewportPoint(worldPos)
    if not visible then return end

    local Label = Instance.new("TextLabel")
    Label.BackgroundTransparency = 1
    Label.Text = tostring(math.floor(value))
    Label.TextColor3 = critical and Color3.fromRGB(255, 50, 80) or Color3.fromRGB(255, 255, 255)
    Label.Font = critical and Enum.Font.GothamBlack or Enum.Font.GothamBold
    Label.TextSize = critical and 20 or 15
    Label.TextStrokeTransparency = 0
    Label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    
    local dX = math.random(-35, 35)
    local dY = math.random(-12, 12)
    
    Label.Position = UDim2.new(0, screenPos.X + dX, 0, screenPos.Y + dY)
    Label.Size = UDim2.new(0, 50, 0, 25)
    Label.AnchorPoint = Vector2.new(0.5, 0.5)
    Label.Parent = self.DamageTextLayer

    local arcY = screenPos.Y - math.random(50, 90)
    local arcX = screenPos.X + (dX * 1.6)
    
    local tween1 = TweenService:Create(Label, TweenInfo.new(0.25, Enum.EasingStyle.OutQuad), {
        Position = UDim2.new(0, arcX, 0, arcY),
        TextSize = critical and 24 or 18
    })
    
    local tween2 = TweenService:Create(Label, TweenInfo.new(0.4, Enum.EasingStyle.InQuad), {
        Position = UDim2.new(0, arcX, 0, arcY + 20),
        TextTransparency = 1,
        TextStrokeTransparency = 1
    })

    tween1:Play()
    tween1.Completed:Connect(function()
        tween2:Play()
        tween2.Completed:Connect(function() Label:Destroy() end)
    end)
end

