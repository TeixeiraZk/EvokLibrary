    Evok.AcrylicEngine = {
        Enabled = false,
        Intensity = 0.5,
        ViewportFrame = nil,
        GlassPart = nil,
        Connection = nil
    }

    function Evok.AcrylicEngine:Initialize(TargetUIFrame)
        if not TargetUIFrame then return end
        if not Camera then return end

        if self.ViewportFrame then self.ViewportFrame:Destroy() end

        self.ViewportFrame = Evok.Utility.Instance:Create("ViewportFrame", {
            Name = "Evok_Acrylic_Blur",
            Parent = TargetUIFrame,
            Size = UDim2.new(1, 0, 1, 0),
            Position = UDim2.new(0, 0, 0, 0),
            BackgroundTransparency = 1,
            CurrentCamera = Camera,
            LightColor = Color3.new(1, 1, 1),
            Ambient = Color3.new(1, 1, 1),
            ZIndex = -10
        })

        self.GlassPart = Evok.Utility.Instance:Create("Part", {
            Name = "BlurLens",
            Parent = self.ViewportFrame,
            Material = Enum.Material.Glass,
            Color = Evok.ThemeManager:GetColor("Background"),
            Transparency = 0.5 + (0.5 * (1 - self.Intensity)),
            Reflectance = 0,
            CastShadow = false,
            CanCollide = false,
            Anchored = true,
            Size = Vector3.new(100, 100, 0.05)
        })

        self.Connection = RunService.RenderStepped:Connect(function()
            if not self.Enabled then return end
            if not self.ViewportFrame or not self.GlassPart then return end
            
            local camCFrame = Camera.CFrame
            self.GlassPart.CFrame = camCFrame * CFrame.new(0, 0, -0.5)
        end)
        
        table.insert(Evok.Visuals.Connections, self.Connection)
        table.insert(Evok.Visuals.BlurInstances, self.ViewportFrame)
    end

    function Evok.AcrylicEngine:Toggle(State)
        self.Enabled = State
        if self.ViewportFrame then
            self.ViewportFrame.Visible = State
        end
    end

    -- ============================================================================
    -- MÓDULO 4: PHYSICS-BASED NOTIFICATION ENGINE
    -- ============================================================================
    -- Sistema avançado de Notificações. As notificações caem, se empurram 
    -- e possuem barras de progresso reais.

    Evok.NotificationEngine = {
        Container = nil,
        Padding = 10,
        BaseWidth = 300,
        ActiveList = {}
    }

    function Evok.NotificationEngine:Initialize()
        if self.Container then return end
        
        local Screen = Evok.Utility.Instance:Create("ScreenGui", {
            Name = "Evok_Notification_Physics_Layer",
            Parent = CoreGui,
            ZIndexBehavior = Enum.ZIndexBehavior.Global,
            ResetOnSpawn = false
        })
        
        self.Container = Evok.Utility.Instance:Create("Frame", {
            Name = "Boundary",
            Parent = Screen,
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            BorderSizePixel = 0
        })
    end

    function Evok.NotificationEngine:UpdatePhysics()
        local currentY = self.Container.AbsoluteSize.Y - self.Padding
        
        for i = #self.ActiveList, 1, -1 do
            local notif = self.ActiveList[i]
            local targetY = currentY - notif.Frame.AbsoluteSize.Y
            
            TweenService:Create(notif.Frame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Position = UDim2.new(1, -(self.BaseWidth + self.Padding), 0, targetY)
            }):Play()
            
            currentY = targetY - self.Padding
        end
    end

    function Evok.API:Notify(Config)
        Evok.NotificationEngine:Initialize()

        local Title = Config.Title or "Notification"
        local Content = Config.Content or "No content provided."
        local Duration = Config.Duration or 5
        local Type = Config.Type or "Info"

        local ThemeColor = Evok.ThemeManager:GetColor("Accent")
        if Type == "Success" then ThemeColor = Evok.ThemeManager:GetColor("Success") end
        if Type == "Warning" then ThemeColor = Evok.ThemeManager:GetColor("Warning") end
        if Type == "Error" then ThemeColor = Evok.ThemeManager:GetColor("Error") end

        local Frame = Evok.Utility.Instance:Create("Frame", {
            Name = "Notification_" .. Title,
            Parent = Evok.NotificationEngine.Container,
            Size = UDim2.new(0, Evok.NotificationEngine.BaseWidth, 0, 0),
            Position = UDim2.new(1, 50, 0, Evok.NotificationEngine.Container.AbsoluteSize.Y), -- Nasce fora da tela
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundColor3 = Evok.ThemeManager:GetColor("Container"),
            BorderSizePixel = 0
        })

        Evok.Utility.Instance:CreateRound(6).Parent = Frame
        Evok.Utility.Instance:CreateStroke(Evok.ThemeManager:GetColor("Border"), 1).Parent = Frame

        local AccentLine = Evok.Utility.Instance:Create("Frame", {
            Name = "Accent",
            Parent = Frame,
            Size = UDim2.new(0, 3, 1, 0),
            Position = UDim2.new(0, 0, 0, 0),
            BackgroundColor3 = ThemeColor,
            BorderSizePixel = 0
        })
        Evok.Utility.Instance:CreateRound(3).Parent = AccentLine

        local TitleLabel = Evok.Utility.Instance:Create("TextLabel", {
            Name = "Title",
            Parent = Frame,
            Size = UDim2.new(1, -40, 0, 20),
            Position = UDim2.new(0, 15, 0, 8),
            BackgroundTransparency = 1,
            Text = Title,
            TextColor3 = Evok.ThemeManager:GetColor("Text"),
            Font = Evok.Fonts.Bold,
            TextSize = 14,
            TextXAlignment = Enum.TextXAlignment.Left
        })

        local ContentLabel = Evok.Utility.Instance:Create("TextLabel", {
            Name = "Content",
            Parent = Frame,
            Size = UDim2.new(1, -30, 0, 0),
            Position = UDim2.new(0, 15, 0, 30),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            Text = Content,
            TextColor3 = Evok.ThemeManager:GetColor("TextDark"),
            Font = Evok.Fonts.Main,
            TextSize = 13,
            TextWrapped = true,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top
        })

        local Padding = Evok.Utility.Instance:Create("UIPadding", {
            Parent = Frame,
            PaddingBottom = UDim.new(0, 18) -- Espaço para a barra de progresso
        })

        local ProgressBarBG = Evok.Utility.Instance:Create("Frame", {
            Name = "ProgressBG",
            Parent = Frame,
            Size = UDim2.new(1, 0, 0, 2),
            Position = UDim2.new(0, 0, 1, -2),
            BackgroundColor3 = Evok.ThemeManager:GetColor("Background"),
            BorderSizePixel = 0
        })

        local ProgressBar = Evok.Utility.Instance:Create("Frame", {
            Name = "Progress",
            Parent = ProgressBarBG,
            Size = UDim2.new(1, 0, 1, 0),
            Position = UDim2.new(0, 0, 0, 0),
            BackgroundColor3 = ThemeColor,
            BorderSizePixel = 0
        })

        -- Adiciona à lista e recalcula física
        local NotifData = {Frame = Frame, IsAlive = true}
        table.insert(Evok.NotificationEngine.ActiveList, NotifData)
        Evok.NotificationEngine:UpdatePhysics()

        -- Animação da Barra de Tempo
        TweenService:Create(ProgressBar, TweenInfo.new(Duration, Enum.EasingStyle.Linear), {
            Size = UDim2.new(0, 0, 1, 0)
        }):Play()

        -- Sistema de Autodestruição
        task.delay(Duration, function()
            if NotifData.IsAlive then
                NotifData.IsAlive = false
                
                -- Fade Out Anim
                local fade = TweenService:Create(Frame, TweenInfo.new(0.3, Enum.EasingStyle.Sine, Enum.EasingDirection.In), {
                    Position = UDim2.new(1, 50, 0, Frame.Position.Y.Offset),
                    BackgroundTransparency = 1
                })
                
                -- Aplicar transparência a tudo dentro do frame
                for _, child in ipairs(Frame:GetDescendants()) do
                    if child:IsA("TextLabel") then
                        TweenService:Create(child, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
                    elseif child:IsA("Frame") then
                        TweenService:Create(child, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
                    elseif child:IsA("UIStroke") then
                        TweenService:Create(child, TweenInfo.new(0.3), {Transparency = 1}):Play()
                    end
                end

                fade:Play()
                fade.Completed:Wait()
                
                Frame:Destroy()
                
                -- Remove da lista ativa e atualiza as outras
                for i, v in ipairs(Evok.NotificationEngine.ActiveList) do
                    if v == NotifData then
                        table.remove(Evok.NotificationEngine.ActiveList, i)
                        break
                    end
                end
                Evok.NotificationEngine:UpdatePhysics()
            end
        end)
    end

