function VisualsModule:DrawHitmarker(color: Color3)
    if not self.HitmarkerLayer then return end
    
    local center = Camera.ViewportSize / 2
    local mSize = 12
    local thick = 2
    local gap = 4

    local wrapper = Instance.new("Frame")
    wrapper.Size = UDim2.new(0, mSize * 3, 0, mSize * 3)
    wrapper.Position = UDim2.new(0, center.X - (mSize * 1.5), 0, center.Y - (mSize * 1.5))
    wrapper.BackgroundTransparency = 1
    wrapper.Parent = self.HitmarkerLayer

    local angles = {45, 135, 225, 315}
    local lines = {}

    for _, deg in ipairs(angles) do
        local line = Instance.new("Frame")
        line.BackgroundColor3 = color or Color3.fromRGB(255, 255, 255)
        line.BorderSizePixel = 0
        line.AnchorPoint = Vector2.new(0.5, 0.5)
        line.Size = UDim2.new(0, thick, 0, mSize)
        
        local rad = math.rad(deg)
        local cx, cy = (mSize * 1.5), (mSize * 1.5)
        local dx = math.cos(rad) * gap
        local dy = math.sin(rad) * gap
        
        line.Position = UDim2.new(0, cx + dx, 0, cy + dy)
        line.Rotation = deg
        line.Parent = wrapper
        table.insert(lines, line)
    end

    local info = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    for _, line in ipairs(lines) do
        local rad = math.rad(line.Rotation)
        local cx, cy = (mSize * 1.5), (mSize * 1.5)
        local nx = math.cos(rad) * (gap + 12)
        local ny = math.sin(rad) * (gap + 12)
        
        TweenService:Create(line, info, {
            Position = UDim2.new(0, cx + nx, 0, cy + ny),
            BackgroundTransparency = 1
        }):Play()
    end

    task.delay(0.35, function() wrapper:Destroy() end)
end

function VisualsModule:CreateEngineCrosshair(enabled: boolean, color: Color3)
    if not self.CrosshairLayer then return end
    self.CrosshairLayer:ClearAllChildren()
    if not enabled then return end

    local baseSize = 8
    local thick = 2

    local TopLine = Instance.new("Frame", self.CrosshairLayer)
    TopLine.BorderSizePixel = 0
    TopLine.BackgroundColor3 = color
    
    local BottomLine = Instance.new("Frame", self.CrosshairLayer)
    BottomLine.BorderSizePixel = 0
    BottomLine.BackgroundColor3 = color

    local LeftLine = Instance.new("Frame", self.CrosshairLayer)
    LeftLine.BorderSizePixel = 0
    LeftLine.BackgroundColor3 = color

    local RightLine = Instance.new("Frame", self.CrosshairLayer)
    RightLine.BorderSizePixel = 0
    RightLine.BackgroundColor3 = color

    -- Loop de adaptação por velocidade do caractere (Crosshair Spread dinâmico)
    local crossConn = RunService.RenderStepped:Connect(function()
        local c = Camera.ViewportSize / 2
        local spread = 0
        
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum and hum.MoveDirection.Magnitude > 0 then
            spread = math.clamp(hum.WalkSpeed * 0.5, 0, 15)
        end

        TopLine.Size = UDim2.new(0, thick, 0, baseSize)
        TopLine.Position = UDim2.new(0, c.X - (thick/2), 0, c.Y - baseSize - spread)

        BottomLine.Size = UDim2.new(0, thick, 0, baseSize)
        BottomLine.Position = UDim2.new(0, c.X - (thick/2), 0, c.Y + spread)

        LeftLine.Size = UDim2.new(0, baseSize, 0, thick)
        LeftLine.Position = UDim2.new(0, c.X - baseSize - spread, 0, c.Y - (thick/2))

        RightLine.Size = UDim2.new(0, baseSize, 0, thick)
        RightLine.Position = UDim2.new(0, c.X + spread, 0, c.Y - (thick/2))
    end)
    table.insert(self.Connections, crossConn)
end

