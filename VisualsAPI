    local function SanitizeRichText(str)
        str = string.gsub(str, "&", "&amp;")
        str = string.gsub(str, "<", "&lt;")
        str = string.gsub(str, ">", "&gt;")
        str = string.gsub(str, "\"", "&quot;")
        str = string.gsub(str, "'", "&apos;")
        return str
    end

    local function Colorize(text, color)
        local r = math.round(color.R * 255)
        local g = math.round(color.G * 255)
        local b = math.round(color.B * 255)
        local hex = string.format("#%02X%02X%02X", r, g, b)
        return string.format('<font color="%s">%s</font>', hex, SanitizeRichText(text))
    end

    function Evok.Highlighter:FormatCode(sourceCode)
        if not sourceCode or sourceCode == "" then return "" end

        local tokens = {}
        local length = #sourceCode
        local index = 1

        while index <= length do
            local startPos, endPos, matchStr

            -- Match de Comentários Multilinha: --[[ ... ]]
            startPos, endPos, matchStr = string.find(sourceCode, "^%-%-%[%[.-%]%]", index)
            if startPos then
                table.insert(tokens, {Type = "Comment", Text = matchStr})
                index = endPos + 1
                continue
            end

            -- Match de Comentários de Linha Única
            startPos, endPos, matchStr = string.find(sourceCode, "^%-%-[^\n]*", index)
            if startPos then
                table.insert(tokens, {Type = "Comment", Text = matchStr})
                index = endPos + 1
                continue
            end

            -- Match de Strings Multilinha
            startPos, endPos, matchStr = string.find(sourceCode, "^%[%[.-%]%]", index)
            if startPos then
                table.insert(tokens, {Type = "String", Text = matchStr})
                index = endPos + 1
                continue
            end

            -- Match de Strings ("")
            startPos, endPos, matchStr = string.find(sourceCode, '^"[^"\\]*(?:\\.[^"\\]*)*"', index)
            if startPos then
                table.insert(tokens, {Type = "String", Text = matchStr})
                index = endPos + 1
                continue
            end

            -- Match de Strings ('')
            startPos, endPos, matchStr = string.find(sourceCode, "^'[^'\\]*(?:\\.[^'\\]*)*'", index)
            if startPos then
                table.insert(tokens, {Type = "String", Text = matchStr})
                index = endPos + 1
                continue
            end

            -- Match Hexadecimal
            startPos, endPos, matchStr = string.find(sourceCode, "^0x[%d%a]+", index)
            if startPos then
                table.insert(tokens, {Type = "Number", Text = matchStr})
                index = endPos + 1
                continue
            end

            -- Match Números
            startPos, endPos, matchStr = string.find(sourceCode, "^%d+%.?%d*", index)
            if startPos then
                table.insert(tokens, {Type = "Number", Text = matchStr})
                index = endPos + 1
                continue
            end

            -- Match Palavras (Keywords, BuiltIns, Functions)
            startPos, endPos, matchStr = string.find(sourceCode, "^[%a_][%w_]*", index)
            if startPos then
                local tokenType = "Text"
                if self.Keywords[matchStr] then
                    tokenType = "Keyword"
                elseif self.BuiltIns[matchStr] then
                    tokenType = "BuiltIn"
                else
                    local nextChar = string.match(sourceCode, "^%s*(.)", endPos + 1)
                    if nextChar == "(" then
                        tokenType = "Function"
                    end
                end
                
                table.insert(tokens, {Type = tokenType, Text = matchStr})
                index = endPos + 1
                continue
            end

            -- Match Espaços Brancos
            startPos, endPos, matchStr = string.find(sourceCode, "^%s+", index)
            if startPos then
                table.insert(tokens, {Type = "Whitespace", Text = matchStr})
                index = endPos + 1
                continue
            end

            -- Símbolos Restantes
            local char = string.sub(sourceCode, index, index)
            table.insert(tokens, {Type = "Operator", Text = char})
            index = index + 1
        end

        local formattedCode = ""
        for _, token in ipairs(tokens) do
            if token.Type == "Whitespace" then
                formattedCode = formattedCode .. SanitizeRichText(token.Text)
            elseif token.Type == "Text" then
                formattedCode = formattedCode .. Colorize(token.Text, self.Theme.Text)
            else
                local targetColor = self.Theme[token.Type] or self.Theme.Text
                formattedCode = formattedCode .. Colorize(token.Text, targetColor)
            end
        end

        return formattedCode
    end

