Visuals.ParticleEngine = {
    Enabled = true,
    Gravity = Vector2.new(0, 300), 
    Wind = Vector2.new(0, 0),
    BounceFriction = 0.6,
    Container = nil
}

function Visuals.ParticleEngine:Init(TargetGUI)
    if self.Container then return end
    self.Container = Instance.new("Frame")
    self.Container.Name = "EvokParticleContainer"
    self.Container.Size = UDim2.new(1, 0, 1, 0)
    self.Container.BackgroundTransparency = 1
    self.Container.ZIndex = 9000
    self.Container.Parent = TargetGUI

    local lastUpdate = tick()
    local conn = RunService.RenderStepped:Connect(function()
        if not self.Enabled then return end
        local now = tick()
        local dt = math.clamp(now - lastUpdate, 0.001, 0.1)
        lastUpdate = now
        
        local screenSize = Camera.ViewportSize

        for i = #Visuals.Particles, 1, -1 do
            local p = Visuals.Particles[i]
            p.Life = p.Life - dt
            
            if p.Life <= 0 then
                p.Frame:Destroy()
                table.remove(Visuals.Particles, i)
            else
                -- Verlet/Euler Physics Integration
                p.Velocity = p.Velocity + (self.Gravity + self.Wind) * dt
                p.Velocity = p.Velocity * (1 - (p.Drag * dt))
                p.Position = p.Position + p.Velocity * dt
                p.Rotation = p.Rotation + p.Spin * dt
                
                -- Screen Bounce Collision Logic
                if p.Bounce then
                    local sizeHalf = p.CurrentSize / 2
                    if p.Position.X - sizeHalf < 0 then
                        p.Position = Vector2.new(sizeHalf, p.Position.Y)
                        p.Velocity = Vector2.new(math.abs(p.Velocity.X) * self.BounceFriction, p.Velocity.Y)
                    elseif p.Position.X + sizeHalf > screenSize.X then
                        p.Position = Vector2.new(screenSize.X - sizeHalf, p.Position.Y)
                        p.Velocity = Vector2.new(-math.abs(p.Velocity.X) * self.BounceFriction, p.Velocity.Y)
                    end
                    
                    if p.Position.Y + sizeHalf > screenSize.Y then
                        p.Position = Vector2.new(p.Position.X, screenSize.Y - sizeHalf)
                        p.Velocity = Vector2.new(p.Velocity.X, -math.abs(p.Velocity.Y) * self.BounceFriction)
                    elseif p.Position.Y - sizeHalf < 0 then
                        p.Position = Vector2.new(p.Position.X, sizeHalf)
                        p.Velocity = Vector2.new(p.Velocity.X, math.abs(p.Velocity.Y) * self.BounceFriction)
                    end
                end
                
                local lifeRatio = math.clamp(p.Life / p.MaxLife, 0, 1)
                p.CurrentSize = p.StartSize * lifeRatio
                
                -- Dynamic Color Interpolation
                if p.EndColor then
                    p.Frame.BackgroundColor3 = p.EndColor:Lerp(p.StartColor, lifeRatio)
                end
                
                p.Frame.Position = UDim2.new(0, p.Position.X, 0, p.Position.Y)
                p.Frame.Rotation = p.Rotation
                p.Frame.Size = UDim2.new(0, p.CurrentSize, 0, p.CurrentSize)
                p.Frame.BackgroundTransparency = 1 - (math.sin(lifeRatio * math.pi)) -- Smooth fade in and out
            end
        end
    end)
    table.insert(Visuals.Connections, conn)
end

function Visuals.ParticleEngine:Emit(config)
    if not self.Container or not self.Enabled then return end
    
    local amount = config.Amount or 1
    local origin = config.Position or Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local startCol = config.Color or Color3.fromRGB(255, 255, 255)
    local endCol = config.EndColor or startCol
    
    for i = 1, amount do
        local angle = math.rad(math.random(0, 360))
        local speed = math.random(config.MinSpeed or 100, config.MaxSpeed or 400)
        local vel = Vector2.new(math.cos(angle) * speed, math.sin(angle) * speed)
        
        local frame = Instance.new("Frame")
        frame.BackgroundColor3 = startCol
        frame.BorderSizePixel = 0
        frame.AnchorPoint = Vector2.new(0.5, 0.5)
        
        if config.Shape == "Circle" or not config.Shape then
            Instance.new("UICorner", frame).CornerRadius = UDim.new(1, 0)
        end
        
        frame.Parent = self.Container

        local startSize = math.random(config.MinSize or 3, config.MaxSize or 8)
        
        table.insert(Visuals.Particles, {
            Frame = frame,
            Position = origin,
            Velocity = vel,
            StartSize = startSize,
            CurrentSize = startSize,
            StartColor = startCol,
            EndColor = endCol,
            Life = config.Lifetime or 2,
            MaxLife = config.Lifetime or 2,
            Rotation = math.random(0, 360),
            Spin = math.random(-360, 360),
            Drag = config.Drag or 1.5,
            Bounce = config.Bounce or false
        })
    end
end

