function Visuals.Overlay:Hitmarker(color, soundId)
    if not Visuals.HitmarkerGUI then return end
    
    local center = Camera.ViewportSize / 2
    local size = 12
    local thickness = 2
    local gap = 6
    local drawColor = color or Color3.fromRGB(255, 255, 255)

    local container = Instance.new("Frame")
    container.Size = UDim2.new(0, size*3, 0, size*3)
    container.Position = UDim2.new(0, center.X - (size*1.5), 0, center.Y - (size*1.5))
    container.BackgroundTransparency = 1
    container.Parent = Visuals.HitmarkerGUI

    local angles = {45, 135, 225, 315}
    local lines = {}
    
    for _, angle in ipairs(angles) do
        local line = Instance.new("Frame")
        line.BackgroundColor3 = drawColor
        line.BorderSizePixel = 0
        line.AnchorPoint = Vector2.new(0.5, 0.5)
        line.Size = UDim2.new(0, thickness, 0, size)
        
        local rad = math.rad(angle)
        local cx, cy = (size*1.5), (size*1.5)
        local dx, dy = math.cos(rad) * gap, math.sin(rad) * gap
        
        line.Position = UDim2.new(0, cx + dx, 0, cy + dy)
        line.Rotation = angle
        line.Parent = container
        table.insert(lines, line)
    end

    if soundId then
        task.spawn(function()
            local snd = Instance.new("Sound")
            snd.SoundId = "rbxassetid://" .. tostring(soundId)
            snd.Volume = 1
            snd.Parent = workspace
            snd:Play()
            game:GetService("Debris"):AddItem(snd, 2)
        end)
    end

    local tweenInfo = TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
    for _, line in ipairs(lines) do
        local rad = math.rad(line.Rotation)
        local cx, cy = (size*1.5), (size*1.5)
        local nx, ny = math.cos(rad) * (gap + 12), math.sin(rad) * (gap + 12)
        
        local tw = TweenService:Create(line, tweenInfo, {
            Position = UDim2.new(0, cx + nx, 0, cy + ny),
            BackgroundTransparency = 1
        })
        tw:Play()
    end

    task.delay(0.4, function() container:Destroy() end)
end

