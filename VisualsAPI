        LineLabel.TextSize = 12
        LineLabel.TextXAlignment = Enum.TextXAlignment.Right
        LineLabel.TextYAlignment = Enum.TextYAlignment.Top
        LineLabel.Parent = LineScroll

        Scroll:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
            LineScroll.CanvasPosition = Vector2.new(0, Scroll.CanvasPosition.Y)
        end)

        local function UpdateViewer(text)
            rawCode = text
            CodeLabel.Text = ParseSyntax(text)
            
            local lines = CountLines(text)
            local lineStr = ""
            for i = 1, lines do lineStr = lineStr .. tostring(i) .. "\n" end
            LineLabel.Text = lineStr
            
            -- Context Menu Integration for Lexer
            if Visuals.ContextMenuGUI then
                Visuals.ContextMenu:Create(ViewerFrame, {
                    {Name = "Copy All Code", Callback = function() 
                        if setclipboard then setclipboard(rawCode) end 
                    end},
                    {Name = "Clear Viewer", Callback = function() UpdateViewer("-- Cleared") end}
                })
            end
        end

        UpdateViewer(rawCode)

        Core:SubscribeToTheme(function(theme)
            ViewerFrame.BackgroundColor3 = Core.Math.Color.Darken(theme.Background, 0.05)
            ViewerStroke.Color = theme.Border
            LineNumberGutter.BackgroundColor3 = theme.Container
            GutterLine.BackgroundColor3 = theme.Border
            Scroll.ScrollBarImageColor3 = theme.Border
            CodeLabel.TextColor3 = theme.Text
        end)

        return {
            SetCode = function(newCode) UpdateViewer(newCode) end,
            GetCode = function() return rawCode end
        }
    end
end

-- ==============================================================================
-- 💣 SYSTEM 7: GLOBAL UNLOADER & DEEP GARBAGE COLLECTOR
-- ==============================================================================
function Visuals:InjectUnloader(CoreInstance)
    local Core = CoreInstance.Core
    local Window = CoreInstance

    function Window:Unload()
        Core.Logger:Log("Initiating Global Unload Sequence...")

        Visuals:DisablePostProcessing()

        if Visuals.ParticleEngine.Container then
            Visuals.ParticleEngine.Container:Destroy()
            Visuals.ParticleEngine.Enabled = false
        end
        if Visuals.HitmarkerGUI then Visuals.HitmarkerGUI:Destroy() end
        if Visuals.DamageNumGUI then Visuals.DamageNumGUI:Destroy() end
        if Visuals.ContextMenuGUI then Visuals.ContextMenuGUI:Destroy() end

        if Core.Cursor.Instance then
            Core.Cursor.Instance:Destroy()
            Core.Cursor.Enabled = false
            UserInputService.MouseIconEnabled = true
        end

        for _, conn in ipairs(Visuals.Connections) do
            if conn.Connected then conn:Disconnect() end
        end
        table.clear(Visuals.Connections)

        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            Camera.CameraSubject = LocalPlayer.Character.Humanoid
        end

        if Window.GUI then
            local mainFrame = Window.MainFrame.Parent
            local outTween = TweenService:Create(mainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                Size = UDim2.new(0, 0, 0, 0)
            })
            outTween:Play()
            outTween.Completed:Wait()
            
            Window.GUI:Destroy()
            Window.GUI = nil
        end
        
        Core.Logger:Log("Unloaded Evok Library completely. Zero Memory Leaks.")
        if getgenv and getgenv().EvokAPI then getgenv().EvokAPI = nil end
    end
end

-- ==============================================================================
-- 🔗 SYSTEM 8: EXTERNAL API EXPORT & INJECTION BINDING
-- ==============================================================================
function Visuals.Inject(CoreInstance)
    Visuals.ParticleEngine:Init(CoreInstance.GUI)
    Visuals.Overlay:Init(CoreInstance.GUI)
    Visuals.DamageNumbers:Init(CoreInstance.GUI)
    Visuals.ContextMenu:Init(CoreInstance.GUI, CoreInstance.Core)
    
    Visuals:InjectScriptViewer(CoreInstance)
    Visuals:InjectUnloader(CoreInstance)

    local API = {
        EmitParticles = function(config) Visuals.ParticleEngine:Emit(config) end,
        DrawHitmarker = function(color, snd) Visuals.Overlay:Hitmarker(color, snd) end,
        DrawDamage = function(amt, pos, crit) Visuals.DamageNumbers:Show(amt, pos, crit) end,
        ToggleCinematic = function(profile) 
            if profile then Visuals:ApplyCinematicProfile(profile, CoreInstance.Core.Themes.Accent) 
            else Visuals:DisablePostProcessing() end 
        end,
        Notify = function(cfg) CoreInstance.Core:Notify(cfg) end,
        SetTheme = function(col) CoreInstance.Core:SetTheme("API", col) end,
        Unload = function() CoreInstance:Unload() end
    }

    if getgenv then getgenv().EvokAPI = API end
    CoreInstance.Core.Logger:Log("VisualsAPI Injected & Global API Exported.")
    return API
end

return Visuals
