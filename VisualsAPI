-- 🌌 SYSTEM 1: ADVANCED PARTICLE ENGINE 3.5 (With Dynamic Turbulence)
-- ==============================================================================
VisualsModule.ParticleEngine = {
    Active = true,
    Gravity = Vector2.new(0, 200),
    Wind = Vector2.new(15, 0),
    BounceElasticity = 0.6,
    Container = nil
}

function VisualsModule.ParticleEngine:Init(targetGui: ScreenGui)
    if self.Container then return end
    
    local Layer = Instance.new("Frame")
    Layer.Name = "EvokParticleLayer"
    Layer.Size = UDim2.new(1, 0, 1, 0)
    Layer.BackgroundTransparency = 1
    Layer.ZIndex = 9995
    Layer.Parent = targetGui
    self.Container = Layer

    local lastTime = tick()
    local loopConn = RunService.RenderStepped:Connect(function()
        if not self.Active then return end
        local now = tick()
        local dt = math.clamp(now - lastTime, 0.001, 0.1)
        lastTime = now
        
        local bounds = Camera.ViewportSize

        for i = #VisualsModule.Particles, 1, -1 do
            local p = VisualsModule.Particles[i]
            p.Life = p.Life - dt
            
            if p.Life <= 0 then
                p.Frame:Destroy()
                table.remove(VisualsModule.Particles, i)
            else
                -- Aplica turbulência harmônica usando o motor matemático procedural
                local timeFactor = tick() * p.NoiseFrequency
                local turbulenceX = MathExt.PseudoNoise(timeFactor) * p.NoiseAmplitude
                local turbulenceY = MathExt.PseudoNoise(timeFactor + 5) * p.NoiseAmplitude
                local appliedTurbulence = Vector2.new(turbulenceX, turbulenceY)

                -- Pipeline de Integração Cinemática
                p.Velocity = p.Velocity + (self.Gravity + self.Wind + appliedTurbulence) * dt
                p.Velocity = p.Velocity * (1 - (p.Drag * dt))
                p.Position = p.Position + p.Velocity * dt
                p.Rotation = p.Rotation + p.Spin * dt
                
                -- Detecção de Borda da Tela (Tratamento de Colisão Rígida)
                if p.Bounce then
                    local hSize = p.CurrentSize / 2
                    if p.Position.X - hSize < 0 then
                        p.Position = Vector2.new(hSize, p.Position.Y)
                        p.Velocity = Vector2.new(math.abs(p.Velocity.X) * self.BounceElasticity, p.Velocity.Y)
                    elseif p.Position.X + hSize > bounds.X then
                        p.Position = Vector2.new(bounds.X - hSize, p.Position.Y)
                        p.Velocity = Vector2.new(-math.abs(p.Velocity.X) * self.BounceElasticity, p.Velocity.Y)
                    end
                    
                    if p.Position.Y + hSize > bounds.Y then
                        p.Position = Vector2.new(p.Position.X, bounds.Y - hSize)
                        p.Velocity = Vector2.new(p.Velocity.X, -math.abs(p.Velocity.Y) * self.BounceElasticity)
                    elseif p.Position.Y - hSize < 0 then
                        p.Position = Vector2.new(p.Position.X, hSize)
                        p.Velocity = Vector2.new(p.Velocity.X, math.abs(p.Velocity.Y) * self.BounceElasticity)
                    end
                end
                
                local lifeRatio = math.clamp(p.Life / p.MaxLife, 0, 1)
                p.CurrentSize = p.StartSize * lifeRatio
                
                if p.EndColor then
                    p.Frame.BackgroundColor3 = MathExt.LerpColor(p.EndColor, p.StartColor, lifeRatio)
                end
                
                p.Frame.Position = UDim2.new(0, p.Position.X, 0, p.Position.Y)
                p.Frame.Rotation = p.Rotation
                p.Frame.Size = UDim2.new(0, p.CurrentSize, 0, p.CurrentSize)
                p.Frame.BackgroundTransparency = 1 - (math.sin(lifeRatio * math.pi))
            end
        end
    end)
    table.insert(VisualsModule.Connections, loopConn)
end

function VisualsModule.ParticleEngine:Emit(config: table)
    if not self.Container or not self.Active then return end
    
    local amt = config.Amount or 1
    local src = config.Position or Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local sCol = config.Color or Color3.fromRGB(255, 255, 255)
    local eCol = config.EndColor or sCol
    
    for i = 1, amt do
        local angle = math.rad(math.random(0, 360))
        local force = math.random(config.MinSpeed or 50, config.MaxSpeed or 300)
        local initialVel = Vector2.new(math.cos(angle) * force, math.sin(angle) * force)
        
        local element = Instance.new("Frame")
        element.BackgroundColor3 = sCol
        element.BorderSizePixel = 0
        element.AnchorPoint = Vector2.new(0.5, 0.5)
        
        if config.Shape == "Circle" or not config.Shape then
            Instance.new("UICorner", element).CornerRadius = UDim.new(1, 0)
        end
        element.Parent = self.Container

        local sizeStart = math.random(config.MinSize or 3, config.MaxSize or 7)
        
        table.insert(VisualsModule.Particles, {
            Frame = element,
            Position = src,
            Velocity = initialVel,
            StartSize = sizeStart,
            CurrentSize = sizeStart,
            StartColor = sCol,
            EndColor = eCol,
            Life = config.Lifetime or 1.5,
            MaxLife = config.Lifetime or 1.5,
            Rotation = math.random(0, 360),
            Spin = math.random(-180, 180),
            Drag = config.Drag or 1.1,
            Bounce = config.Bounce or false,
            NoiseFrequency = math.random(2, 8),
            NoiseAmplitude = math.random(10, 50)
        })
    end
end

-- ==============================================================================
-- 🌈 SYSTEM 2: CHROMA VECTOR ENGINE (RGB Multi-Property Mapping Threads)
-- ==============================================================================
function VisualsModule:StartChromaThread()
    if self.ChromaActive then return end
    self.ChromaActive = true
    
    local elapsed = 0
    local chromaConn = RunService.Heartbeat:Connect(function(dt)
        if not self.ChromaActive then return end
        elapsed = elapsed + dt
        
        for idx = #self.ChromaRegistry, 1, -1 do
            local entry = self.ChromaRegistry[idx]
            local instance = entry.Object
            
            if instance and instance.Parent then
                local alpha = (elapsed * entry.Speed + entry.Offset) % 1
                local rainbow = Color3.fromHSV(alpha, 0.75, 1)
                
                local success = pcall(function()
                    instance[entry.Property] = rainbow
                end)
                if not success then
                    table.remove(self.ChromaRegistry, idx)
                end
            else
                table.remove(self.ChromaRegistry, idx)
            end
        end
    end)
    table.insert(self.Connections, chromaConn)
end

function VisualsModule:RegisterChromaElement(instance: Instance, propertyName: string, speed: number?, offset: number?)
    table.insert(self.ChromaRegistry, {
        Object = instance,
        Property = propertyName,
        Speed = speed or 0.12,
        Offset = offset or (#self.ChromaRegistry * 0.04)
    })
    if not self.ChromaActive then self:StartChromaThread() end
end

