function Visuals:ApplyCinematicProfile(profileName, themeAccent)
    self:DisablePostProcessing()

    local depth = Instance.new("DepthOfFieldEffect")
    depth.Name = "EvokFX_DOF"
    depth.Parent = Lighting

    local colorCor = Instance.new("ColorCorrectionEffect")
    colorCor.Name = "EvokFX_CC"
    colorCor.Parent = Lighting

    local bloom = Instance.new("BloomEffect")
    bloom.Name = "EvokFX_Bloom"
    bloom.Parent = Lighting

    if profileName == "VibrantAcrylic" then
        depth.FarIntensity = 0; depth.FocusDistance = 0.05; depth.InFocusRadius = 0; depth.NearIntensity = 1
        colorCor.Brightness = 0.02; colorCor.Contrast = 0.15; colorCor.Saturation = 0.3
        colorCor.TintColor = Color3.new(1, 1, 1):Lerp(themeAccent, 0.1)
        bloom.Intensity = 0.4; bloom.Size = 20; bloom.Threshold = 0.8
    elseif profileName == "MutedNight" then
        depth.FarIntensity = 0; depth.FocusDistance = 0.05; depth.InFocusRadius = 0; depth.NearIntensity = 0.8
        colorCor.Brightness = -0.1; colorCor.Contrast = 0.05; colorCor.Saturation = -0.5
        colorCor.TintColor = Color3.fromRGB(200, 200, 255)
        bloom.Intensity = 0.2; bloom.Size = 10; bloom.Threshold = 1.5
    else -- Default Acrylic
        depth.FarIntensity = 0; depth.FocusDistance = 0.05; depth.InFocusRadius = 0; depth.NearIntensity = 1
        colorCor.Brightness = -0.05; colorCor.Contrast = 0.1; colorCor.Saturation = -0.2
        colorCor.TintColor = Color3.new(1, 1, 1):Lerp(themeAccent, 0.05)
        bloom.Intensity = 0; bloom.Size = 0; bloom.Threshold = 2
    end

    self.PostProcessing["DOF"] = depth
    self.PostProcessing["CC"] = colorCor
    self.PostProcessing["Bloom"] = bloom

    local conn = RunService.RenderStepped:Connect(function()
        if depth.Parent then depth.FocusDistance = 0.05 end
    end)
    table.insert(self.Connections, conn)
end

function Visuals:DisablePostProcessing()
    for _, inst in pairs(self.PostProcessing) do
        if inst and inst.Parent then inst:Destroy() end
    end
    table.clear(self.PostProcessing)
end

