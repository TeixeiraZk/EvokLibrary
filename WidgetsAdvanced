-- ==============================================================================
-- 🧮 UTILITY: DISTÂNCIA DE LEVENSHTEIN (Fuzzy Search Engine)
-- ==============================================================================
local function Levenshtein(str1: string, str2: string): number
    local len1, len2 = #str1, #str2
    local matrix = {}
    for i = 0, len1 do matrix[i] = {[0] = i} end
    for j = 0, len2 do matrix[0][j] = j end
    for i = 1, len1 do
        for j = 1, len2 do
            local cost = (str1:sub(i, i) == str2:sub(j, j) and 0 or 1)
            matrix[i][j] = math.min(matrix[i - 1][j] + 1, matrix[i][j - 1] + 1, matrix[i - 1][j - 1] + cost)
        end
    end
    return matrix[len1][len2]
end

local function FuzzyMatch(query: string, text: string): (boolean, number)
    query, text = query:lower(), text:lower()
    if string.find(text, query, 1, true) then return true, 0 end
    local dist = Levenshtein(query, text)
    if dist <= math.clamp(math.floor(#query / 3), 1, 3) then return true, dist end
    return false, 999
end

