        local ScrollContainer = Instance.new("ScrollingFrame")
        ScrollContainer.Size = UDim2.new(1, 0, 1, -70)
        ScrollContainer.Position = UDim2.new(0, 0, 0, 70)
        ScrollContainer.BackgroundTransparency = 1
        ScrollContainer.ScrollBarThickness = 2
        ScrollContainer.ScrollBarImageColor3 = Core.Themes.Border
        ScrollContainer.Parent = DropFrame
        
        local ListLayout = Instance.new("UIListLayout")
        ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
        ListLayout.Parent = ScrollContainer

        local function ToggleDrop()
            Dropdown.Open = not Dropdown.Open
            Icon.Text = Dropdown.Open and "▲" or "▼"
            self.Container.ZIndex = Dropdown.Open and 5 or 1
            DropFrame.ZIndex = Dropdown.Open and 5 or 1
            
            local maxItems = 5
            local itemsCount = math.min(#Dropdown.Options, maxItems)
            local targetSize = Dropdown.Open and UDim2.new(1, 0, 0, 70 + (itemsCount * 25)) or UDim2.new(1, 0, 0, 40)
            
            ScrollContainer.CanvasSize = UDim2.new(0, 0, 0, #Dropdown.Options * 25)
            Core:Tween(DropFrame, {Size = targetSize}, 0.25, Enum.EasingStyle.Quint)
        end

        MainBtn.MouseButton1Click:Connect(ToggleDrop)

        SelectAllBtn.MouseButton1Click:Connect(function()
            Dropdown.Selected = {}
            for _, opt in ipairs(Dropdown.Options) do
                table.insert(Dropdown.Selected, opt)
            end
            UpdateLabel()
            callback(Dropdown.Selected)
            Dropdown:Refresh(Dropdown.Options)
        end)

        ClearBtn.MouseButton1Click:Connect(function()
            Dropdown.Selected = {}
            UpdateLabel()
            callback(Dropdown.Selected)
            Dropdown:Refresh(Dropdown.Options)
        end)

        function Dropdown:Refresh(newOptions)
            Dropdown.Options = newOptions
            for _, child in pairs(ScrollContainer:GetChildren()) do
                if child:IsA("TextButton") then child:Destroy() end
            end

            for _, opt in ipairs(Dropdown.Options) do
                local isSelected = table.find(Dropdown.Selected, opt) ~= nil

                local OptBtn = Instance.new("TextButton")
                OptBtn.Size = UDim2.new(1, 0, 0, 25)
                OptBtn.BackgroundTransparency = 1
                OptBtn.Text = ""
                OptBtn.Parent = ScrollContainer

                local OptLabel = Instance.new("TextLabel")
                OptLabel.Size = UDim2.new(1, -30, 1, 0)
                OptLabel.Position = UDim2.new(0, 30, 0, 0)
                OptLabel.BackgroundTransparency = 1
                OptLabel.Text = tostring(opt)
                OptLabel.TextColor3 = isSelected and Core.Themes.Accent or Core.Themes.Text
                OptLabel.Font = Enum.Font.Gotham
                OptLabel.TextSize = 13
                OptLabel.TextXAlignment = Enum.TextXAlignment.Left
                OptLabel.Parent = OptBtn

                local CheckBox = Instance.new("Frame")
                CheckBox.Size = UDim2.new(0, 12, 0, 12)
                CheckBox.Position = UDim2.new(0, 10, 0.5, -6)
                CheckBox.BackgroundColor3 = isSelected and Core.Themes.Accent or Core.Themes.Background
                CheckBox.Parent = OptBtn
                Instance.new("UICorner", CheckBox).CornerRadius = UDim.new(0, 3)
                local CheckStroke = Instance.new("UIStroke", CheckBox)
                CheckStroke.Color = isSelected and Core.Themes.Accent or Core.Themes.Border

                OptBtn.MouseButton1Click:Connect(function()
                    if isSelected then
                        local idx = table.find(Dropdown.Selected, opt)
                        if idx then table.remove(Dropdown.Selected, idx) end
                    else
                        table.insert(Dropdown.Selected, opt)
                    end
                    UpdateLabel()
                    callback(Dropdown.Selected)
                    Dropdown:Refresh(Dropdown.Options) 
                end)
            end
        end

        Core:SubscribeToTheme(function(theme)
            DropFrame.BackgroundColor3 = theme.Background
            DropStroke.Color = theme.Border
            Label.TextColor3 = theme.TextMuted
            Icon.TextColor3 = theme.TextMuted
            SelectAllBtn.BackgroundColor3 = theme.Container
            ClearBtn.BackgroundColor3 = theme.Container
            SelectAllBtn.TextColor3 = theme.Text
            ClearBtn.TextColor3 = theme.Text
            ScrollContainer.ScrollBarImageColor3 = theme.Border
            Dropdown:Refresh(Dropdown.Options) 
        end)

        Dropdown:Refresh(Dropdown.Options)
        return Dropdown
    end

