    -- ==============================================================================
    -- 📜 WIDGET: ADVANCED DROPDOWN (Com Search Engine Integrado)
    -- ==============================================================================
    function CoreInstance.Tabs.CreateSection:CreateAdvancedDropdown(opts)
        local Dropdown = { 
            Options = opts.Options or {}, 
            Selected = opts.Default, 
            Open = false,
            SearchQuery = ""
        }
        local callback = opts.Callback or function() end

        local DropFrame = Instance.new("Frame")
        DropFrame.Size = UDim2.new(1, 0, 0, 40)
        DropFrame.BackgroundColor3 = Core.Themes.Background
        DropFrame.ClipsDescendants = true
        DropFrame.Parent = self.Container -- 'self' is the Section
        Instance.new("UICorner", DropFrame).CornerRadius = UDim.new(0, 6)
        local DropStroke = Instance.new("UIStroke", DropFrame)
        DropStroke.Color = Core.Themes.Border

        local MainBtn = Instance.new("TextButton")
        MainBtn.Size = UDim2.new(1, 0, 0, 40)
        MainBtn.BackgroundTransparency = 1
        MainBtn.Text = ""
        MainBtn.Parent = DropFrame

        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(1, -30, 1, 0)
        Label.Position = UDim2.new(0, 10, 0, 0)
        Label.BackgroundTransparency = 1
        Label.Text = opts.Name .. ": " .. tostring(Dropdown.Selected or "None")
        Label.TextColor3 = Core.Themes.TextMuted
        Label.Font = Enum.Font.Gotham
        Label.TextSize = 13
        Label.TextXAlignment = Enum.TextXAlignment.Left
        Label.Parent = MainBtn

        local Icon = Instance.new("TextLabel")
        Icon.Size = UDim2.new(0, 20, 0, 20)
        Icon.Position = UDim2.new(1, -25, 0.5, -10)
        Icon.BackgroundTransparency = 1
        Icon.Text = "▼"
        Icon.TextColor3 = Core.Themes.TextMuted
        Icon.Font = Enum.Font.GothamBold
        Icon.TextSize = 12
        Icon.Parent = MainBtn

        -- Search Bar (Apenas visível quando aberto)
        local SearchBg = Instance.new("Frame")
        SearchBg.Size = UDim2.new(1, -10, 0, 25)
        SearchBg.Position = UDim2.new(0, 5, 0, 40)
        SearchBg.BackgroundColor3 = Core.Themes.Container
        SearchBg.Parent = DropFrame
        Instance.new("UICorner", SearchBg).CornerRadius = UDim.new(0, 4)
        local SearchStroke = Instance.new("UIStroke", SearchBg)
        SearchStroke.Color = Core.Themes.Border

        local SearchInput = Instance.new("TextBox")
        SearchInput.Size = UDim2.new(1, -20, 1, 0)
        SearchInput.Position = UDim2.new(0, 10, 0, 0)
        SearchInput.BackgroundTransparency = 1
        SearchInput.PlaceholderText = "Search..."
        SearchInput.Text = ""
        SearchInput.TextColor3 = Core.Themes.Text
        SearchInput.PlaceholderColor3 = Core.Themes.TextMuted
        SearchInput.Font = Enum.Font.Gotham
        SearchInput.TextSize = 12
        SearchInput.TextXAlignment = Enum.TextXAlignment.Left
        SearchInput.Parent = SearchBg

        local ScrollContainer = Instance.new("ScrollingFrame")
        ScrollContainer.Size = UDim2.new(1, 0, 1, -70)
        ScrollContainer.Position = UDim2.new(0, 0, 0, 70)
        ScrollContainer.BackgroundTransparency = 1
        ScrollContainer.ScrollBarThickness = 2
        ScrollContainer.ScrollBarImageColor3 = Core.Themes.Border
        ScrollContainer.Parent = DropFrame
        
        local ListLayout = Instance.new("UIListLayout")
        ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
        ListLayout.Parent = ScrollContainer

        local function ToggleDrop()
            Dropdown.Open = not Dropdown.Open
            Icon.Text = Dropdown.Open and "▲" or "▼"
            
            self.Container.ZIndex = Dropdown.Open and 5 or 1
            DropFrame.ZIndex = Dropdown.Open and 5 or 1
            
            local maxItems = 5
            -- Filtra a contagem de itens para calcular a altura
            local visibleItems = 0
            for _, child in pairs(ScrollContainer:GetChildren()) do
                if child:IsA("TextButton") and child.Visible then
                    visibleItems = visibleItems + 1
                end
            end

            local itemsCount = math.min(visibleItems, maxItems)
            local targetSize = Dropdown.Open and UDim2.new(1, 0, 0, 70 + (itemsCount * 25)) or UDim2.new(1, 0, 0, 40)
            
            ScrollContainer.CanvasSize = UDim2.new(0, 0, 0, visibleItems * 25)
            Core:Tween(DropFrame, {Size = targetSize}, 0.25, Enum.EasingStyle.Quint)
            
            if Dropdown.Open then
                SearchInput:CaptureFocus()
            else
                SearchInput.Text = ""
            end
        end

        MainBtn.MouseButton1Click:Connect(ToggleDrop)

        function Dropdown:Refresh(newOptions)
            Dropdown.Options = newOptions
            for _, child in pairs(ScrollContainer:GetChildren()) do
                if child:IsA("TextButton") then child:Destroy() end
            end

            for _, opt in ipairs(Dropdown.Options) do
                local OptBtn = Instance.new("TextButton")
                OptBtn.Size = UDim2.new(1, 0, 0, 25)
                OptBtn.BackgroundTransparency = 1
                OptBtn.Text = "  " .. tostring(opt)
                OptBtn.TextColor3 = (Dropdown.Selected == opt) and Core.Themes.Accent or Core.Themes.Text
                OptBtn.Font = Enum.Font.Gotham
                OptBtn.TextSize = 13
                OptBtn.TextXAlignment = Enum.TextXAlignment.Left
                OptBtn.Parent = ScrollContainer

                OptBtn.MouseButton1Click:Connect(function()
                    Dropdown.Selected = opt
                    Label.Text = opts.Name .. ": " .. tostring(opt)
                    callback(opt)
                    ToggleDrop()
                    Dropdown:Refresh(Dropdown.Options)
                end)
            end
            
            if Dropdown.Open then
                ScrollContainer.CanvasSize = UDim2.new(0, 0, 0, #Dropdown.Options * 25)
            end
        end

        -- Search Engine Logic
        SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
            local query = SearchInput.Text:lower()
            local visibleCount = 0
            
            for _, child in pairs(ScrollContainer:GetChildren()) do
                if child:IsA("TextButton") then
                    local textStr = child.Text:lower():gsub("^%s+", "")
                    if query == "" or string.find(textStr, query) then
                        child.Visible = true
                        visibleCount = visibleCount + 1
                    else
                        child.Visible = false
                    end
                end
            end
            
            if Dropdown.Open then
                local maxItems = 5
                local itemsCount = math.min(visibleCount, maxItems)
                DropFrame.Size = UDim2.new(1, 0, 0, 70 + (itemsCount * 25))
                ScrollContainer.CanvasSize = UDim2.new(0, 0, 0, visibleCount * 25)
            end
        end)

        Core:SubscribeToTheme(function(theme)
            DropFrame.BackgroundColor3 = theme.Background
            DropStroke.Color = theme.Border
            Label.TextColor3 = theme.TextMuted
            Icon.TextColor3 = theme.TextMuted
            SearchBg.BackgroundColor3 = theme.Container
            SearchStroke.Color = theme.Border
            SearchInput.TextColor3 = theme.Text
            SearchInput.PlaceholderColor3 = theme.TextMuted
            ScrollContainer.ScrollBarImageColor3 = theme.Border
            Dropdown:Refresh(Dropdown.Options) 
        end)

        Dropdown:Refresh(Dropdown.Options)
        return Dropdown
    end

