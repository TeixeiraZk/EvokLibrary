        SatValMap.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then trackingMap = true end end)
        HueBar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then trackingHue = true end end)
        AlphaBar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then trackingAlpha = true end end)
        
        UserInputService.InputEnded:Connect(function(i) 
            if i.UserInputType == Enum.UserInputType.MouseButton1 then trackingMap, trackingHue, trackingAlpha = false, false, false end 
        end)

        UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement then
                if trackingMap then
                    local x = math.clamp((input.Position.X - SatValMap.AbsolutePosition.X) / SatValMap.AbsoluteSize.X, 0, 1)
                    local y = math.clamp((input.Position.Y - SatValMap.AbsolutePosition.Y) / SatValMap.AbsoluteSize.Y, 0, 1)
                    s, v = x, 1 - y
                    MapCursor.Position = UDim2.new(x, 0, y, 0)
                    UpdateColor()
                elseif trackingHue then
                    local y = math.clamp((input.Position.Y - HueBar.AbsolutePosition.Y) / HueBar.AbsoluteSize.Y, 0, 1)
                    h = 1 - y
                    HueCursor.Position = UDim2.new(0, -2, y, -2)
                    UpdateColor()
                elseif trackingAlpha then
                    local x = math.clamp((input.Position.X - AlphaBar.AbsolutePosition.X) / AlphaBar.AbsoluteSize.X, 0, 1)
                    ColorP.Alpha = x
                    AlphaCursor.Position = UDim2.new(x, -2, 0, -2)
                    UpdateColor()
                end
            end
        end)

        HexInput.FocusLost:Connect(function()
            local success, newColor = pcall(function() return Core.Math.Color.FromHex(HexInput.Text) end)
            if success then
                h, s, v = newColor:ToHSV()
                MapCursor.Position = UDim2.new(s, 0, 1 - v, 0)
                HueCursor.Position = UDim2.new(0, -2, 1 - h, -2)
                UpdateColor()
            else
                HexInput.Text = Core.Math.Color.ToHex(ColorP.Color)
            end
        end)

        MainBtn.MouseButton1Click:Connect(function()
            ColorP.Open = not ColorP.Open
            SecFrame.ZIndex = ColorP.Open and 5 or 1
            CPFrame.ZIndex = ColorP.Open and 5 or 1
            Core:Tween(CPFrame, {Size = ColorP.Open and UDim2.new(1, 0, 0, 195) or UDim2.new(1, 0, 0, 30)}, 0.25)
        end)

        Core:SubscribeToTheme(function(theme)
            CPFrame.BackgroundColor3 = theme.Background
            CPStroke.Color = theme.Border
            Label.TextColor3 = theme.TextMuted
            HexInput.BackgroundColor3 = theme.Container
            HexInput.TextColor3 = theme.Text
            HexStroke.Color = theme.Border
            AlphaStroke.Color = theme.Border
        end)

        return ColorP
    end

    -- ==============================================================================
    -- ⌨️ WIDGET: ADVANCED KEYBIND (Com Múltiplos Modos de Escuta)
    -- ==============================================================================
    function CoreInstance.Tabs.CreateSection:CreateAdvancedKeybind(opts: KeybindConfig)
        local Keybind = { 
            Key = opts.Default or Enum.KeyCode.Unknown, 
            Listening = false, 
            State = false, 
            Mode = opts.Mode or "Toggle" -- Toggle, Hold, Always
        }
        local callback = opts.Callback or function() end
        local SecFrame = self.Container

        local KeyFrame = Instance.new("Frame")
        KeyFrame.Size = UDim2.new(1, 0, 0, 26)
        KeyFrame.BackgroundTransparency = 1
        KeyFrame.Parent = SecFrame

        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(1, -115, 1, 0)
        Label.BackgroundTransparency = 1
        Label.Text = opts.Name
        Label.TextColor3 = Core.Themes.TextMuted
        Label.Font = Enum.Font.Gotham
        Label.TextSize = 12
        Label.TextXAlignment = Enum.TextXAlignment.Left
        Label.Parent = KeyFrame

        local ModeBtn = Instance.new("TextButton")
        ModeBtn.Size = UDim2.new(0, 45, 0, 18)
        ModeBtn.Position = UDim2.new(1, -110, 0.5, -9)
        ModeBtn.BackgroundColor3 = Core.Themes.Background
        ModeBtn.Text = Keybind.Mode
        ModeBtn.TextColor3 = Core.Themes.TextMuted
        ModeBtn.Font = Enum.Font.Gotham
        ModeBtn.TextSize = 10
        ModeBtn.Parent = KeyFrame
        Instance.new("UICorner", ModeBtn).CornerRadius = UDim.new(0, 3)
        local ModeStroke = Instance.new("UIStroke", ModeBtn)
        ModeStroke.Color = Core.Themes.Border

        local BindBtn = Instance.new("TextButton")
        BindBtn.Size = UDim2.new(0, 60, 0, 18)
        BindBtn.Position = UDim2.new(1, -60, 0.5, -9)
        BindBtn.BackgroundColor3 = Core.Themes.Background
        BindBtn.Text = Keybind.Key == Enum.KeyCode.Unknown and "None" or Keybind.Key.Name
        BindBtn.TextColor3 = Core.Themes.Text
        BindBtn.Font = Enum.Font.Gotham
        BindBtn.TextSize = 11
        BindBtn.Parent = KeyFrame
        Instance.new("UICorner", BindBtn).CornerRadius = UDim.new(0, 3)
        local BindStroke = Instance.new("UIStroke", BindBtn)
        BindStroke.Color = Core.Themes.Border

        local modes = {"Toggle", "Hold", "Always"}
        ModeBtn.MouseButton1Click:Connect(function()
            local idx = table.find(modes, Keybind.Mode) or 1
            Keybind.Mode = modes[idx >= #modes and 1 or idx + 1]
            ModeBtn.Text = Keybind.Mode
            if Keybind.Mode == "Always" then task.spawn(callback, true) end
        end)

        BindBtn.MouseButton1Click:Connect(function()
            Keybind.Listening = true
            BindBtn.Text = "..."
            Core:Tween(BindStroke, {Color = Core.Themes.Accent}, 0.2)
        end)

        UserInputService.InputBegan:Connect(function(input, gpe)
            if Keybind.Listening and input.UserInputType == Enum.UserInputType.Keyboard then
                local key = input.KeyCode
                if key == Enum.KeyCode.Escape or key == Enum.KeyCode.Backspace then
                    Keybind.Key = Enum.KeyCode.Unknown
                    BindBtn.Text = "None"
                else
                    Keybind.Key = key
                    BindBtn.Text = key.Name
                end
                Keybind.Listening = false
                Core:Tween(BindStroke, {Color = Core.Themes.Border}, 0.2)
            elseif not gpe and input.KeyCode == Keybind.Key and Keybind.Key ~= Enum.KeyCode.Unknown then
                if Keybind.Mode == "Toggle" then
                    Keybind.State = not Keybind.State
                    task.spawn(callback, Keybind.State)
                elseif Keybind.Mode == "Hold" then
                    task.spawn(callback, true)
                end
            end
        end)

        UserInputService.InputEnded:Connect(function(input, gpe)
            if not gpe and input.KeyCode == Keybind.Key and Keybind.Mode == "Hold" and Keybind.Key ~= Enum.KeyCode.Unknown then
                task.spawn(callback, false)
            end
        end)

        Core:SubscribeToTheme(function(theme)
            Label.TextColor3 = theme.TextMuted
            BindBtn.BackgroundColor3 = theme.Background
            BindBtn.TextColor3 = theme.Text
            ModeBtn.BackgroundColor3 = theme.Container
            ModeBtn.TextColor3 = theme.TextMuted
            ModeStroke.Color = theme.Border
            if not Keybind.Listening then BindStroke.Color = theme.Border end
        end)

        return Keybind
    end

    Core.Logger:Log("Advanced Widgets Subsystem Fully Integrated.")
end

return AdvancedWidgets
