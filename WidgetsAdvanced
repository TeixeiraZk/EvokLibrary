        PaletteLayout.Padding = UDim.new(0, 5)
        PaletteLayout.Parent = RecentPalette

        local function AddRecentColor(col)
            for _, child in pairs(RecentPalette:GetChildren()) do
                if child:IsA("Frame") and child.BackgroundColor3 == col then return end
            end
            if #RecentPalette:GetChildren() > 7 then -- Limite de 6 blocos (+1 do layout)
                RecentPalette:GetChildren()[2]:Destroy()
            end
            
            local ColorBlock = Instance.new("TextButton")
            ColorBlock.Size = UDim2.new(0, 20, 0, 20)
            ColorBlock.BackgroundColor3 = col
            ColorBlock.Text = ""
            ColorBlock.Parent = RecentPalette
            Instance.new("UICorner", ColorBlock).CornerRadius = UDim.new(0, 4)
            Instance.new("UIStroke", ColorBlock).Color = Core.Themes.Border
            
            ColorBlock.MouseButton1Click:Connect(function()
                h, s, v = col:ToHSV()
                MapCursor.Position = UDim2.new(s, 0, 1 - v, 0)
                HueCursor.Position = UDim2.new(0, -2, 1 - h, -2)
                ColorP.Color = col
                DisplayColor.BackgroundColor3 = col
                SatValMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                HexInput.Text = Core.Math.Color.ToHex(col)
                RGBInput.Text = math.floor(col.R*255)..", "..math.floor(col.G*255)..", "..math.floor(col.B*255)
                AlphaGradient.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromRGB(0,0,0)), ColorSequenceKeypoint.new(1, col)})
                callback(col, ColorP.Alpha)
            end)
        end

        local function UpdateColor()
            ColorP.Color = Color3.fromHSV(h, s, v)
            DisplayColor.BackgroundColor3 = ColorP.Color
            DisplayColor.BackgroundTransparency = 1 - ColorP.Alpha
            SatValMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
            HexInput.Text = Core.Math.Color.ToHex(ColorP.Color)
            RGBInput.Text = math.floor(ColorP.Color.R*255)..", "..math.floor(ColorP.Color.G*255)..", "..math.floor(ColorP.Color.B*255)
            AlphaGradient.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromRGB(0,0,0)), ColorSequenceKeypoint.new(1, ColorP.Color)})
            callback(ColorP.Color, ColorP.Alpha)
        end

        local trackingMap, trackingHue, trackingAlpha = false, false, false

        SatValMap.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then trackingMap = true end
        end)
        HueBar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then trackingHue = true end
        end)
        AlphaBar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then trackingAlpha = true end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                if trackingMap or trackingHue or trackingAlpha then
                    AddRecentColor(ColorP.Color)
                end
                trackingMap, trackingHue, trackingAlpha = false, false, false
            end
        end)

        UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement then
                if trackingMap then
                    local x = math.clamp((input.Position.X - SatValMap.AbsolutePosition.X) / SatValMap.AbsoluteSize.X, 0, 1)
                    local y = math.clamp((input.Position.Y - SatValMap.AbsolutePosition.Y) / SatValMap.AbsoluteSize.Y, 0, 1)
                    s, v = x, 1 - y
                    MapCursor.Position = UDim2.new(x, 0, y, 0)
                    UpdateColor()
                elseif trackingHue then
                    local y = math.clamp((input.Position.Y - HueBar.AbsolutePosition.Y) / HueBar.AbsoluteSize.Y, 0, 1)
                    h = 1 - y
                    HueCursor.Position = UDim2.new(0, -2, y, -2)
                    UpdateColor()
                elseif trackingAlpha then
                    local x = math.clamp((input.Position.X - AlphaBar.AbsolutePosition.X) / AlphaBar.AbsoluteSize.X, 0, 1)
                    ColorP.Alpha = x
                    AlphaCursor.Position = UDim2.new(x, -2, 0, -2)
                    UpdateColor()
                end
            end
        end)

        MainBtn.MouseButton1Click:Connect(function()
            ColorP.Open = not ColorP.Open
            self.Container.ZIndex = ColorP.Open and 5 or 1
            CPFrame.ZIndex = ColorP.Open and 5 or 1
            Core:Tween(CPFrame, {Size = ColorP.Open and UDim2.new(1, 0, 0, 260) or UDim2.new(1, 0, 0, 40)}, 0.25, Enum.EasingStyle.Quint)
        end)

        Core:SubscribeToTheme(function(theme)
            CPFrame.BackgroundColor3 = theme.Background
            CPStroke.Color = theme.Border
            Label.TextColor3 = theme.TextMuted
            HexInput.BackgroundColor3 = theme.Container
            HexInput.TextColor3 = theme.Text
            HexStroke.Color = theme.Border
            RGBInput.BackgroundColor3 = theme.Container
            RGBInput.TextColor3 = theme.Text
            RGBStroke.Color = theme.Border
        end)

        return ColorP
    end

    -- ==============================================================================
    -- ⌨️ WIDGET: ADVANCED KEYBIND (Com Modos Toggle/Hold)
    -- ==============================================================================
    function CoreInstance.Tabs.CreateSection:CreateAdvancedKeybind(opts)
        local Keybind = { 
            Key = opts.Default or Enum.KeyCode.Unknown, 
            Mode = opts.Mode or "Toggle", -- "Toggle", "Hold", "Always"
            State = false,
            Listening = false 
        }
        local callback = opts.Callback or function() end

        local KeyFrame = Instance.new("Frame")
        KeyFrame.Size = UDim2.new(1, 0, 0, 35)
        KeyFrame.BackgroundTransparency = 1
        KeyFrame.Parent = self.Container

        local Label = Instance.new("TextLabel")
        Label.Size = UDim2.new(1, -120, 1, 0)
        Label.BackgroundTransparency = 1
        Label.Text = opts.Name
        Label.TextColor3 = Core.Themes.TextMuted
        Label.Font = Enum.Font.Gotham
        Label.TextSize = 13
        Label.TextXAlignment = Enum.TextXAlignment.Left
        Label.Parent = KeyFrame

        local ModeBtn = Instance.new("TextButton")
        ModeBtn.Size = UDim2.new(0, 50, 0, 22)
        ModeBtn.Position = UDim2.new(1, -120, 0.5, -11)
        ModeBtn.BackgroundColor3 = Core.Themes.Container
        ModeBtn.Text = Keybind.Mode
        ModeBtn.TextColor3 = Core.Themes.TextMuted
        ModeBtn.Font = Enum.Font.Gotham
        ModeBtn.TextSize = 11
        ModeBtn.Parent = KeyFrame
        Instance.new("UICorner", ModeBtn).CornerRadius = UDim.new(0, 4)
        local ModeStroke = Instance.new("UIStroke", ModeBtn)
        ModeStroke.Color = Core.Themes.Border

        local BindBtn = Instance.new("TextButton")
        BindBtn.Size = UDim2.new(0, 60, 0, 22)
        BindBtn.Position = UDim2.new(1, -60, 0.5, -11)
        BindBtn.BackgroundColor3 = Core.Themes.Background
        BindBtn.Text = Keybind.Key == Enum.KeyCode.Unknown and "None" or Keybind.Key.Name
        BindBtn.TextColor3 = Core.Themes.Text
        BindBtn.Font = Enum.Font.Gotham
        BindBtn.TextSize = 12
        BindBtn.Parent = KeyFrame
        Instance.new("UICorner", BindBtn).CornerRadius = UDim.new(0, 4)
        local BindStroke = Instance.new("UIStroke", BindBtn)
        BindStroke.Color = Core.Themes.Border

        -- Lógica de Mudança de Modo
        local modes = {"Toggle", "Hold", "Always"}
        ModeBtn.MouseButton1Click:Connect(function()
            local currentIdx = table.find(modes, Keybind.Mode) or 1
            local nextIdx = currentIdx >= #modes and 1 or currentIdx + 1
            Keybind.Mode = modes[nextIdx]
            ModeBtn.Text = Keybind.Mode
            
            if Keybind.Mode == "Always" then
                Keybind.State = true
                callback(true)
            end
        end)

        BindBtn.MouseButton1Click:Connect(function()
            Keybind.Listening = true
            BindBtn.Text = "..."
            Core:Tween(BindStroke, {Color = Core.Themes.Accent}, 0.2)
        end)

        UserInputService.InputBegan:Connect(function(input, gpe)
            if Keybind.Listening and input.UserInputType == Enum.UserInputType.Keyboard then
                local key = input.KeyCode
                if key == Enum.KeyCode.Escape or key == Enum.KeyCode.Backspace then
                    Keybind.Key = Enum.KeyCode.Unknown
                    BindBtn.Text = "None"
                else
                    Keybind.Key = key
                    BindBtn.Text = key.Name
                end
                Keybind.Listening = false
                Core:Tween(BindStroke, {Color = Core.Themes.Border}, 0.2)
            elseif not gpe and input.KeyCode == Keybind.Key and Keybind.Key ~= Enum.KeyCode.Unknown then
                if Keybind.Mode == "Toggle" then
                    Keybind.State = not Keybind.State
                    callback(Keybind.State)
                elseif Keybind.Mode == "Hold" then
                    Keybind.State = true
                    callback(true)
                end
            end
        end)

        UserInputService.InputEnded:Connect(function(input, gpe)
            if not gpe and input.KeyCode == Keybind.Key and Keybind.Mode == "Hold" and Keybind.Key ~= Enum.KeyCode.Unknown then
                Keybind.State = false
                callback(false)
            end
        end)

        Core:SubscribeToTheme(function(theme)
            Label.TextColor3 = theme.TextMuted
            BindBtn.BackgroundColor3 = theme.Background
            BindBtn.TextColor3 = theme.Text
            ModeBtn.BackgroundColor3 = theme.Container
            ModeBtn.TextColor3 = theme.TextMuted
            ModeStroke.Color = theme.Border
            if not Keybind.Listening then
                BindStroke.Color = theme.Border
            else
                BindStroke.Color = theme.Accent
            end
        end)

        return Keybind
    end

    Core.Logger:Log("Advanced Widgets Engine Loaded.")
end

return AdvancedWidgets
