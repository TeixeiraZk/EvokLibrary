function AdvancedWidgets.Inject(WindowInstance)
    local Core = WindowInstance.Core

    -- Hooking na classe de Sections criada no Módulo Básico
    -- Isso garante que as funções fiquem disponíveis via metatable ou herança direta
    local SectionProto = WindowInstance.Tabs and WindowInstance.Tabs.CreateSection or nil
    if not SectionProto then
        -- Fallback seguro para injeção direta caso o ciclo de carregamento mude
        SectionProto = getmetatable(WindowInstance) or WindowInstance
    end

