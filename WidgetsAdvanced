                    task.spawn(callback, opt)
                    ToggleDrop()
                    Dropdown:Refresh(Dropdown.Options)
                end)
            end
        end

        -- Algoritmo do Campo de Pesquisa
        SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
            local query = SearchInput.Text
            local visibleCount = 0
            
            for _, child in pairs(ScrollContainer:GetChildren()) do
                if child:IsA("TextButton") then
                    local cleanedText = child.Text:gsub("^%s+", "")
                    local isMatch = (query == "") or FuzzyMatch(query, cleanedText)
                    child.Visible = isMatch
                    if isMatch then visibleCount = visibleCount + 1 end
                end
            end
            
            if Dropdown.Open then
                local itemsCount = math.min(visibleCount, 5)
                DropFrame.Size = UDim2.new(1, 0, 0, 64 + (itemsCount * 22))
                ScrollContainer.CanvasSize = UDim2.new(0, 0, 0, visibleCount * 22)
            end
        end)

        Core:SubscribeToTheme(function(theme)
            DropFrame.BackgroundColor3 = theme.Background
            DropStroke.Color = theme.Border
            Label.TextColor3 = theme.TextMuted
            Icon.TextColor3 = theme.TextMuted
            SearchBg.BackgroundColor3 = theme.Container
            SearchStroke.Color = theme.Border
            SearchInput.TextColor3 = theme.Text
            ScrollContainer.ScrollBarImageColor3 = theme.Border
            Dropdown:Refresh(Dropdown.Options)
            if Dropdown.Selected then
                Label.Text = string.format("%s  :  <font color='%s'>%s</font>", opts.Name, Core.Math.Color.ToHex(theme.Accent), tostring(Dropdown.Selected))
            end
        end)

        return Dropdown
    end

