    local function RemoveESP(player)
        if Systems.ESPDrawings[player.Name] then
            for _, drawing in pairs(Systems.ESPDrawings[player.Name]) do drawing:Remove() end
            Systems.ESPDrawings[player.Name] = nil
        end
    end

    local function UpdateESP()
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local drawings = Systems.ESPDrawings[player.Name]
                if not drawings then CreateESP(player); drawings = Systems.ESPDrawings[player.Name] end

                local character = player.Character
                local humanoid = character and character:FindFirstChild("Humanoid")
                local rootPart = character and character:FindFirstChild("HumanoidRootPart")

                if ESPEngine.Enabled and character and humanoid and rootPart and humanoid.Health > 0 then
                    local vector, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
                    local distance = (Camera.CFrame.Position - rootPart.Position).Magnitude

                    if onScreen and distance <= ESPEngine.MaxDistance then
                        local head = character:FindFirstChild("Head")
                        local headPos = head and Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0)) or vector
                        local legPos = Camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0))
                        local height = math.abs(headPos.Y - legPos.Y)
                        local width = height / 2

                        if ESPEngine.Boxes then
                            drawings.BoxOutline.Size = Vector2.new(width, height)
                            drawings.BoxOutline.Position = Vector2.new(vector.X - width/2, headPos.Y)
                            drawings.BoxOutline.Visible = true
                            drawings.Box.Size = Vector2.new(width, height)
                            drawings.Box.Position = Vector2.new(vector.X - width/2, headPos.Y)
                            drawings.Box.Color = ESPEngine.Color
                            drawings.Box.Visible = true
                        else
                            drawings.BoxOutline.Visible = false; drawings.Box.Visible = false
                        end

                        if ESPEngine.Names then
                            drawings.Name.Text = player.DisplayName .. " ["..math.floor(distance).."m]"
                            drawings.Name.Position = Vector2.new(vector.X, headPos.Y - 20)
                            drawings.Name.Color = ESPEngine.Color
                            drawings.Name.Visible = true
                        else
                            drawings.Name.Visible = false
                        end

                        if ESPEngine.Health then
                            local hpRatio = humanoid.Health / humanoid.MaxHealth
                            local hpHeight = height * hpRatio
                            local hpColor = Color3.fromHSV(0.3 * hpRatio, 1, 1)

                            drawings.HealthOutline.From = Vector2.new(vector.X - width/2 - 5, headPos.Y)
                            drawings.HealthOutline.To = Vector2.new(vector.X - width/2 - 5, legPos.Y)
                            drawings.HealthOutline.Visible = true
                            drawings.Health.From = Vector2.new(vector.X - width/2 - 5, legPos.Y)
                            drawings.Health.To = Vector2.new(vector.X - width/2 - 5, legPos.Y - hpHeight)
                            drawings.Health.Color = hpColor
                            drawings.Health.Visible = true
                        else
                            drawings.HealthOutline.Visible = false; drawings.Health.Visible = false
                        end

                        if ESPEngine.Tracers then
                            drawings.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                            drawings.Tracer.To = Vector2.new(vector.X, legPos.Y)
                            drawings.Tracer.Color = ESPEngine.Color
                            drawings.Tracer.Visible = true
                        else
                            drawings.Tracer.Visible = false
                        end
                    else
                        for _, drawing in pairs(drawings) do drawing.Visible = false end
                    end
                else
                    for _, drawing in pairs(drawings) do drawing.Visible = false end
                end
            end
        end
    end

    local espConn = RunService.RenderStepped:Connect(UpdateESP)
    table.insert(Systems.Connections, espConn)
    Players.PlayerRemoving:Connect(RemoveESP)

    function Window:CreatePlayerManager(tabName)
        local PTab = self:CreateTab(tabName or "ESP Engine")
        local ESPSection = PTab:CreateSection("Visual Settings", "Left")
        
        ESPSection:CreateToggle({
            Name = "Enable Master ESP", Default = false,
            Callback = function(val) ESPEngine.Enabled = val end
        })
        ESPSection:CreateToggle({
            Name = "Draw Boxes", Default = false,
            Callback = function(val) ESPEngine.Boxes = val end
        })
        ESPSection:CreateToggle({
            Name = "Draw Names & Distance", Default = false,
            Callback = function(val) ESPEngine.Names = val end
        })
        ESPSection:CreateToggle({
            Name = "Draw Health Bars", Default = false,
            Callback = function(val) ESPEngine.Health = val end
        })
        ESPSection:CreateToggle({
            Name = "Draw Tracers", Default = false,
            Callback = function(val) ESPEngine.Tracers = val end
        })
        ESPSection:CreateAdvancedColorPicker({
            Name = "ESP Render Color", Default = Core.Themes.Accent,
            Callback = function(color) ESPEngine.Color = color end
        })
    end

    Core.Logger:Log("All Evok Systems Booted Successfully.")
end

return Systems
