            Size = UDim2.new(0, 48, 0, 18),
            Position = UDim2.new(1, -56, 0.5, -9),
            BackgroundColor3 = TC("Primary"),
            BackgroundTransparency = 0.2,
            Text = "Teleport",
            TextColor3 = Color3.new(0, 0, 0),
            TextSize = 9,
            Font = Enum.Font.GothamBold,
            BorderSizePixel = 0,
            Parent = card,
        })
        Utility.Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = tpBtn })

        -- Hover effects on card
        local cardBtn = Utility.Create("TextButton", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Text = "",
            ZIndex = card.ZIndex - 1,
            Parent = card,
        })

        cardBtn.MouseEnter:Connect(function()
            Utility.TweenObject(card, { BackgroundTransparency = 0.1 }, 0.2)
        end)
        cardBtn.MouseLeave:Connect(function()
            Utility.TweenObject(card, { BackgroundTransparency = 0.25 }, 0.2)
        end)
        cardBtn.MouseButton1Click:Connect(function()
            if self._onSelect then
                task.spawn(self._onSelect, player)
            end
        end)

        specBtn.MouseButton1Click:Connect(function()
            if self._onSpectate then
                task.spawn(self._onSpectate, player)
            end
        end)

        tpBtn.MouseButton1Click:Connect(function()
            if self._onTeleport then
                task.spawn(self._onTeleport, player)
            end
        end)

        -- Hover on buttons
        specBtn.MouseEnter:Connect(function()
            Utility.TweenObject(specBtn, { BackgroundTransparency = 0.1 }, 0.15)
        end)
        specBtn.MouseLeave:Connect(function()
            Utility.TweenObject(specBtn, { BackgroundTransparency = 0.3 }, 0.15)
        end)
        tpBtn.MouseEnter:Connect(function()
            Utility.TweenObject(tpBtn, { BackgroundTransparency = 0.05 }, 0.15)
        end)
        tpBtn.MouseLeave:Connect(function()
            Utility.TweenObject(tpBtn, { BackgroundTransparency = 0.2 }, 0.15)
        end)

