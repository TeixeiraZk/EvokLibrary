--// ============================================================

local UnloadManager = {}
UnloadManager.__index = UnloadManager
UnloadManager._connections = {}
UnloadManager._instances   = {}
UnloadManager._callbacks   = {}

function UnloadManager:Track(connection)
    table.insert(self._connections, connection)
    return connection
end

function UnloadManager:TrackInstance(instance)
    table.insert(self._instances, instance)
    return instance
end

function UnloadManager:OnUnload(fn)
    table.insert(self._callbacks, fn)
end

function UnloadManager:DisconnectEvents()
    for _, conn in ipairs(self._connections) do
        if typeof(conn) == "RBXScriptConnection" then
            pcall(function() conn:Disconnect() end)
        elseif type(conn) == "table" and conn.Disconnect then
            pcall(function() conn:Disconnect() end)
        end
    end
    self._connections = {}
end

function UnloadManager:ClearMemory()
    for _, inst in ipairs(self._instances) do
        if inst and inst.Parent then
            pcall(function() inst:Destroy() end)
        end
    end
    self._instances = {}
end

function UnloadManager:UnloadUI(screenGuiRef)
    -- Run callbacks
    for _, fn in ipairs(self._callbacks) do
        pcall(fn)
    end
    self._callbacks = {}

    -- Disconnect events
    self:DisconnectEvents()

    -- Clear memory
    self:ClearMemory()

    -- Destroy UI
    if screenGuiRef and screenGuiRef.Parent then
        pcall(function()
            Utility.TweenObject(screenGuiRef, { }, 0.3)
            task.delay(0.35, function()
                screenGuiRef:Destroy()
            end)
        end)
    end

    -- Hide cursor if needed
    UserInputService.MouseIconEnabled = true
end

