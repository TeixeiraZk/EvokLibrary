    --[[
        Algoritmo Fuzzy Match para buscar jogadores digitando apenas 
        partes do nome, ignorando letras maiúsculas/minúsculas.
    ]]
    function Evok.PlayerListAPI:FuzzyMatch(str, pattern)
        if pattern == "" or not pattern then return true end
        if not str then return false end
        
        str = string.lower(str)
        pattern = string.lower(pattern)
        
        local pIndex = 1
        for sIndex = 1, #str do
            if string.sub(str, sIndex, sIndex) == string.sub(pattern, pIndex, pIndex) then
                pIndex = pIndex + 1
                if pIndex > #pattern then
                    return true
                end
            end
        end
        return false
    end

    --[[
        Funções de cálculo auxiliares para ordenação
    ]]
    function Evok.PlayerListAPI:GetPlayerDistance(TargetPlayer)
        if not TargetPlayer or not TargetPlayer.Character then return math.huge end
        if not LocalPlayer.Character then return math.huge end
        
        local tRoot = TargetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local lRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if tRoot and lRoot then
            return (tRoot.Position - lRoot.Position).Magnitude
        end
        return math.huge
    end

    function Evok.PlayerListAPI:GetPlayerHealth(TargetPlayer)
        if not TargetPlayer or not TargetPlayer.Character then return 0 end
        local hum = TargetPlayer.Character:FindFirstChild("Humanoid")
        if hum then
            return hum.Health
        end
        return 0
    end

    --[[
        Motor de Ordenação Principal
    ]]
    function Evok.PlayerListAPI:SortPlayers(PlayerA, PlayerB)
        local sortType = self.CurrentSort

        if sortType == "Alphabetical" then
            return string.lower(PlayerA.DisplayName) < string.lower(PlayerB.DisplayName)
            
        elseif sortType == "UserId" then
            return PlayerA.UserId < PlayerB.UserId
            
        elseif sortType == "AccountAge" then
            -- Menos dias = conta mais nova
            return PlayerA.AccountAge < PlayerB.AccountAge
            
        elseif sortType == "Distance" then
            local distA = self:GetPlayerDistance(PlayerA)
            local distB = self:GetPlayerDistance(PlayerB)
            return distA < distB
            
        elseif sortType == "Health" then
            local hpA = self:GetPlayerHealth(PlayerA)
            local hpB = self:GetPlayerHealth(PlayerB)
            return hpA > hpB -- Maior vida primeiro
            
        elseif sortType == "Team" then
            local teamA = PlayerA.Team and PlayerA.Team.Name or "Neutral"
            local teamB = PlayerB.Team and PlayerB.Team.Name or "Neutral"
            
            if teamA == teamB then
                return string.lower(PlayerA.DisplayName) < string.lower(PlayerB.DisplayName)
            end
            return teamA < teamB
        end
        
        -- Fallback
        return PlayerA.Name < PlayerB.Name
    end

    --[[
        Retorna a lista de jogadores já filtrada pela barra de pesquisa
        e ordenada pelo algoritmo escolhido.
    ]]
    function Evok.PlayerListAPI:GetFilteredAndSortedPlayers()
        local result = {}
        
        for _, player in ipairs(Players:GetPlayers()) do
            local matchesSearch = false
            
            if self.SearchQuery == "" then
                matchesSearch = true
            else
                -- Tenta match no DisplayName ou Username
                local matchDisplay = self:FuzzyMatch(player.DisplayName, self.SearchQuery)
                local matchUser = self:FuzzyMatch(player.Name, self.SearchQuery)
                
                if matchDisplay or matchUser then
                    matchesSearch = true
                end
            end

            if matchesSearch then
                table.insert(result, player)
            end
        end

        table.sort(result, function(a, b)
            return self:SortPlayers(a, b)
        end)

        return result
    end

