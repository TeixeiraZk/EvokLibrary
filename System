local ExternalAPI = {}
ExternalAPI.__index = ExternalAPI
ExternalAPI._registry = {}

function ExternalAPI:Register(id, widget)
    self._registry[id] = widget
end

function ExternalAPI:Get(id)
    return self._registry[id]
end

function ExternalAPI:Toggle(id, state)
    local w = self._registry[id]
    if w and w.SetState then
        w:SetState(state)
    end
end

function ExternalAPI:SetSlider(id, value)
    local w = self._registry[id]
    if w and w.SetValue then
        w:SetValue(value)
    end
end

function ExternalAPI:SetDropdown(id, option)
    local w = self._registry[id]
    if w and w.SelectOption then
        w:SelectOption(option)
    end
end

function ExternalAPI:SetColor(id, color)
    local w = self._registry[id]
    if w and w.SetColor then
        w:SetColor(color)
    end
end

function ExternalAPI:SetKeybind(id, key)
    local w = self._registry[id]
    if w and w.SetKeybind then
        w:SetKeybind(key)
    end
end

function ExternalAPI:FireButton(id)
    local w = self._registry[id]
    if w and w._callback then
        task.spawn(w._callback)
    end
end

function ExternalAPI:SetEnabled(id, enabled)
    local w = self._registry[id]
    if w and w.SetEnabled then
        w:SetEnabled(enabled)
    end
end

