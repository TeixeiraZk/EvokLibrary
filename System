local ConfigSystem = {}
ConfigSystem.__index = ConfigSystem
ConfigSystem._folder     = "EvokConfigs"
ConfigSystem._profiles   = {}
ConfigSystem._components = {}
ConfigSystem._autoLoad   = false
ConfigSystem._currentProfile = "default"

function ConfigSystem:Init(folderName)
    self._folder = folderName or "EvokConfigs"

    -- Create folder if it doesn't exist
    if not isfolder(self._folder) then
        makefolder(self._folder)
    end
    if not isfolder(self._folder .. "/Profiles") then
        makefolder(self._folder .. "/Profiles")
    end
end

function ConfigSystem:RegisterComponent(id, component, serializeFn, deserializeFn)
    self._components[id] = {
        Component     = component,
        Serialize     = serializeFn,
        Deserialize   = deserializeFn,
    }
end

-- Register a Toggle
function ConfigSystem:RegisterToggle(id, toggle)
    self:RegisterComponent(id, toggle,
        function() return toggle:GetState() end,
        function(val) toggle:SetState(val, true) end
    )
end

-- Register a Slider
function ConfigSystem:RegisterSlider(id, slider)
    self:RegisterComponent(id, slider,
        function() return slider:GetValue() end,
        function(val) slider:SetValue(val, true) end
    )
end

-- Register a Dropdown
function ConfigSystem:RegisterDropdown(id, dropdown)
    self:RegisterComponent(id, dropdown,
        function() return dropdown:GetSelected() end,
        function(val) if val then dropdown:SelectOption(val, true) end end
    )
end

-- Register a MultiDropdown
function ConfigSystem:RegisterMultiDropdown(id, multiDrop)
    self:RegisterComponent(id, multiDrop,
        function() return multiDrop:GetSelected() end,
        function(val)
            multiDrop._selectedSet = {}
            multiDrop._selected = val or {}
            for _, v in ipairs(multiDrop._selected) do
                multiDrop._selectedSet[v] = true
            end
        end
    )
end

-- Register a ColorPicker
function ConfigSystem:RegisterColorPicker(id, picker)
    self:RegisterComponent(id, picker,
        function()
            local c = picker:GetColor()
            return { R = c.R, G = c.G, B = c.B, A = picker:GetAlpha() }
        end,
        function(val)
            if val then
                picker:SetColor(Color3.new(val.R, val.G, val.B), true)
            end
        end
    )
end

-- Register a Keybind
function ConfigSystem:RegisterKeybind(id, keybind)
    self:RegisterComponent(id, keybind,
        function()
            local key = keybind:GetKeybind()
            return key and key.Name or "None"
        end,
        function(val)
            if val and val ~= "None" then
                local ok, kc = pcall(function()
                    return Enum.KeyCode[val]
                end)
                if ok then keybind:SetKeybind(kc) end
            end
        end
    )
end

function ConfigSystem:_Serialize()
    local data = {}
    for id, comp in pairs(self._components) do
        local ok, val = pcall(comp.Serialize)
        if ok then
            data[id] = val
        end
    end
    return data
end

function ConfigSystem:_Deserialize(data)
    for id, val in pairs(data) do
        if self._components[id] then
            local ok, err = pcall(self._components[id].Deserialize, val)
            if not ok then
                warn("[ConfigSystem] Failed to deserialize: " .. id .. " -> " .. tostring(err))
            end
        end
    end
end

function ConfigSystem:SaveConfig(name)
    name = name or self._currentProfile
    self._currentProfile = name

    local data = self:_Serialize()
    local encoded = HttpService:JSONEncode(data)
    local path = self._folder .. "/Profiles/" .. name .. ".json"

    writefile(path, encoded)
    return true
end

function ConfigSystem:LoadConfig(name)
    name = name or self._currentProfile
    self._currentProfile = name

    local path = self._folder .. "/Profiles/" .. name .. ".json"
    if not isfile(path) then
        return false, "Config not found: " .. name
    end

    local ok, content = pcall(readfile, path)
    if not ok then return false, "Failed to read file" end

    local ok2, data = pcall(HttpService.JSONDecode, HttpService, content)
    if not ok2 then return false, "Failed to decode JSON" end

    self:_Deserialize(data)
    return true
end

function ConfigSystem:DeleteConfig(name)
    local path = self._folder .. "/Profiles/" .. name .. ".json"
    if isfile(path) then
        delfile(path)
        return true
    end
    return false
end

function ConfigSystem:ListConfigs()
    local path = self._folder .. "/Profiles/"
    local files = {}
    if isfolder(path) then
        local list = listfiles(path)
        for _, f in ipairs(list) do
            local name = f:gsub(path, ""):gsub("%.json$", "")
            table.insert(files, name)
        end
    end
    return files
end

function ConfigSystem:AutoLoad(name)
    local ok = self:LoadConfig(name)
    if not ok then
        warn("[ConfigSystem] AutoLoad: no config found for " .. tostring(name))
    end
end

function ConfigSystem:ResetAll()
    -- Call each component's deserialize with nil (components should handle reset themselves)
    for id, comp in pairs(self._components) do
        pcall(comp.Deserialize, nil)
    end
end

