            for index, player in ipairs(SortedPlayers) do
                local Card = Evok.Utility.Instance:Create("TextButton", {
                    Name = "Card_" .. player.Name,
                    Parent = PlayerScrollArea,
                    Size = UDim2.new(1, 0, 0, 50),
                    Position = UDim2.new(0, 0, 0, 0),
                    BackgroundColor3 = Evok.ThemeManager:GetColor("Background"),
                    Text = "",
                    AutoButtonColor = false,
                    ZIndex = 4
                })
                
                Evok.Utility.Instance:CreateRound(6).Parent = Card
                local CardStroke = Evok.Utility.Instance:CreateStroke(Evok.ThemeManager:GetColor("Border"), 1)
                CardStroke.Parent = Card

                -- Avatar Thumbnail (Headshot)
                local HeadshotImage = Evok.Utility.Instance:Create("ImageLabel", {
                    Name = "Headshot",
                    Parent = Card,
                    Size = UDim2.new(0, 36, 0, 36),
                    Position = UDim2.new(0, 7, 0.5, -18),
                    BackgroundColor3 = Evok.ThemeManager:GetColor("ContainerHover"),
                    Image = "",
                    ZIndex = 5
                })
                Evok.Utility.Instance:CreateRound(100).Parent = HeadshotImage
                
                Evok.PlayerListAPI:FetchAvatar(player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48, function(ImageUrl)
                    if Card.Parent then HeadshotImage.Image = ImageUrl end
                end)

                -- Textos do Cartão
                Evok.Utility.Instance:Create("TextLabel", {
                    Name = "NameDisplay",
                    Parent = Card,
                    Size = UDim2.new(1, -60, 0, 18),
                    Position = UDim2.new(0, 50, 0, 8),
                    BackgroundTransparency = 1,
                    Text = player.DisplayName,
                    TextColor3 = Evok.ThemeManager:GetColor("Text"),
                    Font = Evok.Fonts.Semibold,
                    TextSize = 14,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextTruncate = Enum.TextTruncate.AtEnd,
                    ZIndex = 5
                })

                Evok.Utility.Instance:Create("TextLabel", {
                    Name = "NameUser",
                    Parent = Card,
                    Size = UDim2.new(1, -60, 0, 14),
                    Position = UDim2.new(0, 50, 0, 28),
                    BackgroundTransparency = 1,
                    Text = "@" .. player.Name,
                    TextColor3 = Evok.ThemeManager:GetColor("TextDark"),
                    Font = Evok.Fonts.Main,
                    TextSize = 12,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextTruncate = Enum.TextTruncate.AtEnd,
                    ZIndex = 5
                })

                -- Indicação Visual se for o selecionado atual
                if Evok.PlayerListAPI.SelectedPlayer == player then
                    CardStroke.Color = Evok.ThemeManager:GetColor("Accent")
                end

                -- Eventos do Cartão
                Card.MouseEnter:Connect(function()
                    if Evok.PlayerListAPI.SelectedPlayer ~= player then
                        TweenService:Create(CardStroke, TweenInfo.new(0.2), {Color = Evok.ThemeManager:GetColor("BorderHighlight")}):Play()
                    end
                end)
                
                Card.MouseLeave:Connect(function()
                    if Evok.PlayerListAPI.SelectedPlayer ~= player then
                        TweenService:Create(CardStroke, TweenInfo.new(0.2), {Color = Evok.ThemeManager:GetColor("Border")}):Play()
                    end
                end)

                Card.MouseButton1Click:Connect(function()
                    SetSelectedPlayer(player)
                    RenderPlayerList() -- Atualiza a lista para refletir a borda colorida no novo alvo
                end)
            end

            PlayerScrollArea.CanvasSize = UDim2.new(0, 0, 0, #SortedPlayers * 56)
        end

        -- ============================================================================
        -- MÓDULO 6: CORE EVENT LOOPS E CONEXÕES
        -- ============================================================================
        
        -- Evento da Caixa de Pesquisa
        SearchTextBox.Changed:Connect(function(Property)
            if Property == "Text" then
                Evok.PlayerListAPI.SearchQuery = SearchTextBox.Text
                RenderPlayerList()
            end
        end)

        -- Eventos de Conexão Roblox
        local ConnectionAdded = Players.PlayerAdded:Connect(function()
            RenderPlayerList()
        end)
        
        local ConnectionRemoved = Players.PlayerRemoving:Connect(function(LeftPlayer)
            if Evok.PlayerListAPI.SelectedPlayer == LeftPlayer then
                SetSelectedPlayer(nil)
            end
            RenderPlayerList()
        end)

        table.insert(Evok.PlayerListAPI.Connections, ConnectionAdded)
        table.insert(Evok.PlayerListAPI.Connections, ConnectionRemoved)

        -- Loop de Atualização Dinâmica (Vida e Distância)
        -- Usando Heartbeat para não travar a renderização visual do jogo
        local StatusLoop = RunService.Heartbeat:Connect(function()
            if not Evok.PlayerListAPI.Active then return end
            
            local Target = Evok.PlayerListAPI.SelectedPlayer
            if not Target then return end
            
            local TargetChar = Target.Character
            
            -- Calculando a Vida Atualizada
            if TargetChar and TargetChar:FindFirstChild("Humanoid") then
                local Hum = TargetChar.Humanoid
                local HpStr = tostring(math.floor(Hum.Health)) .. " / " .. tostring(math.floor(Hum.MaxHealth))
                StatHealthLabel.Text = HpStr
            else
                StatHealthLabel.Text = "N/A"
            end

            -- Calculando a Distância Atualizada
            local LChar = LocalPlayer.Character
            if TargetChar and LChar and TargetChar:FindFirstChild("HumanoidRootPart") and LChar:FindFirstChild("HumanoidRootPart") then
                local Dist = math.floor((TargetChar.HumanoidRootPart.Position - LChar.HumanoidRootPart.Position).Magnitude)
                StatDistanceLabel.Text = tostring(Dist) .. " studs"
            else
                StatDistanceLabel.Text = "N/A"
            end
        end)
        
        table.insert(Evok.PlayerListAPI.Connections, StatusLoop)

        -- Renderização Inicial
        RenderPlayerList()
    end

    -- ============================================================================
    -- FIM DO ARQUIVO SYSTEM.LUA
    -- ============================================================================
end
