-- 🧮 UTILITY 2: STRING MATH & LEVENSHTEIN DISTANCE
-- ==============================================================================
local function CalculateDistance(s1: string, s2: string): number
    local len1, len2 = #s1, #s2
    local matrix = {}
    
    for i = 0, len1 do matrix[i] = {[0] = i} end
    for j = 0, len2 do matrix[0][j] = j end
    
    for i = 1, len1 do
        for j = 1, len2 do
            local cost = (s1:sub(i, i) == s2:sub(j, j)) and 0 or 1
            matrix[i][j] = math.min(
                matrix[i - 1][j] + 1,     
                matrix[i][j - 1] + 1,     
                matrix[i - 1][j - 1] + cost 
            )
        end
    end
    return matrix[len1][len2]
end

local function PerformFuzzySearch(query: string, text: string): (boolean, number)
    query, text = query:lower(), text:lower()
    if query == "" then return true, 0 end
    if text == query then return true, 0 end
    
    local foundIndex = string.find(text, query, 1, true)
    if foundIndex then return true, foundIndex end
    
    local distance = CalculateDistance(query, text)
    local threshold = math.clamp(math.floor(#query * 0.4), 1, 4)
    
    if distance <= threshold then return true, distance + 10 end
    return false, 999
end

local function SplitString(str: string, sep: string): {string}
    if sep == nil then sep = "%s" end
    local t = {}
    for s in string.gmatch(str, "([^" .. sep .. "]+)") do table.insert(t, s) end
    return t
end

