    local ConfigManager = { Folder = "EvokConfigs", ThemeFolder = "EvokThemes", Ext = ".evok" }

    function ConfigManager:Setup()
        if not isfolder(self.Folder) then makefolder(self.Folder) end
        if not isfolder(self.ThemeFolder) then makefolder(self.ThemeFolder) end
    end

    function ConfigManager:SerializeConfig()
        local data = {}
        for id, widget in pairs(Systems.WidgetsRegistry) do
            if widget.Save then
                local success, val = pcall(widget.Save)
                if success and val ~= nil then data[id] = val end
            end
        end
        return HttpService:JSONEncode(data)
    end

    function ConfigManager:DeserializeConfig(jsonString)
        local success, data = pcall(function() return HttpService:JSONDecode(jsonString) end)
        if not success or type(data) ~= "table" then return false end
        for id, val in pairs(data) do
            if Systems.WidgetsRegistry[id] and Systems.WidgetsRegistry[id].Load then
                pcall(function() Systems.WidgetsRegistry[id].Load(val) end)
            end
        end
        return true
    end

    function ConfigManager:SerializeTheme()
        local themeData = {}
        for k, color in pairs(Core.Themes) do
            if typeof(color) == "Color3" then
                themeData[k] = Core.Math.Color.ToHex(color)
            end
        end
        return HttpService:JSONEncode(themeData)
    end

    function ConfigManager:DeserializeTheme(jsonString)
        local success, data = pcall(function() return HttpService:JSONDecode(jsonString) end)
        if not success or type(data) ~= "table" then return false end
        
        for k, hex in pairs(data) do
            if Core.Themes[k] then
                pcall(function() Core.Themes[k] = Core.Math.Color.FromHex(hex) end)
            end
        end
        Core:SetTheme("Custom", Core.Themes.Accent) -- Atualiza tudo
        return true
    end

