                            data.BoxOutline.Visible = false; data.Box.Visible = false
                        end

                        if ESPEngine.Names then
                            data.NameLabel.Text = string.format("%s (%dm)", plr.DisplayName, math.floor(distance))
                            data.NameLabel.Position = Vector2.new(screenPos.X, topPos.Y - 18)
                            data.NameLabel.Visible = true
                        else
                            data.NameLabel.Visible = false
                        end

                        if ESPEngine.Health then
                            local hpPercent = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                            local barHeight = h * hpPercent
                            
                            data.HealthBg.From = Vector2.new(screenPos.X - w/2 - 6, topPos.Y)
                            data.HealthBg.To = Vector2.new(screenPos.X - w/2 - 6, bottomPos.Y)
                            data.HealthBg.Visible = true

                            data.HealthBar.From = Vector2.new(screenPos.X - w/2 - 6, bottomPos.Y)
                            data.HealthBar.To = Vector2.new(screenPos.X - w/2 - 6, bottomPos.Y - barHeight)
                            data.HealthBar.Color = Color3.fromRGB(255, 0, 0):Lerp(Color3.fromRGB(0, 255, 0), hpPercent)
                            data.HealthBar.Visible = true
                        else
                            data.HealthBg.Visible = false; data.HealthBar.Visible = false
                        end

                        if ESPEngine.Tracers then
                            data.TracerLine.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                            data.TracerLine.To = Vector2.new(screenPos.X, bottomPos.Y)
                            data.TracerLine.Color = renderColor
                            data.TracerLine.Visible = true
                        else
                            data.TracerLine.Visible = false
                        end
                    else
                        for _, d in pairs(data) do d.Visible = false end
                    end
                else
                    for _, d in pairs(data) do d.Visible = false end
                end
            end
        end
    end)
    table.insert(SystemsModule.Connections, renderConn)
    Players.PlayerRemoving:Connect(ClearPlayerDrawings)

    -- Interface de Gerenciamento do ESP e Controle de Alvos
    function WindowInstance:CreatePlayerManager(tabName: string)
        local PTab = self:CreateTab(tabName or "Player List")
        local VisualSec = PTab:CreateSection("ESP Configurations", "Left")
        
        VisualSec:CreateToggle({
            Name = "Master Activation ESP", Default = false,
            Callback = function(state) ESPEngine.Active = state end
        })
        VisualSec:CreateToggle({
            Name = "Render 2D Bounding Boxes", Default = false,
            Callback = function(state) ESPEngine.Boxes = state end
        })
        VisualSec:CreateToggle({
            Name = "Render Entity Name Headers", Default = false,
            Callback = function(state) ESPEngine.Names = state end
        })
        VisualSec:CreateToggle({
            Name = "Render Fractional Health Bars", Default = false,
            Callback = function(state) ESPEngine.Health = state end
        })
        VisualSec:CreateToggle({
            Name = "Render Vector Screen Tracers", Default = false,
            Callback = function(state) ESPEngine.Tracers = state end
        })
        VisualSec:CreateToggle({
            Name = "Perform Raycast Occulsion Check", Default = true,
            Callback = function(state) ESPEngine.VisibleCheck = state end
        })

        local ActionsSec = PTab:CreateSection("Target Action Panel", "Right")
        
        local function PopulatePlayerTable(): {string}
            local tbl = {}
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer then table.insert(tbl, p.Name) end
            end
            return tbl
        end

        local PlrDropdown = ActionsSec:CreateDropdown({
            Name = "Target Entity", Options = PopulatePlayerTable(), Default = "None"
        })

        Players.PlayerAdded:Connect(function() PlrDropdown:Refresh(PopulatePlayerTable()) end)
        Players.PlayerRemoving:Connect(function() PlrDropdown:Refresh(PopulatePlayerTable()) end)

        local activeSpectate = false
        ActionsSec:CreateButton({
            Name = "Toggle Camera Spectate",
            Callback = function()
                local tName = PlrDropdown.Selected
                local target = Players:FindFirstChild(tName or "")
                if target and target.Character then
                    if activeSpectate then
                        local myHum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                        if myHum then Camera.CameraSubject = myHum end
                        activeSpectate = false
                        Core:Notify({Title = "Spectate", Text = "Camera focused back to LocalPlayer."})
                    else
                        local tHum = target.Character:FindFirstChildOfClass("Humanoid")
                        if tHum then Camera.CameraSubject = tHum end
                        activeSpectate = true
                        Core:Notify({Title = "Spectate", Text = "Camera locked on: " .. target.DisplayName})
                    end
                end
            end
        })

        ActionsSec:CreateButton({
            Name = "Vector Warp Behind Target", Cooldown = 1.5,
            Callback = function()
                local tName = PlrDropdown.Selected
                local target = Players:FindFirstChild(tName or "")
                local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                local tRoot = target and target.Character and target.Character:FindFirstChild("HumanoidRootPart")
                
                if myRoot and tRoot then
                    myRoot.CFrame = tRoot.CFrame * CFrame.new(0, 0, 3.5)
                end
            end
        })
    end
end

return SystemsModule
