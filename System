    --[[
        Busca a imagem do jogador de forma assíncrona.
        Se já estiver no cache, retorna instantaneamente.
    ]]
    function Evok.PlayerListAPI:FetchAvatar(UserId, ThumbType, ThumbSize, Callback)
        if not self.Config.EnableAvatarCache then
            task.spawn(function()
                local success, content = pcall(function()
                    return Players:GetUserThumbnailAsync(UserId, ThumbType, ThumbSize)
                end)
                Callback(success and content or "rbxassetid://0")
            end)
            return
        end

        local CacheTable = nil
        
        if ThumbType == Enum.ThumbnailType.HeadShot then
            CacheTable = self.AvatarCache.Headshots
        elseif ThumbType == Enum.ThumbnailType.AvatarBust then
            CacheTable = self.AvatarCache.Busts
        elseif ThumbType == Enum.ThumbnailType.AvatarThumbnail then
            CacheTable = self.AvatarCache.FullBody
        end

        if CacheTable and CacheTable[UserId] then
            Callback(CacheTable[UserId])
            return
        end

        task.spawn(function()
            local success, content, isReady = pcall(function()
                return Players:GetUserThumbnailAsync(UserId, ThumbType, ThumbSize)
            end)

            if success and isReady and content then
                if CacheTable then
                    CacheTable[UserId] = content
                end
                Callback(content)
            else
                Callback("rbxassetid://0")
            end
        end)
    end

    --[[
        Limpa avatares de jogadores que já saíram do servidor
        para prevenir Memory Leaks em sessões longas.
    ]]
    function Evok.PlayerListAPI:RunGarbageCollection()
        local activeIds = {}
        for _, player in ipairs(Players:GetPlayers()) do
            activeIds[player.UserId] = true
        end

        local function CleanTable(cacheTable)
            for cachedId, _ in pairs(cacheTable) do
                if not activeIds[cachedId] then
                    cacheTable[cachedId] = nil
                end
            end
        end

        CleanTable(self.AvatarCache.Headshots)
        CleanTable(self.AvatarCache.Busts)
        CleanTable(self.AvatarCache.FullBody)
    end

    -- Loop de Garbage Collection
