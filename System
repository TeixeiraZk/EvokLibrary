    local ProfileManager = {}

    function ProfileManager:GetProfiles(): {string}
        local files = SafeListFiles(SystemsModule.ConfigFolder)
        local profiles = {}
        for _, file in ipairs(files) do
            if file:match("%.json$") then
                local name = file:match("([^/%\\]+)%.json$")
                if name then table.insert(profiles, name) end
            end
        end
        return profiles
    end

    function ProfileManager:GenerateIntegrityHash(dataString: string): string
        local hash = 0
        for i = 1, #dataString do
            hash = (hash * 31 + string.byte(dataString, i)) % 2^32
        end
        return string.format("%X", hash)
    end

    function ProfileManager:Save(profileName: string)
        local runtimeData = {}
        for id, widget in pairs(SystemsModule.Registry) do
            if widget.SaveCallback then
                local success, stateValue = pcall(widget.SaveCallback)
                if success and stateValue ~= nil then
                    runtimeData[id] = stateValue
                end
            end
        end

        local rawPayload = HttpService:JSONEncode(runtimeData)
        local encryptedPayload = Base64.Encode(XorCipher(rawPayload, SystemsModule.EncryptionKey))
        
        local package: ProfileMetadata = {
            Name = profileName,
            Created = os.date("%Y-%m-%d %H:%M:%S"),
            Version = "5.0.0",
            WidgetCount = table.create(#runtimeData),
            Hash = self:GenerateIntegrityHash(encryptedPayload)
        }

        local finalWrapper = HttpService:JSONEncode({
            Envelope = package,
            Payload = encryptedPayload
        })

        local path = SystemsModule.ConfigFolder .. "/" .. profileName .. ".json"
        SafeWriteFile(path, finalWrapper)
        Core:Notify({Title = "Profile Engine", Text = "Configuration '" .. profileName .. "' synchronized.", Type = "Success", Duration = 3})
    end

    function ProfileManager:Load(profileName: string)
        local path = SystemsModule.ConfigFolder .. "/" .. profileName .. ".json"
        if not SafeIsFile(path) then return end

        local fileContent = SafeReadFile(path)
        local success, rootTable = pcall(function() return HttpService:JSONDecode(fileContent) end)
        
        if not success or type(rootTable) ~= "table" or not rootTable.Envelope or not rootTable.Payload then
            Core:Notify({Title = "Profile Error", Text = "Failed to parse profile manifest.", Type = "Error", Duration = 4})
            return
        end

        -- Verificação de integridade antifalsificação de hash
        local currentHash = self:GenerateIntegrityHash(rootTable.Payload)
        if currentHash ~= rootTable.Envelope.Hash then
            Core:Notify({Title = "Profile Refused", Text = "File corruption detected (Hash mismatch).", Type = "Error", Duration = 4})
            return
        end

        local decryptedRaw = XorCipher(Base64.Decode(rootTable.Payload), SystemsModule.EncryptionKey)
        local parsingSuccess, stateData = pcall(function() return HttpService:JSONDecode(decryptedRaw) end)

        if not parsingSuccess or type(stateData) ~= "table" then return end

        for id, val in pairs(stateData) do
            local widget = SystemsModule.Registry[id]
            if widget and widget.LoadCallback then
                pcall(function() widget.LoadCallback(val) end)
            end
        end
        Core:Notify({Title = "Profile Loaded", Text = "Active configurations updated to match '" .. profileName .. "'.", Type = "Success", Duration = 3})
    end

