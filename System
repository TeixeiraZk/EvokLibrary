local SearchBar = {}
SearchBar.__index = SearchBar

function SearchBar.new(parentFrame, options)
    local self = setmetatable({}, SearchBar)
    options = options or {}

    self._items       = {}
    self._placeholder = options.Placeholder or "Search widgets..."
    self._visible     = false

    -- Search frame
    local frame = Utility.Create("Frame", {
        Name = "SearchBar",
        Size = UDim2.new(1, 0, 0, 28),
        Position = UDim2.new(0, 0, 1, -36),
        BackgroundColor3 = TC("SectionBg"),
        BackgroundTransparency = 0.1,
        BorderSizePixel = 0,
        Visible = false,
        ZIndex = 20,
        Parent = parentFrame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = frame })
    Utility.Create("UIStroke", {
        Color = TC("Border"),
        Thickness = 1,
        Transparency = 0.3,
        Parent = frame,
    })

    local searchIcon = Utility.Create("TextLabel", {
        Size = UDim2.new(0, 24, 1, 0),
        BackgroundTransparency = 1,
        Text = "🔍",
        TextSize = 11,
        Font = Enum.Font.Gotham,
        ZIndex = frame.ZIndex + 1,
        Parent = frame,
    })

    local inputBox = Utility.Create("TextBox", {
        Size = UDim2.new(1, -28, 1, 0),
        Position = UDim2.new(0, 24, 0, 0),
        BackgroundTransparency = 1,
        Text = "",
        PlaceholderText = self._placeholder,
        TextColor3 = TC("TextPrimary"),
        PlaceholderColor3 = TC("TextMuted"),
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        ClearTextOnFocus = false,
        ZIndex = frame.ZIndex + 1,
        Parent = frame,
    })

    self._frame    = frame
    self._inputBox = inputBox

    -- Filter logic
    inputBox:GetPropertyChangedSignal("Text"):Connect(function()
        local query = inputBox.Text:lower()
        self:_Filter(query)
    end)

    -- Toggle with keyboard shortcut (Ctrl+F)
    UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.KeyCode == Enum.KeyCode.F and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
            self:Toggle()
        end
        if input.KeyCode == Enum.KeyCode.Escape and self._visible then
            self:Hide()
        end
    end)

    return self
end

function SearchBar:RegisterItem(frame, name)
    table.insert(self._items, { Frame = frame, Name = name:lower() })
end

function SearchBar:_Filter(query)
    if query == "" then
        for _, item in ipairs(self._items) do
            if item.Frame and item.Frame.Parent then
                Utility.TweenObject(item.Frame, { BackgroundTransparency = 1 }, 0.1)
                item.Frame.Visible = true
            end
        end
        return
    end

    for _, item in ipairs(self._items) do
        if item.Frame and item.Frame.Parent then
            local matches = item.Name:find(query, 1, true)
            if matches then
                item.Frame.Visible = true
                Utility.TweenObject(item.Frame, { BackgroundTransparency = 0 }, 0.1)
            else
                Utility.TweenObject(item.Frame, { BackgroundTransparency = 0.8 }, 0.15)
                task.delay(0.15, function()
                    if not item.Name:find(self._inputBox.Text:lower(), 1, true) then
                        item.Frame.Visible = false
                    end
                end)
            end
        end
    end
end

function SearchBar:Show()
    self._visible = true
    self._frame.Visible = true
    self._frame.BackgroundTransparency = 1
    Utility.TweenObject(self._frame, { BackgroundTransparency = 0.1 }, 0.2)
    self._inputBox:CaptureFocus()
end

function SearchBar:Hide()
    self._visible = false
    Utility.TweenObject(self._frame, { BackgroundTransparency = 1 }, 0.2)
    task.delay(0.22, function()
        self._frame.Visible = false
    end)
    self._inputBox:ReleaseFocus()
    self._inputBox.Text = ""
    self:_Filter("")
end

function SearchBar:Toggle()
    if self._visible then self:Hide() else self:Show() end
end

