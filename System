local ScriptViewer = {}
ScriptViewer.__index = ScriptViewer

function ScriptViewer.new(tab, options)
    local self = setmetatable({}, ScriptViewer)
    options = options or {}

    -- Outer container
    local container = Utility.Create("Frame", {
        Name = "ScriptViewer",
        Size = UDim2.new(1, 0, 0, 300),
        BackgroundColor3 = Utility.HexToColor3("#080808"),
        BackgroundTransparency = 0.05,
        BorderSizePixel = 0,
        LayoutOrder = #tab.Content:GetChildren(),
        Parent = tab.Content,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = container })
    Utility.Create("UIStroke", {
        Color = TC("Border"),
        Thickness = 1,
        Transparency = 0.4,
        Parent = container,
    })

    -- Toolbar
    local toolbar = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 26),
        BackgroundColor3 = Utility.HexToColor3("#0D0D0D"),
        BackgroundTransparency = 0.2,
        BorderSizePixel = 0,
        Parent = container,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = toolbar })
    Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 0.5, 0),
        Position = UDim2.new(0, 0, 0.5, 0),
        BackgroundColor3 = Utility.HexToColor3("#0D0D0D"),
        BackgroundTransparency = 0.2,
        BorderSizePixel = 0,
        Parent = toolbar,
    })

    local fileLabel = Utility.Create("TextLabel", {
        Size = UDim2.new(0.5, 0, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = options.FileName or "script.lua",
        TextColor3 = TC("TextMuted"),
        TextSize = 10,
        Font = Enum.Font.Code,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = toolbar,
    })

    -- Syntax colors
    local syntax = {
        keyword  = Utility.HexToColor3("#C77DFF"),
        string   = Utility.HexToColor3("#A8FF78"),
        number   = Utility.HexToColor3("#FFD080"),
        comment  = Utility.HexToColor3("#555555"),
        default  = Utility.HexToColor3("#CCCCCC"),
        builtin  = Utility.HexToColor3("#7EB8FF"),
    }

    -- Line numbers + code frame
    local codeArea = Utility.Create("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, -26),
        Position = UDim2.new(0, 0, 0, 26),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = TC("ScrollBar"),
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Parent = container,
    })

    local lineNumFrame = Utility.Create("Frame", {
        Name = "LineNumbers",
        Size = UDim2.new(0, 36, 1, 0),
        BackgroundColor3 = Utility.HexToColor3("#0A0A0A"),
        BackgroundTransparency = 0.5,
        BorderSizePixel = 0,
        Parent = codeArea,
    })

    local lineNumLayout = Utility.Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 0),
        Parent = lineNumFrame,
    })

    local codeFrame = Utility.Create("Frame", {
        Name = "CodeFrame",
        Size = UDim2.new(1, -40, 1, 0),
        Position = UDim2.new(0, 40, 0, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Parent = codeArea,
    })

    local codeLayout = Utility.Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 0),
        Parent = codeFrame,
    })

    self._container = container
    self._codeArea  = codeArea
    self._lineNumFrame = lineNumFrame
    self._codeFrame = codeFrame

    function self:SetScript(code)
        -- Clear
        for _, c in ipairs(lineNumFrame:GetChildren()) do
            if not c:IsA("UIListLayout") then c:Destroy() end
        end
        for _, c in ipairs(codeFrame:GetChildren()) do
            if not c:IsA("UIListLayout") then c:Destroy() end
        end

        local lines = code:split("\n")
        for i, line in ipairs(lines) do
            -- Line number
            local numLabel = Utility.Create("TextLabel", {
                Size = UDim2.new(1, 0, 0, 16),
                BackgroundTransparency = 1,
                Text = tostring(i),
                TextColor3 = TC("TextMuted"),
                TextSize = 10,
                Font = Enum.Font.Code,
                TextXAlignment = Enum.TextXAlignment.Right,
                LayoutOrder = i,
                Parent = lineNumFrame,
            })
            Utility.Create("UIPadding", { PaddingRight = UDim.new(0, 6), Parent = numLabel })

            -- Code line
            local codeLabel = Utility.Create("TextLabel", {
                Size = UDim2.new(1, 0, 0, 16),
                BackgroundTransparency = 1,
                Text = line == "" and " " or line,
                TextColor3 = syntax.default,
                TextSize = 10,
                Font = Enum.Font.Code,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextTruncate = Enum.TextTruncate.AtEnd,
                RichText = false,
                LayoutOrder = i,
                Parent = codeFrame,
            })
            Utility.Create("UIPadding", { PaddingLeft = UDim.new(0, 4), Parent = codeLabel })

            -- Basic keyword detection
            local keywords = {"local", "function", "end", "if", "then", "else", "elseif", "return", "for", "do", "while", "repeat", "until", "break", "true", "false", "nil", "and", "or", "not", "in"}
            for _, kw in ipairs(keywords) do
                if line:match("^%s*" .. kw .. "%s") or line:match("%s" .. kw .. "%s") or line:match("^" .. kw .. "$") then
                    codeLabel.TextColor3 = syntax.keyword
                    break
                end
            end

            -- Comment detection
            if line:match("^%s*%-%-") then
                codeLabel.TextColor3 = syntax.comment
            end

            -- String detection
            if line:match('"') or line:match("'") or line:match("%[%[") then
                codeLabel.TextColor3 = syntax.string
            end

            -- Number detection
            if line:match("^%s*%d") then
                codeLabel.TextColor3 = syntax.number
            end
        end
    end

    if options.Script then
        self:SetScript(options.Script)
    end

    return self
end

