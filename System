local AcrylicBlur = {}
AcrylicBlur.__index = AcrylicBlur

function AcrylicBlur.new(parent, options)
    local self = setmetatable({}, AcrylicBlur)
    options = options or {}

    self._opacity  = options.Opacity  or 0.6
    self._tint     = options.Tint     or TC("Background")
    self._noise    = options.Noise    ~= false

    -- Base dark layer
    local blur = Utility.Create("Frame", {
        Name = "AcrylicBlur",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = self._tint,
        BackgroundTransparency = 1 - self._opacity,
        BorderSizePixel = 0,
        ZIndex = 1,
        Parent = parent,
    })

    -- Tint overlay
    local tint = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = TC("Primary"),
        BackgroundTransparency = 0.95,
        BorderSizePixel = 0,
        ZIndex = 2,
        Parent = blur,
    })

    -- Noise texture simulation using gradient
    if self._noise then
        local noiseGrad = Utility.Create("Frame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundColor3 = Color3.new(1, 1, 1),
            BackgroundTransparency = 0.98,
            BorderSizePixel = 0,
            ZIndex = 3,
            Parent = blur,
        })
        Utility.Create("UIGradient", {
            Rotation = 45,
            Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
                ColorSequenceKeypoint.new(0.5, Color3.new(0, 0, 0)),
                ColorSequenceKeypoint.new(1, Color3.new(1, 1, 1)),
            }),
            Parent = noiseGrad,
        })
    end

    -- Highlight stripe
    local highlight = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BackgroundTransparency = 0.85,
        BorderSizePixel = 0,
        ZIndex = 4,
        Parent = blur,
    })

    self._blur = blur

    -- Animate opacity in
    Utility.TweenObject(blur, { BackgroundTransparency = 1 - self._opacity }, 0.4)

    function self:SetOpacity(opacity)
        self._opacity = opacity
        Utility.TweenObject(blur, { BackgroundTransparency = 1 - opacity }, 0.3)
    end

    function self:SetTint(color)
        self._tint = color
        Utility.TweenObject(blur, { BackgroundColor3 = color }, 0.3)
    end

    return self
end

