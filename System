        if self._playerCards[playerName] then
            local card = self._playerCards[playerName]
            Utility.TweenObject(card, { BackgroundTransparency = 1 }, 0.2)
            task.delay(0.25, function()
                if card.Parent then card:Destroy() end
            end)
            self._playerCards[playerName] = nil
        end
    end

    local function refreshList()
        local playerList = Players:GetPlayers()
        countLabel.Text = "Players (" .. #playerList .. ")"

        -- Remove cards for players who left
        for name, _ in pairs(self._playerCards) do
            local found = false
            for _, p in ipairs(playerList) do
                if p.Name == name then found = true break end
            end
            if not found then removePlayerCard(name) end
        end

        -- Add new players
        for _, player in ipairs(playerList) do
            if player ~= LocalPlayer then
                buildPlayerCard(player)
            end
        end
    end

    -- Auto refresh
    refreshList()

    Players.PlayerAdded:Connect(function(player)
        task.wait(0.5)
        refreshList()
    end)

    Players.PlayerRemoving:Connect(function(player)
        removePlayerCard(player.Name)
        countLabel.Text = "Players (" .. (#Players:GetPlayers() - 1) .. ")"
    end)

    refreshBtn.MouseButton1Click:Connect(function()
        refreshList()
        Utility.TweenObject(refreshBtn, { BackgroundTransparency = 0.05 }, 0.1)
        task.delay(0.2, function()
            Utility.TweenObject(refreshBtn, { BackgroundTransparency = 0.3 }, 0.2)
        end)
    end)

    return self
end

