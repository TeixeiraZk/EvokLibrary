            BackgroundTransparency = 1,
            Text = "@" .. player.DisplayName,
            TextColor3 = TC("TextMuted"),
            TextSize = 9,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = card,
        })

        -- Spectate button
        local specBtn = Utility.Create("TextButton", {
            Size = UDim2.new(0, 52, 0, 18),
            Position = UDim2.new(1, -112, 0.5, -9),
            BackgroundColor3 = TC("Secondary"),
