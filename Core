-- 8. WINDOW CONSTRUCTOR (O CORE VISUAL)
-- ============================================================================
function Evok:CreateWindow(Config)
    local Window = {
        Tabs = {},
        ActiveTab = nil,
        Dragging = false
    }

    local Existing = ParentGui:FindFirstChild("Evok_Main_Interface")
    if Existing then Existing:Destroy() end

    local MainGui = self.Utility.Instance:Create("ScreenGui", {
        Name = "Evok_Main_Interface",
        Parent = ParentGui,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling, -- FIX: ISSO RESOLVE A TELA PRETA
        ResetOnSpawn = false,
        IgnoreGuiInset = true
    })
    Window.Gui = MainGui

    local RootSize = Config.Size or UDim2.new(0, 550, 0, 650)
    local RootFrame = self.Utility.Instance:Create("Frame", {
        Name = "Root",
        Parent = MainGui,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = self.ThemeManager:GetColor("Background"),
        BorderSizePixel = 0,
        ClipsDescendants = true
    })
    Window.Root = RootFrame

    self.Utility.Instance:CreateRound(8, RootFrame)
    self.Utility.Instance:CreateStroke(self.ThemeManager:GetColor("Border"), 1, RootFrame)

    local Glow = self.Utility.Instance:Create("ImageLabel", {
        Name = "GlowShadow",
        Parent = RootFrame,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(1, 40, 1, 40),
        BackgroundTransparency = 1,
        Image = "rbxassetid://6014261993",
        ImageColor3 = Color3.new(0, 0, 0),
        ImageTransparency = 0.5,
        SliceCenter = Rect.new(49, 49, 450, 450),
        ScaleType = Enum.ScaleType.Slice,
        ZIndex = 0
    })

    local Header = self.Utility.Instance:Create("Frame", {
        Name = "Header",
        Parent = RootFrame,
        Size = UDim2.new(1, 0, 0, 35),
        BackgroundColor3 = self.ThemeManager:GetColor("Container"), -- Levemente mais claro
        BorderSizePixel = 0
    })

    local HeaderIcon = self.Utility.Instance:Create("ImageLabel", {
        Name = "Icon",
        Parent = Header,
        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new(0, 12, 0.5, -8),
        BackgroundTransparency = 1,
        Image = "rbxassetid://10057377888",
        ImageColor3 = self.ThemeManager:GetColor("Accent")
    })

    local Title = self.Utility.Instance:Create("TextLabel", {
        Name = "Title",
        Parent = Header,
        Size = UDim2.new(1, -50, 1, 0),
        Position = UDim2.new(0, 35, 0, 0),
        BackgroundTransparency = 1,
        Text = Config.Title or "Evok Framework",
        TextColor3 = self.ThemeManager:GetColor("Text"),
        Font = self.Fonts.Semibold,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        RichText = true
    })

    local HeaderLine = self.Utility.Instance:Create("Frame", {
        Name = "HeaderLine",
        Parent = Header,
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = self.ThemeManager:GetColor("Border"),
        BorderSizePixel = 0
    })

    local TabNavigation = self.Utility.Instance:Create("ScrollingFrame", {
        Name = "TabNavigation",
        Parent = RootFrame,
        Size = UDim2.new(1, -20, 0, 30),
        Position = UDim2.new(0, 10, 0, 45),
        BackgroundTransparency = 1,
        ScrollBarThickness = 0,
        ScrollingDirection = Enum.ScrollingDirection.X
    })
    Window.Navigation = TabNavigation

    local NavLayout = self.Utility.Instance:Create("UIListLayout", {
        Parent = TabNavigation,
        FillDirection = Enum.FillDirection.Horizontal,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 5)
    })
    NavLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        TabNavigation.CanvasSize = UDim2.new(0, NavLayout.AbsoluteContentSize.X, 0, 0)
    end)

    local PagesContainer = self.Utility.Instance:Create("Frame", {
        Name = "PagesContainer",
        Parent = RootFrame,
        Size = UDim2.new(1, -20, 1, -85),
        Position = UDim2.new(0, 10, 0, 75),
        BackgroundTransparency = 1
    })
    Window.Pages = PagesContainer

    -- ============================================================================
    -- 9. SISTEMA DE ARRASTE SUAVE
    -- ============================================================================
    local DragInput, DragStart, StartPos
    
    local function UpdateDrag(input)
        local Delta = input.Position - DragStart
        local TargetPos = UDim2.new(
            StartPos.X.Scale, StartPos.X.Offset + Delta.X,
            StartPos.Y.Scale, StartPos.Y.Offset + Delta.Y
        )
        TweenService:Create(RootFrame, TweenInfo.new(0.15, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
            Position = TargetPos
        }):Play()
    end

    Header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            Window.Dragging = true
            DragStart = input.Position
            StartPos = RootFrame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    Window.Dragging = false
                end
            end)
        end
    end)

    Header.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            DragInput = input
        end
    end)

    local DragConn = UserInputService.InputChanged:Connect(function(input)
        if input == DragInput and Window.Dragging then
            UpdateDrag(input)
        end
    end)
    table.insert(Evok.Connections, DragConn)

    local ToggleConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not gameProcessed then
            if input.KeyCode == Enum.KeyCode.RightShift or input.KeyCode == Enum.KeyCode.Insert then
                MainGui.Enabled = not MainGui.Enabled
            end
        end
    end)
    table.insert(Evok.Connections, ToggleConn)

    local BootTween = TweenService:Create(RootFrame, TweenInfo.new(0.6, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Size = RootSize
    })
    BootTween:Play()
    BootTween.Completed:Connect(function()
        RootFrame.ClipsDescendants = false
    end)

    setmetatable(Window, {__index = Evok.WindowFunctions})

    return Window
end

return Evok
