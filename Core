NotificationManager._container = nil
NotificationManager._maxNotifications = 5
NotificationManager._yOffset = 12
NotificationManager._notifHeight = 70
NotificationManager._notifWidth = 280

function NotificationManager:_InitContainer()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "EvokNotifications"
    screenGui.ResetOnSpawn = false
    screenGui.IgnoreGuiInset = true
    screenGui.DisplayOrder = 999

    if syn and syn.protect_gui then
        syn.protect_gui(screenGui)
        screenGui.Parent = game:GetService("CoreGui")
    elseif gethui then
        screenGui.Parent = gethui()
    else
        screenGui.Parent = game:GetService("CoreGui")
    end

    self._container = Instance.new("Frame")
    self._container.Name = "NotifContainer"
    self._container.AnchorPoint = Vector2.new(1, 1)
    self._container.Position = UDim2.new(1, -16, 1, -16)
    self._container.Size = UDim2.new(0, self._notifWidth, 1, -32)
    self._container.BackgroundTransparency = 1
    self._container.Parent = screenGui
end

function NotificationManager:_RearrangeNotifications()
    local y = 0
    for i = #self._notifications, 1, -1 do
        local notif = self._notifications[i]
        if notif and notif.Frame and notif.Frame.Parent then
            Utility.TweenObject(
                notif.Frame,
                { Position = UDim2.new(0, 0, 1, -(y + self._notifHeight)) },
                0.3
            )
            y = y + self._notifHeight + self._yOffset
        end
    end
end

function NotificationManager:Notify(options)
    if not self._container then
        self:_InitContainer()
    end

    options = options or {}
    local title    = options.Title    or "Evok"
    local message  = options.Message  or ""
    local duration = options.Duration or 4
    local notifType= options.Type     or "Info"
    local icon     = options.Icon     or "rbxassetid://7733960981"

    -- Remove oldest if too many
    if #self._notifications >= self._maxNotifications then
        local oldest = table.remove(self._notifications, 1)
        if oldest and oldest.Frame then
            Utility.TweenObject(oldest.Frame, { Position = UDim2.new(1.2, 0, oldest.Frame.Position.Y.Scale, oldest.Frame.Position.Y.Offset) }, 0.3)
            task.delay(0.35, function()
                if oldest.Frame.Parent then
                    oldest.Frame:Destroy()
                end
            end)
        end
    end

    local theme = ThemeManager:GetColor

    -- Accent colors per type
    local accentColor = ThemeManager:GetColor("Primary")
    if notifType == "Success" then accentColor = ThemeManager:GetColor("Success")
    elseif notifType == "Warning" then accentColor = ThemeManager:GetColor("Warning")
    elseif notifType == "Error"   then accentColor = ThemeManager:GetColor("Error")
    end

    -- Main frame
    local frame = Utility.Create("Frame", {
        Name = "Notification_" .. Utility.GenerateID(),
        Size = UDim2.new(0, self._notifWidth, 0, self._notifHeight),
        Position = UDim2.new(1.2, 0, 1, 0),
        BackgroundColor3 = ThemeManager:GetColor("Surface"),
        BackgroundTransparency = 0.05,
        BorderSizePixel = 0,
        Parent = self._container,
    })

    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 8), Parent = frame })
    Utility.Create("UIStroke", {
        Color = accentColor,
        Thickness = 1,
        Transparency = 0.4,
        Parent = frame,
    })

    -- Accent bar on left
    local accentBar = Utility.Create("Frame", {
        Size = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = accentColor,
        BorderSizePixel = 0,
        Parent = frame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = accentBar })

    -- Glow
    local glow = Utility.Create("Frame", {
        Size = UDim2.new(1, 20, 1, 20),
        Position = UDim2.new(0, -10, 0, -10),
        BackgroundColor3 = accentColor,
        BackgroundTransparency = 0.85,
        BorderSizePixel = 0,
        ZIndex = frame.ZIndex - 1,
        Parent = frame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 14), Parent = glow })

    -- Title label
    local titleLabel = Utility.Create("TextLabel", {
        Size = UDim2.new(1, -20, 0, 22),
        Position = UDim2.new(0, 14, 0, 10),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = ThemeManager:GetColor("TextPrimary"),
        TextSize = 13,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
    })

    -- Message label
    local messageLabel = Utility.Create("TextLabel", {
        Size = UDim2.new(1, -20, 0, 32),
        Position = UDim2.new(0, 14, 0, 30),
        BackgroundTransparency = 1,
        Text = message,
        TextColor3 = ThemeManager:GetColor("TextSecondary"),
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = frame,
    })

    -- Progress bar
    local progressBg = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, -2),
        BackgroundColor3 = Utility.DarkenColor(accentColor, 0.4),
        BorderSizePixel = 0,
        Parent = frame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 2), Parent = progressBg })

    local progressFill = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = accentColor,
        BorderSizePixel = 0,
        Parent = progressBg,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 2), Parent = progressFill })

    -- Track notification
    local notifEntry = { Frame = frame }
    table.insert(self._notifications, notifEntry)

    -- Slide in animation
    self:_RearrangeNotifications()
    task.delay(0.05, function()
        Utility.TweenObject(frame, { Position = UDim2.new(0, 0, frame.Position.Y.Scale, frame.Position.Y.Offset) }, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    end)

    -- Progress bar animation
    Utility.TweenObject(progressFill, { Size = UDim2.new(0, 0, 1, 0) }, duration, Enum.EasingStyle.Linear)

    -- Auto dismiss
    task.delay(duration, function()
        self:_RemoveNotification(notifEntry)
    end)

    return notifEntry
end

function NotificationManager:_RemoveNotification(notifEntry)
    for i, n in ipairs(self._notifications) do
        if n == notifEntry then
            table.remove(self._notifications, i)
            break
        end
    end

    if notifEntry.Frame and notifEntry.Frame.Parent then
        Utility.TweenObject(
            notifEntry.Frame,
            { Position = UDim2.new(1.2, 0, notifEntry.Frame.Position.Y.Scale, notifEntry.Frame.Position.Y.Offset) },
            0.35
        )
        task.delay(0.4, function()
            if notifEntry.Frame.Parent then
                notifEntry.Frame:Destroy()
            end
        end)
    end

    self:_RearrangeNotifications()
end

function NotificationManager:RemoveNotification(notifEntry)
    self:_RemoveNotification(notifEntry)
end

function NotificationManager:ClearAll()
    for _, n in ipairs(self._notifications) do
        if n.Frame and n.Frame.Parent then
            n.Frame:Destroy()
        end
    end
    self._notifications = {}
end

