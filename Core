	self.Glow = Glow
	self.Shadow = Shadow
	self.CloseButton = Close

	Utility.MakeStroke(Main, self.Theme.StrokeColor, 1, 0.35)

	local Blur = Utility.CreateBlur("EvokBlur", 0)
	self.Blur = Blur

	local function UpdateDrag(input)
		if not self.Dragging or not self.CanDrag then return end
		local delta = input.Position - self.DragStart
		Main.Position = UDim2.new(
			self.StartPos.X.Scale,
			self.StartPos.X.Offset + delta.X,
			self.StartPos.Y.Scale,
			self.StartPos.Y.Offset + delta.Y
		)
	end

	self.Maid:Give(TopBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			self.Dragging = true
			self.DragStart = input.Position
			self.StartPos = Main.Position
		end
	end))

	self.Maid:Give(TopBar.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			self.Dragging = false
		end
	end))

	self.Maid:Give(UserInputService.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			UpdateDrag(input)
		end
	end))

	self.Maid:Give(Close.MouseEnter:Connect(function()
		Utility.TweenObject(Close, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 0,
			TextColor3 = self.Theme.AccentColor
		})
	end))

	self.Maid:Give(Close.MouseLeave:Connect(function()
		Utility.TweenObject(Close, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 0.12,
			TextColor3 = self.Theme.TextColor
		})
	end))

	self.Maid:Give(Close.Activated:Connect(function()
		self:ToggleVisibility(false)
	end))

	ThemeManager:RegisterObject(Main, "BackgroundColor3", "Background")
	ThemeManager:RegisterObject(TopBar, "BackgroundColor3", "Panel")
	ThemeManager:RegisterObject(Title, "TextColor3", "TextColor")
	ThemeManager:RegisterObject(Close, "TextColor3", "TextColor")
	ThemeManager:RegisterObject(Close, "BackgroundColor3", "PanelAlt")
	ThemeManager:RegisterObject(Glow, "BackgroundColor3", "PrimaryColor")

	self:Show(true)
	return self
end

function WindowManager:UpdateTheme()
