local Utility = {}
Utility.__index = Utility

-- Math helpers
function Utility.Clamp(value, min, max)
    return math.max(min, math.min(max, value))
end

function Utility.Round(value, decimals)
    decimals = decimals or 0
    local factor = 10 ^ decimals
    return math.floor(value * factor + 0.5) / factor
end

function Utility.Lerp(a, b, t)
    return a + (b - a) * t
end

function Utility.Map(value, inMin, inMax, outMin, outMax)
    return outMin + (outMax - outMin) * ((value - inMin) / (inMax - inMin))
end

function Utility.Sign(value)
    if value > 0 then return 1
    elseif value < 0 then return -1
    else return 0 end
end

function Utility.Percentage(value, total)
    if total == 0 then return 0 end
    return (value / total) * 100
end

function Utility.PercentageOf(percent, total)
    return (percent / 100) * total
end

-- String helpers
function Utility.Trim(str)
    return str:match("^%s*(.-)%s*$")
end

function Utility.Split(str, sep)
    local result = {}
    local pattern = string.format("([^%s]+)", sep)
    for part in str:gmatch(pattern) do
        table.insert(result, part)
    end
    return result
end

function Utility.StartsWith(str, prefix)
    return str:sub(1, #prefix) == prefix
end

function Utility.EndsWith(str, suffix)
    return suffix == "" or str:sub(-#suffix) == suffix
end

function Utility.Contains(str, sub)
    return str:find(sub, 1, true) ~= nil
end

function Utility.Capitalize(str)
    return str:sub(1, 1):upper() .. str:sub(2):lower()
end

function Utility.TruncateString(str, maxLen, suffix)
    suffix = suffix or "..."
    if #str <= maxLen then return str end
    return str:sub(1, maxLen - #suffix) .. suffix
end

-- Color helpers
function Utility.HexToColor3(hex)
    hex = hex:gsub("#", "")
    local r = tonumber(hex:sub(1, 2), 16) / 255
    local g = tonumber(hex:sub(3, 4), 16) / 255
    local b = tonumber(hex:sub(5, 6), 16) / 255
    return Color3.new(r, g, b)
end

function Utility.Color3ToHex(color)
    return string.format(
        "#%02X%02X%02X",
        math.floor(color.R * 255),
        math.floor(color.G * 255),
        math.floor(color.B * 255)
    )
end

function Utility.Color3ToHSV(color)
    return Color3.toHSV(color)
end

function Utility.HSVToColor3(h, s, v)
    return Color3.fromHSV(h, s, v)
end

function Utility.LightenColor(color, amount)
    local h, s, v = Color3.toHSV(color)
    v = math.clamp(v + amount, 0, 1)
    return Color3.fromHSV(h, s, v)
end

function Utility.DarkenColor(color, amount)
    local h, s, v = Color3.toHSV(color)
    v = math.clamp(v - amount, 0, 1)
    return Color3.fromHSV(h, s, v)
end

function Utility.MixColors(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

-- Table helpers
function Utility.DeepCopy(original)
    local copy = {}
    for k, v in pairs(original) do
        if type(v) == "table" then
            copy[k] = Utility.DeepCopy(v)
        else
            copy[k] = v
        end
    end
    return copy
end

function Utility.Merge(t1, t2)
    local result = Utility.DeepCopy(t1)
    for k, v in pairs(t2) do
        result[k] = v
    end
    return result
end

function Utility.Contains_Table(tbl, value)
    for _, v in ipairs(tbl) do
        if v == value then return true end
    end
    return false
end

function Utility.IndexOf(tbl, value)
    for i, v in ipairs(tbl) do
        if v == value then return i end
    end
    return nil
end

function Utility.Filter(tbl, fn)
    local result = {}
    for _, v in ipairs(tbl) do
        if fn(v) then
            table.insert(result, v)
        end
    end
    return result
end

function Utility.Map_Table(tbl, fn)
    local result = {}
    for i, v in ipairs(tbl) do
        result[i] = fn(v)
    end
    return result
end

function Utility.Reduce(tbl, fn, init)
    local acc = init
    for _, v in ipairs(tbl) do
        acc = fn(acc, v)
    end
    return acc
end

-- Instance helpers
function Utility.Create(class, properties)
    local instance = Instance.new(class)
    for k, v in pairs(properties or {}) do
        if k ~= "Parent" then
            instance[k] = v
        end
    end
    if properties and properties.Parent then
        instance.Parent = properties.Parent
    end
    return instance
end

function Utility.Destroy(instance)
    if instance and instance.Parent then
        instance:Destroy()
    end
end

function Utility.ApplyProperties(instance, properties)
    for k, v in pairs(properties) do
        instance[k] = v
    end
end

-- Tween helper
function Utility.TweenObject(instance, properties, duration, easingStyle, easingDirection)
    easingStyle     = easingStyle     or Enum.EasingStyle.Quad
    easingDirection = easingDirection or Enum.EasingDirection.Out

    local info = TweenInfo.new(duration, easingStyle, easingDirection)
    local tween = TweenService:Create(instance, info, properties)
    tween:Play()
    return tween
end

function Utility.TweenObjectChain(instance, steps)
    local function runStep(i)
        if i > #steps then return end
        local step = steps[i]
        local tween = Utility.TweenObject(
            instance,
            step.Properties,
            step.Duration,
            step.EasingStyle,
            step.EasingDirection
        )
        tween.Completed:Connect(function()
            runStep(i + 1)
        end)
    end
    runStep(1)
end

-- Signal system
function Utility.CreateSignal()
    local signal = {}
    local connections = {}

    function signal:Connect(fn)
        local id = HttpService:GenerateGUID(false)
        connections[id] = fn
        return {
            Disconnect = function()
                connections[id] = nil
            end
        }
    end

    function signal:Fire(...)
        for _, fn in pairs(connections) do
            task.spawn(fn, ...)
        end
    end

    function signal:Wait()
        local co = coroutine.running()
        local conn
        conn = signal:Connect(function(...)
            conn:Disconnect()
            coroutine.resume(co, ...)
        end)
        return coroutine.yield()
    end

    function signal:DisconnectAll()
        connections = {}
    end

    return signal
end

-- Debounce
function Utility.Debounce(fn, cooldown)
    local lastCall = 0
    return function(...)
        local now = tick()
        if now - lastCall >= cooldown then
            lastCall = now
            return fn(...)
        end
    end
end

-- Throttle
function Utility.Throttle(fn, interval)
    local lastTime = 0
    return function(...)
        local now = tick()
        if now - lastTime >= interval then
            lastTime = now
            fn(...)
        end
    end
end

-- Unique ID generator
function Utility.GenerateID()
    return HttpService:GenerateGUID(false)
end

-- Wait with timeout
function Utility.WaitFor(fn, timeout)
    timeout = timeout or 10
    local startTime = tick()
    while not fn() do
        if tick() - startTime >= timeout then
            return false
        end
        task.wait(0.05)
    end
    return true
end

-- Keyboard helper
function Utility.KeycodeToString(keycode)
    local name = keycode.Name
    if name:sub(1, 6) == "KeyPad" then
        return "Numpad " .. name:sub(7)
    end
    return name
end

