-- ==============================================================================
-- 🎨 ADVANCED COLOR MATH ENGINE
-- ==============================================================================
Core.Math = { Color = {} }

-- Converte Color3 para Hex (Ex: #FFFFFF)
function Core.Math.Color.ToHex(color: Color3): string
    local r = math.floor(color.R * 255 + 0.5)
    local g = math.floor(color.G * 255 + 0.5)
    local b = math.floor(color.B * 255 + 0.5)
    return string.format("#%02X%02X%02X", r, g, b)
end

-- Converte Hex para Color3
function Core.Math.Color.FromHex(hex: string): Color3
    hex = hex:gsub("#", "")
    local r = tonumber(hex:sub(1, 2), 16) or 255
    local g = tonumber(hex:sub(3, 4), 16) or 255
    local b = tonumber(hex:sub(5, 6), 16) or 255
    return Color3.fromRGB(r, g, b)
end

-- Inversão de Cor (Contraste)
function Core.Math.Color.Invert(color: Color3): Color3
    return Color3.new(1 - color.R, 1 - color.G, 1 - color.B)
end

-- Escurece a cor
function Core.Math.Color.Darken(color: Color3, amount: number): Color3
    local h, s, v = color:ToHSV()
    return Color3.fromHSV(h, s, math.clamp(v - amount, 0, 1))
end

-- Clareia a cor
function Core.Math.Color.Lighten(color: Color3, amount: number): Color3
    local h, s, v = color:ToHSV()
    return Color3.fromHSV(h, s, math.clamp(v + amount, 0, 1))
end

function Core.Math.Map(val, inMin, inMax, outMin, outMax)
    return (val - inMin) * (outMax - outMin) / (inMax - inMin) + outMin
end

function Core.Math.Lerp(a, b, t)
    return a + (b - a) * math.clamp(t, 0, 1)
end

-- ==============================================================================
-- 🧮 EASING ENGINE (PENNER EQUATIONS)
-- ==============================================================================
Core.Easing = {}

function Core.Easing.Linear(t, b, c, d) return c * t / d + b end
function Core.Easing.InSine(t, b, c, d) return -c * math.cos(t / d * (math.pi / 2)) + c + b end
function Core.Easing.OutSine(t, b, c, d) return c * math.sin(t / d * (math.pi / 2)) + b end
function Core.Easing.InOutSine(t, b, c, d) return -c / 2 * (math.cos(math.pi * t / d) - 1) + b end

function Core.Easing.InQuad(t, b, c, d)
    t = t / d
    return c * math.pow(t, 2) + b
end
function Core.Easing.OutQuad(t, b, c, d)
    t = t / d
    return -c * t * (t - 2) + b
end
function Core.Easing.InOutQuad(t, b, c, d)
    t = t / d * 2
    if t < 1 then return c / 2 * math.pow(t, 2) + b end
    return -c / 2 * ((t - 1) * (t - 3) - 1) + b
end

function Core.Easing.InCubic(t, b, c, d)
    t = t / d
    return c * math.pow(t, 3) + b
end
function Core.Easing.OutCubic(t, b, c, d)
    t = t / d - 1
    return c * (math.pow(t, 3) + 1) + b
end
function Core.Easing.InOutCubic(t, b, c, d)
    t = t / d * 2
    if t < 1 then return c / 2 * t * t * t + b end
    t = t - 2
    return c / 2 * (t * t * t + 2) + b
end

function Core.Easing.InQuart(t, b, c, d)
    t = t / d
    return c * math.pow(t, 4) + b
end
function Core.Easing.OutQuart(t, b, c, d)
    t = t / d - 1
    return -c * (math.pow(t, 4) - 1) + b
end
function Core.Easing.InOutQuart(t, b, c, d)
    t = t / d * 2
    if t < 1 then return c / 2 * math.pow(t, 4) + b end
    t = t - 2
    return -c / 2 * (math.pow(t, 4) - 2) + b
end

function Core.Easing.InQuint(t, b, c, d)
    t = t / d
    return c * math.pow(t, 5) + b
end
function Core.Easing.OutQuint(t, b, c, d)
    t = t / d - 1
    return c * (math.pow(t, 5) + 1) + b
end
function Core.Easing.InOutQuint(t, b, c, d)
    t = t / d * 2
    if t < 1 then return c / 2 * math.pow(t, 5) + b end
    t = t - 2
    return c / 2 * (math.pow(t, 5) + 2) + b
end

function Core.Easing.InExpo(t, b, c, d)
    if t == 0 then return b end
    return c * math.pow(2, 10 * (t / d - 1)) + b - c * 0.001
end
function Core.Easing.OutExpo(t, b, c, d)
    if t == d then return b + c end
    return c * 1.001 * (-math.pow(2, -10 * t / d) + 1) + b
end
function Core.Easing.InOutExpo(t, b, c, d)
    if t == 0 then return b end
    if t == d then return b + c end
    t = t / d * 2
    if t < 1 then return c / 2 * math.pow(2, 10 * (t - 1)) + b - c * 0.0005 end
    return c / 2 * 1.0005 * (-math.pow(2, -10 * (t - 1)) + 2) + b
end

function Core.Easing.OutBack(t, b, c, d, s)
    if not s then s = 1.70158 end
    t = t / d - 1
    return c * (t * t * ((s + 1) * t + s) + 1) + b
end

-- ==============================================================================
-- 🎨 THEME MANAGER (Reatividade Completa)
-- ==============================================================================
function Core:SetTheme(themeName: string, newAccent: Color3?)
    if newAccent then
        self.Themes.Accent = newAccent
    end
    
    for _, listener in pairs(self.ThemeListeners) do
        if type(listener) == "function" then
            local success, err = pcall(listener, self.Themes)
            if not success then Core.Logger:Warn("Failed to update theme listener: " .. tostring(err)) end
        end
    end
    Core.Logger:Log("Theme updated successfully.")
end

function Core:SubscribeToTheme(callback: (theme: ColorTheme) -> void)
    table.insert(self.ThemeListeners, callback)
    callback(self.Themes) 
end

-- ==============================================================================
-- 🛠️ UTILITIES & ANIMATION MANAGER
-- ==============================================================================
function Core:Tween(instance: Instance, properties: table, duration: number?, style: Enum.EasingStyle?, direction: Enum.EasingDirection?)
    local tweenInfo = TweenInfo.new(
        duration or 0.25,
        style or Enum.EasingStyle.Quint,
        direction or Enum.EasingDirection.Out
    )
    local tween = TweenService:Create(instance, tweenInfo, properties)
    tween:Play()
    return tween
end

function Core:MakeDraggable(dragArea: Instance, target: Instance, dragSpeed: number?)
    dragSpeed = dragSpeed or 0.16
    local dragging = false
    local dragInput = nil
    local dragStart = nil
    local startPos = nil

    local function update(input)
        local delta = input.Position - dragStart
        local targetPosition = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
        self:Tween(target, {Position = targetPosition}, dragSpeed, Enum.EasingStyle.Sine)
    end

    dragArea.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = target.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    dragArea.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            update(input)
        end
    end)
end

