function Utility.DeepCopy(Table)
	local Copy = {}
	for Key, Value in pairs(Table) do
		if type(Value) == "table" then
			Copy[Key] = Utility.DeepCopy(Value)
		else
			Copy[Key] = Value
		end
	end
	return Copy
end

