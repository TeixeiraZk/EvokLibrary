local Utility = require(script.Parent.Utility)
local ThemeManager = require(script.Parent.ThemeManager)

local NotificationManager = {}
NotificationManager.__index = NotificationManager
NotificationManager.List = {}
NotificationManager.Container = nil

function NotificationManager:Init(Parent)
	if self.Container then
		return
	end

	local Holder = Utility.CreateInstance("Frame", {
		Name = "Notifications",
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		Parent = Parent,
	})

	self.Container = Holder
end

function NotificationManager:_CreateToast(Text, Color, Duration)
	local Frame = Utility.CreateInstance("Frame", {
		BackgroundColor3 = Color3.fromRGB(18, 18, 18),
		BackgroundTransparency = 0.06,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(260, 54),
		Position = UDim2.new(1, 280, 1, -18),
		AnchorPoint = Vector2.new(1, 1),
		Parent = self.Container,
	})

	Utility.MakeCorner(Frame, UDim.new(0, 12))
	Utility.MakeStroke(Frame, Color, 1, 0.45)

	local Glow = Utility.CreateInstance("Frame", {
		BackgroundColor3 = Color,
		BackgroundTransparency = 0.9,
		BorderSizePixel = 0,
		Size = UDim2.new(1, 10, 1, 10),
		Position = UDim2.new(0, -5, 0, -5),
		Parent = Frame,
	})
	Utility.MakeCorner(Glow, UDim.new(0, 14))

	local Title = Utility.CreateInstance("TextLabel", {
		Name = "Title",
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -16, 1, 0),
		Position = UDim2.new(0, 8, 0, 0),
		Font = Enum.Font.GothamMedium,
		Text = Text,
		TextColor3 = ThemeManager.CurrentTheme.TextColor,
		TextSize = 13,
		TextWrapped = true,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Frame
	})

	return {
		Frame = Frame,
		Glow = Glow,
		Title = Title,
		Color = Color,
		Duration = Duration
	}
end

function NotificationManager:_Reflow()
	for Index, Item in ipairs(self.List) do
		local TargetY = 1 - (Index * 0.085)
		Utility.TweenObject(Item.Frame, TweenInfo.new(0.28, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Position = UDim2.new(1, -18, TargetY, 0)
		})
	end
end

function NotificationManager:Notify(Config)
	Config = Config or {}

	if not self.Container then
		return
	end

	local Text = Config.Text or "Notification"
	local Duration = Config.Duration or 3
	local Color = Config.Color or ThemeManager.CurrentTheme.PrimaryColor

	local Item = self:_CreateToast(Text, Color, Duration)
	table.insert(self.List, Item)

	self:_Reflow()

	Utility.TweenObject(Item.Frame, TweenInfo.new(0.36, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Position = UDim2.new(1, -18, 1 - (#self.List * 0.085), 0)
	})

	task.delay(Duration, function()
		if not Item.Frame or not Item.Frame.Parent then
			return
		end

		Utility.TweenObject(Item.Frame, TweenInfo.new(0.24, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			Position = UDim2.new(1, 280, Item.Frame.Position.Y.Scale, 0),
			BackgroundTransparency = 1
		})

		task.delay(0.26, function()
			if Item.Frame then
				Item.Frame:Destroy()
			end

			for Index, Entry in ipairs(self.List) do
				if Entry == Item then
					table.remove(self.List, Index)
					break
				end
			end

			self:_Reflow()
		end)
	end)

	return Item
end

function NotificationManager:RemoveNotification(Item)
	if not Item or not Item.Frame then
		return
	end

	Item.Frame:Destroy()

	for Index, Entry in ipairs(self.List) do
		if Entry == Item then
			table.remove(self.List, Index)
			break
		end
	end

	self:_Reflow()
end

function NotificationManager:Clear()
	for _, Item in ipairs(self.List) do
		if Item.Frame then
			Item.Frame:Destroy()
		end
	end
	table.clear(self.List)
end

return NotificationManager

