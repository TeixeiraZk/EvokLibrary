local ThemeManager = {}
ThemeManager.__index = ThemeManager

ThemeManager.Themes = {
	Default = {
		PrimaryColor = Color3.fromRGB(199, 125, 255),
		SecondaryColor = Color3.fromRGB(157, 78, 221),
		AccentColor = Color3.fromRGB(255, 179, 255),
		Background = Color3.fromRGB(10, 10, 10),
		Panel = Color3.fromRGB(16, 16, 16),
		PanelAlt = Color3.fromRGB(22, 22, 22),
		TextColor = Color3.fromRGB(245, 245, 245),
		MutedTextColor = Color3.fromRGB(175, 175, 175),
		StrokeColor = Color3.fromRGB(76, 46, 96),
		ShadowColor = Color3.fromRGB(0, 0, 0),
		Transparency = 0.12,
	},
}

ThemeManager.CurrentTheme = ThemeManager.Themes.Default
ThemeManager.Registered = {}
ThemeManager.Queued = {}

function ThemeManager:SetTheme(Name, Theme)
	if Theme then
		self.Themes[Name] = Theme
	end
	if self.Themes[Name] then
		self.CurrentTheme = self.Themes[Name]
		self:ApplyTheme()
	end
end

function ThemeManager:SetCurrentTheme(Theme)
	if Theme then
		self.CurrentTheme = Theme
		self:ApplyTheme()
	end
end

function ThemeManager:UpdateAccent(Color)
	self.CurrentTheme.PrimaryColor = Color
	self:ApplyTheme()
end

function ThemeManager:RegisterObject(Object, Property, Key)
	Key = Key or Property
	self.Registered[Object] = self.Registered[Object] or {}
	self.Registered[Object][Key] = Property
	self:ApplyObject(Object)
end

function ThemeManager:UnregisterObject(Object)
	self.Registered[Object] = nil
end

function ThemeManager:SetProperty(Key, Value)
	self.CurrentTheme[Key] = Value
	self:ApplyTheme()
end

function ThemeManager:Get(Key)
	return self.CurrentTheme[Key]
end

function ThemeManager:ApplyObject(Object)
	if not Object or not Object.Parent then return end
	local Info = self.Registered[Object]
	if not Info then return end
	local Theme = self.CurrentTheme
	for Key, Property in pairs(Info) do
		pcall(function()
			if Key == "Background" then Object[Property] = Theme.Background end
			if Key == "PrimaryColor" then Object[Property] = Theme.PrimaryColor end
			if Key == "SecondaryColor" then Object[Property] = Theme.SecondaryColor end
			if Key == "AccentColor" then Object[Property] = Theme.AccentColor end
			if Key == "TextColor" then Object[Property] = Theme.TextColor end
			if Key == "MutedTextColor" then Object[Property] = Theme.MutedTextColor end
			if Key == "StrokeColor" then Object[Property] = Theme.StrokeColor end
			if Key == "Panel" then Object[Property] = Theme.Panel end
			if Key == "PanelAlt" then Object[Property] = Theme.PanelAlt end
		end)
	end
end

function ThemeManager:ApplyTheme()
	for Object in pairs(self.Registered) do
		self:ApplyObject(Object)
	end
end

return ThemeManager

