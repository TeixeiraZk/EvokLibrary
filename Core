local Easing = {}

Easing.Functions = {
	Linear = function(t) return t end,
	Sine = function(t) return 1 - math.cos((t * math.pi) / 2) end,
	Quad = function(t) return t * t end,
	Cubic = function(t) return t * t * t end,
	Quart = function(t) return t ^ 4 end,
	Quint = function(t) return t ^ 5 end,
	Expo = function(t) return t == 0 and 0 or 2 ^ (10 * (t - 1)) end,
	Circ = function(t) return 1 - math.sqrt(1 - t * t) end,
	Back = function(t)
		local s = 1.70158
		return t * t * ((s + 1) * t - s)
	end,
	Elastic = function(t)
		if t == 0 or t == 1 then
			return t
		end
		return -2 ^ (10 * (t - 1)) * math.sin((t - 1.075) * (2 * math.pi) / 0.3)
	end,
	Bounce = function(t)
		if t < 1 / 2.75 then
			return 7.5625 * t * t
		elseif t < 2 / 2.75 then
			t = t - 1.5 / 2.75
			return 7.5625 * t * t + 0.75
		elseif t < 2.5 / 2.75 then
			t = t - 2.25 / 2.75
			return 7.5625 * t * t + 0.9375
		else
			t = t - 2.625 / 2.75
			return 7.5625 * t * t + 0.984375
		end
	end,
	Spring = function(t)
		return (1 - math.cos(t * math.pi * 2)) * (1 - t)
	end,
}

function Easing.Apply(Name, Alpha)
	local Fn = Easing.Functions[Name] or Easing.Functions.Quad
	return Fn(math.clamp(Alpha, 0, 1))
end

function Easing.InOut(Name, Alpha)
	Alpha = math.clamp(Alpha, 0, 1)
	local InName = Easing.Functions[Name] or Easing.Functions.Quad
	if Alpha < 0.5 then
		return InName(Alpha * 2) / 2
	end
	return 1 - InName((1 - Alpha) * 2) / 2
end

function Easing.Lerp(A, B, Alpha, Name)
	return A + (B - A) * Easing.Apply(Name or "Quad", Alpha)
end

function Easing.Lerp2(A, B, Alpha, Name)
	return Vector2.new(
		Easing.Lerp(A.X, B.X, Alpha, Name),
		Easing.Lerp(A.Y, B.Y, Alpha, Name)
	)
end

function Easing.Lerp3(A, B, Alpha, Name)
	return Vector3.new(
		Easing.Lerp(A.X, B.X, Alpha, Name),
		Easing.Lerp(A.Y, B.Y, Alpha, Name),
		Easing.Lerp(A.Z, B.Z, Alpha, Name)
	)
end

function Easing.LerpColor(A, B, Alpha, Name)
	return Color3.new(
		Easing.Lerp(A.R, B.R, Alpha, Name),
		Easing.Lerp(A.G, B.G, Alpha, Name),
		Easing.Lerp(A.B, B.B, Alpha, Name)
	)
end

return Easing

