function Easing.Get(name)
    return Easing.Map[name] or Easing.Map.Linear
end

-- Animated value runner
function Easing.Animate(from, to, duration, easingName, callback, onComplete)
    easingName = easingName or "CubicOut"
    local easingFn = Easing.Get(easingName)
    local startTime = tick()
    local connection

    connection = RunService.Heartbeat:Connect(function()
        local elapsed = tick() - startTime
        local t = math.clamp(elapsed / duration, 0, 1)
        local value = Easing.Lerp(from, to, easingFn(t))

        if callback then
            callback(value)
        end

        if t >= 1 then
            connection:Disconnect()
            if onComplete then
                onComplete()
            end
        end
    end)

    return connection
end

