-- ==============================================================================
-- 🎨 ADVANCED COLOR MATH ENGINE (RGB, HSV, HSL, CMYK Conversions)
-- ==============================================================================
Core.Math = { Color = {} }

function Core.Math.Color.ToHex(color: Color3): string
    return string.format("#%02X%02X%02X", color.R * 255, color.G * 255, color.B * 255)
end

function Core.Math.Color.FromHex(hex: string): Color3
    hex = hex:gsub("#", "")
    return Color3.fromRGB(tonumber(hex:sub(1,2),16) or 255, tonumber(hex:sub(3,4),16) or 255, tonumber(hex:sub(5,6),16) or 255)
end

function Core.Math.Color.ToHSL(color: Color3)
    local r, g, b = color.R, color.G, color.B
    local max, min = math.max(r, g, b), math.min(r, g, b)
    local h, s, l
    l = (max + min) / 2
    if max == min then
        h, s = 0, 0
    else
        local d = max - min
        s = l > 0.5 and d / (2 - max - min) or d / (max + min)
        if max == r then h = (g - b) / d + (g < b and 6 or 0)
        elseif max == g then h = (b - r) / d + 2
        elseif max == b then h = (r - g) / d + 4 end
        h = h / 6
    end
    return h, s, l
end

function Core.Math.Color.FromHSL(h: number, s: number, l: number): Color3
    local r, g, b
    if s == 0 then
        r, g, b = l, l, l
    else
        local function hue2rgb(p, q, t)
            if t < 0 then t = t + 1 end
            if t > 1 then t = t - 1 end
            if t < 1/6 then return p + (q - p) * 6 * t end
            if t < 1/2 then return q end
            if t < 2/3 then return p + (q - p) * (2/3 - t) * 6 end
            return p
        end
        local q = l < 0.5 and l * (1 + s) or l + s - l * s
        local p = 2 * l - q
        r = hue2rgb(p, q, h + 1/3)
        g = hue2rgb(p, q, h)
        b = hue2rgb(p, q, h - 1/3)
    end
    return Color3.new(r, g, b)
end

function Core.Math.Color.ToCMYK(color: Color3)
    local c = 1 - color.R
    local m = 1 - color.G
    local y = 1 - color.B
    local k = math.min(c, math.min(m, y))
    if k == 1 then return 0, 0, 0, 1 end
    c = (c - k) / (1 - k)
    m = (m - k) / (1 - k)
    y = (y - k) / (1 - k)
    return c, m, y, k
end

function Core.Math.Color.FromCMYK(c: number, m: number, y: number, k: number): Color3
    local r = 1 - math.min(1, c * (1 - k) + k)
    local g = 1 - math.min(1, m * (1 - k) + k)
    local b = 1 - math.min(1, y * (1 - k) + k)
    return Color3.new(r, g, b)
end

function Core.Math.Color.Darken(color: Color3, amount: number): Color3
    local h, s, v = color:ToHSV()
    return Color3.fromHSV(h, s, math.clamp(v - amount, 0, 1))
end

function Core.Math.Color.Lighten(color: Color3, amount: number): Color3
    local h, s, v = color:ToHSV()
    return Color3.fromHSV(h, s, math.clamp(v + amount, 0, 1))
end

function Core.Math.Color.Blend(color1: Color3, color2: Color3, alpha: number): Color3
    return color1:Lerp(color2, alpha)
end

function Core.Math.Color.GetLuminance(color: Color3): number
    return 0.2126 * color.R + 0.7152 * color.G + 0.0722 * color.B
end

function Core.Math.Color.GetContrastRatio(color1: Color3, color2: Color3): number
    local l1 = Core.Math.Color.GetLuminance(color1)
    local l2 = Core.Math.Color.GetLuminance(color2)
    if l1 > l2 then
        return (l1 + 0.05) / (l2 + 0.05)
    else
        return (l2 + 0.05) / (l1 + 0.05)
    end
end

-- ==============================================================================
-- 🧮 CUSTOM EASING ENGINE (33 Penner Equations - High Performance)
-- ==============================================================================
Core.Easing = {}

-- Linear
function Core.Easing.Linear(t, b, c, d) return c * t / d + b end

-- Sine
function Core.Easing.InSine(t, b, c, d) return -c * math.cos(t / d * (math.pi / 2)) + c + b end
function Core.Easing.OutSine(t, b, c, d) return c * math.sin(t / d * (math.pi / 2)) + b end
function Core.Easing.InOutSine(t, b, c, d) return -c / 2 * (math.cos(math.pi * t / d) - 1) + b end

-- Quad
function Core.Easing.InQuad(t, b, c, d) t = t / d; return c * math.pow(t, 2) + b end
function Core.Easing.OutQuad(t, b, c, d) t = t / d; return -c * t * (t - 2) + b end
function Core.Easing.InOutQuad(t, b, c, d)
    t = t / d * 2
    if t < 1 then return c / 2 * math.pow(t, 2) + b end
    return -c / 2 * ((t - 1) * (t - 3) - 1) + b
end

-- Cubic
function Core.Easing.InCubic(t, b, c, d) t = t / d; return c * math.pow(t, 3) + b end
function Core.Easing.OutCubic(t, b, c, d) t = t / d - 1; return c * (math.pow(t, 3) + 1) + b end
function Core.Easing.InOutCubic(t, b, c, d)
    t = t / d * 2
    if t < 1 then return c / 2 * t * t * t + b end
    t = t - 2; return c / 2 * (t * t * t + 2) + b
end

-- Quart
function Core.Easing.InQuart(t, b, c, d) t = t / d; return c * math.pow(t, 4) + b end
function Core.Easing.OutQuart(t, b, c, d) t = t / d - 1; return -c * (math.pow(t, 4) - 1) + b end
function Core.Easing.InOutQuart(t, b, c, d)
    t = t / d * 2
    if t < 1 then return c / 2 * math.pow(t, 4) + b end
    t = t - 2; return -c / 2 * (math.pow(t, 4) - 2) + b
end

-- Quint
function Core.Easing.InQuint(t, b, c, d) t = t / d; return c * math.pow(t, 5) + b end
function Core.Easing.OutQuint(t, b, c, d) t = t / d - 1; return c * (math.pow(t, 5) + 1) + b end
function Core.Easing.InOutQuint(t, b, c, d)
    t = t / d * 2
    if t < 1 then return c / 2 * math.pow(t, 5) + b end
    t = t - 2; return c / 2 * (math.pow(t, 5) + 2) + b
end

-- Expo
function Core.Easing.InExpo(t, b, c, d)
    if t == 0 then return b end
    return c * math.pow(2, 10 * (t / d - 1)) + b - c * 0.001
end
function Core.Easing.OutExpo(t, b, c, d)
    if t == d then return b + c end
    return c * 1.001 * (-math.pow(2, -10 * t / d) + 1) + b
end
function Core.Easing.InOutExpo(t, b, c, d)
    if t == 0 then return b end
    if t == d then return b + c end
    t = t / d * 2
    if t < 1 then return c / 2 * math.pow(2, 10 * (t - 1)) + b - c * 0.0005 end
    return c / 2 * 1.0005 * (-math.pow(2, -10 * (t - 1)) + 2) + b
end

-- Circ
function Core.Easing.InCirc(t, b, c, d) t = t / d; return -c * (math.sqrt(1 - t * t) - 1) + b end
function Core.Easing.OutCirc(t, b, c, d) t = t / d - 1; return c * math.sqrt(1 - t * t) + b end
function Core.Easing.InOutCirc(t, b, c, d)
    t = t / d * 2
    if t < 1 then return -c / 2 * (math.sqrt(1 - t * t) - 1) + b end
    t = t - 2; return c / 2 * (math.sqrt(1 - t * t) + 1) + b
end

-- Back
function Core.Easing.InBack(t, b, c, d, s)
    if not s then s = 1.70158 end
    t = t / d; return c * t * t * ((s + 1) * t - s) + b
end
function Core.Easing.OutBack(t, b, c, d, s)
    if not s then s = 1.70158 end
    t = t / d - 1; return c * (t * t * ((s + 1) * t + s) + 1) + b
end
function Core.Easing.InOutBack(t, b, c, d, s)
    if not s then s = 1.70158 end
    s = s * 1.525
    t = t / d * 2
    if t < 1 then return c / 2 * (t * t * ((s + 1) * t - s)) + b end
    t = t - 2; return c / 2 * (t * t * ((s + 1) * t + s) + 2) + b
end

-- Bounce
function Core.Easing.OutBounce(t, b, c, d)
    t = t / d
    if t < (1 / 2.75) then return c * (7.5625 * t * t) + b
    elseif t < (2 / 2.75) then t = t - (1.5 / 2.75); return c * (7.5625 * t * t + 0.75) + b
    elseif t < (2.5 / 2.75) then t = t - (2.25 / 2.75); return c * (7.5625 * t * t + 0.9375) + b
    else t = t - (2.625 / 2.75); return c * (7.5625 * t * t + 0.984375) + b end
end
function Core.Easing.InBounce(t, b, c, d) return c - Core.Easing.OutBounce(d - t, 0, c, d) + b end
function Core.Easing.InOutBounce(t, b, c, d)
    if t < d / 2 then return Core.Easing.InBounce(t * 2, 0, c, d) * 0.5 + b end
    return Core.Easing.OutBounce(t * 2 - d, 0, c, d) * 0.5 + c * 0.5 + b
end

-- ==============================================================================
-- 🎨 THEME MANAGER (Reatividade Ultrarrápida)
-- ==============================================================================
function Core:SetTheme(themeName: string, newAccent: Color3?)
    if newAccent then self.Themes.Accent = newAccent end
    Core.ThemeSignal:Fire(self.Themes)
    Core.Logger:Log("Theme Engine Synchronized.")
end

function Core:SubscribeToTheme(callback: (theme: ColorTheme) -> void)
    Core.ThemeSignal:Connect(callback)
    callback(self.Themes) 
end

-- ==============================================================================
-- 🛠️ UTILITIES & ANIMATION MANAGER
-- ==============================================================================
function Core:Tween(instance: Instance, properties: table, duration: number?, style: Enum.EasingStyle?, direction: Enum.EasingDirection?)
    local tweenInfo = TweenInfo.new(
        duration or 0.25,
        style or Enum.EasingStyle.Quint,
        direction or Enum.EasingDirection.Out
    )
    local tween = TweenService:Create(instance, tweenInfo, properties)
    tween:Play()
    return tween
end

function Core:MakeDraggable(dragArea: Instance, target: Instance, dragSpeed: number?)
    dragSpeed = dragSpeed or 0.16
    local dragging = false
    local dragInput = nil
    local dragStart = nil
    local startPos = nil

    dragArea.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = target.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    dragArea.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            local targetPosition = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
            self:Tween(target, {Position = targetPosition}, dragSpeed, Enum.EasingStyle.Sine)
        end
    end)
end

