-- [ MATH UTILITIES ]
function Evok.Utility.Math:Round(Number, Decimals)
    local Mult = 10 ^ (Decimals or 0)
    return math.floor(Number * Mult + 0.5) / Mult
end

function Evok.Utility.Math:Clamp(Value, Min, Max)
    if Value < Min then return Min end
    if Value > Max then return Max end
    return Value
end

function Evok.Utility.Math:Lerp(A, B, T)
    return A + (B - A) * T
end

function Evok.Utility.Math:Map(Value, InMin, InMax, OutMin, OutMax)
    return OutMin + (OutMax - OutMin) * ((Value - InMin) / (InMax - InMin))
end

-- [ COLOR UTILITIES ]
function Evok.Utility.Color:ToHex(Color)
    local r = math.round(Color.R * 255)
    local g = math.round(Color.G * 255)
    local b = math.round(Color.B * 255)
    return string.format("#%02X%02X%02X", r, g, b)
end

function Evok.Utility.Color:FromHex(Hex)
    Hex = Hex:gsub("#", "")
    if #Hex == 3 then
        Hex = Hex:sub(1,1)..Hex:sub(1,1)..Hex:sub(2,2)..Hex:sub(2,2)..Hex:sub(3,3)..Hex:sub(3,3)
    end
    local r = tonumber("0x" .. Hex:sub(1, 2))
    local g = tonumber("0x" .. Hex:sub(3, 4))
    local b = tonumber("0x" .. Hex:sub(5, 6))
    return Color3.fromRGB(r, g, b)
end

function Evok.Utility.Color:Darken(Color, Amount)
    local h, s, v = Color3.toHSV(Color)
    return Color3.fromHSV(h, s, math.clamp(v - Amount, 0, 1))
end

function Evok.Utility.Color:Lighten(Color, Amount)
    local h, s, v = Color3.toHSV(Color)
    return Color3.fromHSV(h, s, math.clamp(v + Amount, 0, 1))
end

function Evok.Utility.Color:Invert(Color)
    return Color3.new(1 - Color.R, 1 - Color.G, 1 - Color.B)
end

function Evok.Utility.Color:Lerp(ColorA, ColorB, Alpha)
    return ColorA:Lerp(ColorB, Alpha)
end

-- [ STRING UTILITIES ]
function Evok.Utility.String:Capitalize(Str)
    return (Str:gsub("^%l", string.upper))
end

function Evok.Utility.String:Trim(Str)
    return (Str:gsub("^%s*(.-)%s*$", "%1"))
end

function Evok.Utility.String:StartsWith(Str, Start)
    return string.sub(Str, 1, string.len(Start)) == Start
end

function Evok.Utility.String:EndsWith(Str, End)
    return Start == "" or string.sub(Str, -string.len(End)) == End
end

-- [ INSTANCE UTILITIES ]
function Evok.Utility.Instance:Create(ClassName, Properties)
    local Inst = Instance.new(ClassName)
    for Key, Value in pairs(Properties or {}) do
        if Key ~= "Parent" then
            Inst[Key] = Value
        end
    end
    if Properties and Properties.Parent then
        Inst.Parent = Properties.Parent
    end
    table.insert(Evok.Instances, Inst)
    return Inst
end

function Evok.Utility.Instance:CreateRound(Radius, Parent)
    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, Radius or 6)
    if Parent then Corner.Parent = Parent end
    table.insert(Evok.Instances, Corner)
    return Corner
end

function Evok.Utility.Instance:CreateStroke(Color, Thickness, Parent)
    local Stroke = Instance.new("UIStroke")
    Stroke.Color = Color or Color3.new(1, 1, 1)
    Stroke.Thickness = Thickness or 1
    Stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    if Parent then Stroke.Parent = Parent end
    table.insert(Evok.Instances, Stroke)
    return Stroke
end

