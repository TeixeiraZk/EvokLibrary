-- ==============================================================================
Core.Cursor = { Enabled = false, Instance = nil }

function Core:EnableCustomCursor()
    if self.Cursor.Enabled or not self.GUI then return end
    self.Cursor.Enabled = true
    UserInputService.MouseIconEnabled = false

    local CursorFrame = Instance.new("Frame")
    CursorFrame.Name = "EvokCursor"
    CursorFrame.Size = UDim2.new(0, 8, 0, 8)
    CursorFrame.BackgroundColor3 = self.Themes.Accent
    CursorFrame.ZIndex = 9999
    CursorFrame.Parent = self.GUI

    Instance.new("UICorner", CursorFrame).CornerRadius = UDim.new(1, 0)
    
    local CursorStroke = Instance.new("UIStroke", CursorFrame)
    CursorStroke.Color = Color3.fromRGB(0, 0, 0)
    CursorStroke.Thickness = 1

    self.Cursor.Instance = CursorFrame

    self:SubscribeToTheme(function(theme)
        if self.Cursor.Instance then self.Cursor.Instance.BackgroundColor3 = theme.Accent end
    end)

    RunService.RenderStepped:Connect(function()
        if self.Cursor.Enabled and self.Cursor.Instance then
            local mouseLoc = UserInputService:GetMouseLocation()
            self.Cursor.Instance.Position = UDim2.new(0, mouseLoc.X, 0, mouseLoc.Y - 36) 
        end
    end)

    UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and self.Cursor.Enabled then
            self:Tween(CursorFrame, {Size = UDim2.new(0, 5, 0, 5)}, 0.1)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and self.Cursor.Enabled then
            self:Tween(CursorFrame, {Size = UDim2.new(0, 8, 0, 8)}, 0.1)
        end
    end)
end

