function Utility.WaitForChild(Parent, Name, Timeout)
	local Start = os.clock()
	local Child = Parent:FindFirstChild(Name)
	while not Child do
		if Timeout and os.clock() - Start > Timeout then
			return nil
		end
		task.wait()
		Child = Parent:FindFirstChild(Name)
	end
	return Child
end

function Utility.CreateConnection(Obj, EventName, Fn, Maid)
