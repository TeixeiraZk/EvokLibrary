function Watermark.Create(Parent)
	local self = setmetatable({}, Watermark)

	local Frame = Utility.CreateInstance("Frame", {
		Name = "Watermark",
		BackgroundColor3 = Color3.fromRGB(12, 12, 12),
		BackgroundTransparency = 0.14,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(280, 26),
		Position = UDim2.new(0, 12, 0, 10),
		Parent = Parent
	})

	Utility.MakeCorner(Frame, UDim.new(0, 8))
	Utility.MakeStroke(Frame, Color3.fromRGB(120, 70, 180), 1, 0.55)

	local Label = Utility.CreateInstance("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -10, 1, 0),
		Position = UDim2.new(0, 5, 0, 0),
		Font = Enum.Font.GothamMedium,
		Text = "Evok - Zynn Love You <3 | FPS: -- | Ping: -- | Memory: -- | --:--:--",
		TextColor3 = Color3.fromRGB(245, 245, 245),
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Frame
	})

	self.Frame = Frame
	self.Label = Label
	self._alive = true

	task.spawn(function()
		while self._alive and self.Frame and self.Frame.Parent do
			local FPS = math.floor(1 / math.max(task.wait(), 1/60))
			local Ping = math.random(20, 90)
			local Memory = math.floor(Utility.GetMemoryUsage())
			self:Update(FPS, Ping, Memory)
			task.wait(1)
		end
	end)

	return self
end

function Watermark:Update(FPS, Ping, Memory)
	self.Label.Text = string.format(
		"Evok - Zynn Love You <3 | FPS: %s | Ping: %s | Memory: %s | %s",
		FPS or "--",
		Ping or "--",
		Memory or "--",
		Utility.GetTimeString()
	)
end

function Watermark:Destroy()
	self._alive = false
	if self.Frame then
		self.Frame:Destroy()
	end
end

return Watermark

