function Core:Notify(config)
    if not self.NotifyContainer then self:InitNotificationSystem() end

    local title = config.Title or "Notification"
    local text = config.Text or "System Message"
    local duration = config.Duration or 5
    local nType = config.Type or "Info" 

    local sideColor = self.Themes.Accent
    if nType == "Success" then sideColor = self.Themes.Success
    elseif nType == "Warning" then sideColor = self.Themes.Warning
    elseif nType == "Error" then sideColor = self.Themes.Error end

    local NotifFrame = Instance.new("Frame")
    NotifFrame.Size = UDim2.new(1, 0, 0, 0)
    NotifFrame.AutomaticSize = Enum.AutomaticSize.Y
    NotifFrame.Position = UDim2.new(1, 350, 0, 0) 
    NotifFrame.BackgroundColor3 = self.Themes.NotificationBg
    NotifFrame.Parent = self.NotifyContainer

    Instance.new("UICorner", NotifFrame).CornerRadius = UDim.new(0, 6)
    local NStroke = Instance.new("UIStroke", NotifFrame)
    NStroke.Color = self.Themes.Border

    local SideBar = Instance.new("Frame")
    SideBar.Size = UDim2.new(0, 4, 1, 0)
    SideBar.BackgroundColor3 = sideColor
    SideBar.BorderSizePixel = 0
    SideBar.Parent = NotifFrame
    Instance.new("UICorner", SideBar).CornerRadius = UDim.new(0, 6)

    local NPadding = Instance.new("UIPadding", NotifFrame)
    NPadding.PaddingTop = UDim.new(0, 12)
    NPadding.PaddingBottom = UDim.new(0, 15)
    NPadding.PaddingLeft = UDim.new(0, 15)
    NPadding.PaddingRight = UDim.new(0, 15)

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Size = UDim2.new(1, -10, 0, 16)
    TitleLabel.Position = UDim2.new(0, 10, 0, 0)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = title
    TitleLabel.TextColor3 = self.Themes.Text
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.TextSize = 14
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    TitleLabel.Parent = NotifFrame

    local TextLabel = Instance.new("TextLabel")
    TextLabel.Size = UDim2.new(1, -10, 0, 0)
    TextLabel.Position = UDim2.new(0, 10, 0, 22)
    TextLabel.AutomaticSize = Enum.AutomaticSize.Y
    TextLabel.BackgroundTransparency = 1
    TextLabel.Text = text
    TextLabel.TextColor3 = self.Themes.TextMuted
    TextLabel.Font = Enum.Font.Gotham
    TextLabel.TextSize = 13
    TextLabel.TextWrapped = true
    TextLabel.TextXAlignment = Enum.TextXAlignment.Left
    TextLabel.Parent = NotifFrame

    local TimeBarBg = Instance.new("Frame")
    TimeBarBg.Size = UDim2.new(1, 0, 0, 3)
    TimeBarBg.Position = UDim2.new(0, 0, 1, -3)
    TimeBarBg.BackgroundColor3 = self.Themes.Border
    TimeBarBg.BorderSizePixel = 0
    TimeBarBg.Parent = NotifFrame
    Instance.new("UICorner", TimeBarBg).CornerRadius = UDim.new(0, 4)

    local TimeBarFill = Instance.new("Frame")
    TimeBarFill.Size = UDim2.new(1, 0, 1, 0)
    TimeBarFill.BackgroundColor3 = sideColor
    TimeBarFill.BorderSizePixel = 0
    TimeBarFill.Parent = TimeBarBg
    Instance.new("UICorner", TimeBarFill).CornerRadius = UDim.new(0, 4)

    self:Tween(NotifFrame, {Position = UDim2.new(0, 0, 0, 0)}, 0.4, Enum.EasingStyle.Back)
    local barTween = self:Tween(TimeBarFill, {Size = UDim2.new(0, 0, 1, 0)}, duration, Enum.EasingStyle.Linear)

    local closed = false
    local function CloseNotification()
        if closed then return end
        closed = true
        barTween:Cancel()
        local outTween = self:Tween(NotifFrame, {Position = UDim2.new(1, 350, 0, 0)}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        outTween.Completed:Wait()
        NotifFrame:Destroy()
    end

    local ClickBtn = Instance.new("TextButton")
    ClickBtn.Size = UDim2.new(1, 0, 1, 0)
    ClickBtn.BackgroundTransparency = 1
    ClickBtn.Text = ""
    ClickBtn.ZIndex = 10
    ClickBtn.Parent = NotifFrame
    ClickBtn.MouseButton1Click:Connect(CloseNotification)

    task.delay(duration, CloseNotification)
end

-- ==============================================================================
-- 🖼️ WINDOW MANAGER (BUILDER ENGINE - SIDEBAR 800x500)
-- ==============================================================================
function Core:CreateWindow(config)
    Core.Logger:Log("Initializing Sidebar Window Manager...")
    
    local title = config.Title or "Evok - Zynn Love you <3"
    local size = config.Size or UDim2.new(0, 550, 0, 800) 
    
    local targetGui
    if pcall(function() return CoreGui.Name end) then
        targetGui = CoreGui
    else
        targetGui = LocalPlayer:WaitForChild("PlayerGui")
    end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "EvokUI_" .. HttpService:GenerateGUID(false)
    ScreenGui.ResetOnSpawn = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Global
    ScreenGui.Parent = targetGui
    self.GUI = ScreenGui

    local ShadowFrame = Instance.new("Frame")
    ShadowFrame.Name = "Shadow"
    ShadowFrame.Size = size
    ShadowFrame.Position = UDim2.new(0.5, -size.X.Offset/2, 0.5, -size.Y.Offset/2)
    ShadowFrame.BackgroundTransparency = 1
    ShadowFrame.Parent = ScreenGui

    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.new(1, 0, 1, 0)
    MainFrame.BackgroundColor3 = self.Themes.Background
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = true
    MainFrame.Parent = ShadowFrame

    local MainCorner = Instance.new("UICorner")
    MainCorner.CornerRadius = UDim.new(0, 8)
    MainCorner.Parent = MainFrame

    local MainStroke = Instance.new("UIStroke")
    MainStroke.Color = self.Themes.Border
    MainStroke.Thickness = 1
    MainStroke.Parent = MainFrame

    -- ==========================================
    -- SIDEBAR (Menu Lateral)
    -- ==========================================
    local Sidebar = Instance.new("Frame")
    Sidebar.Name = "Sidebar"
    Sidebar.Size = UDim2.new(0, 200, 1, 0)
    Sidebar.BackgroundColor3 = self.Themes.Sidebar
    Sidebar.BorderSizePixel = 0
    Sidebar.Parent = MainFrame
    
    local SidebarLine = Instance.new("Frame")
    SidebarLine.Size = UDim2.new(0, 1, 1, 0)
    SidebarLine.Position = UDim2.new(1, 0, 0, 0)
    SidebarLine.BackgroundColor3 = self.Themes.Border
    SidebarLine.BorderSizePixel = 0
    SidebarLine.Parent = Sidebar

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Name = "Title"
    TitleLabel.Size = UDim2.new(1, -40, 0, 60)
    TitleLabel.Position = UDim2.new(0, 20, 0, 15)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = "<font size='20'>Evok</font>\n<font size='12' color='#888888'>Zynn Love you &lt;3</font>"
    TitleLabel.RichText = true
    TitleLabel.TextColor3 = self.Themes.Accent
    TitleLabel.Font = Enum.Font.GothamBold
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    TitleLabel.TextYAlignment = Enum.TextYAlignment.Center
    TitleLabel.Parent = Sidebar

    -- ==========================================
    -- CONTAINERS (Onde os Widgets e Abas vão ficar)
    -- ==========================================
    local TabContainer = Instance.new("Frame")
    TabContainer.Name = "TabContainer"
    TabContainer.Size = UDim2.new(1, 0, 1, -90)
    TabContainer.Position = UDim2.new(0, 0, 0, 90)
    TabContainer.BackgroundTransparency = 1
    TabContainer.Parent = Sidebar
    
    local TabListLayout = Instance.new("UIListLayout")
    TabListLayout.FillDirection = Enum.FillDirection.Vertical
    TabListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    TabListLayout.Padding = UDim.new(0, 8)
    TabListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    TabListLayout.Parent = TabContainer

    local PageContainer = Instance.new("Frame")
    PageContainer.Name = "PageContainer"
    PageContainer.Size = UDim2.new(1, -200, 1, 0)
    PageContainer.Position = UDim2.new(0, 200, 0, 0)
    PageContainer.BackgroundTransparency = 1
    PageContainer.Parent = MainFrame

    -- Área de Dragging invisível sobre o Content para arrastar a janela
    local DragBar = Instance.new("Frame")
    DragBar.Size = UDim2.new(1, 0, 0, 40)
    DragBar.BackgroundTransparency = 1
    DragBar.Parent = MainFrame
    
    self:MakeDraggable(Sidebar, ShadowFrame)
    self:MakeDraggable(DragBar, ShadowFrame)

    -- Registro Reativo
    self:SubscribeToTheme(function(theme)
        MainFrame.BackgroundColor3 = theme.Background
        MainStroke.Color = theme.Border
        Sidebar.BackgroundColor3 = theme.Sidebar
        SidebarLine.BackgroundColor3 = theme.Border
        TitleLabel.TextColor3 = theme.Accent
    end)

    -- Animação de Entrada
    ShadowFrame.Size = UDim2.new(0, 0, 0, 0)
    self:Tween(ShadowFrame, {Size = size}, 0.5, Enum.EasingStyle.Quint)

    return {
        Core = self,
        GUI = ScreenGui,
        MainFrame = MainFrame,
        TopBar = Sidebar, -- Expõe a Sidebar como TopBar para retrocompatibilidade
        TabContainer = TabContainer,
        PageContainer = PageContainer,
        Tabs = {},
        CurrentTab = nil
    }
end

-- Congela metatables sensíveis
table.freeze(Core.Easing)
table.freeze(Core.Math)

return Core
