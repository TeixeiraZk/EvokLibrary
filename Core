function Utility.Clamp(Value, Min, Max)
	if Value < Min then
		return Min
	elseif Value > Max then
		return Max
	end
	return Value
end

function Utility.Lerp(A, B, Alpha)
	return A + (B - A) * Alpha
end

function Utility.Round(Number, Decimals)
	Decimals = Decimals or 0
	local Mult = 10 ^ Decimals
	return math.floor(Number * Mult + 0.5) / Mult
end

function Utility.LerpColor(ColorA, ColorB, Alpha)
	return Color3.new(
		Utility.Lerp(ColorA.R, ColorB.R, Alpha),
		Utility.Lerp(ColorA.G, ColorB.G, Alpha),
		Utility.Lerp(ColorA.B, ColorB.B, Alpha)
	)
end

function Utility.TweenObject(Object, TweenInfoData, Goal)
	local Tween = TweenService:Create(Object, TweenInfoData, Goal)
	Tween:Play()
	return Tween
end

function Utility.InstantTween(Object, Goal)
	for Property, Value in pairs(Goal) do
		Object[Property] = Value
	end
end

function Utility.CreateSignal()
	local Signal = {}
	Signal._binds = {}

	function Signal:Connect(Fn)
		local Bind = {
			Fn = Fn,
			Connected = true
		}

		function Bind:Disconnect()
			self.Connected = false
		end

		table.insert(Signal._binds, Bind)
		return Bind
	end

	function Signal:Fire(...)
		for _, Bind in ipairs(Signal._binds) do
			if Bind.Connected then
				task.spawn(Bind.Fn, ...)
			end
		end
	end

	function Signal:Destroy()
		table.clear(Signal._binds)
	end

	return Signal
end

function Utility.Maid()
	local Maid = {Tasks = {}}

	function Maid:Give(Task)
		table.insert(self.Tasks, Task)
		return Task
	end

	function Maid:DoCleaning()
		for _, Task in ipairs(self.Tasks) do
			local TypeName = typeof(Task)
			if TypeName == "RBXScriptConnection" then
				Task:Disconnect()
			elseif TypeName == "Instance" then
				Task:Destroy()
			elseif type(Task) == "function" then
				pcall(Task)
			end
		end
		table.clear(self.Tasks)
	end

	return Maid
end

function Utility.CreateInstance(ClassName, Properties)
	local Obj = Instance.new(ClassName)
	for Prop, Value in pairs(Properties or {}) do
		Obj[Prop] = Value
	end
	return Obj
end

function Utility.SetProperties(Obj, Properties)
