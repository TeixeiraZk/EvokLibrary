local Easing = {}
Easing.__index = Easing

-- Pi constant
local PI = math.pi
local TAU = PI * 2

-- Cubic easing
function Easing.CubicIn(t)
    return t * t * t
end

function Easing.CubicOut(t)
    local f = t - 1
    return f * f * f + 1
end

function Easing.CubicInOut(t)
    if t < 0.5 then
        return 4 * t * t * t
    else
        local f = (2 * t) - 2
        return 0.5 * f * f * f + 1
    end
end

-- Quart easing
function Easing.QuartIn(t)
    return t * t * t * t
end

function Easing.QuartOut(t)
    local f = t - 1
    return 1 - f * f * f * f
end

function Easing.QuartInOut(t)
    if t < 0.5 then
        return 8 * t * t * t * t
    else
        local f = t - 1
        return 1 - 8 * f * f * f * f
    end
end

-- Quint easing
function Easing.QuintIn(t)
    return t * t * t * t * t
end

function Easing.QuintOut(t)
    local f = t - 1
    return f * f * f * f * f + 1
end

function Easing.QuintInOut(t)
    if t < 0.5 then
        return 16 * t * t * t * t * t
    else
        local f = (2 * t) - 2
        return 0.5 * f * f * f * f * f + 1
    end
end

-- Sine easing
function Easing.SineIn(t)
    return math.sin((t - 1) * PI / 2) + 1
end

function Easing.SineOut(t)
    return math.sin(t * PI / 2)
end

function Easing.SineInOut(t)
    return 0.5 * (1 - math.cos(t * PI))
end

-- Circular easing
function Easing.CircIn(t)
    return 1 - math.sqrt(1 - (t * t))
end

function Easing.CircOut(t)
    return math.sqrt((2 - t) * t)
end

function Easing.CircInOut(t)
    if t < 0.5 then
        return 0.5 * (1 - math.sqrt(1 - 4 * (t * t)))
    else
        return 0.5 * (math.sqrt(-((2 * t) - 3) * ((2 * t) - 1)) + 1)
    end
end

-- Exponential easing
function Easing.ExpoIn(t)
    if t == 0 then return 0 end
    return math.pow(2, 10 * (t - 1))
end

function Easing.ExpoOut(t)
    if t == 1 then return 1 end
    return 1 - math.pow(2, -10 * t)
end

function Easing.ExpoInOut(t)
    if t == 0 or t == 1 then return t end
    if t < 0.5 then
        return 0.5 * math.pow(2, (20 * t) - 10)
    else
        return -0.5 * math.pow(2, (-20 * t) + 10) + 1
    end
end

-- Elastic easing
function Easing.ElasticIn(t)
    return math.sin(13 * PI / 2 * t) * math.pow(2, 10 * (t - 1))
end

function Easing.ElasticOut(t)
    return math.sin(-13 * PI / 2 * (t + 1)) * math.pow(2, -10 * t) + 1
end

function Easing.ElasticInOut(t)
    if t < 0.5 then
        return 0.5 * math.sin(13 * PI / 2 * (2 * t)) * math.pow(2, 10 * ((2 * t) - 1))
    else
        return 0.5 * (math.sin(-13 * PI / 2 * ((2 * t - 1) + 1)) * math.pow(2, -10 * (2 * t - 1)) + 2)
    end
end

-- Back easing
function Easing.BackIn(t)
    local s = 1.70158
    return t * t * ((s + 1) * t - s)
end

function Easing.BackOut(t)
    local s = 1.70158
    local f = t - 1
    return f * f * ((s + 1) * f + s) + 1
end

function Easing.BackInOut(t)
    local s = 1.70158 * 1.525
    if t < 0.5 then
        return 0.5 * ((2 * t) * (2 * t) * ((s + 1) * (2 * t) - s))
    else
        local f = 2 * t - 2
        return 0.5 * (f * f * ((s + 1) * f + s) + 2)
    end
end

-- Bounce easing
function Easing.BounceOut(t)
    if t < 4 / 11 then
        return (121 * t * t) / 16
    elseif t < 8 / 11 then
        return (363 / 40 * t * t) - (99 / 10 * t) + 17 / 5
    elseif t < 9 / 10 then
        return (4356 / 361 * t * t) - (35442 / 1805 * t) + 16061 / 1805
    else
        return (54 / 5 * t * t) - (513 / 25 * t) + 268 / 25
    end
end

function Easing.BounceIn(t)
    return 1 - Easing.BounceOut(1 - t)
end

function Easing.BounceInOut(t)
    if t < 0.5 then
        return 0.5 * Easing.BounceIn(t * 2)
    else
        return 0.5 * Easing.BounceOut(t * 2 - 1) + 0.5
    end
end

-- Spring easing
function Easing.Spring(t, mass, stiffness, damping, velocity)
    mass      = mass      or 1
    stiffness = stiffness or 100
    damping   = damping   or 10
    velocity  = velocity  or 0

    local omega  = math.sqrt(stiffness / mass)
    local zeta   = damping / (2 * math.sqrt(stiffness * mass))
    local result = 0

    if zeta < 1 then
        local omega_d = omega * math.sqrt(1 - zeta * zeta)
        local A = 1
        local B = (zeta * omega + velocity) / omega_d
        result = 1 - math.exp(-zeta * omega * t) * (A * math.cos(omega_d * t) + B * math.sin(omega_d * t))
    elseif zeta == 1 then
        local A = 1
        local B = velocity + omega
        result = 1 - math.exp(-omega * t) * (A + B * t)
    else
        local omega_1 = -omega * (zeta - math.sqrt(zeta * zeta - 1))
        local omega_2 = -omega * (zeta + math.sqrt(zeta * zeta - 1))
        local A = (omega_2 + velocity) / (omega_2 - omega_1)
        local B = 1 - A
        result = 1 - (A * math.exp(omega_1 * t) + B * math.exp(omega_2 * t))
    end

    return result
end

-- Interpolation helpers
function Easing.Lerp(a, b, t)
    return a + (b - a) * t
end

function Easing.LerpColor3(a, b, t)
    return Color3.new(
        Easing.Lerp(a.R, b.R, t),
        Easing.Lerp(a.G, b.G, t),
        Easing.Lerp(a.B, b.B, t)
    )
end

function Easing.LerpUDim2(a, b, t)
    return UDim2.new(
        Easing.Lerp(a.X.Scale,  b.X.Scale,  t),
        Easing.Lerp(a.X.Offset, b.X.Offset, t),
        Easing.Lerp(a.Y.Scale,  b.Y.Scale,  t),
        Easing.Lerp(a.Y.Offset, b.Y.Offset, t)
    )
end

function Easing.LerpVector2(a, b, t)
    return Vector2.new(
        Easing.Lerp(a.X, b.X, t),
        Easing.Lerp(a.Y, b.Y, t)
    )
end

function Easing.SmoothStep(t)
    return t * t * (3 - 2 * t)
end

function Easing.SmootherStep(t)
    return t * t * t * (t * (t * 6 - 15) + 10)
end

