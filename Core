-- ==============================================================================
function Core:CreateWatermark(text: string)
    if self.WatermarkActive or not self.GUI then return end
    self.WatermarkActive = true

    local WatermarkFrame = Instance.new("Frame")
    WatermarkFrame.Name = "EvokWatermark"
    WatermarkFrame.Size = UDim2.new(0, 0, 0, 30)
    WatermarkFrame.AutomaticSize = Enum.AutomaticSize.X
    WatermarkFrame.Position = UDim2.new(0, 15, 0, 15)
    WatermarkFrame.BackgroundColor3 = self.Themes.Sidebar
    WatermarkFrame.Parent = self.GUI

    Instance.new("UICorner", WatermarkFrame).CornerRadius = UDim.new(0, 6)
    local WMStroke = Instance.new("UIStroke", WatermarkFrame)
    WMStroke.Color = self.Themes.Accent
    WMStroke.Thickness = 1

    local WMPadding = Instance.new("UIPadding", WatermarkFrame)
    WMPadding.PaddingLeft = UDim.new(0, 10)
    WMPadding.PaddingRight = UDim.new(0, 10)

    local WMLabel = Instance.new("TextLabel")
    WMLabel.Size = UDim2.new(1, 0, 1, 0)
    WMLabel.BackgroundTransparency = 1
    WMLabel.Text = ""
    WMLabel.TextColor3 = self.Themes.Text
    WMLabel.Font = Enum.Font.GothamSemibold
    WMLabel.TextSize = 12
    WMLabel.RichText = true
    WMLabel.TextXAlignment = Enum.TextXAlignment.Center
    WMLabel.Parent = WatermarkFrame

    self:SubscribeToTheme(function(theme)
        WMStroke.Color = theme.Accent
        WatermarkFrame.BackgroundColor3 = theme.Sidebar
        WMLabel.TextColor3 = theme.Text
    end)

    local lastTick = tick()
    local frames = 0
    local fps = 0

    RunService.RenderStepped:Connect(function()
        frames = frames + 1
        if tick() - lastTick >= 1 then
            fps = frames
            frames = 0
            lastTick = tick()
            
            local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
            local memory = math.floor(Stats:GetTotalMemoryUsageMb())
            local accentHex = Core.Math.Color.ToHex(self.Themes.Accent)
            
            WMLabel.Text = string.format(
                "<font color='%s'>%s</font> | %s FPS | %s ms | %s MB",
                accentHex, text, tostring(fps), tostring(ping), tostring(memory)
            )
        end
    end)
    
    self:MakeDraggable(WatermarkFrame, WatermarkFrame)
end

