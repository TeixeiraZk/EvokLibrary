-- 5. THE ULTIMATE EASING ENGINE
-- ============================================================================
Evok.Easing = {}

function Evok.Easing.SineIn(t) return 1 - math.cos(t * (math.pi / 2)) end
function Evok.Easing.SineOut(t) return math.sin(t * (math.pi / 2)) end
function Evok.Easing.SineInOut(t) return -0.5 * (math.cos(math.pi * t) - 1) end

function Evok.Easing.QuadIn(t) return t * t end
function Evok.Easing.QuadOut(t) return t * (2 - t) end
function Evok.Easing.QuadInOut(t) return t < 0.5 and 2 * t * t or -1 + (4 - 2 * t) * t end

function Evok.Easing.CubicIn(t) return t * t * t end
function Evok.Easing.CubicOut(t) t = t - 1 return t * t * t + 1 end
function Evok.Easing.CubicInOut(t) return t < 0.5 and 4 * t * t * t or (t - 1) * (2 * t - 2) * (2 * t - 2) + 1 end

function Evok.Easing.QuartIn(t) return t * t * t * t end
function Evok.Easing.QuartOut(t) t = t - 1 return 1 - (t * t * t * t) end
function Evok.Easing.QuartInOut(t) return t < 0.5 and 8 * t * t * t * t or 1 - 8 * (t - 1) * (t - 1) * (t - 1) * (t - 1) end

function Evok.Easing.QuintIn(t) return t * t * t * t * t end
function Evok.Easing.QuintOut(t) t = t - 1 return 1 + (t * t * t * t * t) end
function Evok.Easing.QuintInOut(t) return t < 0.5 and 16 * t * t * t * t * t or 1 + 16 * (t - 1) * (t - 1) * (t - 1) * (t - 1) * (t - 1) end

function Evok.Easing.ExpoIn(t) return t == 0 and 0 or math.pow(2, 10 * (t - 1)) end
function Evok.Easing.ExpoOut(t) return t == 1 and 1 or 1 - math.pow(2, -10 * t) end
function Evok.Easing.ExpoInOut(t) 
    if t == 0 then return 0 end
    if t == 1 then return 1 end
    if t < 0.5 then return 0.5 * math.pow(2, 10 * (2 * t - 1)) end
    return 0.5 * (2 - math.pow(2, -10 * (2 * t - 1)))
end

function Evok.Easing.CircIn(t) return 1 - math.sqrt(1 - (t * t)) end
function Evok.Easing.CircOut(t) t = t - 1 return math.sqrt(1 - (t * t)) end
function Evok.Easing.CircInOut(t)
    if t < 0.5 then return 0.5 * (1 - math.sqrt(1 - 4 * (t * t))) end
    t = t * 2 - 2 return 0.5 * (math.sqrt(1 - (t * t)) + 1)
end

function Evok.Easing.BackIn(t) local s = 1.70158 return t * t * ((s + 1) * t - s) end
function Evok.Easing.BackOut(t) local s = 1.70158 t = t - 1 return (t * t * ((s + 1) * t + s) + 1) end
function Evok.Easing.BackInOut(t)
    local s = 1.70158 * 1.525
    if t < 0.5 then
        t = t * 2
        return 0.5 * (t * t * ((s + 1) * t - s))
    end
    t = t * 2 - 2
    return 0.5 * (t * t * ((s + 1) * t + s) + 2)
end

function Evok.Easing.ElasticIn(t)
    if t == 0 then return 0 end
    if t == 1 then return 1 end
    local p = 0.3
    local s = p / 4
    t = t - 1
    return -(math.pow(2, 10 * t) * math.sin((t - s) * (2 * math.pi) / p))
end
function Evok.Easing.ElasticOut(t)
    if t == 0 then return 0 end
    if t == 1 then return 1 end
    local p = 0.3
    local s = p / 4
    return math.pow(2, -10 * t) * math.sin((t - s) * (2 * math.pi) / p) + 1
end

function Evok.Easing.BounceOut(t)
    if t < (1 / 2.75) then return 7.5625 * t * t end
    if t < (2 / 2.75) then t = t - (1.5 / 2.75) return 7.5625 * t * t + 0.75 end
    if t < (2.5 / 2.75) then t = t - (2.25 / 2.75) return 7.5625 * t * t + 0.9375 end
    t = t - (2.625 / 2.75) return 7.5625 * t * t + 0.984375
end
function Evok.Easing.BounceIn(t) return 1 - Evok.Easing.BounceOut(1 - t) end

