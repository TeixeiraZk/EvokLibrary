local WindowManager = require(script.Parent.WindowManager)
local NotificationManager = require(script.Parent.NotificationManager)
local Watermark = require(script.Parent.Watermark)

local Loader = {}
Loader.__index = Loader

function Loader.Initialize(Config)
	Config = Config or {}

	local Window = WindowManager.CreateWindow({
		Parent = Config.Parent,
		Title = Config.Title or "Evok - Zynn Love You <3",
		Size = Config.Size,
		Position = Config.Position,
	})

	NotificationManager:Init(Window.Gui)
	local Mark = Watermark.Create(Window.Gui)

	local API = {}

	function API:GetWindow()
		return Window
	end

	function API:SetTheme(ThemeName)
		ThemeManager:SetTheme(ThemeName)
	end

	function API:SetAccent(Color)
		ThemeManager:UpdateAccent(Color)
	end

	function API:Notify(Data)
		return NotificationManager:Notify(Data)
	end

