function WindowManager:_StartGlowPulse()
    local baseTransparency = 0.75
    local glowFrame = self._glow
    local t = 0

    self._glowPulseConn = RunService.Heartbeat:Connect(function(dt)
        t = t + dt
        local pulse = 0.07 * math.sin(t * 2.5)
        if glowFrame and glowFrame.Parent then
            glowFrame.BackgroundTransparency = baseTransparency + pulse
        end
    end)
end

function WindowManager:_EnableDragging()
    local dragging   = false
    local dragOffset = Vector2.new()

    self._header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging   = true
            dragOffset = Vector2.new(
                self._mainFrame.Position.X.Offset - input.Position.X,
                self._mainFrame.Position.Y.Offset - input.Position.Y
            )
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local newX = input.Position.X + dragOffset.X
            local newY = input.Position.Y + dragOffset.Y

            -- Smooth drag using lerp
            local currentPos = self._mainFrame.Position
            local targetPos = UDim2.new(0, newX, 0, newY)

            self._mainFrame.Position = targetPos

            -- Update shadow and glow positions
            self._shadow.Position = UDim2.new(0, newX - 15, 0, newY - 15)
            self._glow.Position   = UDim2.new(0, newX - 25, 0, newY - 25)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

function WindowManager:SetSize(width, height, animate)
    self._size = Vector2.new(width, height)
    if animate then
        Utility.TweenObject(self._mainFrame, { Size = UDim2.new(0, width, 0, height) }, 0.35)
    else
        self._mainFrame.Size = UDim2.new(0, width, 0, height)
    end
end

function WindowManager:SetPosition(x, y, animate)
    if animate then
        Utility.TweenObject(self._mainFrame, { Position = UDim2.new(0, x, 0, y) }, 0.35)
        Utility.TweenObject(self._shadow,    { Position = UDim2.new(0, x - 15, 0, y - 15) }, 0.35)
        Utility.TweenObject(self._glow,      { Position = UDim2.new(0, x - 25, 0, y - 25) }, 0.35)
    else
        self._mainFrame.Position = UDim2.new(0, x, 0, y)
        self._shadow.Position    = UDim2.new(0, x - 15, 0, y - 15)
        self._glow.Position      = UDim2.new(0, x - 25, 0, y - 25)
    end
end

function WindowManager:ToggleVisibility()
    self._open = not self._open
    if self._open then
        self._mainFrame.Visible = true
        Utility.TweenObject(self._mainFrame, {
            BackgroundTransparency = 0.04,
            Size = UDim2.new(0, self._size.X, 0, self._size.Y),
        }, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    else
        Utility.TweenObject(self._mainFrame, {
            BackgroundTransparency = 1,
            Size = UDim2.new(0, self._size.X, 0, 0),
        }, 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        task.delay(0.35, function()
            if not self._open then
                self._mainFrame.Visible = false
            end
        end)
    end
end

function WindowManager:ToggleMinimize()
    self._minimized = not self._minimized
    if self._minimized then
        Utility.TweenObject(self._mainFrame, {
            Size = UDim2.new(0, self._size.X, 0, 42),
        }, 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    else
        Utility.TweenObject(self._mainFrame, {
            Size = UDim2.new(0, self._size.X, 0, self._size.Y),
        }, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    end
end

function WindowManager:Close()
    self._open = false

    -- Exit animation
    Utility.TweenObject(self._mainFrame, {
        BackgroundTransparency = 1,
        Size = UDim2.new(0, self._size.X, 0, 0),
    }, 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

    Utility.TweenObject(self._glow, { BackgroundTransparency = 1 }, 0.3)
    Utility.TweenObject(self._shadow, { BackgroundTransparency = 1 }, 0.3)

    task.delay(0.35, function()
        if self._glowPulseConn then
            self._glowPulseConn:Disconnect()
        end
        if self._screenGui then
            self._screenGui:Destroy()
        end
    end)
end

function WindowManager:CreateTab(name, icon)
    local tab = {}
    tab.Name = name
    tab.Icon = icon
    tab.Content = nil
    tab.Button  = nil

    -- Tab button
    local btn = Utility.Create("TextButton", {
        Name = "Tab_" .. name,
        Size = UDim2.new(0, 0, 1, -6),
        AutomaticSize = Enum.AutomaticSize.X,
        Position = UDim2.new(0, 0, 0, 3),
        BackgroundColor3 = ThemeManager:GetColor("TabInactive"),
        BackgroundTransparency = 0.6,
        Text = "",
        BorderSizePixel = 0,
        LayoutOrder = #self._tabs + 1,
        ZIndex = 5,
        Parent = self._tabList,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = btn })
    Utility.Create("UIPadding", {
        PaddingLeft  = UDim.new(0, 10),
        PaddingRight = UDim.new(0, 10),
        Parent = btn,
    })

    local btnLabel = Utility.Create("TextLabel", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = ThemeManager:GetColor("TextMuted"),
        TextSize = 11,
        Font = Enum.Font.Gotham,
        ZIndex = 6,
        Parent = btn,
    })

    -- Tab content frame
    local contentFrame = Utility.Create("ScrollingFrame", {
        Name = "Content_" .. name,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = ThemeManager:GetColor("ScrollBar"),
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        ZIndex = 3,
        Parent = self._contentArea,
    })

    Utility.Create("UIPadding", {
        PaddingTop    = UDim.new(0, 8),
        PaddingBottom = UDim.new(0, 8),
        PaddingLeft   = UDim.new(0, 8),
        PaddingRight  = UDim.new(0, 8),
        Parent = contentFrame,
    })

    local contentLayout = Utility.Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 6),
        Parent = contentFrame,
    })

    tab.Button  = btn
    tab.Label   = btnLabel
    tab.Content = contentFrame
    tab.Layout  = contentLayout

    -- Tab click handler
    btn.MouseButton1Click:Connect(function()
        self:SelectTab(tab)
    end)

    btn.MouseEnter:Connect(function()
        if self._activeTab ~= tab then
            Utility.TweenObject(btn, { BackgroundTransparency = 0.4 }, 0.2)
            Utility.TweenObject(btnLabel, { TextColor3 = ThemeManager:GetColor("TextSecondary") }, 0.2)
        end
    end)

    btn.MouseLeave:Connect(function()
        if self._activeTab ~= tab then
            Utility.TweenObject(btn, { BackgroundTransparency = 0.6 }, 0.2)
            Utility.TweenObject(btnLabel, { TextColor3 = ThemeManager:GetColor("TextMuted") }, 0.2)
        end
    end)

    table.insert(self._tabs, tab)

    -- Auto-select first tab
    if #self._tabs == 1 then
        self:SelectTab(tab)
    end

    return tab
end

function WindowManager:SelectTab(targetTab)
    -- Deactivate all
    for _, tab in ipairs(self._tabs) do
        tab.Content.Visible = false
        Utility.TweenObject(tab.Button, {
            BackgroundColor3 = ThemeManager:GetColor("TabInactive"),
            BackgroundTransparency = 0.6,
        }, 0.25)
        Utility.TweenObject(tab.Label, {
            TextColor3 = ThemeManager:GetColor("TextMuted"),
            -- Font cannot tween but we swap it
        }, 0.25)
        tab.Label.Font = Enum.Font.Gotham
    end

    -- Activate target
    self._activeTab = targetTab
    targetTab.Content.Visible = true
    Utility.TweenObject(targetTab.Button, {
        BackgroundColor3 = ThemeManager:GetColor("TabActive"),
        BackgroundTransparency = 0.1,
    }, 0.25)
    Utility.TweenObject(targetTab.Label, {
        TextColor3 = Color3.new(0, 0, 0),
    }, 0.25)
    targetTab.Label.Font = Enum.Font.GothamBold
end

