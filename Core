function Utility.Ripple(parent, color)
	local RippleFrame = Utility.CreateInstance("Frame", {
		BackgroundColor3 = color or Color3.fromRGB(255, 255, 255),
		BackgroundTransparency = 0.7,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(0, 0),
		Parent = parent
	})
	Utility.MakeCorner(RippleFrame, UDim.new(1, 0))
	task.spawn(function()
		local target = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2
		Utility.TweenObject(RippleFrame, TweenInfo.new(0.45, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			BackgroundTransparency = 1,
			Size = UDim2.fromOffset(target, target),
			Position = UDim2.new(0.5, -target / 2, 0.5, -target / 2)
		})
		task.wait(0.5)
		RippleFrame:Destroy()
	end)
	return RippleFrame
end

function Utility.PreventOverflow(Obj)
	if Obj:IsA("ScrollingFrame") then
		Obj.AutomaticCanvasSize = Enum.AutomaticSize.Y
	end
end

function Utility.GetViewport()
	return workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.zero
end

function Utility.CalculateCenterOffset(Size)
	local Viewport = Utility.GetViewport()
	return UDim2.fromOffset((Viewport.X - Size.X) / 2, (Viewport.Y - Size.Y) / 2)
end

function Utility.MakeResponsive(Obj, MinScale, MaxScale)
	local Viewport = Utility.GetViewport()
	local Base = math.min(Viewport.X / 1920, Viewport.Y / 1080)
	local Scale = math.clamp(Base, MinScale or 0.75, MaxScale or 1)
	local UIScale = Obj:FindFirstChildOfClass("UIScale") or Instance.new("UIScale")
	UIScale.Parent = Obj
	UIScale.Scale = Scale
	return UIScale
end

return Utility

