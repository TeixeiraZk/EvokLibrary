function Evok:CreateWatermark(Text)
    local Screen = self.Utility.Instance:Create("ScreenGui", {
        Name = "Evok_Watermark_Pro",
        Parent = ParentGui,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling, -- CORRIGIDO PARA SIBLING
        IgnoreGuiInset = true,
        ResetOnSpawn = false
    })

    local Frame = self.Utility.Instance:Create("Frame", {
        Parent = Screen,
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, -15, 0, 15),
        Size = UDim2.new(0, 0, 0, 28),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundColor3 = self.ThemeManager:GetColor("Container"),
        BorderSizePixel = 0
    })

    self.Utility.Instance:CreateRound(4, Frame)
    self.Utility.Instance:CreateStroke(self.ThemeManager:GetColor("Border"), 1, Frame)

    local Highlight = self.Utility.Instance:Create("Frame", {
        Parent = Frame,
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = self.ThemeManager:GetColor("Accent"),
        BorderSizePixel = 0
    })
    self.Utility.Instance:CreateRound(4, Highlight)

    self.Utility.Instance:Create("UIPadding", {
        Parent = Frame,
        PaddingLeft = UDim.new(0, 12),
        PaddingRight = UDim.new(0, 12)
    })

    local Label = self.Utility.Instance:Create("TextLabel", {
        Parent = Frame,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        Text = Text or "Evok UI",
        TextColor3 = self.ThemeManager:GetColor("Text"),
        Font = self.Fonts.Code,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Center,
        TextYAlignment = Enum.TextYAlignment.Center,
        RichText = true
    })

    local FrameCount = 0
    local LastTick = tick()

    local Conn = RunService.RenderStepped:Connect(function()
        FrameCount = FrameCount + 1
        if tick() - LastTick >= 1 then
            local fps = math.floor(FrameCount / (tick() - LastTick))
            local ping = "N/A"
            local memory = math.floor(Stats:GetTotalMemoryUsageMb())
            
            local success, stats = pcall(function() return Stats.Network.ServerStatsItem["Data Ping"]:GetValueString() end)
            if success and stats then ping = stats:match("%d+") or "0" end
            
            local hexAccent = self.Utility.Color:ToHex(self.ThemeManager:GetColor("Accent"))
            local timeStr = os.date("%H:%M:%S")
            
            Label.Text = string.format(
                "<font color='%s'>%s</font> | %s FPS | %sms | %s MB | %s", 
                hexAccent, Text or "Evok", tostring(fps), tostring(ping), tostring(memory), timeStr
            )
            
            FrameCount = 0
            LastTick = tick()
        end
    end)
    table.insert(self.Connections, Conn)

    return {
        SetVisible = function(state) Frame.Visible = state end,
        Destroy = function() Screen:Destroy() Conn:Disconnect() end
    }
end

