    self.Tooltip.Label = TLabel

    RunService.RenderStepped:Connect(function()
        if self.Tooltip.Active and self.Tooltip.Instance then
            local mouseLoc = UserInputService:GetMouseLocation()
            self.Tooltip.Instance.Position = UDim2.new(0, mouseLoc.X + 15, 0, mouseLoc.Y - 36 + 15)
        end
    end)
end

function Core:AddTooltip(uiElement: Instance, text: string)
    if not self.Tooltip.Instance then self:InitTooltip() end

    uiElement.MouseEnter:Connect(function()
        self.Tooltip.Active = true
        self.Tooltip.Label.Text = text
        self.Tooltip.Instance.Visible = true
        self.Tooltip.Instance.BackgroundTransparency = 1
        self.Tooltip.Label.TextTransparency = 1
        
        self:Tween(self.Tooltip.Instance, {BackgroundTransparency = 0}, 0.2)
        self:Tween(self.Tooltip.Label, {TextTransparency = 0}, 0.2)
    end)

    uiElement.MouseLeave:Connect(function()
        self.Tooltip.Active = false
        self.Tooltip.Instance.Visible = false
    end)
end

