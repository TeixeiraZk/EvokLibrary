function ThemeManager:GetTheme(name)
    return self._themes[name] or self._themes["Evok"]
end

function ThemeManager:ListThemes()
    local names = {}
    for name in pairs(self._themes) do
        table.insert(names, name)
    end
    return names
end

function ThemeManager:RegisterObject(instance, themeKey, property)
    table.insert(self._registeredObjects, {
        Instance = instance,
        ThemeKey = themeKey,
        Property = property or "BackgroundColor3",
    })
end

function ThemeManager:SetTheme(name, animate)
    local theme = self:GetTheme(name)
    self._currentTheme = theme
    self:ApplyTheme(animate)
end

function ThemeManager:ApplyTheme(animate)
    local theme = self._currentTheme
    if not theme then return end

    for _, obj in ipairs(self._registeredObjects) do
        if obj.Instance and obj.Instance.Parent then
            local color = theme[obj.ThemeKey]
            if color then
                if animate then
                    Utility.TweenObject(obj.Instance, { [obj.Property] = color }, 0.35)
                else
                    obj.Instance[obj.Property] = color
                end
            end
        end
    end
end

function ThemeManager:GetColor(key)
    if self._currentTheme then
        return self._currentTheme[key]
    end
    return self._themes["Evok"][key]
end

function ThemeManager:UpdateAccent(color, animate)
    if self._currentTheme then
        self._currentTheme.Primary    = color
        self._currentTheme.TabActive  = color
        self._currentTheme.SliderFill = color
        self._currentTheme.ToggleOn   = color
        self._currentTheme.Glow       = color
        self:ApplyTheme(animate)
    end
end

