}

function Evok:Notify(Config)
    if not self.NotificationEngine.Container then
        local Screen = self.Utility.Instance:Create("ScreenGui", {
            Name = "Evok_Notifications",
            Parent = ParentGui,
            ZIndexBehavior = Enum.ZIndexBehavior.Sibling, -- CORRIGIDO PARA SIBLING
            ResetOnSpawn = false
        })
        self.NotificationEngine.Container = self.Utility.Instance:Create("Frame", {
            Parent = Screen,
            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.new(1, -20, 1, -20),
            Size = UDim2.new(0, 320, 1, 0),
            BackgroundTransparency = 1
        })
        self.Utility.Instance:Create("UIListLayout", {
            Parent = self.NotificationEngine.Container,
            SortOrder = Enum.SortOrder.LayoutOrder,
            VerticalAlignment = Enum.VerticalAlignment.Bottom,
            HorizontalAlignment = Enum.HorizontalAlignment.Right,
            Padding = UDim.new(0, 10)
        })
    end

    local Title = Config.Title or "Notification"
    local Content = Config.Content or ""
    local Duration = Config.Duration or 5
    local Type = Config.Type or "Info"

    local ThemeColor = self.ThemeManager:GetColor("Accent")
    if Type == "Success" then ThemeColor = self.ThemeManager:GetColor("Success") end
    if Type == "Warning" then ThemeColor = self.ThemeManager:GetColor("Warning") end
    if Type == "Error" then ThemeColor = self.ThemeManager:GetColor("Error") end

    local Frame = self.Utility.Instance:Create("Frame", {
        Parent = self.NotificationEngine.Container,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = self.ThemeManager:GetColor("Container"),
        BackgroundTransparency = 1,
        ClipsDescendants = true
    })

    self.Utility.Instance:CreateRound(6, Frame)
    self.Utility.Instance:CreateStroke(self.ThemeManager:GetColor("Border"), 1, Frame)

    local SideBar = self.Utility.Instance:Create("Frame", {
        Parent = Frame,
        Size = UDim2.new(0, 4, 1, 0),
        BackgroundColor3 = ThemeColor,
        BorderSizePixel = 0
    })
    
    local TitleLabel = self.Utility.Instance:Create("TextLabel", {
        Parent = Frame,
        Size = UDim2.new(1, -45, 0, 20),
        Position = UDim2.new(0, 15, 0, 10),
        BackgroundTransparency = 1,
        Text = Title,
        TextColor3 = self.ThemeManager:GetColor("Text"),
        Font = self.Fonts.Bold,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local ContentLabel = self.Utility.Instance:Create("TextLabel", {
        Parent = Frame,
        Size = UDim2.new(1, -30, 0, 0),
        Position = UDim2.new(0, 15, 0, 35),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Text = Content,
        TextColor3 = self.ThemeManager:GetColor("TextDark"),
        Font = self.Fonts.Main,
        TextSize = 13,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top
    })

    self.Utility.Instance:Create("UIPadding", {
        Parent = Frame,
        PaddingBottom = UDim.new(0, 20)
    })

    TweenService:Create(Frame, TweenInfo.new(0.5, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {
        BackgroundTransparency = 0
    }):Play()

    task.delay(Duration, function()
        local tw = TweenService:Create(Frame, TweenInfo.new(0.4, Enum.EasingStyle.Sine, Enum.EasingDirection.In), {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 0)
        })
        tw:Play()
        tw.Completed:Wait()
        Frame:Destroy()
    end)
end

