end

function WindowManager:SetBlurAmount(Value)
	if self.Blur then
		self.Blur.Size = Value
	end
end

function WindowManager:EnableDragging(State)
	self.CanDrag = State ~= false
end

function WindowManager:EnableResize(State)
	self.CanResize = State ~= false
end

function WindowManager:Show(Instant)
	self.Visible = true
	self.Gui.Enabled = true

	if Instant then
		self.Main.Visible = true
		self.Scale.Scale = 1
		self:SetBlurAmount(12)
		return
	end

	self.Main.Visible = true
	self.Scale.Scale = 0.92
	self.Backdrop.BackgroundTransparency = 1
	self.Glow.BackgroundTransparency = 0.95
	self:SetBlurAmount(0)

	Utility.TweenObject(self.Scale, TweenInfo.new(0.42, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Scale = 1
	})

	Utility.TweenObject(self.Backdrop, TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundTransparency = 0.58
	})

	Utility.TweenObject(self.Glow, TweenInfo.new(0.7, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {
		BackgroundTransparency = 0.82
	})

	Utility.TweenObject(self.Blur, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Size = 12
	})
end

function WindowManager:Hide(Instant)
	self.Visible = false

	if Instant then
		self.Main.Visible = false
		self.Gui.Enabled = false
		self:SetBlurAmount(0)
		return
	end

	local Tween = Utility.TweenObject(self.Scale, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Scale = 0.94
	})

	Utility.TweenObject(self.Backdrop, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		BackgroundTransparency = 1
	})

	Utility.TweenObject(self.Blur, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
		Size = 0
	})

	Tween.Completed:Connect(function()
		self.Main.Visible = false
		self.Gui.Enabled = false
	end)
end

function WindowManager:ToggleVisibility(State)
	if State == nil then
		State = not self.Visible
	end

	if State then
		self:Show(false)
	else
		self:Hide(false)
	end
end

function WindowManager:SetSize(Size)
	self.TargetSize = Size
	Utility.TweenObject(self.Main, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Size = Size
	})
end

function WindowManager:SetPosition(Position)
	self.TargetPosition = Position
	Utility.TweenObject(self.Main, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Position = Position
	})
end

function WindowManager:SetTitle(Text)
	self.TitleLabel.Text = Text
end

function WindowManager:PulseGlow()
	task.spawn(function()
		while self.Main and self.Main.Parent do
			Utility.TweenObject(self.Glow, TweenInfo.new(1.1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
				BackgroundTransparency = 0.78
			})
			task.wait(1.1)
			Utility.TweenObject(self.Glow, TweenInfo.new(1.1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
				BackgroundTransparency = 0.88
			})
			task.wait(1.1)
		end
	end)
end

function WindowManager:CreateGlow()
	return self.Glow
end

function WindowManager:CreateShadow()
	return self.Shadow
end

function WindowManager:Destroy()
	self.Maid:DoCleaning()
	Utility.DestroyBlur("EvokBlur")
	if self.Gui then
		self.Gui:Destroy()
	end
end

return WindowManager

