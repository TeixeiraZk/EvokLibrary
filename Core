        closed = true
        barTween:Cancel()
        local outTween = self:Tween(NotifFrame, {Position = UDim2.new(1, 350, 0, 0)}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        outTween.Completed:Wait()
        NotifFrame:Destroy()
    end

    local ClickBtn = Instance.new("TextButton")
    ClickBtn.Size = UDim2.new(1, 0, 1, 0)
    ClickBtn.BackgroundTransparency = 1
    ClickBtn.Text = ""
    ClickBtn.ZIndex = 10
    ClickBtn.Parent = NotifFrame
    ClickBtn.MouseButton1Click:Connect(CloseNotification)

    task.delay(duration, CloseNotification)
end

-- ==============================================================================
-- 🖼️ WINDOW MANAGER (BUILDER ENGINE)
-- Design: Matcha Style (Top Navigation), Dark/Pink, 650x600
-- ==============================================================================
function Core:CreateWindow(config)
    Core.Logger:Log("Initializing Evok Window Manager (Matcha Design)...")
    
    local title = config.Title or "Evok - Zynn Love you <3"
    local size = config.Size or UDim2.new(0, 650, 0, 600) 
    
    local targetGui
    if pcall(function() return CoreGui.Name end) then
        targetGui = CoreGui
    else
        targetGui = LocalPlayer:WaitForChild("PlayerGui")
    end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "EvokUI_" .. HttpService:GenerateGUID(false)
    ScreenGui.ResetOnSpawn = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Global
    ScreenGui.Parent = targetGui
    self.GUI = ScreenGui

    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = size
    MainFrame.Position = UDim2.new(0.5, -size.X.Offset/2, 0.5, -size.Y.Offset/2)
    MainFrame.BackgroundColor3 = self.Themes.Background
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = true
    MainFrame.Parent = ScreenGui

    local MainCorner = Instance.new("UICorner")
    MainCorner.CornerRadius = UDim.new(0, 8)
    MainCorner.Parent = MainFrame

    local MainStroke = Instance.new("UIStroke")
    MainStroke.Color = self.Themes.Border
    MainStroke.Thickness = 1
    MainStroke.Parent = MainFrame

    -- ==========================================
    -- TOP BAR (Title + Tab Navigation)
    -- ==========================================
    local TopBar = Instance.new("Frame")
    TopBar.Name = "TopBar"
    TopBar.Size = UDim2.new(1, 0, 0, 70)
    TopBar.BackgroundColor3 = self.Themes.TopBar
    TopBar.BorderSizePixel = 0
    TopBar.Parent = MainFrame

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Name = "Title"
    TitleLabel.Size = UDim2.new(1, -30, 0, 30)
    TitleLabel.Position = UDim2.new(0, 15, 0, 5)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = title
    TitleLabel.TextColor3 = self.Themes.TextMuted
    TitleLabel.Font = Enum.Font.GothamSemibold
    TitleLabel.TextSize = 13
    TitleLabel.RichText = true
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    TitleLabel.Parent = TopBar
    
    -- Replace the first word with Accent color for Matcha feel
    local firstWord, rest = title:match("([^%s]+)(.*)")
    if firstWord then
        TitleLabel.Text = string.format("<font color='%s'>%s</font>%s", self.Math.Color.ToHex(self.Themes.Accent), firstWord, rest)
    end

    local TabContainer = Instance.new("Frame")
    TabContainer.Name = "TabContainer"
    TabContainer.Size = UDim2.new(1, -30, 0, 30)
    TabContainer.Position = UDim2.new(0, 15, 0, 35)
    TabContainer.BackgroundTransparency = 1
    TabContainer.Parent = TopBar
    
    local TabListLayout = Instance.new("UIListLayout")
    TabListLayout.FillDirection = Enum.FillDirection.Horizontal
    TabListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    TabListLayout.Padding = UDim.new(0, 15)
    TabListLayout.Parent = TabContainer

    local TopLine = Instance.new("Frame")
    TopLine.Size = UDim2.new(1, 0, 0, 1)
    TopLine.Position = UDim2.new(0, 0, 1, -1)
    TopLine.BackgroundColor3 = self.Themes.Border
    TopLine.BorderSizePixel = 0
    TopLine.Parent = TopBar

    -- ==========================================
    -- PAGE CONTAINER
    -- ==========================================
    local PageContainer = Instance.new("Frame")
    PageContainer.Name = "PageContainer"
    PageContainer.Size = UDim2.new(1, -20, 1, -80)
    PageContainer.Position = UDim2.new(0, 10, 0, 75)
    PageContainer.BackgroundTransparency = 1
    PageContainer.Parent = MainFrame

    self:MakeDraggable(TopBar, MainFrame)

    self:SubscribeToTheme(function(theme)
        MainFrame.BackgroundColor3 = theme.Background
        MainStroke.Color = theme.Border
        TopBar.BackgroundColor3 = theme.TopBar
        TopLine.BackgroundColor3 = theme.Border
        if firstWord then
            TitleLabel.Text = string.format("<font color='%s'>%s</font>%s", self.Math.Color.ToHex(theme.Accent), firstWord, rest)
        end
    end)

    MainFrame.Size = UDim2.new(0, 0, 0, 0)
    self:Tween(MainFrame, {Size = size}, 0.5, Enum.EasingStyle.Quint)

    return {
        Core = self,
        GUI = ScreenGui,
        MainFrame = MainFrame,
        TopBar = TopBar, 
        TabContainer = TabContainer,
        PageContainer = PageContainer,
        Tabs = {},
        CurrentTab = nil
    }
end

table.freeze(Core.Easing)
table.freeze(Core.Math)

return Core
