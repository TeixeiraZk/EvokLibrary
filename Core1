-- Substitui a necessidade do TweenService para componentes ultra rápidos
Evok.Utility.Easing = {
    Linear = function(t) 
        return t 
    end,
    -- Quadratic
    QuadIn = function(t) 
        return t * t 
    end,
    QuadOut = function(t) 
        return t * (2 - t) 
    end,
    QuadInOut = function(t)
        if t < 0.5 then
            return 2 * t * t
        else
            return -1 + (4 - 2 * t) * t
        end
    end,
    -- Cubic
    CubicIn = function(t)
        return t * t * t
    end,
    CubicOut = function(t)
        t = t - 1
        return t * t * t + 1
    end,
    CubicInOut = function(t)
        if t < 0.5 then
            return 4 * t * t * t
        else
            t = t - 1
            return (t * t * t + 1) * 4 - 3
        end
    end,
    -- Quartic
    QuartIn = function(t)
        return t * t * t * t
    end,
    QuartOut = function(t)
        t = t - 1
        return 1 - (t * t * t * t)
    end,
    QuartInOut = function(t)
        if t < 0.5 then
            return 8 * t * t * t * t
        else
            t = t - 1
            return 1 - 8 * (t * t * t * t)
        end
    end,
    -- Quintic
    QuintIn = function(t)
        return t * t * t * t * t
    end,
    QuintOut = function(t)
        t = t - 1
        return 1 + (t * t * t * t * t)
    end,
    QuintInOut = function(t)
        if t < 0.5 then
            return 16 * t * t * t * t * t
        else
            t = t - 1
            return 1 + 16 * (t * t * t * t * t)
        end
    end,
    -- Sine
    SineIn = function(t)
        return 1 - math.cos(t * (math.pi / 2))
    end,
    SineOut = function(t)
        return math.sin(t * (math.pi / 2))
    end,
    SineInOut = function(t)
        return -0.5 * (math.cos(math.pi * t) - 1)
    end,
    -- Exponential
    ExpoIn = function(t)
        return t == 0 and 0 or math.pow(2, 10 * (t - 1))
    end,
    ExpoOut = function(t)
        return t == 1 and 1 or 1 - math.pow(2, -10 * t)
    end,
    ExpoInOut = function(t)
        if t == 0 then return 0 end
        if t == 1 then return 1 end
        if t < 0.5 then
            return 0.5 * math.pow(2, 10 * (2 * t - 1))
        else
            return 0.5 * (2 - math.pow(2, -10 * (2 * t - 1)))
        end
    end,
    -- Circular
    CircIn = function(t)
        return 1 - math.sqrt(1 - (t * t))
    end,
    CircOut = function(t)
        t = t - 1
        return math.sqrt(1 - (t * t))
    end,
    CircInOut = function(t)
        if t < 0.5 then
            return 0.5 * (1 - math.sqrt(1 - 4 * (t * t)))
        else
            t = 2 * t - 2
            return 0.5 * (math.sqrt(1 - (t * t)) + 1)
        end
    end,
    -- Elastic
    ElasticIn = function(t)
        if t == 0 then return 0 end
        if t == 1 then return 1 end
        local p = 0.3
        local s = p / 4
        t = t - 1
        return -(math.pow(2, 10 * t) * math.sin((t - s) * (2 * math.pi) / p))
    end,
    ElasticOut = function(t)
        if t == 0 then return 0 end
        if t == 1 then return 1 end
        local p = 0.3
        local s = p / 4
        return math.pow(2, -10 * t) * math.sin((t - s) * (2 * math.pi) / p) + 1
    end,
    -- Back
    BackIn = function(t)
        local s = 1.70158
        return t * t * ((s + 1) * t - s)
    end,
    BackOut = function(t)
        local s = 1.70158
        t = t - 1
        return (t * t * ((s + 1) * t + s) + 1)
    end,
    -- Bounce
    BounceOut = function(t)
        if t < (1 / 2.75) then
            return 7.5625 * t * t
        elseif t < (2 / 2.75) then
            t = t - (1.5 / 2.75)
            return 7.5625 * t * t + 0.75
        elseif t < (2.5 / 2.75) then
            t = t - (2.25 / 2.75)
            return 7.5625 * t * t + 0.9375
        else
            t = t - (2.625 / 2.75)
            return 7.5625 * t * t + 0.984375
        end
    end
}

-- [ COLOR UTILITIES ] --
function Evok.Utility.Color:ToHex(color3)
    local r = math.round(color3.R * 255)
    local g = math.round(color3.G * 255)
    local b = math.round(color3.B * 255)
    return string.format("#%02X%02X%02X", r, g, b)
end

function Evok.Utility.Color:FromHex(hex)
    hex = hex:gsub("#", "")
    if #hex == 3 then
        hex = hex:sub(1,1)..hex:sub(1,1)..hex:sub(2,2)..hex:sub(2,2)..hex:sub(3,3)..hex:sub(3,3)
    end
    return Color3.fromRGB(
        tonumber("0x" .. hex:sub(1, 2)),
        tonumber("0x" .. hex:sub(3, 4)),
        tonumber("0x" .. hex:sub(5, 6))
    )
end

function Evok.Utility.Color:ToHSV(color3)
    return Color3.toHSV(color3)
end

function Evok.Utility.Color:FromHSV(h, s, v)
    return Color3.fromHSV(h, s, v)
end

function Evok.Utility.Color:ShiftHue(color3, amount)
    local h, s, v = Color3.toHSV(color3)
    h = (h + amount) % 1
    return Color3.fromHSV(h, s, v)
end

function Evok.Utility.Color:Darken(color3, amount)
    local h, s, v = Color3.toHSV(color3)
    v = math.clamp(v - amount, 0, 1)
    return Color3.fromHSV(h, s, v)
end

function Evok.Utility.Color:Lighten(color3, amount)
    local h, s, v = Color3.toHSV(color3)
    v = math.clamp(v + amount, 0, 1)
    return Color3.fromHSV(h, s, v)
end

-- [ INSTANCE BUILDER ] --
function Evok.Utility.Instance:Create(className, properties, children)
    local inst = Instance.new(className)
    
    for propName, propValue in pairs(properties or {}) do
        if propName ~= "Parent" then
            inst[propName] = propValue
        end
    end
    
    for _, child in ipairs(children or {}) do
        if typeof(child) == "Instance" then
            child.Parent = inst
        end
    end
    
    if properties and properties.Parent then
        inst.Parent = properties.Parent
    end
    
    table.insert(Evok.Instances, inst)
    return inst
end

function Evok.Utility.Instance:CreateRound(radius)
    return Evok.Utility.Instance:Create("UICorner", {
        CornerRadius = UDim.new(0, radius or 6)
    })
end

function Evok.Utility.Instance:CreateStroke(color, thickness, mode)
    return Evok.Utility.Instance:Create("UIStroke", {
        Color = color or Color3.new(1, 1, 1),
        Thickness = thickness or 1,
        ApplyStrokeMode = mode or Enum.ApplyStrokeMode.Border
    })
end

