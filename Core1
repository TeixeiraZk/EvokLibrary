function Evok.ThemeManager:GetColor(colorName)
    local theme = self.Themes[self.CurrentTheme]
    if theme and theme[colorName] then
        return theme[colorName]
    end
    -- Fallback default
    return Color3.new(1, 1, 1)
end

function Evok.ThemeManager:SetTheme(themeName)
    if self.Themes[themeName] then
        self.CurrentTheme = themeName
        -- Em futuras partes, aqui haverá um fire() para atualizar toda a UI real-time
    end
end

function Evok.ThemeManager:GetAllThemes()
    local list = {}
    for name, _ in pairs(self.Themes) do
        table.insert(list, name)
    end
    return list
end

