    -- Lifetime handler
    task.delay(Duration, function()
        local tweenOut = TweenService:Create(NotifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Sine, Enum.EasingDirection.In), {BackgroundTransparency = 1, Size = UDim2.new(0, 320, 0, 0)})
        tweenOut:Play()
        tweenOut.Completed:Wait()
        NotifFrame:Destroy()
    end)
end

-- ============================================================================
-- 11. MAIN WINDOW CONSTRUCTOR (The Interface Core)
-- ============================================================================
function Evok:CreateWindow(Config)
    local Window = {
        Title = Config.Title or "Evok - <3 ZynnReal",
        Size = Config.Size or UDim2.new(0, 550, 0, 800),
        Dragging = false,
        Elements = {},
        Tabs = {}
    }

    -- Safety Check
    local existing = CoreGui:FindFirstChild("Evok_Main_UI")
    if existing then existing:Destroy() end

    -- Create ScreenGui
    local MainGui = Evok.Utility.Instance:Create("ScreenGui", {
        Name = "Evok_Main_UI",
        Parent = CoreGui,
        ZIndexBehavior = Enum.ZIndexBehavior.Global,
        ResetOnSpawn = false,
        IgnoreGuiInset = true
    })
    Window.Gui = MainGui

    -- Create Root Frame
    local RootFrame = Evok.Utility.Instance:Create("Frame", {
        Name = "Root",
        Parent = MainGui,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(0, 0, 0, 0), -- Starts at 0 for animation
        BackgroundColor3 = self.ThemeManager:GetColor("Background"),
        BorderSizePixel = 0,
        ClipsDescendants = true
    })
    Window.Root = RootFrame

    Evok.Utility.Instance:CreateRound(8).Parent = RootFrame
    Evok.Utility.Instance:CreateStroke(self.ThemeManager:GetColor("Border"), 1.5).Parent = RootFrame

    -- [ TOP HEADER ]
    local Header = Evok.Utility.Instance:Create("Frame", {
        Name = "Header",
        Parent = RootFrame,
        Size = UDim2.new(1, 0, 0, 45),
        BackgroundColor3 = self.ThemeManager:GetColor("Container"),
        BorderSizePixel = 0
    })
    
    Evok.Utility.Instance:CreateRound(8).Parent = Header
    
    -- Bottom corner fix for header
    Evok.Utility.Instance:Create("Frame", {
        Name = "CornerBlocker",
        Parent = Header,
        Size = UDim2.new(1, 0, 0, 10),
        Position = UDim2.new(0, 0, 1, -10),
        BackgroundColor3 = self.ThemeManager:GetColor("Container"),
        BorderSizePixel = 0
    })

    local Separator = Evok.Utility.Instance:Create("Frame", {
        Name = "NeonSeparator",
        Parent = Header,
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = self.ThemeManager:GetColor("Accent"),
        BorderSizePixel = 0,
        BackgroundTransparency = 0.2
    })

    local TitleText = Evok.Utility.Instance:Create("TextLabel", {
        Name = "Title",
        Parent = Header,
        Size = UDim2.new(1, -50, 1, 0),
        Position = UDim2.new(0, 15, 0, 0),
        BackgroundTransparency = 1,
        Text = Window.Title,
        TextColor3 = self.ThemeManager:GetColor("Text"),
        Font = self.Fonts.Title,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
        RichText = true
    })

    -- [ SMOOTH DRAG LOGIC ]
    local dragInput, dragStart, startPos
    
    local function updateDrag(input)
        local delta = input.Position - dragStart
        local targetPos = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X, 
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
        TweenService:Create(RootFrame, TweenInfo.new(0.15, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {Position = targetPos}):Play()
    end

    Header.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            Window.Dragging = true
            dragStart = input.Position
            startPos = RootFrame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    Window.Dragging = false
                end
            end)
        end
    end)

    Header.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)

    local dragConn = UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and Window.Dragging then
            updateDrag(input)
        end
    end)
    table.insert(self.Connections, dragConn)

    -- [ CONTAINER NAVIGATION (TABS) ]
    local NavigationContainer = Evok.Utility.Instance:Create("ScrollingFrame", {
        Name = "Navigation",
        Parent = RootFrame,
        Size = UDim2.new(1, -20, 0, 35),
        Position = UDim2.new(0, 10, 0, 55),
        BackgroundTransparency = 1,
        ScrollBarThickness = 0,
        ScrollingDirection = Enum.ScrollingDirection.X
    })
    Window.Navigation = NavigationContainer

    local NavLayout = Evok.Utility.Instance:Create("UIListLayout", {
        Parent = NavigationContainer,
        FillDirection = Enum.FillDirection.Horizontal,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 5)
    })

    -- [ PAGES CONTAINER ]
    local PagesContainer = Evok.Utility.Instance:Create("Frame", {
        Name = "Pages",
        Parent = RootFrame,
        Size = UDim2.new(1, -20, 1, -100),
        Position = UDim2.new(0, 10, 0, 95),
        BackgroundTransparency = 1
    })
    Window.Pages = PagesContainer

    -- Boot Animation
    local openTween = TweenService:Create(RootFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = Window.Size})
    openTween:Play()
    openTween.Completed:Connect(function()
        RootFrame.ClipsDescendants = false -- Libera para Dropdowns vazarem
    end)

    return Window
end

return Evok

