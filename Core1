-- 8. GARBAGE COLLECTION & CLEANUP SYSTEM
-- ============================================================================
function Evok:DisconnectAll()
    Evok.Logger:Log("Disconnecting all event connections...", "INFO")
    for _, conn in pairs(self.Connections) do
        if typeof(conn) == "RBXScriptConnection" and conn.Connected then
            conn:Disconnect()
        end
    end
    self.Connections = {}
end

function Evok:DestroyInstances()
    Evok.Logger:Log("Destroying all UI instances...", "INFO")
    for _, inst in pairs(self.Instances) do
        if typeof(inst) == "Instance" and inst.Parent then
            inst:Destroy()
        end
    end
    self.Instances = {}
end

function Evok:Unload()
    self:DisconnectAll()
    self:DestroyInstances()
    self.IsRunning = false
    Evok.Logger:Log("Evok Framework successfully unloaded.", "INFO")
end

