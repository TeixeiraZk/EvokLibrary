-- [ MATH UTILITIES ] --
function Evok.Utility.Math:Lerp(startValue, endValue, alpha)
    return startValue + (endValue - startValue) * alpha
end

function Evok.Utility.Math:Clamp(value, minimum, maximum)
    return math.max(minimum, math.min(maximum, value))
end

function Evok.Utility.Math:Round(number, decimals)
    local multiplier = 10 ^ (decimals or 0)
    return math.floor(number * multiplier + 0.5) / multiplier
end

function Evok.Utility.Math:Map(value, inMin, inMax, outMin, outMax)
    return outMin + (outMax - outMin) * ((value - inMin) / (inMax - inMin))
end

function Evok.Utility.Math:RandomFloat(min, max)
    return min + math.random() * (max - min)
end

