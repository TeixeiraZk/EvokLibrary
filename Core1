function Evok:CreateWatermark(customText)
    local WatermarkObj = {
        Visible = true
    }

    local Screen = Evok.Utility.Instance:Create("ScreenGui", {
        Name = "Evok_Watermark_Layer",
        Parent = CoreGui,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        IgnoreGuiInset = true,
        ResetOnSpawn = false
    })

    local MainContainer = Evok.Utility.Instance:Create("Frame", {
        Name = "MainContainer",
        Parent = Screen,
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, -20, 0, 20),
        Size = UDim2.new(0, 0, 0, 32),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundColor3 = self.ThemeManager:GetColor("Background"),
        BorderSizePixel = 0
    })

    Evok.Utility.Instance:CreateRound(6).Parent = MainContainer
    Evok.Utility.Instance:CreateStroke(self.ThemeManager:GetColor("Border"), 1).Parent = MainContainer

    Evok.Utility.Instance:Create("UIPadding", {
        Parent = MainContainer,
        PaddingLeft = UDim.new(0, 12),
        PaddingRight = UDim.new(0, 12),
        PaddingTop = UDim.new(0, 0),
        PaddingBottom = UDim.new(0, 0)
    })

    local TopLine = Evok.Utility.Instance:Create("Frame", {
        Name = "TopLineHighlight",
        Parent = MainContainer,
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = self.ThemeManager:GetColor("Accent"),
        BorderSizePixel = 0
    })
    
    Evok.Utility.Instance:CreateRound(2).Parent = TopLine

    local TextLabel = Evok.Utility.Instance:Create("TextLabel", {
        Name = "WatermarkText",
        Parent = MainContainer,
        BackgroundTransparency = 1,
        Size = UDim2.new(0, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        Font = self.Fonts.Semibold,
        Text = customText or "Evok | Initializing...",
        TextColor3 = self.ThemeManager:GetColor("Text"),
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Center,
        TextYAlignment = Enum.TextYAlignment.Center,
        RichText = true
    })

    local LastUpdate = tick()
    local FrameCount = 0

    local renderConn = RunService.RenderStepped:Connect(function()
        FrameCount = FrameCount + 1
        local CurrentTime = tick()
        
        if CurrentTime - LastUpdate >= 1 then
            local fps = math.floor(FrameCount / (CurrentTime - LastUpdate))
            local memory = math.floor(Stats:GetTotalMemoryUsageMb())
            
            -- Ping is generally faked or grabbed via Stats in executors
            local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValueString():match("%d+")) or 0
            
            TextLabel.Text = string.format(
                "<font color='%s'>Evok</font> | %s FPS | %sms | %s MB", 
                Evok.Utility.Color:ToHex(Evok.ThemeManager:GetColor("Accent")),
                tostring(fps),
                tostring(ping),
                tostring(memory)
            )
            
            LastUpdate = CurrentTime
            FrameCount = 0
        end
    end)
    table.insert(self.Connections, renderConn)

    function WatermarkObj:SetVisible(state)
        self.Visible = state
        MainContainer.Visible = state
    end

    return WatermarkObj
end

