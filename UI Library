function Evok:Notify(title, text, time)
	local Notif = Instance.new("Frame", NotifyContainer)
	Notif.Size = UDim2.new(1, 0, 0, 70)
	Notif.BackgroundColor3 = Theme.Container
	Notif.BackgroundTransparency = 1
	Instance.new("UICorner", Notif).CornerRadius = UDim.new(0, 6)
	local Stroke = Instance.new("UIStroke", Notif)
	Stroke.Color = Theme.Accent
	Stroke.Transparency = 1
	
	local NTitle = Instance.new("TextLabel", Notif)
	NTitle.Size = UDim2.new(1, -20, 0, 25)
	NTitle.Position = UDim2.new(0, 10, 0, 5)
	NTitle.BackgroundTransparency = 1
	NTitle.Text = title
	NTitle.TextColor3 = Theme.Accent
	NTitle.Font = Enum.Font.GothamBold
	NTitle.TextSize = 14
	NTitle.TextXAlignment = Enum.TextXAlignment.Left
	NTitle.TextTransparency = 1

	local NText = Instance.new("TextLabel", Notif)
	NText.Size = UDim2.new(1, -20, 0, 30)
	NText.Position = UDim2.new(0, 10, 0, 30)
	NText.BackgroundTransparency = 1
	NText.Text = text
	NText.TextColor3 = Theme.TextMuted
	NText.Font = Enum.Font.Gotham
	NText.TextSize = 13
	NText.TextXAlignment = Enum.TextXAlignment.Left
	NText.TextWrapped = true
	NText.TextTransparency = 1

	Utils:Tween(Notif, {BackgroundTransparency = 0})
	Utils:Tween(Stroke, {Transparency = 0.5})
	Utils:Tween(NTitle, {TextTransparency = 0})
	Utils:Tween(NText, {TextTransparency = 0})

	task.delay(time or 3, function()
		Utils:Tween(Notif, {BackgroundTransparency = 1})
		Utils:Tween(Stroke, {Transparency = 1})
		Utils:Tween(NTitle, {TextTransparency = 1})
		Utils:Tween(NText, {TextTransparency = 1}).Completed:Connect(function() Notif:Destroy() end)
	end)
end

