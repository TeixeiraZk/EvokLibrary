-- ==========================================
-- 2. FUNÇÕES UTILITÁRIAS (ENGINE)
-- ==========================================
local Utility = {}

function Utility:Create(class, properties)
    local instance = Instance.new(class)
    for i, v in pairs(properties) do
        if i ~= "Parent" then instance[i] = v end
    end
    if properties.Parent then instance.Parent = properties.Parent end
    return instance
end

function Utility:MakeDraggable(Frame, Handle)
    local dragging, dragInput, dragStart, startPos
    Handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = Frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    Handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

function Utility:GetTextBounds(text, font, size)
    return TextService:GetTextSize(text, size, font, Vector2.new(10000, 10000))
end

-- ==========================================
-- 3. CRIAÇÃO DA JANELA PRINCIPAL
-- ==========================================
function Evok:Window(config)
    local WindowName = config.Name or "Evok Ultimate"
    local WindowSize = config.Size or UDim2.new(0, 650, 0, 500)

    -- Fundo Principal
    local Main = Utility:Create("Frame", {
        Size = WindowSize,
        Position = UDim2.new(0.5, -WindowSize.X.Offset/2, 0.5, -WindowSize.Y.Offset/2),
        BackgroundColor3 = self.Theme.BackgroundColor,
        BorderSizePixel = 1,
        BorderColor3 = self.Theme.OutlineColor,
        Parent = EvokGui
    })

    local InnerBorder = Utility:Create("UIStroke", {
        Color = self.Theme.WindowBorder,
        Thickness = 1,
        LineJoinMode = Enum.LineJoinMode.Miter,
        Parent = Main
    })

    -- Header (Título no estilo da sua imagem)
    local Header = Utility:Create("Frame", {
        Size = UDim2.new(1, 0, 0, 25),
        BackgroundColor3 = self.Theme.BackgroundColor,
        BorderSizePixel = 0,
        Parent = Main
    })
    Utility:MakeDraggable(Main, Header)

    local TitleLabel = Utility:Create("TextLabel", {
        Size = UDim2.new(1, -10, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = WindowName,
        TextColor3 = self.Theme.TextColor,
        Font = Enum.Font.Code, -- Fonte mais "hacker" estilo a imagem
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        RichText = true,
        Parent = Header
    })

    -- Container de Abas (Tabs)
    local TabContainer = Utility:Create("Frame", {
        Size = UDim2.new(1, 0, 0, 30),
        Position = UDim2.new(0, 0, 0, 25),
        BackgroundColor3 = self.Theme.TabBackground,
        BorderSizePixel = 1,
        BorderColor3 = self.Theme.WindowBorder,
        Parent = Main
    })

    local TabList = Utility:Create("UIListLayout", {
        FillDirection = Enum.FillDirection.Horizontal,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = TabContainer
    })

    -- Área onde as colunas vão ficar
    local ContentContainer = Utility:Create("Frame", {
        Size = UDim2.new(1, -20, 1, -65),
        Position = UDim2.new(0, 10, 0, 60),
        BackgroundTransparency = 1,
        Parent = Main
    })

    local WindowLogic = {
        CurrentTab = nil
    }

    -- ==========================================
    -- 4. SISTEMA DE ABAS (TABS)
    -- ==========================================
    function WindowLogic:Tab(nome)
        local TabSize = Utility:GetTextBounds(nome, Enum.Font.Code, 13).X + 20

        local TabBtn = Utility:Create("TextButton", {
            Size = UDim2.new(0, TabSize, 1, 0),
            BackgroundTransparency = 1,
            Text = nome,
            TextColor3 = Evok.Theme.TextMuted,
            Font = Enum.Font.Code,
            TextSize = 13,
            Parent = TabContainer
        })

        local TabLine = Utility:Create("Frame", {
            Size = UDim2.new(1, 0, 0, 2),
            Position = UDim2.new(0, 0, 1, -2),
            BackgroundColor3 = Evok.Theme.AccentColor,
            BorderSizePixel = 0,
            Visible = false,
            Parent = TabBtn
        })

        local TabContent = Utility:Create("Frame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            Visible = false,
            Parent = ContentContainer
        })

        -- Layout de Colunas (Esquerda e Direita) idêntico à sua foto
        local LeftColumn = Utility:Create("ScrollingFrame", {
            Size = UDim2.new(0.5, -5, 1, 0),
            Position = UDim2.new(0, 0, 0, 0),
            BackgroundTransparency = 1,
            ScrollBarThickness = 0,
            Parent = TabContent
        })
        local RightColumn = Utility:Create("ScrollingFrame", {
            Size = UDim2.new(0.5, -5, 1, 0),
            Position = UDim2.new(0.5, 5, 0, 0),
            BackgroundTransparency = 1,
            ScrollBarThickness = 0,
            Parent = TabContent
        })

        Utility:Create("UIListLayout", {Padding = UDim.new(0, 10), Parent = LeftColumn})
        Utility:Create("UIListLayout", {Padding = UDim.new(0, 10), Parent = RightColumn})

        TabBtn.MouseButton1Click:Connect(function()
            if WindowLogic.CurrentTab == TabBtn then return end
            if WindowLogic.CurrentTab then
                WindowLogic.CurrentTab.TextColor3 = Evok.Theme.TextMuted
                WindowLogic.CurrentTab.Frame.Visible = false
                ContentContainer[WindowLogic.CurrentTab.Name .. "_Content"].Visible = false
            end
            WindowLogic.CurrentTab = TabBtn
            TabBtn.TextColor3 = Evok.Theme.TextColor
            TabLine.Visible = true
            TabContent.Name = TabBtn.Name .. "_Content"
            TabContent.Visible = true
        end)

        if #TabContainer:GetChildren() == 2 then -- Ativa a primeira aba
            WindowLogic.CurrentTab = TabBtn
            TabBtn.TextColor3 = Evok.Theme.TextColor
            TabLine.Visible = true
            TabContent.Name = TabBtn.Name .. "_Content"
            TabContent.Visible = true
        end

        local TabLogic = {}

        -- ==========================================
        -- 5. CRIAÇÃO DE GROUPBOXES (SEÇÕES)
        -- ==========================================
        function TabLogic:Groupbox(config)
            local gbName = config.Name or "Groupbox"
            local gbSide = config.Side or "Left" -- Left ou Right
            
            local TargetColumn = gbSide == "Left" and LeftColumn or RightColumn

            local GroupboxFrame = Utility:Create("Frame", {
                Size = UDim2.new(1, 0, 0, 20), -- Altura auto-ajustável depois
                BackgroundColor3 = Evok.Theme.GroupboxBackground,
                BorderColor3 = Evok.Theme.OutlineColor,
                BorderSizePixel = 1,
                Parent = TargetColumn
            })

            local GroupInnerBorder = Utility:Create("UIStroke", {
                Color = Evok.Theme.GroupboxBorder,
                Thickness = 1,
                LineJoinMode = Enum.LineJoinMode.Miter,
                Parent = GroupboxFrame
            })

            local GroupTitle = Utility:Create("TextLabel", {
                Size = UDim2.new(1, -10, 0, 20),
                Position = UDim2.new(0, 10, 0, -10),
                BackgroundColor3 = Evok.Theme.BackgroundColor, -- Fundo para "cortar" a linha
                Text = " " .. gbName .. " ",
                TextColor3 = Evok.Theme.TextColor,
                Font = Enum.Font.Code,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = GroupboxFrame
            })
            GroupTitle.Size = UDim2.new(0, Utility:GetTextBounds(GroupTitle.Text, Enum.Font.Code, 13).X, 0, 20)

            local GroupContainer = Utility:Create("Frame", {
                Size = UDim2.new(1, -16, 1, -20),
                Position = UDim2.new(0, 8, 0, 15),
                BackgroundTransparency = 1,
                Parent = GroupboxFrame
            })

            local GroupLayout = Utility:Create("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding = UDim.new(0, 5),
                Parent = GroupContainer
            })

            -- Auto-ajusta o tamanho do Groupbox com base nos elementos dentro
            GroupLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                GroupboxFrame.Size = UDim2.new(1, 0, 0, GroupLayout.AbsoluteContentSize.Y + 25)
                TargetColumn.CanvasSize = UDim2.new(0, 0, 0, TargetColumn.UIListLayout.AbsoluteContentSize.Y + 10)
            end)

            local Elements = {}
            
            -- [A PARTE 2 ENTRARÁ AQUI DENTRO (TOGGLES, SLIDERS INLINE)]

            return Elements
        end

        return TabLogic
    end

    return WindowLogic
end

return Evok
