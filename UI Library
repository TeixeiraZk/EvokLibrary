function Evok:Notify(config)
	local title = config.Title or "Evok Info"
	local content = config.Content or ""
	local duration = config.Duration or 5
	local type = config.Type or "Info" -- Info, Warning, Error

	local NotifColor = Theme.Accent
	if type == "Warning" then NotifColor = Color3.fromRGB(255, 170, 0)
	elseif type == "Error" then NotifColor = Theme.Risk end

	local Notif = Instance.new("Frame", NotifyContainer)
	Notif.Size = UDim2.new(1, 0, 0, 75)
	Notif.BackgroundColor3 = Theme.Container
	Notif.BackgroundTransparency = 1
	Instance.new("UICorner", Notif).CornerRadius = UDim.new(0, 6)
	
	local NStroke = Instance.new("UIStroke", Notif)
	NStroke.Color = NotifColor
	NStroke.Thickness = 1
	NStroke.Transparency = 1

	local NTitle = Instance.new("TextLabel", Notif)
	NTitle.Size = UDim2.new(1, -30, 0, 25)
	NTitle.Position = UDim2.new(0, 15, 0, 10)
	NTitle.BackgroundTransparency = 1
	NTitle.Text = title
	NTitle.TextColor3 = NotifColor
	NTitle.Font = Enum.Font.GothamBold
	NTitle.TextSize = 14
	NTitle.TextXAlignment = Enum.TextXAlignment.Left
	NTitle.TextTransparency = 1

	local NDesc = Instance.new("TextLabel", Notif)
	NDesc.Size = UDim2.new(1, -30, 0, 30)
	NDesc.Position = UDim2.new(0, 15, 0, 35)
	NDesc.BackgroundTransparency = 1
	NDesc.Text = content
	NDesc.TextColor3 = Theme.TextMuted
	NDesc.Font = Enum.Font.Gotham
	NDesc.TextSize = 13
	NDesc.TextXAlignment = Enum.TextXAlignment.Left
	NDesc.TextWrapped = true
	NDesc.TextTransparency = 1

	Utility:Tween(Notif, {BackgroundTransparency = 0})
	Utility:Tween(NStroke, {Transparency = 0.5})
	Utility:Tween(NTitle, {TextTransparency = 0})
	Utility:Tween(NDesc, {TextTransparency = 0})

	task.delay(duration, function()
		Utility:Tween(Notif, {BackgroundTransparency = 1})
		Utility:Tween(NStroke, {Transparency = 1})
		Utility:Tween(NTitle, {TextTransparency = 1})
		local fade = Utility:Tween(NDesc, {TextTransparency = 1})
		fade.Completed:Connect(function() Notif:Destroy() end)
	end)
end

function Evok:SetWatermark(text)
	if not EvokGui:FindFirstChild("Watermark") then
		local WM = Instance.new("Frame", EvokGui)
		WM.Name = "Watermark"
		WM.Size = UDim2.new(0, 200, 0, 30)
		WM.Position = UDim2.new(0, 20, 0, 20)
		WM.BackgroundColor3 = Theme.Container
		Instance.new("UICorner", WM).CornerRadius = UDim.new(0, 6)
		Instance.new("UIStroke", WM).Color = Theme.Accent

		local WMText = Instance.new("TextLabel", WM)
		WMText.Name = "Label"
		WMText.Size = UDim2.new(1, -20, 1, 0)
		WMText.Position = UDim2.new(0, 10, 0, 0)
		WMText.BackgroundTransparency = 1
		WMText.TextColor3 = Theme.Text
		WMText.Font = Enum.Font.GothamMedium
		WMText.TextSize = 13
		WMText.TextXAlignment = Enum.TextXAlignment.Left
	end
	
	local lbl = EvokGui.Watermark.Label
	lbl.Text = text
	local bounds = TextService:GetTextSize(text, 13, Enum.Font.GothamMedium, Vector2.new(1000, 30))
	EvokGui.Watermark.Size = UDim2.new(0, bounds.X + 20, 0, 30)
end

