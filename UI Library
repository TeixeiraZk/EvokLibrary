--[[
    E V O K   U I   L I B R A R Y
    V4.1 - MATCHA AESTHETIC CLONE
    CORREÇÃO DE AUTO-SIZE E ELEMENTOS VISUAIS
]]--

local Evok = {
    Theme = {
        Background = Color3.fromRGB(15, 15, 15),
        GroupboxBg = Color3.fromRGB(20, 20, 20),
        Border = Color3.fromRGB(35, 35, 35),
        Accent = Color3.fromRGB(245, 160, 200), -- Rosa Matcha
        Text = Color3.fromRGB(255, 255, 255),
        TextMuted = Color3.fromRGB(130, 130, 130),
        ElementBg = Color3.fromRGB(25, 25, 25),
        Thumb = Color3.fromRGB(255, 255, 255) -- Bolinha branca do slider
    }
}

local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local TextService = game:GetService("TextService")

local function GetGuiParent()
    if gethui then return gethui() end
    local s, r = pcall(function() return CoreGui end)
    if s and r then return r end
    return game.Players.LocalPlayer:WaitForChild("PlayerGui")
end

local EvokGui = Instance.new("ScreenGui")
EvokGui.Name = "EvokUI_" .. tostring(math.random(1000, 9999))
EvokGui.ResetOnSpawn = false
EvokGui.Parent = GetGuiParent()

local function Tween(obj, props, time)
    local tw = TweenService:Create(obj, TweenInfo.new(time or 0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props)
    tw:Play(); return tw
end

local function MakeDraggable(Frame, Handle)
    local dragging, dragStart, startPos
    Handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = Frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
            local delta = input.Position - dragStart
            Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

function Evok:Window(config)
    local Main = Instance.new("Frame", EvokGui)
    Main.Size = UDim2.new(0, 800, 0, 550) -- TAMANHO EXATO PEDIDO
    Main.Position = UDim2.new(0.5, -400, 0.5, -275)
    Main.BackgroundColor3 = self.Theme.Background
    Main.BorderColor3 = self.Theme.Border
    Main.BorderSizePixel = 1

    local Header = Instance.new("Frame", Main)
    Header.Size = UDim2.new(1, 0, 0, 25)
    Header.BackgroundColor3 = self.Theme.Background
    Header.BorderSizePixel = 0
    MakeDraggable(Main, Header)

    local Title = Instance.new("TextLabel", Header)
    Title.Size = UDim2.new(1, -10, 1, 0)
    Title.Position = UDim2.new(0, 10, 0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = config.Name or "Evok"
    Title.TextColor3 = self.Theme.Accent
    Title.Font = Enum.Font.Code
    Title.TextSize = 13
    Title.TextXAlignment = Enum.TextXAlignment.Left

    local TabBar = Instance.new("Frame", Main)
    TabBar.Size = UDim2.new(1, -20, 0, 25)
    TabBar.Position = UDim2.new(0, 10, 0, 25)
    TabBar.BackgroundTransparency = 1
    local TabList = Instance.new("UIListLayout", TabBar)
    TabList.FillDirection = Enum.FillDirection.Horizontal
    TabList.Padding = UDim.new(0, 15)

    local Content = Instance.new("Frame", Main)
    Content.Size = UDim2.new(1, -20, 1, -60)
    Content.Position = UDim2.new(0, 10, 0, 55)
    Content.BackgroundTransparency = 1

    local WindowLogic = { CurrentTab = nil }

    function WindowLogic:Tab(nome)
        local TabBtn = Instance.new("TextButton", TabBar)
        TabBtn.Size = UDim2.new(0, TextService:GetTextSize(nome, 13, Enum.Font.Code, Vector2.new(1000, 25)).X, 1, 0)
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = nome
        TabBtn.TextColor3 = Evok.Theme.TextMuted
        TabBtn.Font = Enum.Font.Code
        TabBtn.TextSize = 13

        local TabFrame = Instance.new("Frame", Content)
        TabFrame.Size = UDim2.new(1, 0, 1, 0)
        TabFrame.BackgroundTransparency = 1
        TabFrame.Visible = false

        -- Colunas Modernas com AutoSize (Impede de esmagar)
        local LeftCol = Instance.new("ScrollingFrame", TabFrame)
        LeftCol.Size = UDim2.new(0.5, -5, 1, 0)
        LeftCol.BackgroundTransparency = 1
        LeftCol.ScrollBarThickness = 0
        LeftCol.AutomaticCanvasSize = Enum.AutomaticSize.Y

        local RightCol = Instance.new("ScrollingFrame", TabFrame)
        RightCol.Size = UDim2.new(0.5, -5, 1, 0)
        RightCol.Position = UDim2.new(0.5, 5, 0, 0)
        RightCol.BackgroundTransparency = 1
        RightCol.ScrollBarThickness = 0
        RightCol.AutomaticCanvasSize = Enum.AutomaticSize.Y

        Instance.new("UIListLayout", LeftCol).Padding = UDim.new(0, 10)
        Instance.new("UIListLayout", RightCol).Padding = UDim.new(0, 10)

        TabBtn.MouseButton1Click:Connect(function()
            if WindowLogic.CurrentTab == TabBtn then return end
            if WindowLogic.CurrentTab then
                WindowLogic.CurrentTab.TextColor3 = Evok.Theme.TextMuted
                Content[WindowLogic.CurrentTab.Name .. "_C"].Visible = false
            end
            WindowLogic.CurrentTab = TabBtn
            TabBtn.TextColor3 = Evok.Theme.Text
            TabFrame.Name = TabBtn.Name .. "_C"
            TabFrame.Visible = true
        end)

        if #TabBar:GetChildren() == 2 then
            WindowLogic.CurrentTab = TabBtn
            TabBtn.TextColor3 = Evok.Theme.Text
            TabFrame.Name = TabBtn.Name .. "_C"
            TabFrame.Visible = true
        end

        local TabLogic = {}

        function TabLogic:Groupbox(config)
            local Col = config.Side == "Right" and RightCol or LeftCol

            local GB = Instance.new("Frame", Col)
            GB.Size = UDim2.new(1, 0, 0, 0)
            GB.AutomaticSize = Enum.AutomaticSize.Y -- MAGIA QUE IMPEDE DE ESMAGAR
            GB.BackgroundColor3 = Evok.Theme.GroupboxBg
            GB.BorderColor3 = Evok.Theme.Border
            GB.BorderSizePixel = 1

            local TitleLabel = Instance.new("TextLabel", GB)
            TitleLabel.Size = UDim2.new(0, TextService:GetTextSize(" " .. config.Name .. " ", 12, Enum.Font.Code, Vector2.new(1000, 15)).X, 0, 15)
            TitleLabel.Position = UDim2.new(0, 10, 0, -8) -- Corta a borda superior
            TitleLabel.BackgroundColor3 = Evok.Theme.Background -- Esconde a linha
            TitleLabel.Text = " " .. config.Name .. " "
            TitleLabel.TextColor3 = Evok.Theme.Text
            TitleLabel.Font = Enum.Font.Code
            TitleLabel.TextSize = 12
            TitleLabel.BorderSizePixel = 0

            local GBContainer = Instance.new("Frame", GB)
            GBContainer.Size = UDim2.new(1, -16, 0, 0)
            GBContainer.Position = UDim2.new(0, 8, 0, 15)
            GBContainer.BackgroundTransparency = 1
            GBContainer.AutomaticSize = Enum.AutomaticSize.Y

            local GBLayout = Instance.new("UIListLayout", GBContainer)
            GBLayout.Padding = UDim.new(0, 8)

            -- Padding invisível no fundo pro groupbox respirar
            local Spacer = Instance.new("Frame", GBContainer)
            Spacer.Size = UDim2.new(1, 0, 0, 4)
            Spacer.BackgroundTransparency = 1
            Spacer.LayoutOrder = 999

            local Elements = {}

            -- ==========================================
            -- TOGGLE (BOLINHA)
            -- ==========================================
            function Elements:Toggle(cfg)
                local state = cfg.Default or false

                local Tgl = Instance.new("TextButton", GBContainer)
                Tgl.Size = UDim2.new(1, 0, 0, 16)
                Tgl.BackgroundTransparency = 1
                Tgl.Text = ""

                local Circle = Instance.new("Frame", Tgl)
                Circle.Size = UDim2.new(0, 14, 0, 14)
                Circle.Position = UDim2.new(0, 0, 0.5, -7)
                Circle.BackgroundColor3 = state and Evok.Theme.Accent or Evok.Theme.GroupboxBg
                Circle.BorderColor3 = Evok.Theme.Border
                Circle.BorderSizePixel = 1
                Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

                local Lbl = Instance.new("TextLabel", Tgl)
                Lbl.Size = UDim2.new(1, -22, 1, 0)
                Lbl.Position = UDim2.new(0, 22, 0, 0)
                Lbl.BackgroundTransparency = 1
                Lbl.Text = cfg.Name
                Lbl.TextColor3 = state and Evok.Theme.Text or Evok.Theme.TextMuted
                Lbl.Font = Enum.Font.Code
                Lbl.TextSize = 12
                Lbl.TextXAlignment = Enum.TextXAlignment.Left

                Tgl.MouseButton1Click:Connect(function()
                    state = not state
                    Tween(Circle, {BackgroundColor3 = state and Evok.Theme.Accent or Evok.Theme.GroupboxBg})
                    Tween(Lbl, {TextColor3 = state and Evok.Theme.Text or Evok.Theme.TextMuted})
                    if cfg.Callback then cfg.Callback(state) end
                end)
            end

            -- ==========================================
            -- DROPDOWN
            -- ==========================================
            function Elements:Dropdown(cfg)
                local isOpen = false
                local selected = cfg.Default or cfg.Options[1] or ""

                local Drop = Instance.new("Frame", GBContainer)
                Drop.Size = UDim2.new(1, 0, 0, 36)
                Drop.BackgroundTransparency = 1

                local Lbl = Instance.new("TextLabel", Drop)
                Lbl.Size = UDim2.new(1, 0, 0, 14)
                Lbl.BackgroundTransparency = 1
                Lbl.Text = cfg.Name
                Lbl.TextColor3 = Evok.Theme.Text
                Lbl.Font = Enum.Font.Code
                Lbl.TextSize = 12
                Lbl.TextXAlignment = Enum.TextXAlignment.Left

                local Btn = Instance.new("TextButton", Drop)
                Btn.Size = UDim2.new(1, 0, 0, 20)
                Btn.Position = UDim2.new(0, 0, 0, 16)
                Btn.BackgroundColor3 = Evok.Theme.ElementBg
                Btn.BorderColor3 = Evok.Theme.Border
                Btn.Text = "  " .. selected
                Btn.TextColor3 = Evok.Theme.TextMuted
                Btn.Font = Enum.Font.Code
                Btn.TextSize = 12
                Btn.TextXAlignment = Enum.TextXAlignment.Left

                local Arrow = Instance.new("TextLabel", Btn)
                Arrow.Size = UDim2.new(0, 20, 1, 0)
                Arrow.Position = UDim2.new(1, -20, 0, 0)
                Arrow.BackgroundTransparency = 1
                Arrow.Text = "▼"
                Arrow.TextColor3 = Evok.Theme.TextMuted
                Arrow.Font = Enum.Font.Code
                Arrow.TextSize = 10
            end

            -- ==========================================
            -- SLIDER (COM NÚMERO DENTRO E BOLINHA BRANCA)
            -- ==========================================
            function Elements:Slider(cfg)
                local min, max, val = cfg.Min or 0, cfg.Max or 100, cfg.Default or 0

                local Sld = Instance.new("Frame", GBContainer)
                Sld.Size = UDim2.new(1, 0, 0, 32)
                Sld.BackgroundTransparency = 1

                local Lbl = Instance.new("TextLabel", Sld)
                Lbl.Size = UDim2.new(1, 0, 0, 14)
                Lbl.BackgroundTransparency = 1
                Lbl.Text = cfg.Name
                Lbl.TextColor3 = Evok.Theme.Text
                Lbl.Font = Enum.Font.Code
                Lbl.TextSize = 12
                Lbl.TextXAlignment = Enum.TextXAlignment.Left

                local Track = Instance.new("TextButton", Sld)
                Track.Size = UDim2.new(1, 0, 0, 14)
                Track.Position = UDim2.new(0, 0, 0, 18)
                Track.BackgroundColor3 = Evok.Theme.ElementBg
                Track.BorderColor3 = Evok.Theme.Border
                Track.Text = ""
                Track.AutoButtonColor = false

                local Fill = Instance.new("Frame", Track)
                Fill.Size = UDim2.new((val - min) / (max - min), 0, 1, 0)
                Fill.BackgroundColor3 = Evok.Theme.Accent
                Fill.BorderSizePixel = 0

                local Thumb = Instance.new("Frame", Fill)
                Thumb.Size = UDim2.new(0, 14, 0, 14)
                Thumb.Position = UDim2.new(1, -7, 0.5, -7)
                Thumb.BackgroundColor3 = Evok.Theme.Thumb
                Thumb.BorderSizePixel = 0
                Instance.new("UICorner", Thumb).CornerRadius = UDim.new(1, 0)

                local ValTxt = Instance.new("TextLabel", Track)
                ValTxt.Size = UDim2.new(1, 0, 1, 0)
                ValTxt.BackgroundTransparency = 1
                ValTxt.Text = string.format("%s/%s", tostring(val), tostring(max))
                ValTxt.TextColor3 = Evok.Theme.Text
                ValTxt.Font = Enum.Font.Code
                ValTxt.TextSize = 11

                local dragging = false
                local function update(input)
                    local pct = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    val = math.floor(min + ((max - min) * pct))
                    ValTxt.Text = string.format("%s/%s", tostring(val), tostring(max))
                    Tween(Fill, {Size = UDim2.new(pct, 0, 1, 0)})
                    if cfg.Callback then cfg.Callback(val) end
                end

                Track.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; update(input) end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update(input) end
                end)
            end

            return Elements
        end
        return TabLogic
    end
    return WindowLogic
end

return Evok
