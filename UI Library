	Title.TextSize = 16
	Title.TextXAlignment = Enum.TextXAlignment.Left

	-- Lógica de Esconder/Mostrar Menu (Keybind Global)
	UserInputService.InputBegan:Connect(function(input, proc)
		if not proc and input.KeyCode == EvokSettings.MenuBind then
			EvokSettings.Toggled = not EvokSettings.Toggled
			MainFrame.Visible = EvokSettings.Toggled
		end
	end)

	-- SISTEMA DE ABAS (ESQUERDA)
	local Sidebar = Instance.new("Frame", MainFrame)
	Sidebar.Size = UDim2.new(0, 160, 1, -46)
	Sidebar.Position = UDim2.new(0, 0, 0, 46)
	Sidebar.BackgroundColor3 = Theme.Container
	Sidebar.BorderSizePixel = 0

	local SidebarLine = Instance.new("Frame", Sidebar)
	SidebarLine.Size = UDim2.new(0, 1, 1, 0)
	SidebarLine.Position = UDim2.new(1, 0, 0, 0)
	SidebarLine.BackgroundColor3 = Theme.Outline
	SidebarLine.BorderSizePixel = 0

	local TabContainer = Instance.new("ScrollingFrame", Sidebar)
	TabContainer.Size = UDim2.new(1, 0, 1, -20)
	TabContainer.Position = UDim2.new(0, 0, 0, 10)
	TabContainer.BackgroundTransparency = 1
	TabContainer.ScrollBarThickness = 0
	
	local TabListLayout = Instance.new("UIListLayout", TabContainer)
	TabListLayout.SortOrder = Enum.SortOrder.LayoutOrder
	TabListLayout.Padding = UDim.new(0, 5)
	TabListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

	-- ÁREA DE CONTEÚDO (DIREITA)
	local ContentArea = Instance.new("Frame", MainFrame)
	ContentArea.Size = UDim2.new(1, -161, 1, -46)
	ContentArea.Position = UDim2.new(0, 161, 0, 46)
	ContentArea.BackgroundTransparency = 1

	local windowLogic = { CurrentTab = nil }

	-- ==========================================
	-- CONSTRUTOR DE ABAS
	-- ==========================================
	function windowLogic:CreateTab(tabName)
		local TabBtn = Instance.new("TextButton", TabContainer)
		TabBtn.Size = UDim2.new(1, -20, 0, 35)
		TabBtn.BackgroundColor3 = Theme.Element
		TabBtn.BackgroundTransparency = 1
		TabBtn.Text = "  " .. tabName
		TabBtn.TextColor3 = Theme.TextMuted
		TabBtn.Font = Enum.Font.GothamMedium
		TabBtn.TextSize = 14
		TabBtn.TextXAlignment = Enum.TextXAlignment.Left
		TabBtn.AutoButtonColor = false
		Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)

		local TabScroll = Instance.new("ScrollingFrame", ContentArea)
		TabScroll.Size = UDim2.new(1, -30, 1, -30)
		TabScroll.Position = UDim2.new(0, 15, 0, 15)
		TabScroll.BackgroundTransparency = 1
		TabScroll.ScrollBarThickness = 4
		TabScroll.ScrollBarImageColor3 = Theme.Accent
		TabScroll.Visible = false
		
		local ContentLayout = Instance.new("UIListLayout", TabScroll)
		ContentLayout.SortOrder = Enum.SortOrder.LayoutOrder
		ContentLayout.Padding = UDim.new(0, 10)

		TabBtn.MouseButton1Click:Connect(function()
			if windowLogic.CurrentTab == TabBtn then return end
			if windowLogic.CurrentTab then
				Utility:Tween(windowLogic.CurrentTab, {BackgroundTransparency = 1, TextColor3 = Theme.TextMuted})
				local oldContent = ContentArea:FindFirstChild(windowLogic.CurrentTab.Text:sub(3) .. "_Content")
				if oldContent then oldContent.Visible = false end
			end
			windowLogic.CurrentTab = TabBtn
			Utility:Tween(TabBtn, {BackgroundTransparency = 0, TextColor3 = Theme.Accent})
			TabScroll.Name = tabName .. "_Content"
			TabScroll.Visible = true
		end)

		if #TabContainer:GetChildren() == 2 then
			windowLogic.CurrentTab = TabBtn
			TabBtn.BackgroundTransparency = 0
			TabBtn.TextColor3 = Theme.Accent
			TabScroll.Name = tabName .. "_Content"
			TabScroll.Visible = true
		end

		local tabElements = {}

		-- Elemento: Seção
		function tabElements:CreateSection(nome)
			local Section = Instance.new("TextLabel", TabScroll)
			Section.Size = UDim2.new(1, 0, 0, 30)
			Section.BackgroundTransparency = 1
			Section.Text = nome
			Section.TextColor3 = Theme.Accent
			Section.Font = Enum.Font.GothamBold
			Section.TextSize = 13
			Section.TextXAlignment = Enum.TextXAlignment.Left
			
			local Line = Instance.new("Frame", Section)
			Line.Size = UDim2.new(1, 0, 0, 1)
			Line.Position = UDim2.new(0, 0, 1, -5)
			Line.BackgroundColor3 = Theme.Outline
			Line.BorderSizePixel = 0
		end

		-- Elemento: TextBox (Input de Texto)
		function tabElements:CreateInput(config)
			local text = config.Name or "Input"
			local placeholder = config.Placeholder or "Digite aqui..."
			local callback = config.Callback or function() end

			local InputFrame = Instance.new("Frame", TabScroll)
			InputFrame.Size = UDim2.new(1, -10, 0, 45)
			InputFrame.BackgroundColor3 = Theme.Element
			Instance.new("UICorner", InputFrame).CornerRadius = UDim.new(0, 6)
			Instance.new("UIStroke", InputFrame).Color = Theme.Outline

			local Title = Instance.new("TextLabel", InputFrame)
			Title.Size = UDim2.new(0.5, -20, 1, 0)
			Title.Position = UDim2.new(0, 15, 0, 0)
			Title.BackgroundTransparency = 1
			Title.Text = text
			Title.TextColor3 = Theme.Text
			Title.Font = Enum.Font.GothamMedium
			Title.TextSize = 14
			Title.TextXAlignment = Enum.TextXAlignment.Left

			local TextBox = Instance.new("TextBox", InputFrame)
			TextBox.Size = UDim2.new(0.5, -15, 0, 30)
			TextBox.Position = UDim2.new(0.5, 0, 0.5, -15)
			TextBox.BackgroundColor3 = Theme.Container
			TextBox.PlaceholderText = placeholder
			TextBox.Text = ""
			TextBox.TextColor3 = Theme.Text
			TextBox.Font = Enum.Font.Gotham
			TextBox.TextSize = 13
			TextBox.ClearTextOnFocus = false
			Instance.new("UICorner", TextBox).CornerRadius = UDim.new(0, 4)
			Instance.new("UIStroke", TextBox).Color = Theme.Outline

			TextBox.FocusLost:Connect(function()
				callback(TextBox.Text)
			end)
		end

		-- Elemento: Toggle
		function tabElements:CreateToggle(config)
			local text = config.Name or "Toggle"
			local toggled = config.Default or false
			local callback = config.Callback or function() end

			local TglBtn = Instance.new("TextButton", TabScroll)
			TglBtn.Size = UDim2.new(1, -10, 0, 45)
			TglBtn.BackgroundColor3 = Theme.Element
			TglBtn.Text = "   " .. text
			TglBtn.TextColor3 = Theme.Text
			TglBtn.Font = Enum.Font.GothamMedium
			TglBtn.TextSize = 14
			TglBtn.TextXAlignment = Enum.TextXAlignment.Left
			TglBtn.AutoButtonColor = false
			Instance.new("UICorner", TglBtn).CornerRadius = UDim.new(0, 6)
			Instance.new("UIStroke", TglBtn).Color = Theme.Outline

			local IndicatorBG = Instance.new("Frame", TglBtn)
			IndicatorBG.Size = UDim2.new(0, 40, 0, 20)
			IndicatorBG.Position = UDim2.new(1, -55, 0.5, -10)
			IndicatorBG.BackgroundColor3 = toggled and Theme.Accent or Theme.Background
			Instance.new("UICorner", IndicatorBG).CornerRadius = UDim.new(1, 0)
			local TglStroke = Instance.new("UIStroke", IndicatorBG)
			TglStroke.Color = Theme.Outline

			local Indicator = Instance.new("Frame", IndicatorBG)
			Indicator.Size = UDim2.new(0, 16, 0, 16)
			Indicator.Position = toggled and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
			Indicator.BackgroundColor3 = Theme.Text
			Instance.new("UICorner", Indicator).CornerRadius = UDim.new(1, 0)

			TglBtn.MouseButton1Click:Connect(function()
				toggled = not toggled
				Utility:Tween(IndicatorBG, {BackgroundColor3 = toggled and Theme.Accent or Theme.Background})
				Utility:Tween(Indicator, {Position = toggled and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)})
				callback(toggled)
			end)
			if toggled then callback(toggled) end
		end

		-- Elemento: ColorPicker (BÁSICO, POIS É COMPLEXO)
		function tabElements:CreateColorPicker(config)
			local text = config.Name or "Color Picker"
			local color = config.Default or Color3.fromRGB(255, 255, 255)
			local callback = config.Callback or function() end

			local CPFrame = Instance.new("TextButton", TabScroll)
			CPFrame.Size = UDim2.new(1, -10, 0, 45)
			CPFrame.BackgroundColor3 = Theme.Element
			CPFrame.Text = "   " .. text
			CPFrame.TextColor3 = Theme.Text
			CPFrame.Font = Enum.Font.GothamMedium
			CPFrame.TextSize = 14
			CPFrame.TextXAlignment = Enum.TextXAlignment.Left
			CPFrame.AutoButtonColor = false
			Instance.new("UICorner", CPFrame).CornerRadius = UDim.new(0, 6)
			Instance.new("UIStroke", CPFrame).Color = Theme.Outline

			local DisplayColor = Instance.new("Frame", CPFrame)
			DisplayColor.Size = UDim2.new(0, 30, 0, 20)
			DisplayColor.Position = UDim2.new(1, -45, 0.5, -10)
			DisplayColor.BackgroundColor3 = color
			Instance.new("UICorner", DisplayColor).CornerRadius = UDim.new(0, 4)
			Instance.new("UIStroke", DisplayColor).Color = Theme.Outline

			CPFrame.MouseButton1Click:Connect(function()
				Evok:Notify({
					Title = "Color Picker",
					Content = "A interface avançada de ColorPicker está em construção na Evok V2.0!",
					Type = "Warning"
				})
			end)
		end

		return tabElements
	end

	return windowLogic
end

return Evok
