local Evok = {
    Theme = {
        -- Cores extraídas diretamente da sua imagem de referência
        Background = Color3.fromRGB(18, 18, 18),
        GroupboxBg = Color3.fromRGB(24, 24, 24),
        GroupboxBorder = Color3.fromRGB(40, 40, 40),
        Accent = Color3.fromRGB(245, 160, 200), -- O Rosa/Pink exato da foto
        Text = Color3.fromRGB(255, 255, 255),
        TextMuted = Color3.fromRGB(120, 120, 120),
        ElementBg = Color3.fromRGB(30, 30, 30),
        Outline = Color3.fromRGB(10, 10, 10)
    }
}

local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local TextService = game:GetService("TextService")

local function GetGuiParent()
    if gethui then return gethui() end
    local s, r = pcall(function() return CoreGui end)
    if s and r then return r end
    return game.Players.LocalPlayer:WaitForChild("PlayerGui")
end

local EvokGui = Instance.new("ScreenGui")
EvokGui.Name = "EvokMatchaUI"
EvokGui.ResetOnSpawn = false
EvokGui.Parent = GetGuiParent()

local Utility = {}
function Utility:Tween(obj, props, time)
    local tw = TweenService:Create(obj, TweenInfo.new(time or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props)
    tw:Play()
    return tw
end

function Utility:MakeDraggable(Frame, Handle)
    local dragging, dragStart, startPos
    Handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = Frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
            local delta = input.Position - dragStart
            Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- ==========================================
-- ESTRUTURA PRINCIPAL (WINDOW)
-- ==========================================
function Evok:Window(config)
    local Main = Instance.new("Frame", EvokGui)
    Main.Size = UDim2.new(0, 600, 0, 550)
    Main.Position = UDim2.new(0.5, -300, 0.5, -275)
    Main.BackgroundColor3 = self.Theme.Background
    Main.BorderColor3 = self.Theme.Outline
    Main.BorderSizePixel = 1

    local Header = Instance.new("Frame", Main)
    Header.Size = UDim2.new(1, 0, 0, 25)
    Header.BackgroundTransparency = 1
    Utility:MakeDraggable(Main, Header)

    local Title = Instance.new("TextLabel", Header)
    Title.Size = UDim2.new(1, -10, 1, 0)
    Title.Position = UDim2.new(0, 10, 0, 0)
    Title.BackgroundTransparency = 1
    Title.Text = config.Name or "Evok UI"
    Title.TextColor3 = self.Theme.Accent
    Title.Font = Enum.Font.RobotoMono
    Title.TextSize = 13
    Title.TextXAlignment = Enum.TextXAlignment.Left

    local TabContainer = Instance.new("Frame", Main)
    TabContainer.Size = UDim2.new(1, -20, 0, 25)
    TabContainer.Position = UDim2.new(0, 10, 0, 25)
    TabContainer.BackgroundTransparency = 1
    local TabList = Instance.new("UIListLayout", TabContainer)
    TabList.FillDirection = Enum.FillDirection.Horizontal
    TabList.Padding = UDim.new(0, 15)

    local ContentContainer = Instance.new("Frame", Main)
    ContentContainer.Size = UDim2.new(1, -20, 1, -60)
    ContentContainer.Position = UDim2.new(0, 10, 0, 50)
    ContentContainer.BackgroundTransparency = 1

    local WindowLogic = { CurrentTab = nil }

    function WindowLogic:Tab(nome)
        local TabBtn = Instance.new("TextButton", TabContainer)
        TabBtn.Size = UDim2.new(0, TextService:GetTextSize(nome, 13, Enum.Font.RobotoMono, Vector2.new(1000, 25)).X, 1, 0)
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = nome
        TabBtn.TextColor3 = Evok.Theme.TextMuted
        TabBtn.Font = Enum.Font.RobotoMono
        TabBtn.TextSize = 13

        local TabContent = Instance.new("Frame", ContentContainer)
        TabContent.Size = UDim2.new(1, 0, 1, 0)
        TabContent.BackgroundTransparency = 1
        TabContent.Visible = false

        -- Layout das Colunas (Idêntico à foto)
        local LeftCol = Instance.new("ScrollingFrame", TabContent)
        LeftCol.Size = UDim2.new(0.5, -5, 1, 0)
        LeftCol.BackgroundTransparency = 1
        LeftCol.ScrollBarThickness = 0
        local RightCol = Instance.new("ScrollingFrame", TabContent)
        RightCol.Size = UDim2.new(0.5, -5, 1, 0)
        RightCol.Position = UDim2.new(0.5, 5, 0, 0)
        RightCol.BackgroundTransparency = 1
        RightCol.ScrollBarThickness = 0

        Instance.new("UIListLayout", LeftCol).Padding = UDim.new(0, 10)
        Instance.new("UIListLayout", RightCol).Padding = UDim.new(0, 10)

        TabBtn.MouseButton1Click:Connect(function()
            if WindowLogic.CurrentTab == TabBtn then return end
            if WindowLogic.CurrentTab then
                WindowLogic.CurrentTab.TextColor3 = Evok.Theme.TextMuted
                ContentContainer[WindowLogic.CurrentTab.Name .. "_C"].Visible = false
            end
            WindowLogic.CurrentTab = TabBtn
            TabBtn.TextColor3 = Evok.Theme.Text
            TabContent.Name = TabBtn.Name .. "_C"
            TabContent.Visible = true
        end)

        if #TabContainer:GetChildren() == 2 then
            WindowLogic.CurrentTab = TabBtn
            TabBtn.TextColor3 = Evok.Theme.Text
            TabContent.Name = TabBtn.Name .. "_C"
            TabContent.Visible = true
        end

        local TabLogic = {}

        -- ==========================================
        -- GROUPBOX (AS CAIXAS DA IMAGEM)
        -- ==========================================
        function TabLogic:Groupbox(config)
            local gbSide = config.Side or "Left"
            local TargetCol = gbSide == "Left" and LeftCol or RightCol

            local GBFrame = Instance.new("Frame", TargetCol)
            GBFrame.Size = UDim2.new(1, 0, 0, 20)
            GBFrame.BackgroundColor3 = Evok.Theme.GroupboxBg
            GBFrame.BorderColor3 = Evok.Theme.Outline
            GBFrame.BorderSizePixel = 1

            local GBStroke = Instance.new("UIStroke", GBFrame)
            GBStroke.Color = Evok.Theme.GroupboxBorder

            local GBTitle = Instance.new("TextLabel", GBFrame)
            GBTitle.Size = UDim2.new(0, TextService:GetTextSize(" " .. config.Name .. " ", 12, Enum.Font.RobotoMono, Vector2.new(1000, 20)).X, 0, 20)
            GBTitle.Position = UDim2.new(0, 10, 0, -10)
            GBTitle.BackgroundColor3 = Evok.Theme.Background
            GBTitle.Text = " " .. config.Name .. " "
            GBTitle.TextColor3 = Evok.Theme.Text
            GBTitle.Font = Enum.Font.RobotoMono
            GBTitle.TextSize = 12
            GBTitle.BorderSizePixel = 0

            local GBContainer = Instance.new("Frame", GBFrame)
            GBContainer.Size = UDim2.new(1, -20, 1, -20)
            GBContainer.Position = UDim2.new(0, 10, 0, 15)
            GBContainer.BackgroundTransparency = 1
            local GBLayout = Instance.new("UIListLayout", GBContainer)
            GBLayout.Padding = UDim.new(0, 8)

            GBLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                GBFrame.Size = UDim2.new(1, 0, 0, GBLayout.AbsoluteContentSize.Y + 25)
                TargetCol.CanvasSize = UDim2.new(0, 0, 0, TargetCol.UIListLayout.AbsoluteContentSize.Y + 10)
            end)

            local Elements = {}

            -- ==========================================
            -- TOGGLE (ESTILO MATCHA - BOLINHA)
            -- ==========================================
            function Elements:Toggle(cfg)
                local state = cfg.Default or false

                local TglFrame = Instance.new("TextButton", GBContainer)
                TglFrame.Size = UDim2.new(1, 0, 0, 15)
                TglFrame.BackgroundTransparency = 1
                TglFrame.Text = ""

                local Indicator = Instance.new("Frame", TglFrame)
                Indicator.Size = UDim2.new(0, 12, 0, 12)
                Indicator.Position = UDim2.new(0, 0, 0.5, -6)
                Indicator.BackgroundColor3 = state and Evok.Theme.Accent or Evok.Theme.ElementBg
                Indicator.BorderColor3 = Evok.Theme.Outline
                Instance.new("UICorner", Indicator).CornerRadius = UDim.new(1, 0) -- Deixa redondo

                local Title = Instance.new("TextLabel", TglFrame)
                Title.Size = UDim2.new(1, -20, 1, 0)
                Title.Position = UDim2.new(0, 20, 0, 0)
                Title.BackgroundTransparency = 1
                Title.Text = cfg.Name
                Title.TextColor3 = state and Evok.Theme.Text or Evok.Theme.TextMuted
                Title.Font = Enum.Font.RobotoMono
                Title.TextSize = 12
                Title.TextXAlignment = Enum.TextXAlignment.Left

                TglFrame.MouseButton1Click:Connect(function()
                    state = not state
                    Utility:Tween(Indicator, {BackgroundColor3 = state and Evok.Theme.Accent or Evok.Theme.ElementBg})
                    Utility:Tween(Title, {TextColor3 = state and Evok.Theme.Text or Evok.Theme.TextMuted})
                    if cfg.Callback then cfg.Callback(state) end
                end)
            end

            -- ==========================================
            -- SLIDER INLINE (ESTILO MATCHA)
            -- ==========================================
            function Elements:Slider(cfg)
                local min, max, val = cfg.Min or 0, cfg.Max or 100, cfg.Default or 0

                local SldFrame = Instance.new("Frame", GBContainer)
                SldFrame.Size = UDim2.new(1, 0, 0, 35)
                SldFrame.BackgroundTransparency = 1

                local Title = Instance.new("TextLabel", SldFrame)
                Title.Size = UDim2.new(1, 0, 0, 15)
                Title.BackgroundTransparency = 1
                Title.Text = cfg.Name
                Title.TextColor3 = Evok.Theme.Text
                Title.Font = Enum.Font.RobotoMono
                Title.TextSize = 12
                Title.TextXAlignment = Enum.TextXAlignment.Left

                local Track = Instance.new("TextButton", SldFrame)
                Track.Size = UDim2.new(1, 0, 0, 16)
                Track.Position = UDim2.new(0, 0, 0, 19)
                Track.BackgroundColor3 = Evok.Theme.ElementBg
                Track.BorderColor3 = Evok.Theme.Outline
                Track.Text = ""
                Track.AutoButtonColor = false
                Instance.new("UICorner", Track).CornerRadius = UDim.new(0, 4)

                local Fill = Instance.new("Frame", Track)
                Fill.Size = UDim2.new((val - min) / (max - min), 0, 1, 0)
                Fill.BackgroundColor3 = Evok.Theme.Accent
                Fill.BorderSizePixel = 0
                Instance.new("UICorner", Fill).CornerRadius = UDim.new(0, 4)

                -- Texto do Valor (Igual ao "1112/2000" da foto)
                local ValueTxt = Instance.new("TextLabel", Track)
                ValueTxt.Size = UDim2.new(1, 0, 1, 0)
                ValueTxt.BackgroundTransparency = 1
                ValueTxt.Text = tostring(val) .. "/" .. tostring(max)
                ValueTxt.TextColor3 = Evok.Theme.Text
                ValueTxt.Font = Enum.Font.RobotoMono
                ValueTxt.TextSize = 11

                local dragging = false
                local function update(input)
                    local pct = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    val = math.floor(min + ((max - min) * pct))
                    ValueTxt.Text = tostring(val) .. "/" .. tostring(max)
                    Utility:Tween(Fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.1)
                    if cfg.Callback then cfg.Callback(val) end
                end

                Track.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; update(input) end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update(input) end
                end)
            end

            -- ==========================================
            -- DROPDOWN
            -- ==========================================
            function Elements:Dropdown(cfg)
                local isOpen = false
                local selected = cfg.Default or cfg.Options[1]

                local DropFrame = Instance.new("Frame", GBContainer)
                DropFrame.Size = UDim2.new(1, 0, 0, 35)
                DropFrame.BackgroundTransparency = 1

                local Title = Instance.new("TextLabel", DropFrame)
                Title.Size = UDim2.new(1, 0, 0, 15)
                Title.BackgroundTransparency = 1
                Title.Text = cfg.Name
                Title.TextColor3 = Evok.Theme.Text
                Title.Font = Enum.Font.RobotoMono
                Title.TextSize = 12
                Title.TextXAlignment = Enum.TextXAlignment.Left

                local DropBtn = Instance.new("TextButton", DropFrame)
                DropBtn.Size = UDim2.new(1, 0, 0, 16)
                DropBtn.Position = UDim2.new(0, 0, 0, 19)
                DropBtn.BackgroundColor3 = Evok.Theme.ElementBg
                DropBtn.BorderColor3 = Evok.Theme.Outline
                DropBtn.Text = "  " .. selected
                DropBtn.TextColor3 = Evok.Theme.TextMuted
                DropBtn.Font = Enum.Font.RobotoMono
                DropBtn.TextSize = 11
                DropBtn.TextXAlignment = Enum.TextXAlignment.Left
                Instance.new("UICorner", DropBtn).CornerRadius = UDim.new(0, 4)

                -- O resto da lógica do Dropdown iria aqui (cortei para caber no limite, mas a estética base está aplicada!)
                -- (Na parte 3 finalizaremos o Dropdown aberto)
            end

            return Elements
        end

        return TabLogic
    end

    return WindowLogic
end

return Evok
