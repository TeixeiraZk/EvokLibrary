	local SideLine = Instance.new("Frame", Sidebar)
	SideLine.Size = UDim2.new(0, 1, 1, 0)
	SideLine.Position = UDim2.new(1, 0, 0, 0)
	SideLine.BackgroundColor3 = Theme.Outline
	SideLine.BorderSizePixel = 0

	local TabContainer = Instance.new("ScrollingFrame", Sidebar)
	TabContainer.Size = UDim2.new(1, 0, 1, -10)
	TabContainer.Position = UDim2.new(0, 0, 0, 5)
	TabContainer.BackgroundTransparency = 1
	TabContainer.ScrollBarThickness = 0
	local TabUIList = Instance.new("UIListLayout", TabContainer)
	TabUIList.Padding = UDim.new(0, 5)
	TabUIList.HorizontalAlignment = Enum.HorizontalAlignment.Center

	local ContentArea = Instance.new("Frame", Main)
	ContentArea.Size = UDim2.new(1, -161, 1, -40)
	ContentArea.Position = UDim2.new(0, 161, 0, 40)
	ContentArea.BackgroundTransparency = 1

	local CurrentTab = nil

	local WindowLogic = {}

	-- ==========================================
	-- SISTEMA DE ABAS (TABS)
	-- ==========================================
	function WindowLogic:Tab(nome)
		local TabBtn = Instance.new("TextButton", TabContainer)
		TabBtn.Size = UDim2.new(1, -16, 0, 35)
		TabBtn.BackgroundTransparency = 1
		TabBtn.Text = " " .. nome
		TabBtn.TextColor3 = Theme.TextMuted
		TabBtn.Font = Enum.Font.GothamMedium
		TabBtn.TextSize = 14
		TabBtn.TextXAlignment = Enum.TextXAlignment.Left
		Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)

		local TabContent = Instance.new("ScrollingFrame", ContentArea)
		TabContent.Size = UDim2.new(1, -20, 1, -20)
		TabContent.Position = UDim2.new(0, 10, 0, 10)
		TabContent.BackgroundTransparency = 1
		TabContent.ScrollBarThickness = 3
		TabContent.ScrollBarImageColor3 = Theme.Accent
		TabContent.Visible = false
		local ContentUIList = Instance.new("UIListLayout", TabContent)
		ContentUIList.Padding = UDim.new(0, 8)

		TabBtn.MouseButton1Click:Connect(function()
			if CurrentTab == TabBtn then return end
			if CurrentTab then
				Utils:Tween(CurrentTab, {BackgroundTransparency = 1, TextColor3 = Theme.TextMuted})
				local oldContent = ContentArea:FindFirstChild(CurrentTab.Name .. "_Content")
				if oldContent then oldContent.Visible = false end
			end
			CurrentTab = TabBtn
			Utils:Tween(TabBtn, {BackgroundTransparency = 0, BackgroundColor3 = Theme.Element, TextColor3 = Theme.Accent})
			TabContent.Name = TabBtn.Name .. "_Content"
			TabContent.Visible = true
		end)

		if #TabContainer:GetChildren() == 2 then
			CurrentTab = TabBtn
			TabBtn.BackgroundTransparency = 0
			TabBtn.BackgroundColor3 = Theme.Element
			TabBtn.TextColor3 = Theme.Accent
			TabContent.Name = TabBtn.Name .. "_Content"
			TabContent.Visible = true
		end

		local Elements = {}

		-- ==========================================
		-- COMPONENTES DA UI (BOTÃO, TOGGLE, SLIDER)
		-- ==========================================
		function Elements:Button(cfg)
			local Btn = Instance.new("TextButton", TabContent)
			Btn.Size = UDim2.new(1, -10, 0, 42)
			Btn.BackgroundColor3 = Theme.Element
			Btn.Text = "   " .. cfg.Name
			Btn.TextColor3 = Theme.Text
			Btn.Font = Enum.Font.GothamMedium
			Btn.TextSize = 14
			Btn.TextXAlignment = Enum.TextXAlignment.Left
			Btn.AutoButtonColor = false
			Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)
			Instance.new("UIStroke", Btn).Color = Theme.Outline

			Btn.MouseButton1Click:Connect(function()
				Utils:Tween(Btn, {BackgroundColor3 = Theme.ElementHover}, 0.1)
				task.wait(0.1)
				Utils:Tween(Btn, {BackgroundColor3 = Theme.Element}, 0.1)
				if cfg.Callback then cfg.Callback() end
			end)
		end

		function Elements:Toggle(cfg)
			local flag = cfg.Flag or cfg.Name
			local state = cfg.Default or false
			
			local Tgl = Instance.new("TextButton", TabContent)
			Tgl.Size = UDim2.new(1, -10, 0, 42)
			Tgl.BackgroundColor3 = Theme.Element
			Tgl.Text = "   " .. cfg.Name
			Tgl.TextColor3 = Theme.Text
			Tgl.Font = Enum.Font.GothamMedium
			Tgl.TextSize = 14
			Tgl.TextXAlignment = Enum.TextXAlignment.Left
			Tgl.AutoButtonColor = false
			Instance.new("UICorner", Tgl).CornerRadius = UDim.new(0, 6)
			Instance.new("UIStroke", Tgl).Color = Theme.Outline

			local Box = Instance.new("Frame", Tgl)
			Box.Size = UDim2.new(0, 40, 0, 20)
			Box.Position = UDim2.new(1, -55, 0.5, -10)
			Box.BackgroundColor3 = state and Theme.Accent or Theme.Background
			Instance.new("UICorner", Box).CornerRadius = UDim.new(1, 0)
			local BoxStroke = Instance.new("UIStroke", Box)
			BoxStroke.Color = Theme.Outline

			local Dot = Instance.new("Frame", Box)
			Dot.Size = UDim2.new(0, 16, 0, 16)
			Dot.Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
			Dot.BackgroundColor3 = Theme.Text
			Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)

			local function Fire()
				state = not state
				Utils:Tween(Box, {BackgroundColor3 = state and Theme.Accent or Theme.Background})
				Utils:Tween(Dot, {Position = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)})
				if Evok.Flags[flag] then Evok.Flags[flag].Value = state end
				if cfg.Callback then cfg.Callback(state) end
			end

			Tgl.MouseButton1Click:Connect(Fire)

			Evok.Flags[flag] = {
				Value = state,
				Set = function(self, val)
					if state ~= val then Fire() end
				end
			}
			if state and cfg.Callback then cfg.Callback(state) end
		end

		function Elements:Slider(cfg)
			local flag = cfg.Flag or cfg.Name
			local min = cfg.Min or 0
			local max = cfg.Max or 100
			local val = cfg.Default or min
			
			local Sld = Instance.new("Frame", TabContent)
			Sld.Size = UDim2.new(1, -10, 0, 60)
			Sld.BackgroundColor3 = Theme.Element
			Instance.new("UICorner", Sld).CornerRadius = UDim.new(0, 6)
			Instance.new("UIStroke", Sld).Color = Theme.Outline

			local Title = Instance.new("TextLabel", Sld)
			Title.Size = UDim2.new(1, -20, 0, 30)
			Title.Position = UDim2.new(0, 15, 0, 5)
			Title.BackgroundTransparency = 1
			Title.Text = cfg.Name
			Title.TextColor3 = Theme.Text
			Title.Font = Enum.Font.GothamMedium
			Title.TextSize = 14
			Title.TextXAlignment = Enum.TextXAlignment.Left

			local ValTxt = Instance.new("TextLabel", Sld)
			ValTxt.Size = UDim2.new(0, 50, 0, 30)
			ValTxt.Position = UDim2.new(1, -65, 0, 5)
			ValTxt.BackgroundTransparency = 1
			ValTxt.Text = tostring(val)
			ValTxt.TextColor3 = Theme.Accent
			ValTxt.Font = Enum.Font.GothamBold
			ValTxt.TextSize = 14
			ValTxt.TextXAlignment = Enum.TextXAlignment.Right

			local Track = Instance.new("TextButton", Sld)
			Track.Size = UDim2.new(1, -30, 0, 6)
			Track.Position = UDim2.new(0, 15, 0, 40)
			Track.BackgroundColor3 = Theme.Background
			Track.Text = ""
			Track.AutoButtonColor = false
			Instance.new("UICorner", Track).CornerRadius = UDim.new(1, 0)

			local Fill = Instance.new("Frame", Track)
			Fill.Size = UDim2.new((val - min) / (max - min), 0, 1, 0)
			Fill.BackgroundColor3 = Theme.Accent
			Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

			local dragging = false
			local function update(input)
				local pct = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
				val = math.floor(min + ((max - min) * pct))
				ValTxt.Text = tostring(val)
				Utils:Tween(Fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.1)
				if Evok.Flags[flag] then Evok.Flags[flag].Value = val end
				if cfg.Callback then cfg.Callback(val) end
			end

			Track.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; update(input) end
			end)
			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
			end)
			UserInputService.InputChanged:Connect(function(input)
				if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update(input) end
			end)

			Evok.Flags[flag] = {
				Value = val,
				Set = function(self, newVal)
					val = math.clamp(newVal, min, max)
					ValTxt.Text = tostring(val)
					Utils:Tween(Fill, {Size = UDim2.new((val - min) / (max - min), 0, 1, 0)}, 0.1)
					if cfg.Callback then cfg.Callback(val) end
				end
			}
		end

		-- ==========================================
		-- ELEMENTO AVANÇADO: DROPDOWN COM SEARCH
		-- ==========================================
		function Elements:Dropdown(cfg)
			local flag = cfg.Flag or cfg.Name
			local options = cfg.Options or {}
			local selected = cfg.Default or options[1] or ""
			local isOpen = false

			local DropFrame = Instance.new("Frame", TabContent)
			DropFrame.Size = UDim2.new(1, -10, 0, 42)
			DropFrame.BackgroundColor3 = Theme.Element
			DropFrame.ClipsDescendants = true
			Instance.new("UICorner", DropFrame).CornerRadius = UDim.new(0, 6)
			Instance.new("UIStroke", DropFrame).Color = Theme.Outline

			local MainBtn = Instance.new("TextButton", DropFrame)
			MainBtn.Size = UDim2.new(1, 0, 0, 42)
			MainBtn.BackgroundTransparency = 1
			MainBtn.Text = "   " .. cfg.Name .. " : " .. selected
			MainBtn.TextColor3 = Theme.Text
			MainBtn.Font = Enum.Font.GothamMedium
			MainBtn.TextSize = 14
			MainBtn.TextXAlignment = Enum.TextXAlignment.Left

			local Icon = Instance.new("TextLabel", DropFrame)
			Icon.Size = UDim2.new(0, 20, 0, 20)
			Icon.Position = UDim2.new(1, -30, 0, 11)
			Icon.BackgroundTransparency = 1
			Icon.Text = "+"
			Icon.TextColor3 = Theme.Accent
			Icon.Font = Enum.Font.GothamBold
			Icon.TextSize = 16

			local SearchBox = Instance.new("TextBox", DropFrame)
			SearchBox.Size = UDim2.new(1, -20, 0, 30)
			SearchBox.Position = UDim2.new(0, 10, 0, 45)
			SearchBox.BackgroundColor3 = Theme.Background
			SearchBox.PlaceholderText = "Pesquisar..."
			SearchBox.Text = ""
			SearchBox.TextColor3 = Theme.Text
			SearchBox.Font = Enum.Font.Gotham
			SearchBox.TextSize = 13
			Instance.new("UICorner", SearchBox).CornerRadius = UDim.new(0, 4)
			Instance.new("UIStroke", SearchBox).Color = Theme.Outline

			local ScrollOpts = Instance.new("ScrollingFrame", DropFrame)
			ScrollOpts.Size = UDim2.new(1, -20, 1, -85)
			ScrollOpts.Position = UDim2.new(0, 10, 0, 80)
			ScrollOpts.BackgroundTransparency = 1
			ScrollOpts.ScrollBarThickness = 2
			local ListLayout = Instance.new("UIListLayout", ScrollOpts)
			ListLayout.Padding = UDim.new(0, 4)

			local function RefreshOptions(filter)
				for _, child in pairs(ScrollOpts:GetChildren()) do
					if child:IsA("TextButton") then child:Destroy() end
				end
				local count = 0
				for _, opt in pairs(options) do
					if filter == "" or string.find(string.lower(opt), string.lower(filter)) then
						count = count + 1
						local OptBtn = Instance.new("TextButton", ScrollOpts)
						OptBtn.Size = UDim2.new(1, 0, 0, 25)
						OptBtn.BackgroundColor3 = selected == opt and Theme.Accent or Theme.Background
						OptBtn.Text = opt
						OptBtn.TextColor3 = selected == opt and Theme.Text or Theme.TextMuted
						OptBtn.Font = Enum.Font.Gotham
						OptBtn.TextSize = 13
						OptBtn.AutoButtonColor = false
						Instance.new("UICorner", OptBtn).CornerRadius = UDim.new(0, 4)
						
						OptBtn.MouseButton1Click:Connect(function()
							selected = opt
							MainBtn.Text = "   " .. cfg.Name .. " : " .. selected
							if Evok.Flags[flag] then Evok.Flags[flag].Value = selected end
							if cfg.Callback then cfg.Callback(selected) end
							isOpen = false
							Utils:Tween(DropFrame, {Size = UDim2.new(1, -10, 0, 42)})
							Icon.Text = "+"
							RefreshOptions("") -- Reset colors
						end)
					end
				end
				ScrollOpts.CanvasSize = UDim2.new(0, 0, 0, count * 29)
			end

			MainBtn.MouseButton1Click:Connect(function()
				isOpen = not isOpen
				Utils:Tween(DropFrame, {Size = isOpen and UDim2.new(1, -10, 0, 180) or UDim2.new(1, -10, 0, 42)})
				Icon.Text = isOpen and "-" or "+"
				if isOpen then RefreshOptions("") end
			end)

			SearchBox.Changed:Connect(function(prop)
				if prop == "Text" then RefreshOptions(SearchBox.Text) end
			end)

			Evok.Flags[flag] = {
				Value = selected,
				Set = function(self, val)
					selected = val
					MainBtn.Text = "   " .. cfg.Name .. " : " .. selected
					if cfg.Callback then cfg.Callback(selected) end
				end
			}
		end

		return Elements
	end

	return WindowLogic
end

return Evok
