function MultiDropdown.new(section, text, options_list, defaults, callback, options)
    local self = setmetatable({}, MultiDropdown)
    options = options or {}

    self._options      = options_list or {}
    self._selected     = defaults     or {}
    self._callback     = callback
    self._enabled      = true
    self._open         = false
    self._maxVisible   = options.MaxVisible or 5

    local itemHeight   = 26
    local maxHeight    = itemHeight * self._maxVisible

    -- Convert defaults to a set
    local selectedSet = {}
    for _, v in ipairs(self._selected) do
        selectedSet[v] = true
    end
    self._selectedSet = selectedSet

    -- Layout wrapper
    local wrapper = Utility.Create("Frame", {
        Name = "MultiDropdownWrapper",
        Size = UDim2.new(1, 0, 0, 46),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        LayoutOrder = #section.Content:GetChildren(),
        Parent = section.Content,
    })

    local labelText = Utility.Create("TextLabel", {
        Size = UDim2.new(1, 0, 0, 16),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = ThemeManager:GetColor("TextSecondary"),
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = wrapper,
    })

    local btn = Utility.Create("Frame", {
        Name = "MultiDropdownBtn",
        Size = UDim2.new(1, 0, 0, 26),
        Position = UDim2.new(0, 0, 0, 18),
        BackgroundColor3 = ThemeManager:GetColor("DropdownBg"),
        BackgroundTransparency = 0.1,
        BorderSizePixel = 0,
        Parent = wrapper,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = btn })
    Utility.Create("UIStroke", {
        Color = ThemeManager:GetColor("Border"),
        Thickness = 1,
        Transparency = 0.4,
        Parent = btn,
    })

    local function getTitle()
        local keys = {}
        for k in pairs(self._selectedSet) do
            table.insert(keys, k)
        end
        if #keys == 0 then return "None selected" end
        if #keys <= 2 then return table.concat(keys, ", ") end
        return keys[1] .. ", " .. keys[2] .. " (+" .. (#keys - 2) .. ")"
    end

    local selectedLabel = Utility.Create("TextLabel", {
        Size = UDim2.new(1, -28, 1, 0),
        Position = UDim2.new(0, 8, 0, 0),
        BackgroundTransparency = 1,
        Text = getTitle(),
        TextColor3 = ThemeManager:GetColor("TextSecondary"),
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = btn,
    })

    local arrow = Utility.Create("TextLabel", {
        Size = UDim2.new(0, 20, 1, 0),
        Position = UDim2.new(1, -24, 0, 0),
        BackgroundTransparency = 1,
        Text = "▼",
        TextColor3 = ThemeManager:GetColor("TextMuted"),
        TextSize = 8,
        Font = Enum.Font.GothamBold,
        Parent = btn,
    })

    local clickBtn = Utility.Create("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = btn.ZIndex + 1,
        Parent = btn,
    })

    local listFrame = Utility.Create("Frame", {
        Name = "MultiList",
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 0, 46),
        BackgroundColor3 = ThemeManager:GetColor("DropdownBg"),
        BackgroundTransparency = 0.05,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Visible = false,
        ZIndex = btn.ZIndex + 5,
        Parent = wrapper,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = listFrame })
    Utility.Create("UIStroke", {
        Color = ThemeManager:GetColor("Border"),
        Thickness = 1,
        Transparency = 0.3,
        Parent = listFrame,
    })

    local scrollFrame = Utility.Create("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = ThemeManager:GetColor("ScrollBar"),
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ZIndex = listFrame.ZIndex + 1,
        Parent = listFrame,
    })

    Utility.Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 2),
        Parent = scrollFrame,
    })
    Utility.Create("UIPadding", {
        PaddingAll = UDim.new(0, 4),
        Parent = scrollFrame,
    })

    self._wrapper       = wrapper
    self._listFrame     = listFrame
    self._scrollFrame   = scrollFrame
    self._selectedLabel = selectedLabel
    self._arrow         = arrow

    local function buildItems()
        for _, child in ipairs(scrollFrame:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end

        for i, optName in ipairs(self._options) do
            local isSelected = self._selectedSet[optName] == true

            local item = Utility.Create("Frame", {
                Size = UDim2.new(1, 0, 0, itemHeight),
                BackgroundColor3 = isSelected
                    and ThemeManager:GetColor("Primary")
                    or  Color3.new(1, 1, 1),
                BackgroundTransparency = isSelected and 0.15 or 0.95,
                BorderSizePixel = 0,
                LayoutOrder = i,
                Parent = scrollFrame,
            })
            Utility.Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = item })

            -- Checkmark
            local checkFrame = Utility.Create("Frame", {
                Size = UDim2.new(0, 14, 0, 14),
                Position = UDim2.new(0, 6, 0.5, -7),
                BackgroundColor3 = isSelected
                    and ThemeManager:GetColor("Primary")
                    or  ThemeManager:GetColor("Border"),
                BackgroundTransparency = isSelected and 0 or 0.4,
                BorderSizePixel = 0,
                ZIndex = item.ZIndex + 1,
                Parent = item,
            })
            Utility.Create("UICorner", { CornerRadius = UDim.new(0, 3), Parent = checkFrame })

            local checkMark = Utility.Create("TextLabel", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = isSelected and "✓" or "",
                TextColor3 = Color3.new(0, 0, 0),
                TextSize = 9,
                Font = Enum.Font.GothamBold,
                ZIndex = item.ZIndex + 2,
                Parent = checkFrame,
            })

            local itemLabel = Utility.Create("TextLabel", {
                Size = UDim2.new(1, -28, 1, 0),
                Position = UDim2.new(0, 26, 0, 0),
                BackgroundTransparency = 1,
                Text = optName,
                TextColor3 = isSelected
                    and Color3.new(0, 0, 0)
                    or  ThemeManager:GetColor("TextSecondary"),
                TextSize = 11,
                Font = isSelected and Enum.Font.GothamBold or Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = item.ZIndex + 1,
                Parent = item,
            })

            local itemBtn = Utility.Create("TextButton", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = "",
                ZIndex = item.ZIndex + 3,
                Parent = item,
            })

            itemBtn.MouseButton1Click:Connect(function()
                if self._selectedSet[optName] then
                    self._selectedSet[optName] = nil
                else
                    self._selectedSet[optName] = true
                end

                -- Update selected list
                self._selected = {}
                for k in pairs(self._selectedSet) do
                    table.insert(self._selected, k)
                end

                selectedLabel.Text = getTitle()
                buildItems()

                if self._callback then
                    task.spawn(self._callback, Utility.DeepCopy(self._selected))
                end
            end)
        end
    end

    function self:_Open()
        self._open = true
        buildItems()

        local count = #self._options
        local listH = math.min(count * itemHeight + 10, maxHeight)
        wrapper.Size = UDim2.new(1, 0, 0, 46 + listH + 4)

        listFrame.Visible = true
        listFrame.Size = UDim2.new(1, 0, 0, 0)
        Utility.TweenObject(listFrame, { Size = UDim2.new(1, 0, 0, listH) }, 0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        Utility.TweenObject(arrow, { Rotation = 180 }, 0.25)
    end

    function self:_Close()
        self._open = false
        Utility.TweenObject(listFrame, { Size = UDim2.new(1, 0, 0, 0) }, 0.2)
        Utility.TweenObject(arrow, { Rotation = 0 }, 0.2)
        task.delay(0.22, function()
            listFrame.Visible = false
            wrapper.Size = UDim2.new(1, 0, 0, 46)
        end)
    end

    clickBtn.MouseButton1Click:Connect(function()
        if not self._enabled then return end
        if self._open then self:_Close() else self:_Open() end
    end)

    function self:GetSelected()
        return Utility.DeepCopy(self._selected)
    end

    function self:SetOptions(newOptions)
        self._options = newOptions
        self._selectedSet = {}
        self._selected = {}
        selectedLabel.Text = getTitle()
    end

    return self
end

