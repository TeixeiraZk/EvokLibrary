local Utility = require(script.Parent.Parent.Core.Utility)
local ThemeManager = require(script.Parent.Parent.Core.ThemeManager)

local Slider = {}
Slider.__index = Slider

function Slider.Create(Parent, Text, Min, Max, Default, Callback)
	local self = setmetatable({}, Slider)

	self.Min = Min or 0
	self.Max = Max or 100
	self.Value = Default or self.Min
	self.Callback = Callback
	self.Dragging = false

	self.Frame = Utility.CreateInstance("Frame", {
		Name = "Slider",
		BackgroundColor3 = ThemeManager.CurrentTheme.PanelAlt,
		BackgroundTransparency = 0.14,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -4, 0, 44),
		Parent = Parent
	})
	Utility.MakeCorner(self.Frame, UDim.new(0, 10))
	Utility.MakeStroke(self.Frame, ThemeManager.CurrentTheme.StrokeColor, 1, 0.65)

	self.Title = Utility.CreateInstance("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -20, 0, 16),
		Position = UDim2.new(0, 10, 0, 6),
		Font = Enum.Font.GothamMedium,
		Text = Text or "Slider",
		TextColor3 = ThemeManager.CurrentTheme.TextColor,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = self.Frame
	})

	self.ValueLabel = Utility.CreateInstance("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(0, 80, 0, 16),
		Position = UDim2.new(1, -90, 0, 6),
		Font = Enum.Font.GothamMedium,
		Text = tostring(self.Value),
		TextColor3 = ThemeManager.CurrentTheme.MutedTextColor,
		TextSize = 11,
		TextXAlignment = Enum.TextXAlignment.Right,
		Parent = self.Frame
	})

	self.Bar = Utility.CreateInstance("Frame", {
		Name = "Bar",
		BackgroundColor3 = Color3.fromRGB(24, 24, 24),
		BackgroundTransparency = 0.05,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -20, 0, 10),
		Position = UDim2.new(0, 10, 0, 24),
		Parent = self.Frame
	})
	Utility.MakeCorner(self.Bar, UDim.new(1, 0))
	Utility.MakeStroke(self.Bar, ThemeManager.CurrentTheme.StrokeColor, 1, 0.75)

	self.Fill = Utility.CreateInstance("Frame", {
		Name = "Fill",
		BackgroundColor3 = ThemeManager.CurrentTheme.PrimaryColor,
		BorderSizePixel = 0,
		Size = UDim2.new(0, 0, 1, 0),
		Parent = self.Bar
	})
	Utility.MakeCorner(self.Fill, UDim.new(1, 0))

	self.Knob = Utility.CreateInstance("Frame", {
		Name = "Knob",
		BackgroundColor3 = Color3.fromRGB(255, 255, 255),
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(14, 14),
		Position = UDim2.new(0, 0, 0.5, -7),
		Parent = self.Bar
	})
	Utility.MakeCorner(self.Knob, UDim.new(1, 0))

	local function UpdateFromAlpha(Alpha, Instant)
		Alpha = math.clamp(Alpha, 0, 1)
		self.Value = Utility.Round(self.Min + ((self.Max - self.Min) * Alpha), 2)
		self.ValueLabel.Text = tostring(self.Value)

		local NewFill = UDim2.new(Alpha, 0, 1, 0)
		local NewKnobPos = UDim2.new(Alpha, -7, 0.5, -7)

		if Instant then
			self.Fill.Size = NewFill
			self.Knob.Position = NewKnobPos
		else
			Utility.TweenObject(self.Fill, TweenInfo.new(0.15, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				Size = NewFill
			})
			Utility.TweenObject(self.Knob, TweenInfo.new(0.15, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				Position = NewKnobPos
			})
		end

		if self.Callback then
			task.spawn(self.Callback, self.Value)
		end
	end

	self._UpdateFromAlpha = UpdateFromAlpha

	self.Bar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			self.Dragging = true
			local Alpha = (input.Position.X - self.Bar.AbsolutePosition.X) / self.Bar.AbsoluteSize.X
			UpdateFromAlpha(Alpha, false)
		end
	end)

	self.Bar.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			self.Dragging = false
		end
	end)

	Utility.BindRenderStep("EvokSlider" .. tostring(self), Enum.RenderPriority.Input.Value, function()
		if self.Dragging then
			local MousePos = UserInputService:GetMouseLocation().X
			local Alpha = (MousePos - self.Bar.AbsolutePosition.X) / self.Bar.AbsoluteSize.X
			UpdateFromAlpha(Alpha, false)
		end
	end)

	self.Frame.MouseEnter:Connect(function()
		Utility.TweenObject(self.Frame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 0.03
		})
	end)

	self.Frame.MouseLeave:Connect(function()
		Utility.TweenObject(self.Frame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 0.14
		})
	end)

	self:SetValue(self.Value, true)
	return self
end

function Slider:SetValue(Value, Silent)
	Value = math.clamp(Value, self.Min, self.Max)
	self.Value = Value
	local Alpha = (Value - self.Min) / (self.Max - self.Min)
	self.Fill.Size = UDim2.new(Alpha, 0, 1, 0)
	self.Knob.Position = UDim2.new(Alpha, -7, 0.5, -7)
	self.ValueLabel.Text = tostring(Utility.Round(Value, 2))
	if not Silent and self.Callback then
		task.spawn(self.Callback, self.Value)
	end
end

function Slider:GetValue()
	return self.Value
end

return Slider

