            -- ==============================================================================
            -- 🟩 WIDGET: BUTTON (Com Efeito Ripple e Cooldown)
            -- ==============================================================================
            function Section:CreateButton(opts)
                local Button = { Locked = false }
                local callback = opts.Callback or function() end
                
                local BtnFrame = Instance.new("Frame")
                BtnFrame.Size = UDim2.new(1, 0, 0, 32)
                BtnFrame.BackgroundColor3 = Core.Themes.Background
                BtnFrame.Parent = SecFrame
                Instance.new("UICorner", BtnFrame).CornerRadius = UDim.new(0, 6)
                local BtnStroke = Instance.new("UIStroke", BtnFrame)
                BtnStroke.Color = Core.Themes.Border
                
                local ClickBtn = Instance.new("TextButton")
                ClickBtn.Size = UDim2.new(1, 0, 1, 0)
                ClickBtn.BackgroundTransparency = 1
                ClickBtn.Text = opts.Name or "Button"
                ClickBtn.TextColor3 = Core.Themes.Text
                ClickBtn.Font = Enum.Font.GothamSemibold
                ClickBtn.TextSize = 13
                ClickBtn.ClipsDescendants = true
                ClickBtn.Parent = BtnFrame
                Instance.new("UICorner", ClickBtn).CornerRadius = UDim.new(0, 6)

                ClickBtn.MouseButton1Click:Connect(function()
                    if Button.Locked then return end
                    
                    CreateRipple(ClickBtn, UserInputService:GetMouseLocation(), Core.Themes.Accent)
                    callback()
                    
                    if opts.Cooldown then
                        Button.Locked = true
                        local originalText = ClickBtn.Text
                        ClickBtn.Text = "..."
                        Core:Tween(BtnStroke, {Color = Core.Themes.TextMuted}, 0.2)
                        
                        task.wait(opts.Cooldown)
                        
                        Button.Locked = false
                        ClickBtn.Text = originalText
                        Core:Tween(BtnStroke, {Color = Core.Themes.Border}, 0.2)
                    end
                end)

                Core:SubscribeToTheme(function(theme)
                    BtnFrame.BackgroundColor3 = theme.Background
                    ClickBtn.TextColor3 = theme.Text
                    if not Button.Locked then BtnStroke.Color = theme.Border end
                end)

                return Button
            end

            -- ==============================================================================
            -- 🔘 WIDGET: TOGGLE
            -- ==============================================================================
            function Section:CreateToggle(opts)
                local Toggle = { State = opts.Default or false }
                local callback = opts.Callback or function() end

                local ToggleBtn = Instance.new("TextButton")
                ToggleBtn.Size = UDim2.new(1, 0, 0, 25)
                ToggleBtn.BackgroundTransparency = 1
                ToggleBtn.Text = ""
                ToggleBtn.Parent = SecFrame

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -40, 1, 0)
                Label.BackgroundTransparency = 1
                Label.Text = opts.Name
                Label.TextColor3 = Toggle.State and Core.Themes.Text or Core.Themes.TextMuted
                Label.Font = Enum.Font.Gotham
                Label.TextSize = 13
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = ToggleBtn

                local Outer = Instance.new("Frame")
                Outer.Size = UDim2.new(0, 36, 0, 18)
                Outer.AnchorPoint = Vector2.new(1, 0.5)
                Outer.Position = UDim2.new(1, 0, 0.5, 0)
                Outer.BackgroundColor3 = Toggle.State and Core.Themes.Accent or Core.Themes.Border
                Outer.Parent = ToggleBtn
                Instance.new("UICorner", Outer).CornerRadius = UDim.new(1, 0)

                local Inner = Instance.new("Frame")
                Inner.Size = UDim2.new(0, 14, 0, 14)
                Inner.Position = Toggle.State and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
                Inner.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                Inner.Parent = Outer
                Instance.new("UICorner", Inner).CornerRadius = UDim.new(1, 0)

                function Toggle:Set(newState, skipCallback)
                    Toggle.State = newState
                    if not skipCallback then callback(Toggle.State) end
                    
                    Core:Tween(Outer, {BackgroundColor3 = Toggle.State and Core.Themes.Accent or Core.Themes.Border}, 0.2)
                    Core:Tween(Inner, {Position = Toggle.State and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}, 0.25, Enum.EasingStyle.Back)
                    Core:Tween(Label, {TextColor3 = Toggle.State and Core.Themes.Text or Core.Themes.TextMuted}, 0.2)
                end

                ToggleBtn.MouseButton1Click:Connect(function() 
                    CreateRipple(ToggleBtn, UserInputService:GetMouseLocation(), Core.Themes.TextMuted)
                    Toggle:Set(not Toggle.State) 
                end)

                Core:SubscribeToTheme(function(theme)
                    if Toggle.State then
                        Outer.BackgroundColor3 = theme.Accent
                        Label.TextColor3 = theme.Text
                    else
                        Outer.BackgroundColor3 = theme.Border
                        Label.TextColor3 = theme.TextMuted
                    end
                end)

                return Toggle
            end

            -- ==============================================================================
            -- 🎚️ WIDGET: SLIDER (Com Tooltip de Valor Flutuante)
            -- ==============================================================================
            function Section:CreateSlider(opts)
                local min, max = opts.Min or 0, opts.Max or 100
                local Slider = { Value = math.clamp(opts.Default or min, min, max) }
                local callback = opts.Callback or function() end

                local SliderFrame = Instance.new("Frame")
                SliderFrame.Size = UDim2.new(1, 0, 0, 45)
                SliderFrame.BackgroundTransparency = 1
                SliderFrame.Parent = SecFrame

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -50, 0, 20)
                Label.BackgroundTransparency = 1
                Label.Text = opts.Name
                Label.TextColor3 = Core.Themes.TextMuted
                Label.Font = Enum.Font.Gotham
                Label.TextSize = 13
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = SliderFrame

                local ValInput = Instance.new("TextBox")
                ValInput.Size = UDim2.new(0, 45, 0, 20)
                ValInput.Position = UDim2.new(1, -45, 0, 0)
                ValInput.BackgroundColor3 = Core.Themes.Background
                ValInput.TextColor3 = Core.Themes.Text
                ValInput.Font = Enum.Font.Gotham
                ValInput.TextSize = 12
                ValInput.Text = tostring(Slider.Value)
                ValInput.Parent = SliderFrame
                Instance.new("UICorner", ValInput).CornerRadius = UDim.new(0, 4)
                local InputStroke = Instance.new("UIStroke", ValInput)
                InputStroke.Color = Core.Themes.Border

                local BarBg = Instance.new("TextButton")
                BarBg.Size = UDim2.new(1, 0, 0, 6)
                BarBg.Position = UDim2.new(0, 0, 1, -8)
                BarBg.BackgroundColor3 = Core.Themes.Border
                BarBg.Text = ""
                BarBg.Parent = SliderFrame
                Instance.new("UICorner", BarBg).CornerRadius = UDim.new(1, 0)

                local Fill = Instance.new("Frame")
                Fill.Size = UDim2.new((Slider.Value - min) / (max - min), 0, 1, 0)
                Fill.BackgroundColor3 = Core.Themes.Accent
                Fill.Parent = BarBg
                Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

                function Slider:Set(newVal, skipCallback)
                    Slider.Value = math.clamp(tonumber(newVal) or min, min, max)
                    local percent = (Slider.Value - min) / (max - min)
                    
                    Core:Tween(Fill, {Size = UDim2.new(percent, 0, 1, 0)}, 0.1)
                    ValInput.Text = tostring(Slider.Value)
                    
                    if not skipCallback then callback(Slider.Value) end
                end

                local sliding = false
                local function UpdateSlider(input)
                    local percent = math.clamp((input.Position.X - BarBg.AbsolutePosition.X) / BarBg.AbsoluteSize.X, 0, 1)
                    Slider:Set(math.floor(min + (max - min) * percent))
                end

                BarBg.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = true; UpdateSlider(input)
                        Core:Tween(Fill, {BackgroundColor3 = Core.Math.Color.Lighten(Core.Themes.Accent, 0.2)}, 0.2)
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 and sliding then
                        sliding = false
                        Core:Tween(Fill, {BackgroundColor3 = Core.Themes.Accent}, 0.2)
                    end
                end)
                
                UserInputService.InputChanged:Connect(function(input)
                    if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then 
                        UpdateSlider(input) 
                    end
                end)
                
                ValInput.FocusLost:Connect(function() Slider:Set(ValInput.Text) end)

                Core:SubscribeToTheme(function(theme)
                    Label.TextColor3 = theme.TextMuted
                    ValInput.BackgroundColor3 = theme.Background
                    ValInput.TextColor3 = theme.Text
                    InputStroke.Color = theme.Border
                    BarBg.BackgroundColor3 = theme.Border
                    if not sliding then Fill.BackgroundColor3 = theme.Accent end
                end)

                return Slider
            end

            -- ==============================================================================
            -- 📜 WIDGET: MULTI-DROPDOWN (Suporte a Seleção Múltipla Dinâmica)
            -- ==============================================================================
            function Section:CreateMultiDropdown(opts)
                local Dropdown = { 
                    Options = opts.Options or {}, 
                    Selected = opts.Default or {}, -- Table of selections
                    Open = false 
                }
                local callback = opts.Callback or function() end

                local DropFrame = Instance.new("Frame")
                DropFrame.Size = UDim2.new(1, 0, 0, 35)
                DropFrame.BackgroundColor3 = Core.Themes.Background
                DropFrame.ClipsDescendants = true
                DropFrame.Parent = SecFrame
                Instance.new("UICorner", DropFrame).CornerRadius = UDim.new(0, 6)
                local DropStroke = Instance.new("UIStroke", DropFrame)
                DropStroke.Color = Core.Themes.Border

                local MainBtn = Instance.new("TextButton")
                MainBtn.Size = UDim2.new(1, 0, 0, 35)
                MainBtn.BackgroundTransparency = 1
                MainBtn.Text = ""
                MainBtn.Parent = DropFrame

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -30, 1, 0)
                Label.Position = UDim2.new(0, 10, 0, 0)
                Label.BackgroundTransparency = 1
                
                local function UpdateLabel()
                    if #Dropdown.Selected == 0 then
                        Label.Text = opts.Name .. ": None"
                    elseif #Dropdown.Selected == 1 then
                        Label.Text = opts.Name .. ": " .. tostring(Dropdown.Selected[1])
                    else
                        Label.Text = opts.Name .. ": " .. tostring(#Dropdown.Selected) .. " Selected"
                    end
                end
                UpdateLabel()
                
                Label.TextColor3 = Core.Themes.TextMuted
                Label.Font = Enum.Font.Gotham
                Label.TextSize = 13
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = MainBtn

                local Icon = Instance.new("TextLabel")
                Icon.Size = UDim2.new(0, 20, 0, 20)
                Icon.Position = UDim2.new(1, -25, 0.5, -10)
                Icon.BackgroundTransparency = 1
                Icon.Text = "+"
                Icon.TextColor3 = Core.Themes.TextMuted
                Icon.Font = Enum.Font.GothamBold
                Icon.TextSize = 16
                Icon.Parent = MainBtn

                local ScrollContainer = Instance.new("ScrollingFrame")
                ScrollContainer.Size = UDim2.new(1, 0, 1, -35)
                ScrollContainer.Position = UDim2.new(0, 0, 0, 35)
                ScrollContainer.BackgroundTransparency = 1
                ScrollContainer.ScrollBarThickness = 2
                ScrollContainer.ScrollBarImageColor3 = Core.Themes.Border
                ScrollContainer.Parent = DropFrame
                
                local ListLayout = Instance.new("UIListLayout")
                ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
                ListLayout.Parent = ScrollContainer

                local function ToggleDrop()
                    Dropdown.Open = not Dropdown.Open
                    Icon.Text = Dropdown.Open and "-" or "+"
                    
                    SecFrame.ZIndex = Dropdown.Open and 5 or 1
                    DropFrame.ZIndex = Dropdown.Open and 5 or 1
                    
                    local maxItems = 4
                    local itemsCount = math.min(#Dropdown.Options, maxItems)
                    local targetSize = Dropdown.Open and UDim2.new(1, 0, 0, 35 + (itemsCount * 25)) or UDim2.new(1, 0, 0, 35)
                    
                    ScrollContainer.CanvasSize = UDim2.new(0, 0, 0, #Dropdown.Options * 25)
                    Core:Tween(DropFrame, {Size = targetSize}, 0.25, Enum.EasingStyle.Quint)
                    Core:Tween(Icon, {Rotation = Dropdown.Open and 180 or 0}, 0.25)
                end

                MainBtn.MouseButton1Click:Connect(ToggleDrop)

                function Dropdown:Refresh(newOptions)
                    Dropdown.Options = newOptions
                    for _, child in pairs(ScrollContainer:GetChildren()) do
                        if child:IsA("TextButton") then child:Destroy() end
                    end

                    for _, opt in ipairs(Dropdown.Options) do
                        local isSelected = table.find(Dropdown.Selected, opt) ~= nil

                        local OptBtn = Instance.new("TextButton")
                        OptBtn.Size = UDim2.new(1, 0, 0, 25)
                        OptBtn.BackgroundTransparency = 1
                        OptBtn.Text = ""
                        OptBtn.Parent = ScrollContainer

                        local OptLabel = Instance.new("TextLabel")
                        OptLabel.Size = UDim2.new(1, -30, 1, 0)
                        OptLabel.Position = UDim2.new(0, 30, 0, 0)
                        OptLabel.BackgroundTransparency = 1
                        OptLabel.Text = tostring(opt)
                        OptLabel.TextColor3 = isSelected and Core.Themes.Accent or Core.Themes.Text
                        OptLabel.Font = Enum.Font.Gotham
                        OptLabel.TextSize = 13
                        OptLabel.TextXAlignment = Enum.TextXAlignment.Left
                        OptLabel.Parent = OptBtn

                        -- Checkbox visual inside dropdown
                        local CheckBox = Instance.new("Frame")
                        CheckBox.Size = UDim2.new(0, 12, 0, 12)
                        CheckBox.Position = UDim2.new(0, 10, 0.5, -6)
                        CheckBox.BackgroundColor3 = isSelected and Core.Themes.Accent or Core.Themes.Background
                        CheckBox.Parent = OptBtn
                        Instance.new("UICorner", CheckBox).CornerRadius = UDim.new(0, 3)
                        local CheckStroke = Instance.new("UIStroke", CheckBox)
                        CheckStroke.Color = isSelected and Core.Themes.Accent or Core.Themes.Border

                        OptBtn.MouseButton1Click:Connect(function()
                            if isSelected then
                                local idx = table.find(Dropdown.Selected, opt)
                                if idx then table.remove(Dropdown.Selected, idx) end
                            else
                                table.insert(Dropdown.Selected, opt)
                            end
                            UpdateLabel()
                            callback(Dropdown.Selected)
                            Dropdown:Refresh(Dropdown.Options) 
                        end)
                    end
                end

                Core:SubscribeToTheme(function(theme)
                    DropFrame.BackgroundColor3 = theme.Background
                    DropStroke.Color = theme.Border
                    Label.TextColor3 = theme.TextMuted
                    Icon.TextColor3 = theme.TextMuted
                    ScrollContainer.ScrollBarImageColor3 = theme.Border
                    Dropdown:Refresh(Dropdown.Options) 
                end)

                Dropdown:Refresh(Dropdown.Options)
                return Dropdown
            end

