local Utility = require(script.Parent.Parent.Core.Utility)
local ThemeManager = require(script.Parent.Parent.Core.ThemeManager)

local Toggle = {}
Toggle.__index = Toggle

function Toggle.Create(Parent, Text, Default, Callback)
	local self = setmetatable({}, Toggle)

	self.State = Default and true or false
	self.Callback = Callback

	self.Frame = Utility.CreateInstance("TextButton", {
		Name = "Toggle",
		BackgroundColor3 = ThemeManager.CurrentTheme.PanelAlt,
		BackgroundTransparency = 0.14,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -4, 0, 30),
		Text = "",
		AutoButtonColor = false,
		Parent = Parent
	})
	Utility.MakeCorner(self.Frame, UDim.new(0, 10))
	Utility.MakeStroke(self.Frame, ThemeManager.CurrentTheme.StrokeColor, 1, 0.65)

	self.Label = Utility.CreateInstance("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -52, 1, 0),
		Position = UDim2.new(0, 10, 0, 0),
		Font = Enum.Font.GothamMedium,
		Text = Text or "Toggle",
		TextColor3 = ThemeManager.CurrentTheme.TextColor,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = self.Frame
	})

	self.Switch = Utility.CreateInstance("Frame", {
		Name = "Switch",
		BackgroundColor3 = Color3.fromRGB(32, 32, 32),
		BackgroundTransparency = 0.05,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(34, 18),
		Position = UDim2.new(1, -44, 0.5, -9),
		Parent = self.Frame
	})
	Utility.MakeCorner(self.Switch, UDim.new(1, 0))
	Utility.MakeStroke(self.Switch, ThemeManager.CurrentTheme.StrokeColor, 1, 0.7)

	self.Knob = Utility.CreateInstance("Frame", {
		Name = "Knob",
		BackgroundColor3 = Color3.fromRGB(245, 245, 245),
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(14, 14),
		Position = UDim2.new(0, 2, 0.5, -7),
		Parent = self.Switch
	})
	Utility.MakeCorner(self.Knob, UDim.new(1, 0))

	local function UpdateVisual(Instant)
		local On = self.State
		if Instant then
			self.Switch.BackgroundColor3 = On and ThemeManager.CurrentTheme.PrimaryColor or Color3.fromRGB(32, 32, 32)
			self.Knob.Position = On and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
		else
			Utility.TweenObject(self.Switch, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				BackgroundColor3 = On and ThemeManager.CurrentTheme.PrimaryColor or Color3.fromRGB(32, 32, 32)
			})
			Utility.TweenObject(self.Knob, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				Position = On and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
				BackgroundColor3 = On and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(235, 235, 235)
			})
		end
	end

	UpdateVisual(true)

	self.Frame.MouseEnter:Connect(function()
		Utility.TweenObject(self.Frame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 0.03
		})
	end)

	self.Frame.MouseLeave:Connect(function()
		Utility.TweenObject(self.Frame, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 0.14
		})
	end)

	self.Frame.Activated:Connect(function()
		self.State = not self.State
		UpdateVisual(false)
		if self.Callback then
			task.spawn(self.Callback, self.State)
		end
	end)

	return self
end

function Toggle:SetState(State, Silent)
	self.State = State and true or false
	self.Switch.BackgroundColor3 = self.State and ThemeManager.CurrentTheme.PrimaryColor or Color3.fromRGB(32, 32, 32)
	self.Knob.Position = self.State and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
	if not Silent and self.Callback then
		task.spawn(self.Callback, self.State)
	end
end

function Toggle:GetState()
	return self.State
end

return Toggle

