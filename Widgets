-- ============================================================================
-- 1. GLOBAL TOOLTIP SYSTEM (Motor de Dicas Visuais)
-- ============================================================================
local TooltipGui = Instance.new("ScreenGui")
TooltipGui.Name = "Evok_Tooltip_Layer"
TooltipGui.Parent = CoreGui
TooltipGui.ZIndexBehavior = Enum.ZIndexBehavior.Global

local TooltipFrame = Instance.new("Frame")
TooltipFrame.Name = "Tooltip"
TooltipFrame.Parent = TooltipGui
TooltipFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 18) -- Evok.ThemeManager:GetColor("ContainerHover")
TooltipFrame.Size = UDim2.new(0, 0, 0, 24)
TooltipFrame.Position = UDim2.new(0, 0, 0, 0)
TooltipFrame.Visible = false
TooltipFrame.ZIndex = 100

local TooltipCorner = Instance.new("UICorner")
TooltipCorner.CornerRadius = UDim.new(0, 4)
TooltipCorner.Parent = TooltipFrame

local TooltipStroke = Instance.new("UIStroke")
TooltipStroke.Color = Color3.fromRGB(45, 45, 50) -- Evok.ThemeManager:GetColor("BorderHighlight")
TooltipStroke.Parent = TooltipFrame

local TooltipPadding = Instance.new("UIPadding")
TooltipPadding.PaddingLeft = UDim.new(0, 8)
TooltipPadding.PaddingRight = UDim.new(0, 8)
TooltipPadding.Parent = TooltipFrame

local TooltipText = Instance.new("TextLabel")
TooltipText.Parent = TooltipFrame
TooltipText.BackgroundTransparency = 1
TooltipText.Size = UDim2.new(1, 0, 1, 0)
TooltipText.Font = Enum.Font.Gotham
TooltipText.TextSize = 12
TooltipText.TextColor3 = Color3.fromRGB(200, 200, 200)
TooltipText.TextXAlignment = Enum.TextXAlignment.Center

local function ShowTooltip(text)
    if not text or text == "" then return end
    local textBounds = TextService:GetTextSize(text, 12, Enum.Font.Gotham, Vector2.new(math.huge, 24))
    TooltipFrame.Size = UDim2.new(0, textBounds.X + 16, 0, 24)
    TooltipText.Text = text
    TooltipFrame.Visible = true
    
    local mousePos = UserInputService:GetMouseLocation()
    TooltipFrame.Position = UDim2.new(0, mousePos.X + 15, 0, mousePos.Y + 15)
end

local function HideTooltip()
    TooltipFrame.Visible = false
end

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement and TooltipFrame.Visible then
        local mousePos = UserInputService:GetMouseLocation()
        -- Tween rápido para o tooltip seguir o mouse suavemente
        TweenService:Create(TooltipFrame, TweenInfo.new(0.05, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
            Position = UDim2.new(0, mousePos.X + 15, 0, mousePos.Y + 15)
        }):Play()
    end
end)

-- Adiciona a injeção ao Core da Janela (Assumindo que 'Evok' seja acessível)
function Evok:AttachTooltip(element, text)
    element.MouseEnter:Connect(function() ShowTooltip(text) end)
    element.MouseLeave:Connect(HideTooltip)
    element.SelectionLost:Connect(HideTooltip)
end

-- ============================================================================
-- 2. TAB SYSTEM (Navegação Horizontal Avançada)
-- ============================================================================
function Evok.WindowFunctions:CreateTab(TabName, IconId)
    local Tab = {
        Name = TabName,
        Elements = {},
        LeftColumn = nil,
        RightColumn = nil
    }

    local Window = self -- Referência à instância Window
    
    -- [ BOTAO DA TAB ]
    local TabButton = Evok.Utility.Instance:Create("TextButton", {
        Name = "Tab_" .. TabName,
        Parent = Window.Navigation, -- Vem da Parte 1
        Size = UDim2.new(0, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundTransparency = 1,
        Text = "",
        AutoButtonColor = false
    })

    local TabPadding = Evok.Utility.Instance:Create("UIPadding", {
        Parent = TabButton,
        PaddingLeft = UDim.new(0, 12),
        PaddingRight = UDim.new(0, 12)
    })

    local LayoutGroup = Evok.Utility.Instance:Create("Frame", {
        Name = "Layout",
        Parent = TabButton,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1
    })

    local TabUIList = Evok.Utility.Instance:Create("UIListLayout", {
        Parent = LayoutGroup,
        FillDirection = Enum.FillDirection.Horizontal,
        SortOrder = Enum.SortOrder.LayoutOrder,
        VerticalAlignment = Enum.VerticalAlignment.Center,
        Padding = UDim.new(0, 6)
    })

    if IconId then
        local TabIcon = Evok.Utility.Instance:Create("ImageLabel", {
            Name = "Icon",
            Parent = LayoutGroup,
            Size = UDim2.new(0, 16, 0, 16),
            BackgroundTransparency = 1,
            Image = IconId,
            ImageColor3 = Evok.ThemeManager:GetColor("TextDark")
        })
        Tab.IconObj = TabIcon
    end

    local TabLabel = Evok.Utility.Instance:Create("TextLabel", {
        Name = "Title",
        Parent = LayoutGroup,
        Size = UDim2.new(0, 0, 1, 0),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundTransparency = 1,
        Text = TabName,
        TextColor3 = Evok.ThemeManager:GetColor("TextDark"),
        Font = Evok.Fonts.Semibold,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Center
    })
    Tab.LabelObj = TabLabel

    -- Indicador inferior (Highlight Line)
    local Highlight = Evok.Utility.Instance:Create("Frame", {
        Name = "Highlight",
        Parent = TabButton,
        Size = UDim2.new(0, 0, 0, 2), -- Inicia com tamanho 0
        Position = UDim2.new(0.5, 0, 1, -2),
        AnchorPoint = Vector2.new(0.5, 0),
        BackgroundColor3 = Evok.ThemeManager:GetColor("Accent"),
        BorderSizePixel = 0
    })
    Tab.HighlightObj = Highlight

    -- [ PÁGINA (CONTEÚDO DA TAB) ]
    local Page = Evok.Utility.Instance:Create("ScrollingFrame", {
        Name = "Page_" .. TabName,
        Parent = Window.Pages, -- Vem da Parte 1
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ScrollBarThickness = 0,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        Visible = false
    })
    Tab.PageObj = Page

    local PagePadding = Evok.Utility.Instance:Create("UIPadding", {
        Parent = Page,
        PaddingLeft = UDim.new(0, 5),
        PaddingRight = UDim.new(0, 5),
        PaddingTop = UDim.new(0, 5),
        PaddingBottom = UDim.new(0, 5)
    })

    -- Layout em duas colunas (Padrão de UI Library Profissional)
    local ColumnsLayout = Evok.Utility.Instance:Create("UIListLayout", {
        Parent = Page,
        FillDirection = Enum.FillDirection.Horizontal,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 10)
    })

    local LeftColumn = Evok.Utility.Instance:Create("Frame", {
        Name = "LeftColumn",
        Parent = Page,
        Size = UDim2.new(0.5, -5, 1, 0),
        BackgroundTransparency = 1
    })

    local RightColumn = Evok.Utility.Instance:Create("Frame", {
        Name = "RightColumn",
        Parent = Page,
        Size = UDim2.new(0.5, -5, 1, 0),
        BackgroundTransparency = 1
    })

    Evok.Utility.Instance:Create("UIListLayout", {
        Parent = LeftColumn,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 8)
    })

    Evok.Utility.Instance:Create("UIListLayout", {
        Parent = RightColumn,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 8)
    })

    Tab.LeftColumn = LeftColumn
    Tab.RightColumn = RightColumn

    -- Atualizador de CanvasSize dinâmico
    local function UpdateCanvas()
        local leftSize = 0
        local rightSize = 0
        
        for _, child in ipairs(LeftColumn:GetChildren()) do
            if child:IsA("GuiObject") then leftSize = leftSize + child.AbsoluteSize.Y + 8 end
        end
        for _, child in ipairs(RightColumn:GetChildren()) do
            if child:IsA("GuiObject") then rightSize = rightSize + child.AbsoluteSize.Y + 8 end
        end
        
        local maxSize = math.max(leftSize, rightSize)
        Page.CanvasSize = UDim2.new(0, 0, 0, maxSize + 15)
    end

    LeftColumn.ChildAdded:Connect(UpdateCanvas)
    RightColumn.ChildAdded:Connect(UpdateCanvas)

    -- [ LÓGICA DE SELEÇÃO DE TAB ]
    TabButton.MouseButton1Click:Connect(function()
        if Window.ActiveTab == TabName then return end

        for _, t in pairs(Window.Tabs) do
            t.PageObj.Visible = false
            TweenService:Create(t.LabelObj, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {TextColor3 = Evok.ThemeManager:GetColor("TextDark")}):Play()
            if t.IconObj then
                TweenService:Create(t.IconObj, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {ImageColor3 = Evok.ThemeManager:GetColor("TextDark")}):Play()
            end
            TweenService:Create(t.HighlightObj, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(0, 0, 0, 2)}):Play()
        end

        Page.Visible = true
        Page.Position = UDim2.new(0, 0, 0, 15)
        Page.GroupTransparency = 1
        
        -- Animação de entrada da página
        TweenService:Create(Page, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0), GroupTransparency = 0}):Play()
        
        TweenService:Create(TabLabel, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {TextColor3 = Evok.ThemeManager:GetColor("Accent")}):Play()
        if TabIcon then
            TweenService:Create(TabIcon, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {ImageColor3 = Evok.ThemeManager:GetColor("Accent")}):Play()
        end
        TweenService:Create(Highlight, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = UDim2.new(1, -10, 0, 2)}):Play()
        
        Window.ActiveTab = TabName
    end)

    -- Efeitos de Hover
    TabButton.MouseEnter:Connect(function()
        if Window.ActiveTab ~= TabName then
            TweenService:Create(TabLabel, TweenInfo.new(0.2), {TextColor3 = Evok.ThemeManager:GetColor("Text")}):Play()
            if TabIcon then TweenService:Create(TabIcon, TweenInfo.new(0.2), {ImageColor3 = Evok.ThemeManager:GetColor("Text")}):Play() end
        end
    end)

    TabButton.MouseLeave:Connect(function()
        if Window.ActiveTab ~= TabName then
            TweenService:Create(TabLabel, TweenInfo.new(0.2), {TextColor3 = Evok.ThemeManager:GetColor("TextDark")}):Play()
            if TabIcon then TweenService:Create(TabIcon, TweenInfo.new(0.2), {ImageColor3 = Evok.ThemeManager:GetColor("TextDark")}):Play() end
        end
    end)

    -- Auto-Select se for a primeira Tab
    if #Window.Tabs == 0 then
        Window.ActiveTab = TabName
        Page.Visible = true
        TabLabel.TextColor3 = Evok.ThemeManager:GetColor("Accent")
        if TabIcon then TabIcon.ImageColor3 = Evok.ThemeManager:GetColor("Accent") end
        Highlight.Size = UDim2.new(1, -10, 0, 2)
    end

    table.insert(Window.Tabs, Tab)

    -- ============================================================================
    -- 3. SECTION SYSTEM (Agrupamento de Configurações)
    -- ============================================================================
