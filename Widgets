    Utility.Create("UIStroke", {
        Color = ThemeManager:GetColor("Border"),
        Thickness = 1,
        Transparency = 0.4,
        Parent = pickerPanel,
    })

    local panelPad = Utility.Create("UIPadding", {
        PaddingAll = UDim.new(0, 8),
        Parent = pickerPanel,
    })

    -- SV gradient square
    local svGradientFrame = Utility.Create("Frame", {
        Name = "SVGradient",
        Size = UDim2.new(1, 0, 0, 100),
        BackgroundColor3 = Color3.fromHSV(h, 1, 1),
        BorderSizePixel = 0,
        Parent = pickerPanel,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = svGradientFrame })

    -- White gradient (left to right: white to transparent)
    local whiteGrad = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
        ZIndex = svGradientFrame.ZIndex + 1,
        Parent = svGradientFrame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = whiteGrad })
    local whiteUIGrad = Utility.Create("UIGradient", {
        Rotation = 0,
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.new(1, 1, 1)),
            ColorSequenceKeypoint.new(1, Color3.new(1, 1, 1)),
        }),
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(1, 1),
        }),
        Parent = whiteGrad,
    })

    -- Black gradient (top to bottom: transparent to black)
    local blackGrad = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Color3.new(0, 0, 0),
        BorderSizePixel = 0,
        ZIndex = svGradientFrame.ZIndex + 2,
        Parent = svGradientFrame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = blackGrad })
    local blackUIGrad = Utility.Create("UIGradient", {
        Rotation = 90,
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.new(0, 0, 0)),
            ColorSequenceKeypoint.new(1, Color3.new(0, 0, 0)),
        }),
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(1, 0),
        }),
        Parent = blackGrad,
    })

    -- SV selector dot
    local svDot = Utility.Create("Frame", {
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new(s, -6, 1 - v, -6),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
        ZIndex = svGradientFrame.ZIndex + 3,
        Parent = svGradientFrame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = svDot })
    Utility.Create("UIStroke", {
        Color = Color3.new(0, 0, 0),
        Thickness = 2,
        Parent = svDot,
    })

    -- Hue bar
    local hueBar = Utility.Create("Frame", {
        Name = "HueBar",
        Size = UDim2.new(1, 0, 0, 12),
        Position = UDim2.new(0, 0, 0, 108),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
        Parent = pickerPanel,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = hueBar })

    -- Hue gradient
    local hueColors = {}
    for i = 0, 6 do
        hueColors[i+1] = ColorSequenceKeypoint.new(i/6, Color3.fromHSV(i/6, 1, 1))
    end
    Utility.Create("UIGradient", {
        Color = ColorSequence.new(hueColors),
        Rotation = 0,
        Parent = hueBar,
    })

    -- Hue selector
    local hueDot = Utility.Create("Frame", {
        Size = UDim2.new(0, 12, 1, 4),
        Position = UDim2.new(h, -6, 0, -2),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
        ZIndex = hueBar.ZIndex + 1,
        Parent = hueBar,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = hueDot })
    Utility.Create("UIStroke", {
        Color = Color3.new(0, 0, 0),
        Thickness = 1,
        Parent = hueDot,
    })

    -- Alpha bar
    local alphaBar = Utility.Create("Frame", {
        Name = "AlphaBar",
        Size = UDim2.new(1, 0, 0, 12),
        Position = UDim2.new(0, 0, 0, 124),
        BorderSizePixel = 0,
        Parent = pickerPanel,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = alphaBar })

    local alphaGrad = Utility.Create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.new(0, 0, 0)),
            ColorSequenceKeypoint.new(1, Color3.new(1, 1, 1)),
        }),
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(1, 0),
        }),
        Parent = alphaBar,
    })

    local alphaDot = Utility.Create("Frame", {
        Size = UDim2.new(0, 12, 1, 4),
        Position = UDim2.new(self._a, -6, 0, -2),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
        ZIndex = alphaBar.ZIndex + 1,
        Parent = alphaBar,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = alphaDot })
    Utility.Create("UIStroke", {
        Color = Color3.new(0, 0, 0),
        Thickness = 1,
        Parent = alphaDot,
    })

    -- Hex input
    local hexRow = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 22),
        Position = UDim2.new(0, 0, 0, 140),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Parent = pickerPanel,
    })

    local hexLabel = Utility.Create("TextLabel", {
        Size = UDim2.new(0, 30, 1, 0),
        BackgroundTransparency = 1,
        Text = "HEX",
        TextColor3 = ThemeManager:GetColor("TextMuted"),
        TextSize = 10,
        Font = Enum.Font.GothamBold,
        Parent = hexRow,
    })

    local hexInput = Utility.Create("TextBox", {
        Size = UDim2.new(1, -34, 1, 0),
        Position = UDim2.new(0, 34, 0, 0),
        BackgroundColor3 = ThemeManager:GetColor("SurfaceHover"),
        BackgroundTransparency = 0.2,
        Text = Utility.Color3ToHex(self._color),
        TextColor3 = ThemeManager:GetColor("TextPrimary"),
        TextSize = 11,
        Font = Enum.Font.Code,
        BorderSizePixel = 0,
        PlaceholderText = "#C77DFF",
        Parent = hexRow,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = hexInput })
    Utility.Create("UIPadding", { PaddingLeft = UDim.new(0, 6), Parent = hexInput })

    -- Total panel height
    local panelHeight = 168
    pickerPanel.Size = UDim2.new(1, 0, 0, 0)

    self._swatch     = swatch
    self._svFrame    = svGradientFrame
    self._svDot      = svDot
    self._hueBar     = hueBar
    self._hueDot     = hueDot
    self._alphaBar   = alphaBar
    self._alphaDot   = alphaDot
    self._hexInput   = hexInput
    self._frame      = frame
    self._panel      = pickerPanel

    -- Internal update
    local function fireCallback()
        local color = Color3.fromHSV(self._h, self._s, self._v)
        self._color = color
        swatch.BackgroundColor3 = color
        svGradientFrame.BackgroundColor3 = Color3.fromHSV(self._h, 1, 1)
        svDot.Position = UDim2.new(self._s, -6, 1 - self._v, -6)
        hueDot.Position = UDim2.new(self._h, -6, 0, -2)
        hexInput.Text = Utility.Color3ToHex(color)

        -- Update alpha gradient
        alphaGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromHSV(self._h, self._s, self._v)),
            ColorSequenceKeypoint.new(1, Color3.fromHSV(self._h, self._s, self._v)),
        })

        if self._callback then
            task.spawn(self._callback, color, self._a)
        end
    end

    -- SV drag
    local svDragging = false
    svGradientFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = true
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if svDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local rel = svGradientFrame.AbsolutePosition
            local sz  = svGradientFrame.AbsoluteSize
            self._s = math.clamp((input.Position.X - rel.X) / sz.X, 0, 1)
            self._v = 1 - math.clamp((input.Position.Y - rel.Y) / sz.Y, 0, 1)
            fireCallback()
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = false
        end
    end)

    -- Hue drag
    local hueDragging = false
    hueBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = true
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if hueDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local rel = hueBar.AbsolutePosition
            local sz  = hueBar.AbsoluteSize
            self._h = math.clamp((input.Position.X - rel.X) / sz.X, 0, 1)
            fireCallback()
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = false
        end
    end)

    -- Alpha drag
    local alphaDragging = false
    alphaBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            alphaDragging = true
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if alphaDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local rel = alphaBar.AbsolutePosition
            local sz  = alphaBar.AbsoluteSize
            self._a = math.clamp((input.Position.X - rel.X) / sz.X, 0, 1)
            alphaDot.Position = UDim2.new(self._a, -6, 0, -2)
            fireCallback()
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            alphaDragging = false
        end
    end)

    -- Hex input
    hexInput.FocusLost:Connect(function(enter)
        if enter then
            local hex = hexInput.Text
            local ok, color = pcall(Utility.HexToColor3, hex)
            if ok then
                self:SetColor(color)
            end
        end
    end)

    -- Toggle panel
    swatchBtn.MouseButton1Click:Connect(function()
        if not self._enabled then return end
        self._open = not self._open
        if self._open then
            frame.Size = UDim2.new(1, 0, 0, 26 + panelHeight + 8)
            pickerPanel.Visible = true
            pickerPanel.Size = UDim2.new(1, 0, 0, 0)
            Utility.TweenObject(pickerPanel, { Size = UDim2.new(1, 0, 0, panelHeight) }, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
        else
            Utility.TweenObject(pickerPanel, { Size = UDim2.new(1, 0, 0, 0) }, 0.2)
            task.delay(0.22, function()
                pickerPanel.Visible = false
                frame.Size = UDim2.new(1, 0, 0, 24)
            end)
        end
    end)

    function self:SetColor(color, silent)
        self._color = color
        local nh, ns, nv = Color3.toHSV(color)
        self._h = nh
        self._s = ns
        self._v = nv
        swatch.BackgroundColor3 = color
        svGradientFrame.BackgroundColor3 = Color3.fromHSV(nh, 1, 1)
        svDot.Position = UDim2.new(ns, -6, 1 - nv, -6)
        hueDot.Position = UDim2.new(nh, -6, 0, -2)
        hexInput.Text = Utility.Color3ToHex(color)
        if not silent and self._callback then
            task.spawn(self._callback, color, self._a)
        end
    end

    function self:GetColor()
        return self._color
    end

    function self:GetAlpha()
        return self._a
    end

    return self
end

