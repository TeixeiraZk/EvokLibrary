Core.Tooltip = { Instance = nil, Active = false }

function Core:InitTooltip()
    if self.Tooltip.Instance or not self.GUI then return end

    local TooltipFrame = Instance.new("Frame")
    TooltipFrame.Name = "EvokTooltip"
    TooltipFrame.Size = UDim2.new(0, 0, 0, 25)
    TooltipFrame.AutomaticSize = Enum.AutomaticSize.X
    TooltipFrame.BackgroundColor3 = self.Themes.NotificationBg
    TooltipFrame.Visible = false
    TooltipFrame.ZIndex = 9990
    TooltipFrame.Parent = self.GUI

    Instance.new("UICorner", TooltipFrame).CornerRadius = UDim.new(0, 4)
    local TStroke = Instance.new("UIStroke", TooltipFrame)
    TStroke.Color = self.Themes.Border

    local TPadding = Instance.new("UIPadding", TooltipFrame)
    TPadding.PaddingLeft = UDim.new(0, 8)
    TPadding.PaddingRight = UDim.new(0, 8)

    local TLabel = Instance.new("TextLabel")
    TLabel.Size = UDim2.new(1, 0, 1, 0)
    TLabel.BackgroundTransparency = 1
    TLabel.Text = ""
    TLabel.TextColor3 = self.Themes.Text
    TLabel.Font = Enum.Font.Gotham
    TLabel.TextSize = 12
    TLabel.Parent = TooltipFrame

    self:SubscribeToTheme(function(theme)
        TooltipFrame.BackgroundColor3 = theme.NotificationBg
        TStroke.Color = theme.Border
        TLabel.TextColor3 = theme.Text
    end)

    self.Tooltip.Instance = TooltipFrame
    self.Tooltip.Label = TLabel

    RunService.RenderStepped:Connect(function()
        if self.Tooltip.Active and self.Tooltip.Instance then
            local mouseLoc = UserInputService:GetMouseLocation()
            self.Tooltip.Instance.Position = UDim2.new(0, mouseLoc.X + 15, 0, mouseLoc.Y - 36 + 15)
        end
    end)
end

function Core:AddTooltip(uiElement: Instance, text: string)
    if not self.Tooltip.Instance then self:InitTooltip() end

    uiElement.MouseEnter:Connect(function()
        self.Tooltip.Active = true
        self.Tooltip.Label.Text = text
        self.Tooltip.Instance.Visible = true
        self.Tooltip.Instance.BackgroundTransparency = 1
        self.Tooltip.Label.TextTransparency = 1
        
        self:Tween(self.Tooltip.Instance, {BackgroundTransparency = 0}, 0.2)
        self:Tween(self.Tooltip.Label, {TextTransparency = 0}, 0.2)
    end)

    uiElement.MouseLeave:Connect(function()
        self.Tooltip.Active = false
        self.Tooltip.Instance.Visible = false
    end)
end

