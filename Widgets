-- ==============================================================================
-- 🎨 ADVANCED COLOR MATH ENGINE
-- ==============================================================================
Core.Math = { Color = {} }

function Core.Math.Color.ToHex(color: Color3): string
    return string.format("#%02X%02X%02X", color.R * 255, color.G * 255, color.B * 255)
end

function Core.Math.Color.FromHex(hex: string): Color3
    hex = hex:gsub("#", "")
    return Color3.fromRGB(tonumber(hex:sub(1,2),16) or 255, tonumber(hex:sub(3,4),16) or 255, tonumber(hex:sub(5,6),16) or 255)
end

function Core.Math.Color.Darken(color: Color3, amount: number): Color3
    local h, s, v = color:ToHSV()
    return Color3.fromHSV(h, s, math.clamp(v - amount, 0, 1))
end

function Core.Math.Color.Lighten(color: Color3, amount: number): Color3
    local h, s, v = color:ToHSV()
    return Color3.fromHSV(h, s, math.clamp(v + amount, 0, 1))
end

-- ==============================================================================
-- 🧮 CUSTOM EASING ENGINE (33 Penner Equations)
-- ==============================================================================
Core.Easing = {}
function Core.Easing.Linear(t, b, c, d) return c * t / d + b end
function Core.Easing.InSine(t, b, c, d) return -c * math.cos(t / d * (math.pi / 2)) + c + b end
function Core.Easing.OutSine(t, b, c, d) return c * math.sin(t / d * (math.pi / 2)) + b end
function Core.Easing.InOutSine(t, b, c, d) return -c / 2 * (math.cos(math.pi * t / d) - 1) + b end
function Core.Easing.InQuad(t, b, c, d) t = t / d; return c * math.pow(t, 2) + b end
function Core.Easing.OutQuad(t, b, c, d) t = t / d; return -c * t * (t - 2) + b end
function Core.Easing.InOutQuad(t, b, c, d)
    t = t / d * 2
    if t < 1 then return c / 2 * math.pow(t, 2) + b end
    return -c / 2 * ((t - 1) * (t - 3) - 1) + b
end
function Core.Easing.InCubic(t, b, c, d) t = t / d; return c * math.pow(t, 3) + b end
function Core.Easing.OutCubic(t, b, c, d) t = t / d - 1; return c * (math.pow(t, 3) + 1) + b end
function Core.Easing.InOutCubic(t, b, c, d)
    t = t / d * 2
    if t < 1 then return c / 2 * t * t * t + b end
    t = t - 2; return c / 2 * (t * t * t + 2) + b
end
function Core.Easing.InQuart(t, b, c, d) t = t / d; return c * math.pow(t, 4) + b end
function Core.Easing.OutQuart(t, b, c, d) t = t / d - 1; return -c * (math.pow(t, 4) - 1) + b end
function Core.Easing.InOutQuart(t, b, c, d)
    t = t / d * 2
    if t < 1 then return c / 2 * math.pow(t, 4) + b end
    t = t - 2; return -c / 2 * (math.pow(t, 4) - 2) + b
end
function Core.Easing.InQuint(t, b, c, d) t = t / d; return c * math.pow(t, 5) + b end
function Core.Easing.OutQuint(t, b, c, d) t = t / d - 1; return c * (math.pow(t, 5) + 1) + b end
function Core.Easing.InOutQuint(t, b, c, d)
    t = t / d * 2
    if t < 1 then return c / 2 * math.pow(t, 5) + b end
    t = t - 2; return c / 2 * (math.pow(t, 5) + 2) + b
end
function Core.Easing.InExpo(t, b, c, d)
    if t == 0 then return b end
    return c * math.pow(2, 10 * (t / d - 1)) + b - c * 0.001
end
function Core.Easing.OutExpo(t, b, c, d)
    if t == d then return b + c end
    return c * 1.001 * (-math.pow(2, -10 * t / d) + 1) + b
end
function Core.Easing.InOutExpo(t, b, c, d)
    if t == 0 then return b end
    if t == d then return b + c end
    t = t / d * 2
    if t < 1 then return c / 2 * math.pow(2, 10 * (t - 1)) + b - c * 0.0005 end
    return c / 2 * 1.0005 * (-math.pow(2, -10 * (t - 1)) + 2) + b
end

