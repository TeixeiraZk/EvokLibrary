--// KEYBIND WIDGET
--// ============================================================

local Keybind = {}
Keybind.__index = Keybind

function Keybind.new(section, text, defaultKey, callback, options)
    local self = setmetatable({}, Keybind)
    options = options or {}

    self._key      = defaultKey
    self._callback = callback
    self._mode     = options.Mode or "Toggle"   -- Toggle | Hold | Click
    self._enabled  = true
    self._listening= false
    self._held     = false
    self._active   = false

    -- Row frame
    local frame = Utility.Create("Frame", {
        Name = "KeybindFrame",
        Size = UDim2.new(1, 0, 0, 24),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        LayoutOrder = #section.Content:GetChildren(),
        Parent = section.Content,
    })

    local labelText = Utility.Create("TextLabel", {
        Size = UDim2.new(1, -70, 1, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = ThemeManager:GetColor("TextSecondary"),
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
    })

    local keyBox = Utility.Create("Frame", {
        Size = UDim2.new(0, 64, 0, 18),
        Position = UDim2.new(1, -64, 0.5, -9),
        BackgroundColor3 = ThemeManager:GetColor("SurfaceHover"),
        BackgroundTransparency = 0.3,
        BorderSizePixel = 0,
        Parent = frame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = keyBox })
    Utility.Create("UIStroke", {
        Color = ThemeManager:GetColor("Border"),
        Thickness = 1,
        Transparency = 0.4,
        Parent = keyBox,
    })

    local function getKeyName()
        if self._key then
            return Utility.KeycodeToString(self._key)
        end
        return "None"
    end

    local keyLabel = Utility.Create("TextLabel", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "[" .. getKeyName() .. "]",
        TextColor3 = ThemeManager:GetColor("Primary"),
        TextSize = 10,
        Font = Enum.Font.GothamBold,
        Parent = keyBox,
    })

    local keyBtn = Utility.Create("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = keyBox.ZIndex + 1,
        Parent = keyBox,
    })

    self._frame   = frame
    self._keyBox  = keyBox
    self._keyLabel= keyLabel

    keyBtn.MouseButton1Click:Connect(function()
        if not self._enabled then return end
        if self._listening then return end

        self._listening = true
        keyLabel.Text = "..."
        keyLabel.TextColor3 = ThemeManager:GetColor("Warning")
        Utility.TweenObject(keyBox, { BackgroundTransparency = 0.1 }, 0.2)

        local conn
        conn = UserInputService.InputBegan:Connect(function(input, gp)
            if gp then return end
            if input.UserInputType == Enum.UserInputType.Keyboard then
                self:SetKeybind(input.KeyCode)
                conn:Disconnect()
                self._listening = false
                Utility.TweenObject(keyBox, { BackgroundTransparency = 0.3 }, 0.2)
            elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
                -- Cancel
                conn:Disconnect()
                self._listening = false
                keyLabel.Text = "[" .. getKeyName() .. "]"
                keyLabel.TextColor3 = ThemeManager:GetColor("Primary")
                Utility.TweenObject(keyBox, { BackgroundTransparency = 0.3 }, 0.2)
            end
        end)
    end)

    -- Listen for keybind activation
    UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end
        if not self._enabled or self._listening then return end
        if input.KeyCode ~= self._key then return end

        if self._mode == "Toggle" then
            self._active = not self._active
            if self._callback then
                task.spawn(self._callback, self._active)
            end
        elseif self._mode == "Hold" then
            self._held = true
            self._active = true
            if self._callback then
                task.spawn(self._callback, true)
            end
        elseif self._mode == "Click" then
            if self._callback then
                task.spawn(self._callback)
            end
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if not self._enabled or self._listening then return end
        if input.KeyCode ~= self._key then return end
        if self._mode == "Hold" and self._held then
            self._held = false
            self._active = false
            if self._callback then
                task.spawn(self._callback, false)
            end
        end
    end)

    function self:SetKeybind(key)
        self._key = key
        keyLabel.Text = "[" .. getKeyName() .. "]"
        keyLabel.TextColor3 = ThemeManager:GetColor("Primary")
    end

    function self:GetKeybind()
        return self._key
    end

    function self:SetMode(mode)
        self._mode = mode
    end

    function self:SetEnabled(enabled)
        self._enabled = enabled
        Utility.TweenObject(keyBox, { BackgroundTransparency = enabled and 0.3 or 0.6 }, 0.2)
        labelText.TextTransparency = enabled and 0 or 0.4
    end

    return self
end

