        })

        Evok.Utility.Instance:CreateRound(6).Parent = SectionFrame
        Evok.Utility.Instance:CreateStroke(Evok.ThemeManager:GetColor("Border"), 1).Parent = SectionFrame

        local SectionPadding = Evok.Utility.Instance:Create("UIPadding", {
            Parent = SectionFrame,
            PaddingLeft = UDim.new(0, 10),
            PaddingRight = UDim.new(0, 10),
            PaddingTop = UDim.new(0, 8),
