		Size = UDim2.new(1, -8, 1, 0),
		Position = UDim2.new(0, 8, 0, 0),
		Font = Enum.Font.Gotham,
		Text = Option,
		TextColor3 = ThemeManager.CurrentTheme.TextColor,
		TextSize = 11,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Button
	})

	Button.MouseEnter:Connect(function()
		Utility.TweenObject(Button, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 0.86
		})
	end)

	Button.MouseLeave:Connect(function()
		Utility.TweenObject(Button, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 1
		})
	end)

	Button.Activated:Connect(function()
		self:SelectOption(Option)
	end)
end

function Dropdown:RemoveOption(Option)
	for _, Child in ipairs(self.List:GetChildren()) do
		if Child:IsA("TextButton") and Child:FindFirstChildOfClass("TextLabel") and Child:FindFirstChildOfClass("TextLabel").Text == Option then
			Child:Destroy()
		end
	end
end

function Dropdown:SelectOption(Option)
	self.Selected = Option
	self.SelectedLabel.Text = tostring(Option)

	if self.Callback then
		task.spawn(self.Callback, Option)
	end

	self:Close()
end

function Dropdown:Toggle()
	if self.Open then
		self:Close()
	else
		self:OpenDropdown()
	end
end

function Dropdown:OpenDropdown()
	self.Open = true
	local TargetHeight = math.min(#self.List:GetChildren() * 28 + 4, 140)
	Utility.TweenObject(self.List, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Size = UDim2.new(1, -10, 0, TargetHeight)
	})
	Utility.TweenObject(self.Arrow, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Rotation = 180
	})
	Utility.TweenObject(self.Frame, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Size = UDim2.new(1, -4, 0, 44 + TargetHeight)
	})
end

function Dropdown:Close()
	self.Open = false
	Utility.TweenObject(self.List, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Size = UDim2.new(1, -10, 0, 0)
	})
	Utility.TweenObject(self.Arrow, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Rotation = 0
	})
	Utility.TweenObject(self.Frame, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Size = UDim2.new(1, -4, 0, 44)
	})
end

return Dropdown

