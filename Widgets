                Instance.new("UIStroke", DisplayColor).Color = Core.Themes.Border

                local MapContainer = Instance.new("Frame")
                MapContainer.Size = UDim2.new(1, 0, 0, 160)
                MapContainer.Position = UDim2.new(0, 0, 0, 35)
                MapContainer.BackgroundTransparency = 1
                MapContainer.Parent = CPFrame

                local SatValMap = Instance.new("ImageLabel")
                SatValMap.Size = UDim2.new(1, -45, 0, 110)
                SatValMap.Position = UDim2.new(0, 10, 0, 10)
                SatValMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                SatValMap.Image = "rbxassetid://4155801252"
                SatValMap.Parent = MapContainer
                Instance.new("UICorner", SatValMap).CornerRadius = UDim.new(0, 4)

                local MapCursor = Instance.new("Frame")
                MapCursor.Size = UDim2.new(0, 10, 0, 10)
                MapCursor.AnchorPoint = Vector2.new(0.5, 0.5)
                MapCursor.Position = UDim2.new(s, 0, 1 - v, 0)
                MapCursor.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                MapCursor.Parent = SatValMap
                Instance.new("UICorner", MapCursor).CornerRadius = UDim.new(1, 0)
                Instance.new("UIStroke", MapCursor).Color = Color3.fromRGB(0, 0, 0)

                local HueBar = Instance.new("Frame")
                HueBar.Size = UDim2.new(0, 15, 0, 110)
                HueBar.Position = UDim2.new(1, -25, 0, 10)
                HueBar.Parent = MapContainer
                Instance.new("UICorner", HueBar).CornerRadius = UDim.new(0, 4)
                
                local UIGradient = Instance.new("UIGradient")
                UIGradient.Rotation = 90
                UIGradient.Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
                    ColorSequenceKeypoint.new(0.167, Color3.fromRGB(255, 255, 0)),
                    ColorSequenceKeypoint.new(0.333, Color3.fromRGB(0, 255, 0)),
                    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
                    ColorSequenceKeypoint.new(0.667, Color3.fromRGB(0, 0, 255)),
                    ColorSequenceKeypoint.new(0.833, Color3.fromRGB(255, 0, 255)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
                })
                UIGradient.Parent = HueBar

                local HueCursor = Instance.new("Frame")
                HueCursor.Size = UDim2.new(1, 4, 0, 4)
                HueCursor.Position = UDim2.new(0, -2, 1 - h, -2)
                HueCursor.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                HueCursor.Parent = HueBar
                Instance.new("UICorner", HueCursor).CornerRadius = UDim.new(0, 2)
                Instance.new("UIStroke", HueCursor).Color = Color3.fromRGB(0, 0, 0)

                local HexInput = Instance.new("TextBox")
                HexInput.Size = UDim2.new(1, -20, 0, 25)
                HexInput.Position = UDim2.new(0, 10, 0, 125)
                HexInput.BackgroundColor3 = Core.Themes.Container
                HexInput.TextColor3 = Core.Themes.Text
                HexInput.Font = Enum.Font.Gotham
                HexInput.TextSize = 12
                HexInput.Text = Core.Math.Color.ToHex(ColorP.Color)
                HexInput.Parent = MapContainer
                Instance.new("UICorner", HexInput).CornerRadius = UDim.new(0, 4)
                local HexStroke = Instance.new("UIStroke", HexInput)
                HexStroke.Color = Core.Themes.Border

                local function UpdateColor()
                    ColorP.Color = Color3.fromHSV(h, s, v)
                    DisplayColor.BackgroundColor3 = ColorP.Color
                    SatValMap.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                    HexInput.Text = Core.Math.Color.ToHex(ColorP.Color)
                    callback(ColorP.Color)
                end

                local trackingMap, trackingHue = false, false

                SatValMap.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then trackingMap = true end
                end)
                HueBar.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then trackingHue = true end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        trackingMap, trackingHue = false, false
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseMovement then
                        if trackingMap then
                            local x = math.clamp((input.Position.X - SatValMap.AbsolutePosition.X) / SatValMap.AbsoluteSize.X, 0, 1)
                            local y = math.clamp((input.Position.Y - SatValMap.AbsolutePosition.Y) / SatValMap.AbsoluteSize.Y, 0, 1)
                            s, v = x, 1 - y
                            MapCursor.Position = UDim2.new(x, 0, y, 0)
                            UpdateColor()
                        elseif trackingHue then
                            local y = math.clamp((input.Position.Y - HueBar.AbsolutePosition.Y) / HueBar.AbsoluteSize.Y, 0, 1)
                            h = 1 - y
                            HueCursor.Position = UDim2.new(0, -2, y, -2)
                            UpdateColor()
                        end
                    end
                end)

                HexInput.FocusLost:Connect(function()
                    local success, newColor = pcall(function() return Core.Math.Color.FromHex(HexInput.Text) end)
                    if success then
                        h, s, v = newColor:ToHSV()
                        MapCursor.Position = UDim2.new(s, 0, 1 - v, 0)
                        HueCursor.Position = UDim2.new(0, -2, 1 - h, -2)
                        UpdateColor()
                    else
                        HexInput.Text = Core.Math.Color.ToHex(ColorP.Color) 
                    end
                end)

                MainBtn.MouseButton1Click:Connect(function()
                    ColorP.Open = not ColorP.Open
                    SecFrame.ZIndex = ColorP.Open and 5 or 1
                    CPFrame.ZIndex = ColorP.Open and 5 or 1
                    Core:Tween(CPFrame, {Size = ColorP.Open and UDim2.new(1, 0, 0, 195) or UDim2.new(1, 0, 0, 35)}, 0.25, Enum.EasingStyle.Quint)
                end)

                Core:SubscribeToTheme(function(theme)
                    CPFrame.BackgroundColor3 = theme.Background
                    CPStroke.Color = theme.Border
                    Label.TextColor3 = theme.TextMuted
                    HexInput.BackgroundColor3 = theme.Container
                    HexInput.TextColor3 = theme.Text
                    HexStroke.Color = theme.Border
                end)

                return ColorP
            end

            -- ==============================================================================
            -- ⌨️ WIDGET: KEYBIND
            -- ==============================================================================
            function Section:CreateKeybind(opts)
                local Keybind = { Key = opts.Default or Enum.KeyCode.Unknown, Listening = false }
                local callback = opts.Callback or function() end

                local KeyFrame = Instance.new("Frame")
                KeyFrame.Size = UDim2.new(1, 0, 0, 30)
                KeyFrame.BackgroundTransparency = 1
                KeyFrame.Parent = SecFrame

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -80, 1, 0)
                Label.BackgroundTransparency = 1
                Label.Text = opts.Name
                Label.TextColor3 = Core.Themes.TextMuted
                Label.Font = Enum.Font.Gotham
                Label.TextSize = 13
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = KeyFrame

                local BindBtn = Instance.new("TextButton")
                BindBtn.Size = UDim2.new(0, 70, 0, 22)
                BindBtn.Position = UDim2.new(1, -70, 0.5, -11)
                BindBtn.BackgroundColor3 = Core.Themes.Background
                BindBtn.Text = Keybind.Key == Enum.KeyCode.Unknown and "None" or Keybind.Key.Name
                BindBtn.TextColor3 = Core.Themes.Text
                BindBtn.Font = Enum.Font.Gotham
                BindBtn.TextSize = 12
                BindBtn.Parent = KeyFrame
                Instance.new("UICorner", BindBtn).CornerRadius = UDim.new(0, 4)
                local BindStroke = Instance.new("UIStroke", BindBtn)
                BindStroke.Color = Core.Themes.Border

                BindBtn.MouseButton1Click:Connect(function()
                    Keybind.Listening = true
                    BindBtn.Text = "..."
                    Core:Tween(BindStroke, {Color = Core.Themes.Accent}, 0.2)
                end)

                UserInputService.InputBegan:Connect(function(input, gpe)
                    if Keybind.Listening and input.UserInputType == Enum.UserInputType.Keyboard then
                        local key = input.KeyCode
                        if key == Enum.KeyCode.Escape or key == Enum.KeyCode.Backspace then
                            Keybind.Key = Enum.KeyCode.Unknown
                            BindBtn.Text = "None"
                        else
                            Keybind.Key = key
                            BindBtn.Text = key.Name
                        end
                        Keybind.Listening = false
                        Core:Tween(BindStroke, {Color = Core.Themes.Border}, 0.2)
                    elseif not gpe and input.KeyCode == Keybind.Key and Keybind.Key ~= Enum.KeyCode.Unknown then
                        callback(Keybind.Key)
                    end
                end)

                Core:SubscribeToTheme(function(theme)
                    Label.TextColor3 = theme.TextMuted
                    BindBtn.BackgroundColor3 = theme.Background
                    BindBtn.TextColor3 = theme.Text
                    if not Keybind.Listening then
                        BindStroke.Color = theme.Border
                    else
                        BindStroke.Color = theme.Accent
                    end
                end)

                return Keybind
            end

            return Section
        end

        return Tab
    end
end

return Widgets
