            -- ==============================================================================
            -- 🟩 WIDGET: BUTTON (Com Ripple, Cooldown e Tooltip)
            -- ==============================================================================
            function Section:CreateButton(opts: ButtonConfig)
                local Button = { Locked = false }
                local callback = opts.Callback or function() end
                
                local BtnFrame = Instance.new("Frame")
                BtnFrame.Size = UDim2.new(1, 0, 0, 32)
                BtnFrame.BackgroundColor3 = Core.Themes.Background
                BtnFrame.Parent = SecFrame
                Instance.new("UICorner", BtnFrame).CornerRadius = UDim.new(0, 6)
                local BtnStroke = Instance.new("UIStroke", BtnFrame)
                BtnStroke.Color = Core.Themes.Border
                
                local ClickBtn = Instance.new("TextButton")
                ClickBtn.Size = UDim2.new(1, 0, 1, 0)
                ClickBtn.BackgroundTransparency = 1
                ClickBtn.Text = opts.Name or "Button"
                ClickBtn.TextColor3 = Core.Themes.Text
                ClickBtn.Font = Enum.Font.GothamSemibold
                ClickBtn.TextSize = 13
                ClickBtn.ClipsDescendants = true
                ClickBtn.AutoButtonColor = false
                ClickBtn.Parent = BtnFrame
                Instance.new("UICorner", ClickBtn).CornerRadius = UDim.new(0, 6)

                if opts.Tooltip then Core:AddTooltip(ClickBtn, opts.Tooltip) end

                ClickBtn.MouseEnter:Connect(function()
                    if not Button.Locked then
                        Core:Tween(BtnStroke, {Color = Core.Themes.Accent}, 0.2)
                        Core:Tween(BtnFrame, {BackgroundColor3 = Core.Math.Color.Lighten(Core.Themes.Background, 0.05)}, 0.2)
                    end
                end)

                ClickBtn.MouseLeave:Connect(function()
                    if not Button.Locked then
                        Core:Tween(BtnStroke, {Color = Core.Themes.Border}, 0.2)
                        Core:Tween(BtnFrame, {BackgroundColor3 = Core.Themes.Background}, 0.2)
                    end
                end)

                ClickBtn.MouseButton1Click:Connect(function()
                    if Button.Locked then return end
                    CreateRipple(ClickBtn, Core.Themes.Accent)
                    task.spawn(callback)
                    
                    if opts.Cooldown and opts.Cooldown > 0 then
                        Button.Locked = true
                        local originalText = ClickBtn.Text
                        ClickBtn.Text = "Processing..."
                        Core:Tween(BtnStroke, {Color = Core.Themes.Border}, 0.2)
                        Core:Tween(ClickBtn, {TextColor3 = Core.Themes.TextMuted}, 0.2)
                        
                        task.wait(opts.Cooldown)
                        
                        Button.Locked = false
                        ClickBtn.Text = originalText
                        Core:Tween(ClickBtn, {TextColor3 = Core.Themes.Text}, 0.2)
                    end
                end)

                Core:SubscribeToTheme(function(theme)
                    BtnFrame.BackgroundColor3 = theme.Background
                    ClickBtn.TextColor3 = theme.Text
                    if not Button.Locked then BtnStroke.Color = theme.Border end
                end)

                return Button
            end

            -- ==============================================================================
            -- 🔘 WIDGET: TOGGLE (Switch Material Design)
            -- ==============================================================================
            function Section:CreateToggle(opts: ToggleConfig)
                local Toggle = { State = opts.Default or false }
                local callback = opts.Callback or function() end

                local ToggleBtn = Instance.new("TextButton")
                ToggleBtn.Size = UDim2.new(1, 0, 0, 26)
                ToggleBtn.BackgroundTransparency = 1
                ToggleBtn.Text = ""
                ToggleBtn.AutoButtonColor = false
                ToggleBtn.Parent = SecFrame

                if opts.Tooltip then Core:AddTooltip(ToggleBtn, opts.Tooltip) end

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -45, 1, 0)
                Label.BackgroundTransparency = 1
                Label.Text = opts.Name
                Label.TextColor3 = Toggle.State and Core.Themes.Text or Core.Themes.TextMuted
                Label.Font = Enum.Font.Gotham
                Label.TextSize = 13
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = ToggleBtn

                local Outer = Instance.new("Frame")
                Outer.Size = UDim2.new(0, 40, 0, 20)
                Outer.AnchorPoint = Vector2.new(1, 0.5)
                Outer.Position = UDim2.new(1, 0, 0.5, 0)
                Outer.BackgroundColor3 = Toggle.State and Core.Themes.Accent or Core.Themes.Background
                Outer.Parent = ToggleBtn
                Instance.new("UICorner", Outer).CornerRadius = UDim.new(1, 0)
                local OuterStroke = Instance.new("UIStroke", Outer)
                OuterStroke.Color = Toggle.State and Core.Themes.Accent or Core.Themes.Border

                local Inner = Instance.new("Frame")
                Inner.Size = UDim2.new(0, 14, 0, 14)
                Inner.Position = Toggle.State and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)
                Inner.BackgroundColor3 = Toggle.State and Color3.fromRGB(255, 255, 255) or Core.Themes.TextMuted
                Inner.Parent = Outer
                Instance.new("UICorner", Inner).CornerRadius = UDim.new(1, 0)

                function Toggle:Set(newState: boolean, skipCallback: boolean)
                    Toggle.State = newState
                    
                    local targetColor = Toggle.State and Core.Themes.Accent or Core.Themes.Background
                    local targetPos = Toggle.State and UDim2.new(1, -17, 0.5, -7) or UDim2.new(0, 3, 0.5, -7)
                    local targetInnerColor = Toggle.State and Color3.fromRGB(255, 255, 255) or Core.Themes.TextMuted
                    
                    Core:Tween(Outer, {BackgroundColor3 = targetColor}, 0.25, Enum.EasingStyle.Quad)
                    Core:Tween(OuterStroke, {Color = Toggle.State and Core.Themes.Accent or Core.Themes.Border}, 0.25)
                    Core:Tween(Inner, {Position = targetPos, BackgroundColor3 = targetInnerColor}, 0.3, Enum.EasingStyle.Back)
                    Core:Tween(Label, {TextColor3 = Toggle.State and Core.Themes.Text or Core.Themes.TextMuted}, 0.2)
                    
                    if not skipCallback then task.spawn(callback, Toggle.State) end
                end

                ToggleBtn.MouseButton1Click:Connect(function() Toggle:Set(not Toggle.State) end)

                Core:SubscribeToTheme(function(theme)
                    if Toggle.State then
                        Outer.BackgroundColor3 = theme.Accent
                        OuterStroke.Color = theme.Accent
                        Label.TextColor3 = theme.Text
                        Inner.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                    else
                        Outer.BackgroundColor3 = theme.Background
                        OuterStroke.Color = theme.Border
                        Label.TextColor3 = theme.TextMuted
                        Inner.BackgroundColor3 = theme.TextMuted
                    end
                end)

                if Toggle.State then task.spawn(callback, true) end
                return Toggle
            end

            -- ==============================================================================
            -- 🎚️ WIDGET: SLIDER (Com Botões Plus/Minus Integrados)
            -- ==============================================================================
            function Section:CreateSlider(opts: SliderConfig)
                local min, max = opts.Min or 0, opts.Max or 100
                local step = opts.Step or 1
                local Slider = { Value = math.clamp(opts.Default or min, min, max) }
                local callback = opts.Callback or function() end

                local SliderFrame = Instance.new("Frame")
                SliderFrame.Size = UDim2.new(1, 0, 0, 48)
                SliderFrame.BackgroundTransparency = 1
                SliderFrame.Parent = SecFrame

                if opts.Tooltip then Core:AddTooltip(SliderFrame, opts.Tooltip) end

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -90, 0, 20)
                Label.BackgroundTransparency = 1
                Label.Text = opts.Name
                Label.TextColor3 = Core.Themes.TextMuted
                Label.Font = Enum.Font.Gotham
                Label.TextSize = 13
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = SliderFrame

                -- Controle de Input [+ | Caixa | -]
                local InputContainer = Instance.new("Frame")
                InputContainer.Size = UDim2.new(0, 90, 0, 22)
                InputContainer.Position = UDim2.new(1, -90, 0, 0)
                InputContainer.BackgroundColor3 = Core.Themes.Background
                InputContainer.Parent = SliderFrame
                Instance.new("UICorner", InputContainer).CornerRadius = UDim.new(0, 4)
                local InputStroke = Instance.new("UIStroke", InputContainer)
                InputStroke.Color = Core.Themes.Border

                local MinusBtn = Instance.new("TextButton")
                MinusBtn.Size = UDim2.new(0, 20, 1, 0)
                MinusBtn.Position = UDim2.new(0, 0, 0, 0)
                MinusBtn.BackgroundTransparency = 1
                MinusBtn.Text = "-"
                MinusBtn.TextColor3 = Core.Themes.TextMuted
                MinusBtn.Font = Enum.Font.GothamBold
                MinusBtn.TextSize = 12
                MinusBtn.Parent = InputContainer

                local PlusBtn = Instance.new("TextButton")
                PlusBtn.Size = UDim2.new(0, 20, 1, 0)
                PlusBtn.Position = UDim2.new(1, -20, 0, 0)
                PlusBtn.BackgroundTransparency = 1
                PlusBtn.Text = "+"
                PlusBtn.TextColor3 = Core.Themes.TextMuted
                PlusBtn.Font = Enum.Font.GothamBold
                PlusBtn.TextSize = 12
                PlusBtn.Parent = InputContainer

                local ValInput = Instance.new("TextBox")
                ValInput.Size = UDim2.new(1, -40, 1, 0)
                ValInput.Position = UDim2.new(0, 20, 0, 0)
                ValInput.BackgroundTransparency = 1
                ValInput.TextColor3 = Core.Themes.Text
                ValInput.Font = Enum.Font.Gotham
                ValInput.TextSize = 12
                ValInput.Text = tostring(Slider.Value)
                ValInput.Parent = InputContainer

                local BarBg = Instance.new("TextButton")
                BarBg.Size = UDim2.new(1, 0, 0, 6)
                BarBg.Position = UDim2.new(0, 0, 1, -10)
                BarBg.BackgroundColor3 = Core.Themes.Background
                BarBg.Text = ""
                BarBg.AutoButtonColor = false
                BarBg.Parent = SliderFrame
                Instance.new("UICorner", BarBg).CornerRadius = UDim.new(1, 0)
                local BarStroke = Instance.new("UIStroke", BarBg)
                BarStroke.Color = Core.Themes.Border

                local Fill = Instance.new("Frame")
                local percent = (Slider.Value - min) / (max - min)
                Fill.Size = UDim2.new(percent, 0, 1, 0)
                Fill.BackgroundColor3 = Core.Themes.Accent
                Fill.Parent = BarBg
                Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

                local function RoundStep(val, s) return math.floor((val / s) + 0.5) * s end

                function Slider:Set(newVal: number, skipCallback: boolean)
                    local num = tonumber(newVal)
                    if not num then num = Slider.Value end
                    num = math.clamp(RoundStep(num, step), min, max)
                    
                    Slider.Value = num
                    local p = (Slider.Value - min) / (max - min)
                    
                    Core:Tween(Fill, {Size = UDim2.new(p, 0, 1, 0)}, 0.15, Enum.EasingStyle.Quad)
                    
                    local displayStr = tostring(Slider.Value)
                    if step == math.floor(step) then displayStr = tostring(math.floor(Slider.Value)) end
                    ValInput.Text = displayStr
                    
                    if not skipCallback then task.spawn(callback, Slider.Value) end
                end

                MinusBtn.MouseButton1Click:Connect(function() Slider:Set(Slider.Value - step) end)
                PlusBtn.MouseButton1Click:Connect(function() Slider:Set(Slider.Value + step) end)

                local sliding = false
                local function UpdateSlider(input)
                    local p = math.clamp((input.Position.X - BarBg.AbsolutePosition.X) / BarBg.AbsoluteSize.X, 0, 1)
                    local rawVal = min + ((max - min) * p)
                    Slider:Set(rawVal)
                end

                BarBg.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = true; UpdateSlider(input)
                        Core:Tween(Fill, {BackgroundColor3 = Core.Math.Color.Lighten(Core.Themes.Accent, 0.1)}, 0.2)
                        Core:Tween(BarStroke, {Color = Core.Themes.Accent}, 0.2)
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 and sliding then
                        sliding = false
                        Core:Tween(Fill, {BackgroundColor3 = Core.Themes.Accent}, 0.2)
                        Core:Tween(BarStroke, {Color = Core.Themes.Border}, 0.2)
                    end
                end)
                
                UserInputService.InputChanged:Connect(function(input)
                    if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then UpdateSlider(input) end
                end)
                
                ValInput.FocusLost:Connect(function() Slider:Set(ValInput.Text) end)

                Core:SubscribeToTheme(function(theme)
                    Label.TextColor3 = theme.TextMuted
                    InputContainer.BackgroundColor3 = theme.Background
                    ValInput.TextColor3 = theme.Text
                    MinusBtn.TextColor3 = theme.TextMuted
                    PlusBtn.TextColor3 = theme.TextMuted
                    InputStroke.Color = theme.Border
                    BarBg.BackgroundColor3 = theme.Background
                    if not sliding then 
                        Fill.BackgroundColor3 = theme.Accent 
                        BarStroke.Color = theme.Border
                    end
                end)

                task.spawn(callback, Slider.Value)
                return Slider
            end

            -- ==============================================================================
            -- 🔡 WIDGET: TEXTBOX (Input Seguro com Hover Effects)
            -- ==============================================================================
            function Section:CreateTextBox(opts: TextBoxConfig)
                local TextBoxWidget = { Value = "" }
                local callback = opts.Callback or function() end

                local TBFrame = Instance.new("Frame")
                TBFrame.Size = UDim2.new(1, 0, 0, 40)
                TBFrame.BackgroundTransparency = 1
                TBFrame.Parent = SecFrame

                if opts.Tooltip then Core:AddTooltip(TBFrame, opts.Tooltip) end

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, 0, 0, 15)
                Label.BackgroundTransparency = 1
                Label.Text = opts.Name
                Label.TextColor3 = Core.Themes.TextMuted
                Label.Font = Enum.Font.Gotham
                Label.TextSize = 12
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = TBFrame

                local InputBg = Instance.new("Frame")
                InputBg.Size = UDim2.new(1, 0, 0, 25)
                InputBg.Position = UDim2.new(0, 0, 1, -25)
                InputBg.BackgroundColor3 = Core.Themes.Background
                InputBg.Parent = TBFrame
                Instance.new("UICorner", InputBg).CornerRadius = UDim.new(0, 4)
                local InputStroke = Instance.new("UIStroke", InputBg)
                InputStroke.Color = Core.Themes.Border

                local Input = Instance.new("TextBox")
                Input.Size = UDim2.new(1, -16, 1, 0)
                Input.Position = UDim2.new(0, 8, 0, 0)
                Input.BackgroundTransparency = 1
                Input.Text = ""
                Input.PlaceholderText = opts.Placeholder or "Type here..."
                Input.TextColor3 = Core.Themes.Text
                Input.PlaceholderColor3 = Core.Themes.TextMuted
                Input.Font = Enum.Font.Gotham
                Input.TextSize = 12
                Input.TextXAlignment = Enum.TextXAlignment.Left
                Input.ClearTextOnFocus = opts.ClearOnFocus or false
                Input.ClipsDescendants = true
                Input.Parent = InputBg

                function TextBoxWidget:Set(text: string)
                    TextBoxWidget.Value = text
                    Input.Text = text
                    task.spawn(callback, text)
                end

                function TextBoxWidget:GetValue() return TextBoxWidget.Value end

                Input.Focused:Connect(function() Core:Tween(InputStroke, {Color = Core.Themes.Accent}, 0.2) end)
                Input.FocusLost:Connect(function()
                    Core:Tween(InputStroke, {Color = Core.Themes.Border}, 0.2)
                    TextBoxWidget.Value = Input.Text
                    task.spawn(callback, Input.Text)
                end)

                Core:SubscribeToTheme(function(theme)
                    Label.TextColor3 = theme.TextMuted
                    InputBg.BackgroundColor3 = theme.Background
                    Input.TextColor3 = theme.Text
                    Input.PlaceholderColor3 = theme.TextMuted
                    if not Input:IsFocused() then InputStroke.Color = theme.Border end
                end)

                return TextBoxWidget
            end

            -- ==============================================================================
            -- 🔘 WIDGET: RADIO GROUP (Seleção Exclusiva Múltipla)
            -- ==============================================================================
            function Section:CreateRadioGroup(opts: RadioConfig)
                local Radio = { Selected = opts.Default, Buttons = {} }
                local callback = opts.Callback or function() end

                local RadioFrame = Instance.new("Frame")
                RadioFrame.Size = UDim2.new(1, 0, 0, 0)
                RadioFrame.AutomaticSize = Enum.AutomaticSize.Y
                RadioFrame.BackgroundTransparency = 1
                RadioFrame.Parent = SecFrame

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, 0, 0, 20)
                Label.BackgroundTransparency = 1
                Label.Text = opts.Name
                Label.TextColor3 = Core.Themes.TextMuted
                Label.Font = Enum.Font.Gotham
                Label.TextSize = 13
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = RadioFrame

                local OptionsContainer = Instance.new("Frame")
                OptionsContainer.Size = UDim2.new(1, 0, 0, 0)
                OptionsContainer.Position = UDim2.new(0, 0, 0, 20)
                OptionsContainer.AutomaticSize = Enum.AutomaticSize.Y
                OptionsContainer.BackgroundTransparency = 1
                OptionsContainer.Parent = RadioFrame

                local Layout = Instance.new("UIListLayout", OptionsContainer)
                Layout.SortOrder = Enum.SortOrder.LayoutOrder
                Layout.Padding = UDim.new(0, 5)

                for _, option in ipairs(opts.Options) do
                    local isSelected = (Radio.Selected == option)
                    local OptBtn = Instance.new("TextButton")
                    OptBtn.Size = UDim2.new(1, 0, 0, 22)
                    OptBtn.BackgroundTransparency = 1
                    OptBtn.Text = ""
                    OptBtn.Parent = OptionsContainer

                    local Outer = Instance.new("Frame")
                    Outer.Size = UDim2.new(0, 16, 0, 16)
                    Outer.AnchorPoint = Vector2.new(0, 0.5)
                    Outer.Position = UDim2.new(0, 0, 0.5, 0)
                    Outer.BackgroundColor3 = Core.Themes.Background
                    Outer.Parent = OptBtn
                    Instance.new("UICorner", Outer).CornerRadius = UDim.new(1, 0)
                    local OStroke = Instance.new("UIStroke", Outer)
                    OStroke.Color = isSelected and Core.Themes.Accent or Core.Themes.Border

                    local Inner = Instance.new("Frame")
                    Inner.Size = UDim2.new(0, 8, 0, 8)
                    Inner.AnchorPoint = Vector2.new(0.5, 0.5)
                    Inner.Position = UDim2.new(0.5, 0, 0.5, 0)
                    Inner.BackgroundColor3 = Core.Themes.Accent
                    Inner.BackgroundTransparency = isSelected and 0 or 1
                    Inner.Parent = Outer
                    Instance.new("UICorner", Inner).CornerRadius = UDim.new(1, 0)

                    local OptLabel = Instance.new("TextLabel")
                    OptLabel.Size = UDim2.new(1, -25, 1, 0)
                    OptLabel.Position = UDim2.new(0, 25, 0, 0)
                    OptLabel.BackgroundTransparency = 1
                    OptLabel.Text = option
                    OptLabel.TextColor3 = isSelected and Core.Themes.Text or Core.Themes.TextMuted
                    OptLabel.Font = Enum.Font.Gotham
                    OptLabel.TextSize = 12
                    OptLabel.TextXAlignment = Enum.TextXAlignment.Left
                    OptLabel.Parent = OptBtn

                    Radio.Buttons[option] = { OuterStroke = OStroke, Inner = Inner, Label = OptLabel }

                    OptBtn.MouseButton1Click:Connect(function()
                        if Radio.Selected == option then return end
                        Radio.Selected = option
                        
                        for optName, data in pairs(Radio.Buttons) do
                            local state = (optName == option)
                            Core:Tween(data.OuterStroke, {Color = state and Core.Themes.Accent or Core.Themes.Border}, 0.2)
                            Core:Tween(data.Inner, {BackgroundTransparency = state and 0 or 1}, 0.2)
                            Core:Tween(data.Label, {TextColor3 = state and Core.Themes.Text or Core.Themes.TextMuted}, 0.2)
                        end
                        task.spawn(callback, option)
                    end)
                end

                Core:SubscribeToTheme(function(theme)
                    Label.TextColor3 = theme.TextMuted
                    for optName, data in pairs(Radio.Buttons) do
                        local state = (Radio.Selected == optName)
                        data.OuterStroke.Color = state and theme.Accent or theme.Border
                        data.Inner.BackgroundColor3 = theme.Accent
                        data.Label.TextColor3 = state and theme.Text or theme.TextMuted
                        data.Inner.Parent.BackgroundColor3 = theme.Background
                    end
                end)

                return Radio
            end

            -- ==============================================================================
            -- 📊 WIDGET: PROGRESS BAR (Display Visual de Valores)
            -- ==============================================================================
            function Section:CreateProgressBar(opts: ProgressConfig)
                local Progress = { Value = opts.Default or 0 }
                local formatStr = opts.Format or "%d%%"

                local PFrame = Instance.new("Frame")
                PFrame.Size = UDim2.new(1, 0, 0, 35)
                PFrame.BackgroundTransparency = 1
                PFrame.Parent = SecFrame

                local Label = Instance.new("TextLabel")
                Label.Size = UDim2.new(1, -50, 0, 15)
                Label.BackgroundTransparency = 1
                Label.Text = opts.Name
                Label.TextColor3 = Core.Themes.TextMuted
                Label.Font = Enum.Font.Gotham
                Label.TextSize = 12
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Label.Parent = PFrame

                local ValLabel = Instance.new("TextLabel")
                ValLabel.Size = UDim2.new(0, 50, 0, 15)
                ValLabel.Position = UDim2.new(1, -50, 0, 0)
                ValLabel.BackgroundTransparency = 1
                ValLabel.Text = string.format(formatStr, Progress.Value)
                ValLabel.TextColor3 = Core.Themes.Text
                ValLabel.Font = Enum.Font.GothamBold
                ValLabel.TextSize = 12
                ValLabel.TextXAlignment = Enum.TextXAlignment.Right
                ValLabel.Parent = PFrame

                local BarBg = Instance.new("Frame")
                BarBg.Size = UDim2.new(1, 0, 0, 12)
                BarBg.Position = UDim2.new(0, 0, 1, -12)
                BarBg.BackgroundColor3 = Core.Themes.Background
                BarBg.Parent = PFrame
                Instance.new("UICorner", BarBg).CornerRadius = UDim.new(1, 0)
                local BarStroke = Instance.new("UIStroke", BarBg)
                BarStroke.Color = Core.Themes.Border

                local Fill = Instance.new("Frame")
                Fill.Size = UDim2.new(math.clamp(Progress.Value / 100, 0, 1), 0, 1, 0)
                Fill.BackgroundColor3 = Core.Themes.Accent
                Fill.Parent = BarBg
                Instance.new("UICorner", Fill).CornerRadius = UDim.new(1, 0)

                function Progress:Set(val: number)
                    self.Value = math.clamp(val, 0, 100)
                    Core:Tween(Fill, {Size = UDim2.new(self.Value / 100, 0, 1, 0)}, 0.25, Enum.EasingStyle.Quart)
                    ValLabel.Text = string.format(formatStr, self.Value)
                end

                Core:SubscribeToTheme(function(theme)
                    Label.TextColor3 = theme.TextMuted
                    ValLabel.TextColor3 = theme.Text
                    BarBg.BackgroundColor3 = theme.Background
                    BarStroke.Color = theme.Border
                    Fill.BackgroundColor3 = theme.Accent
                end)

                return Progress
            end

            return Section
        end

        return Tab
    end

    Core.Logger:Log("Basic Widgets Engine Loaded Successfully.")
end

return Widgets
