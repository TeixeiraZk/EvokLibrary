function Core:CreateWindow(config)
    Core.Logger:Log("Initializing Evok Window Manager...")
    
    -- Exatamente o tamanho solicitado no formato Retrato (Portrait)
    local size = config.Size or UDim2.new(0, 500, 0, 800) 
    
    local targetGui
    if pcall(function() return CoreGui.Name end) then
        targetGui = CoreGui
    else
        targetGui = LocalPlayer:WaitForChild("PlayerGui")
    end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "EvokUI_" .. HttpService:GenerateGUID(false)
    ScreenGui.ResetOnSpawn = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Global
    ScreenGui.Parent = targetGui
    self.GUI = ScreenGui

    -- Frame invisível para o Drag e Sombra
    local ShadowFrame = Instance.new("Frame")
    ShadowFrame.Name = "Shadow"
    ShadowFrame.Size = size
    ShadowFrame.Position = UDim2.new(0.5, -size.X.Offset/2, 0.5, -size.Y.Offset/2)
    ShadowFrame.BackgroundTransparency = 1
    ShadowFrame.Parent = ScreenGui

    -- Adiciona a sombra suave procedural no fundo
    self.Shadows:Create(ShadowFrame, 30, 0.5, Vector2.new(0, 0))

    -- O fundo principal da UI (Fundo geral)
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.new(1, 0, 1, 0)
    MainFrame.BackgroundColor3 = self.Themes.Background
    MainFrame.BorderSizePixel = 0
    MainFrame.ClipsDescendants = true
    MainFrame.Parent = ShadowFrame

    local MainCorner = Instance.new("UICorner")
    MainCorner.CornerRadius = UDim.new(0, 8)
    MainCorner.Parent = MainFrame

    -- ==========================================
    -- SIDEBAR (Menu Lateral - Sem linha cinza divisória)
    -- ==========================================
    local SidebarWidth = 140

    local Sidebar = Instance.new("Frame")
    Sidebar.Name = "Sidebar"
    Sidebar.Size = UDim2.new(0, SidebarWidth, 1, 0)
    Sidebar.BackgroundColor3 = self.Themes.Sidebar
    Sidebar.BorderSizePixel = 0
    Sidebar.Parent = MainFrame

    -- Título 1: Evok (Roxo)
    local TitleEvok = Instance.new("TextLabel")
    TitleEvok.Name = "TitleEvok"
    TitleEvok.Size = UDim2.new(1, -20, 0, 20)
    TitleEvok.Position = UDim2.new(0, 15, 0, 20)
    TitleEvok.BackgroundTransparency = 1
    TitleEvok.Text = "Evok"
    TitleEvok.TextColor3 = self.Themes.Accent
    TitleEvok.Font = Enum.Font.GothamBold
    TitleEvok.TextSize = 16
    TitleEvok.TextXAlignment = Enum.TextXAlignment.Left
    TitleEvok.Parent = Sidebar

    -- Título 2: Zynn Love you <3 (Cinza Pequeno)
    local TitleSub = Instance.new("TextLabel")
    TitleSub.Name = "TitleSub"
    TitleSub.Size = UDim2.new(1, -20, 0, 15)
    TitleSub.Position = UDim2.new(0, 15, 0, 40)
    TitleSub.BackgroundTransparency = 1
    TitleSub.Text = "Zynn Love you <3"
    TitleSub.TextColor3 = self.Themes.TextMuted
    TitleSub.Font = Enum.Font.Gotham
    TitleSub.TextSize = 11
    TitleSub.TextXAlignment = Enum.TextXAlignment.Left
    TitleSub.Parent = Sidebar

    -- ==========================================
    -- CONTAINERS (Abas e Conteúdo)
    -- ==========================================
    local TabContainer = Instance.new("Frame")
    TabContainer.Name = "TabContainer"
    TabContainer.Size = UDim2.new(1, 0, 1, -80)
    TabContainer.Position = UDim2.new(0, 0, 0, 80)
    TabContainer.BackgroundTransparency = 1
    TabContainer.Parent = Sidebar
    
    local TabListLayout = Instance.new("UIListLayout")
    TabListLayout.FillDirection = Enum.FillDirection.Vertical
    TabListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    TabListLayout.Padding = UDim.new(0, 5)
    TabListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    TabListLayout.Parent = TabContainer

    local PageContainer = Instance.new("Frame")
    PageContainer.Name = "PageContainer"
    PageContainer.Size = UDim2.new(1, -SidebarWidth, 1, 0)
    PageContainer.Position = UDim2.new(0, SidebarWidth, 0, 0)
    PageContainer.BackgroundTransparency = 1
    PageContainer.Parent = MainFrame

    -- Área invisível para arrastar a UI inteira
    local DragArea = Instance.new("Frame")
    DragArea.Size = UDim2.new(1, 0, 0, 60)
    DragArea.BackgroundTransparency = 1
    DragArea.Parent = MainFrame
    
    self:MakeDraggable(DragArea, ShadowFrame)

    -- Registro no ThemeManager
    self:SubscribeToTheme(function(theme)
        MainFrame.BackgroundColor3 = theme.Background
        Sidebar.BackgroundColor3 = theme.Sidebar
        TitleEvok.TextColor3 = theme.Accent
        TitleSub.TextColor3 = theme.TextMuted
    end)

    -- Animação de Entrada Cinematográfica
    ShadowFrame.Size = UDim2.new(0, 0, 0, 0)
    ShadowFrame.GroupTransparency = 1
    self:Tween(ShadowFrame, {Size = size, GroupTransparency = 0}, 0.6, Enum.EasingStyle.Expo)

    return {
        Core = self,
        GUI = ScreenGui,
        MainFrame = MainFrame,
        TopBar = Sidebar, 
        TabContainer = TabContainer,
        PageContainer = PageContainer,
        Tabs = {},
        CurrentTab = nil
    }
end

table.freeze(Core.Easing)
table.freeze(Core.Math)

return Core
