	})

	self.Arrow = Utility.CreateInstance("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.fromOffset(16, 16),
		Position = UDim2.new(1, -20, 0, 14),
		Font = Enum.Font.GothamBold,
		Text = "▼",
		TextColor3 = ThemeManager.CurrentTheme.TextColor,
		TextSize = 10,
		Parent = self.Frame
	})

	self.List = Utility.CreateInstance("Frame", {
		Name = "List",
		BackgroundColor3 = ThemeManager.CurrentTheme.Background,
		BackgroundTransparency = 0.05,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -10, 0, 0),
		Position = UDim2.new(0, 5, 0, 44),
		ClipsDescendants = true,
		Parent = self.Frame
	})
	Utility.MakeCorner(self.List, UDim.new(0, 8))
	Utility.MakeStroke(self.List, ThemeManager.CurrentTheme.StrokeColor, 1, 0.75)
	self.ListLayout = Utility.MakeListLayout(self.List, 4, Enum.FillDirection.Vertical, Enum.SortOrder.LayoutOrder)

	for _, Option in ipairs(self.Options) do
		self:AddOption(Option)
	end

	self.Frame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			self:Toggle()
		end
	end)

	return self
end

function MultiDropdown:_Refresh()
	local Names = {}
	for Name, Enabled in pairs(self.Selected) do
		if Enabled then
			table.insert(Names, Name)
		end
	end
	self.SelectedLabel.Text = #Names > 0 and table.concat(Names, ", ") or "None"
	if self.Callback then
		task.spawn(self.Callback, Names)
	end
end

function MultiDropdown:AddOption(Option)
	local Button = Utility.CreateInstance("TextButton", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -8, 0, 24),
		Text = "",
		AutoButtonColor = false,
		Parent = self.List
	})

	local Label = Utility.CreateInstance("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -8, 1, 0),
		Position = UDim2.new(0, 8, 0, 0),
		Font = Enum.Font.Gotham,
		Text = Option,
		TextColor3 = ThemeManager.CurrentTheme.TextColor,
		TextSize = 11,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = Button
	})

	local Check = Utility.CreateInstance("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.fromOffset(16, 16),
		Position = UDim2.new(1, -18, 0, 4),
		Font = Enum.Font.GothamBold,
		Text = "✓",
		TextColor3 = ThemeManager.CurrentTheme.PrimaryColor,
		TextSize = 12,
		Visible = false,
		Parent = Button
	})

	Button.Activated:Connect(function()
		self.Selected[Option] = not self.Selected[Option]
		Check.Visible = self.Selected[Option]
		self:_Refresh()
	end)
end

function MultiDropdown:SelectAll()
	for _, Option in ipairs(self.Options) do
		self.Selected[Option] = true
	end
	for _, Child in ipairs(self.List:GetChildren()) do
		local Check = Child:FindFirstChildOfClass("TextLabel")
		if Check and Check.Text == "✓" then
			Check.Visible = true
		end
	end
	self:_Refresh()
end

function MultiDropdown:Clear()
	table.clear(self.Selected)
	for _, Child in ipairs(self.List:GetChildren()) do
		local Check = Child:FindFirstChildOfClass("TextLabel")
		if Check and Check.Text == "✓" then
			Check.Visible = false
		end
	end
	self:_Refresh()
end

function MultiDropdown:Toggle()
	if self.Open then
		self:Close()
	else
		self:OpenDropdown()
	end
end

function MultiDropdown:OpenDropdown()
	self.Open = true
	local TargetHeight = math.min(#self.List:GetChildren() * 28 + 4, 140)
	Utility.TweenObject(self.List, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = UDim2.new(1, -10, 0, TargetHeight)})
	Utility.TweenObject(self.Arrow, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Rotation = 180})
	Utility.TweenObject(self.Frame, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = UDim2.new(1, -4, 0, 44 + TargetHeight)})
end

function MultiDropdown:Close()
	self.Open = false
	Utility.TweenObject(self.List, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = UDim2.new(1, -10, 0, 0)})
	Utility.TweenObject(self.Arrow, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Rotation = 0})
	Utility.TweenObject(self.Frame, TweenInfo.new(0.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = UDim2.new(1, -4, 0, 44)})
end

return MultiDropdown

