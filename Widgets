function Widgets.Inject(WindowInstance)
    local Core = WindowInstance.Core 

    -- ==============================================================================
    -- 🌊 RIPPLE PHYSICS ENGINE (Efeito de Ondulação de Botões)
    -- ==============================================================================
    local function CreateRipple(Parent: GuiObject, ThemeColor: Color3)
        local Ripple = Instance.new("Frame")
        Ripple.Name = "EvokRipple"
        Ripple.BackgroundColor3 = ThemeColor
        Ripple.BackgroundTransparency = 0.6
        Ripple.BorderSizePixel = 0
        Ripple.ZIndex = Parent.ZIndex + 1
        Ripple.ClipsDescendants = true
        
        local Corner = Instance.new("UICorner")
        Corner.CornerRadius = UDim.new(1, 0)
        Corner.Parent = Ripple
        
        local mousePos = UserInputService:GetMouseLocation()
        local absoluteSize = Parent.AbsoluteSize
        local absolutePos = Parent.AbsolutePosition
        
        local relativeX = mousePos.X - absolutePos.X
        local relativeY = (mousePos.Y - 36) - absolutePos.Y
        
        local size = math.max(absoluteSize.X, absoluteSize.Y) * 1.5
        
        Ripple.Size = UDim2.new(0, 0, 0, 0)
        Ripple.Position = UDim2.new(0, relativeX, 0, relativeY)
        Ripple.AnchorPoint = Vector2.new(0.5, 0.5)
        Ripple.Parent = Parent
        
        local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
        local tween = TweenService:Create(Ripple, tweenInfo, {
            Size = UDim2.new(0, size, 0, size),
            BackgroundTransparency = 1
        })
        
        tween:Play()
        tween.Completed:Connect(function()
            Ripple:Destroy()
        end)
    end

    -- ==============================================================================
    -- 📑 TAB SYSTEM (Sidebar Navigation Integration)
    -- ==============================================================================
    function WindowInstance:CreateTab(name: string)
        local Window = self
        local Tab = { Sections = {}, Elements = {} }
        
        local TabBtn = Instance.new("TextButton")
        TabBtn.Name = name .. "_TabBtn"
        TabBtn.Size = UDim2.new(1, -20, 0, 35) 
        TabBtn.Position = UDim2.new(0, 10, 0, 0)
        TabBtn.BackgroundColor3 = Core.Themes.Accent
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = "  " .. name
        TabBtn.Font = Enum.Font.GothamSemibold
        TabBtn.TextSize = 13
        TabBtn.TextColor3 = Core.Themes.TextMuted
        TabBtn.TextXAlignment = Enum.TextXAlignment.Left
        TabBtn.AutoButtonColor = false
        TabBtn.Parent = Window.TabContainer
        
        Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)

        local Indicator = Instance.new("Frame")
        Indicator.Size = UDim2.new(0, 3, 0, 0)
        Indicator.Position = UDim2.new(0, 0, 0.5, 0)
        Indicator.AnchorPoint = Vector2.new(0, 0.5)
        Indicator.BackgroundColor3 = Core.Themes.Text
        Indicator.BorderSizePixel = 0
        Indicator.Parent = TabBtn
        Instance.new("UICorner", Indicator).CornerRadius = UDim.new(1, 0)

        local Page = Instance.new("ScrollingFrame")
        Page.Name = name .. "_Page"
        Page.Size = UDim2.new(1, -20, 1, -20)
        Page.Position = UDim2.new(0, 10, 0, 10)
        Page.BackgroundTransparency = 1
        Page.ScrollBarThickness = 2
        Page.ScrollBarImageColor3 = Core.Themes.Border
        Page.BorderSizePixel = 0
        Page.Visible = false
        Page.Parent = Window.PageContainer

        local LeftCol = Instance.new("Frame")
        LeftCol.Name = "LeftColumn"
        LeftCol.Size = UDim2.new(0.5, -5, 1, 0)
        LeftCol.BackgroundTransparency = 1
        LeftCol.Parent = Page
        
        local LeftLayout = Instance.new("UIListLayout")
        LeftLayout.SortOrder = Enum.SortOrder.LayoutOrder
        LeftLayout.Padding = UDim.new(0, 10)
        LeftLayout.Parent = LeftCol

        local RightCol = Instance.new("Frame")
        RightCol.Name = "RightColumn"
        RightCol.Size = UDim2.new(0.5, -5, 1, 0)
        RightCol.Position = UDim2.new(0.5, 5, 0, 0)
        RightCol.BackgroundTransparency = 1
        RightCol.Parent = Page
        
        local RightLayout = Instance.new("UIListLayout")
        RightLayout.SortOrder = Enum.SortOrder.LayoutOrder
        RightLayout.Padding = UDim.new(0, 10)
        RightLayout.Parent = RightCol

        local function UpdateCanvas()
            local leftSize = LeftLayout.AbsoluteContentSize.Y
            local rightSize = RightLayout.AbsoluteContentSize.Y
            local maxSize = math.max(leftSize, rightSize)
            Page.CanvasSize = UDim2.new(0, 0, 0, maxSize + 20)
        end
        LeftLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateCanvas)
        RightLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateCanvas)

        TabBtn.MouseEnter:Connect(function()
            if Window.CurrentTab ~= Tab then Core:Tween(TabBtn, {TextColor3 = Core.Themes.Text}, 0.15) end
        end)
        
        TabBtn.MouseLeave:Connect(function()
            if Window.CurrentTab ~= Tab then Core:Tween(TabBtn, {TextColor3 = Core.Themes.TextMuted}, 0.15) end
        end)

        TabBtn.MouseButton1Click:Connect(function()
            if Window.CurrentTab == Tab then return end
            
            CreateRipple(TabBtn, Core.Themes.TextMuted)

            for _, t in pairs(Window.Tabs) do
                t.Page.Visible = false
                Core:Tween(t.Btn, {BackgroundTransparency = 1, TextColor3 = Core.Themes.TextMuted}, 0.2)
                Core:Tween(t.Indicator, {Size = UDim2.new(0, 3, 0, 0)}, 0.2)
            end

            Page.Visible = true
            Core:Tween(TabBtn, {BackgroundTransparency = 0.85, TextColor3 = Core.Themes.Text}, 0.2)
            Core:Tween(Indicator, {Size = UDim2.new(0, 3, 0.6, 0)}, 0.2, Enum.EasingStyle.Back)
            Window.CurrentTab = Tab
        end)

        if #Window.Tabs == 0 then
            Page.Visible = true
            TabBtn.BackgroundTransparency = 0.85
            TabBtn.TextColor3 = Core.Themes.Text
            Indicator.Size = UDim2.new(0, 3, 0.6, 0)
            Window.CurrentTab = Tab
        end

        Core:SubscribeToTheme(function(theme)
            Page.ScrollBarImageColor3 = theme.Border
            TabBtn.BackgroundColor3 = theme.Accent
            Indicator.BackgroundColor3 = theme.Accent
            if Window.CurrentTab == Tab then
                TabBtn.TextColor3 = theme.Text
            else
                TabBtn.TextColor3 = theme.TextMuted
            end
        end)

        table.insert(Window.Tabs, {Btn = TabBtn, Page = Page, Indicator = Indicator})

