-- ==============================================================================
-- 📡 SIGNAL ENGINE (Custom RBXScriptSignal Implementation)
-- Framework de eventos de alta performance para a UI
-- ==============================================================================
local Signal = {}
Signal.__index = Signal

function Signal.new()
    local self = setmetatable({
        _bindableEvent = Instance.new("BindableEvent"),
        _argMap = {},
        _argCount = 0,
    }, Signal)
    return self
end

function Signal:Connect(handler)
    if not (type(handler) == "function") then
        error(("Connect(%s)"):format(typeof(handler)), 2)
    end
    return self._bindableEvent.Event:Connect(function(key)
        handler(unpack(self._argMap[key], 1, self._argCount))
    end)
end

function Signal:Fire(...)
    self._argCount = select("#", ...)
    local args = {...}
    local key = HttpService:GenerateGUID(false)
    self._argMap[key] = args
    self._bindableEvent:Fire(key)
    self._argMap[key] = nil
end

function Signal:Wait()
    local key = self._bindableEvent.Event:Wait()
    return unpack(self._argMap[key], 1, self._argCount)
end

function Signal:Destroy()
    if self._bindableEvent then
        self._bindableEvent:Destroy()
        self._bindableEvent = nil
    end
    self._argMap = nil
end

Core.ThemeSignal = Signal.new()

