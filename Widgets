--// Services
local TweenService     = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService       = game:GetService("RunService")

--// Load Core
local Core         = loadstring(game:HttpGet("..."))() -- replace with your loader
local Utility      = Core.Utility
local ThemeManager = Core.ThemeManager
local Easing       = Core.Easing

--// ============================================================
--// SECTION SYSTEM
--// Creates left/right column layout inside a tab
--// ============================================================

local SectionSystem = {}
SectionSystem.__index = SectionSystem

function SectionSystem.new(parentTab, options)
    local self = setmetatable({}, SectionSystem)

    options = options or {}
    self._parent = parentTab.Content
    self._layout = parentTab.Layout
    self._mode   = options.Mode or "Single" -- "Single" | "Double"
    self._sections = {}

    -- Wrapper frame
    local wrapper = Utility.Create("Frame", {
        Name = "SectionWrapper",
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        LayoutOrder = #self._parent:GetChildren(),
        Parent = self._parent,
    })

    if self._mode == "Double" then
        local listLayout = Utility.Create("UIListLayout", {
            FillDirection = Enum.FillDirection.Horizontal,
            SortOrder = Enum.SortOrder.LayoutOrder,
            Padding = UDim.new(0, 6),
            Parent = wrapper,
        })
    end

    self._wrapper = wrapper
    return self
end

function SectionSystem:CreateSection(name, side)
    local section = {}
    side = side or "Left"

    -- Section frame
    local frame = Utility.Create("Frame", {
        Name = "Section_" .. name,
        Size = self._mode == "Double"
            and UDim2.new(0.5, -3, 0, 0)
            or  UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = ThemeManager:GetColor("SectionBg"),
        BackgroundTransparency = 0.2,
        BorderSizePixel = 0,
        LayoutOrder = side == "Left" and 1 or 2,
        Parent = self._wrapper,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 7), Parent = frame })
    Utility.Create("UIStroke", {
        Color = ThemeManager:GetColor("Border"),
        Thickness = 1,
        Transparency = 0.5,
        Parent = frame,
    })

    -- Section header
    local header = Utility.Create("Frame", {
        Name = "SectionHeader",
        Size = UDim2.new(1, 0, 0, 28),
        BackgroundColor3 = ThemeManager:GetColor("HeaderBg"),
        BackgroundTransparency = 0.4,
        BorderSizePixel = 0,
        Parent = frame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 7), Parent = header })
    -- Cover bottom corners
    Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 0.5, 0),
        Position = UDim2.new(0, 0, 0.5, 0),
        BackgroundColor3 = ThemeManager:GetColor("HeaderBg"),
        BackgroundTransparency = 0.4,
        BorderSizePixel = 0,
        Parent = header,
    })

    -- Left accent on header
    local accent = Utility.Create("Frame", {
        Size = UDim2.new(0, 2, 0.6, 0),
        Position = UDim2.new(0, 8, 0.2, 0),
        BackgroundColor3 = ThemeManager:GetColor("Primary"),
        BorderSizePixel = 0,
        Parent = header,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 2), Parent = accent })

    local nameLabel = Utility.Create("TextLabel", {
        Size = UDim2.new(1, -20, 1, 0),
        Position = UDim2.new(0, 16, 0, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = ThemeManager:GetColor("TextSecondary"),
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = header,
    })

    -- Content list
    local content = Utility.Create("Frame", {
        Name = "SectionContent",
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        Position = UDim2.new(0, 0, 0, 28),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Parent = frame,
    })
    Utility.Create("UIPadding", {
        PaddingTop    = UDim.new(0, 6),
        PaddingBottom = UDim.new(0, 8),
        PaddingLeft   = UDim.new(0, 8),
        PaddingRight  = UDim.new(0, 8),
        Parent = content,
    })
    local contentLayout = Utility.Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 5),
        Parent = content,
    })

    section.Frame   = frame
    section.Content = content
    section.Layout  = contentLayout

    table.insert(self._sections, section)
    return section
end

--// ============================================================
--// LABEL WIDGET
--// ============================================================

local Label = {}
Label.__index = Label

function Label.new(section, text, options)
    local self = setmetatable({}, Label)
    options = options or {}

    local style   = options.Style   or "Normal" -- Normal | Muted | Accent | Header
    local prefix  = options.Prefix  or ""
    local richText= options.RichText or false

    local textColor = ThemeManager:GetColor("TextSecondary")
    local textSize  = 11
    local font      = Enum.Font.Gotham

    if style == "Muted" then
        textColor = ThemeManager:GetColor("TextMuted")
    elseif style == "Accent" then
        textColor = ThemeManager:GetColor("Primary")
        font      = Enum.Font.GothamBold
    elseif style == "Header" then
        textColor = ThemeManager:GetColor("TextPrimary")
        textSize  = 12
        font      = Enum.Font.GothamBold
    end

    local frame = Utility.Create("Frame", {
        Name = "Label",
        Size = UDim2.new(1, 0, 0, 18),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        LayoutOrder = #section.Content:GetChildren(),
        Parent = section.Content,
    })

    if prefix ~= "" then
        local prefixLabel = Utility.Create("TextLabel", {
            Size = UDim2.new(0, 8, 1, 0),
            BackgroundTransparency = 1,
            Text = prefix,
            TextColor3 = ThemeManager:GetColor("Primary"),
            TextSize = 11,
            Font = Enum.Font.GothamBold,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = frame,
        })
    end

    local label = Utility.Create("TextLabel", {
        Size = prefix ~= "" and UDim2.new(1, -12, 1, 0) or UDim2.new(1, 0, 1, 0),
        Position = prefix ~= "" and UDim2.new(0, 12, 0, 0) or UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = textColor,
        TextSize = textSize,
        Font = font,
        TextXAlignment = Enum.TextXAlignment.Left,
        RichText = richText,
        TextWrapped = true,
        Parent = frame,
    })

    self._frame = frame
    self._label = label

    function self:SetText(newText)
        label.Text = newText
    end

    function self:SetColor(color)
        label.TextColor3 = color
    end

    return self
end

--// ============================================================
--// BUTTON WIDGET
--// ============================================================

local Button = {}
Button.__index = Button

function Button.new(section, text, callback, options)
    local self = setmetatable({}, Button)
    options = options or {}

    local style   = options.Style   or "Primary" -- Primary | Secondary | Danger | Ghost
    local icon    = options.Icon    or nil
    local tooltip = options.Tooltip or nil
    local width   = options.Width   or 1  -- fraction of section width
    self._callback = callback
    self._enabled  = true

    -- Colors per style
    local bgColor = ThemeManager:GetColor("Primary")
    local bgTrans = 0.1
    local txtColor= Color3.new(0, 0, 0)

    if style == "Secondary" then
        bgColor  = ThemeManager:GetColor("Surface")
        bgTrans  = 0.3
        txtColor = ThemeManager:GetColor("TextPrimary")
    elseif style == "Danger" then
        bgColor  = Utility.HexToColor3("#F44336")
        bgTrans  = 0.2
        txtColor = Color3.new(1, 1, 1)
    elseif style == "Ghost" then
        bgColor  = Color3.new(1, 1, 1)
        bgTrans  = 0.95
        txtColor = ThemeManager:GetColor("Primary")
    end

    -- Outer frame
    local frame = Utility.Create("Frame", {
        Name = "ButtonFrame",
        Size = UDim2.new(width, 0, 0, 28),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        LayoutOrder = #section.Content:GetChildren(),
        Parent = section.Content,
    })

    -- Button
    local btn = Utility.Create("TextButton", {
        Name = "Button",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = bgColor,
        BackgroundTransparency = bgTrans,
        Text = "",
        BorderSizePixel = 0,
        Parent = frame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = btn })
    Utility.Create("UIStroke", {
        Color = style == "Ghost" and ThemeManager:GetColor("Primary") or bgColor,
        Thickness = 1,
        Transparency = style == "Ghost" and 0.3 or 0.6,
        Parent = btn,
    })

    -- Text label
    local btnLabel = Utility.Create("TextLabel", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = txtColor,
        TextSize = 11,
        Font = Enum.Font.GothamBold,
        Parent = btn,
    })

    -- Ripple container
    local rippleContainer = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        BorderSizePixel = 0,
        ZIndex = btn.ZIndex + 1,
        Parent = btn,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 6), Parent = rippleContainer })

    self._frame    = frame
    self._btn      = btn
    self._label    = btnLabel

    -- Ripple effect
    local function createRipple(x, y)
        local ripple = Utility.Create("Frame", {
            Name = "Ripple",
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0, x - frame.AbsolutePosition.X, 0, y - frame.AbsolutePosition.Y),
            AnchorPoint = Vector2.new(0.5, 0.5),
            BackgroundColor3 = Color3.new(1, 1, 1),
            BackgroundTransparency = 0.7,
            BorderSizePixel = 0,
            ZIndex = rippleContainer.ZIndex + 1,
            Parent = rippleContainer,
        })
        Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = ripple })

        local maxSize = math.max(frame.AbsoluteSize.X, frame.AbsoluteSize.Y) * 2.5
        Utility.TweenObject(ripple, {
            Size = UDim2.new(0, maxSize, 0, maxSize),
            BackgroundTransparency = 1,
        }, 0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

        task.delay(0.5, function()
            if ripple.Parent then ripple:Destroy() end
        end)
    end

    -- Hover
    btn.MouseEnter:Connect(function()
        if not self._enabled then return end
        Utility.TweenObject(btn, { BackgroundTransparency = math.max(0, bgTrans - 0.08) }, 0.2)
        Utility.TweenObject(btn, { Size = UDim2.new(1, 0, 1, 2) }, 0.15)
    end)

    btn.MouseLeave:Connect(function()
        Utility.TweenObject(btn, { BackgroundTransparency = bgTrans }, 0.2)
        Utility.TweenObject(btn, { Size = UDim2.new(1, 0, 1, 0) }, 0.15)
    end)

    -- Press
    btn.MouseButton1Down:Connect(function()
        if not self._enabled then return end
        Utility.TweenObject(btn, { Size = UDim2.new(0.97, 0, 0.95, 0) }, 0.1)
    end)

    btn.MouseButton1Up:Connect(function()
        Utility.TweenObject(btn, { Size = UDim2.new(1, 0, 1, 0) }, 0.15)
    end)

    btn.MouseButton1Click:Connect(function(x, y)
        if not self._enabled then return end
        createRipple(Mouse.X, Mouse.Y)
        if self._callback then
            task.spawn(self._callback)
        end
    end)

    function self:SetText(newText)
        btnLabel.Text = newText
    end

    function self:SetEnabled(enabled)
        self._enabled = enabled
        btn.AutoButtonColor = enabled
        Utility.TweenObject(btn, { BackgroundTransparency = enabled and bgTrans or 0.6 }, 0.2)
        Utility.TweenObject(btnLabel, { TextTransparency = enabled and 0 or 0.5 }, 0.2)
    end

    function self:SetCallback(fn)
        self._callback = fn
    end

    return self
end

--// ============================================================
--// TOGGLE WIDGET
--// ============================================================

local Toggle = {}
Toggle.__index = Toggle

function Toggle.new(section, text, defaultState, callback, options)
    local self = setmetatable({}, Toggle)
    options = options or {}

    self._state    = defaultState or false
    self._callback = callback
    self._enabled  = true

    local tooltip  = options.Tooltip or nil
    local hasHint  = options.Hint    or nil

    -- Row frame
    local frame = Utility.Create("Frame", {
        Name = "ToggleFrame",
        Size = UDim2.new(1, 0, 0, 24),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        LayoutOrder = #section.Content:GetChildren(),
        Parent = section.Content,
    })

    -- Label
    local labelText = Utility.Create("TextLabel", {
        Name = "Label",
        Size = UDim2.new(1, -46, 1, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = ThemeManager:GetColor("TextSecondary"),
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
    })

    if hasHint then
        local hintLabel = Utility.Create("TextLabel", {
            Size = UDim2.new(0, 14, 0, 14),
            Position = UDim2.new(0, #text * 6 + 4, 0.5, -7),
            BackgroundColor3 = ThemeManager:GetColor("Border"),
            Text = "?",
            TextColor3 = ThemeManager:GetColor("TextMuted"),
            TextSize = 9,
            Font = Enum.Font.GothamBold,
            BorderSizePixel = 0,
            Parent = frame,
        })
        Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = hintLabel })
    end

    -- Toggle track
    local track = Utility.Create("Frame", {
        Name = "Track",
        Size = UDim2.new(0, 34, 0, 18),
        Position = UDim2.new(1, -34, 0.5, -9),
        BackgroundColor3 = self._state
            and ThemeManager:GetColor("ToggleOn")
            or  ThemeManager:GetColor("ToggleOff"),
        BorderSizePixel = 0,
        Parent = frame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = track })
    Utility.Create("UIStroke", {
        Color = self._state
            and ThemeManager:GetColor("Primary")
            or  ThemeManager:GetColor("Border"),
        Thickness = 1,
        Transparency = 0.4,
        Parent = track,
    })

    -- Toggle thumb
    local thumb = Utility.Create("Frame", {
        Name = "Thumb",
        Size = UDim2.new(0, 12, 0, 12),
        Position = self._state
            and UDim2.new(0, 19, 0.5, -6)
            or  UDim2.new(0, 3, 0.5, -6),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
        ZIndex = track.ZIndex + 1,
        Parent = track,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = thumb })

    -- Glow on thumb when active
    local thumbGlow = Utility.Create("Frame", {
        Size = UDim2.new(1, 8, 1, 8),
        Position = UDim2.new(0, -4, 0, -4),
        BackgroundColor3 = ThemeManager:GetColor("Primary"),
        BackgroundTransparency = self._state and 0.6 or 1,
        BorderSizePixel = 0,
        ZIndex = thumb.ZIndex - 1,
        Parent = thumb,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = thumbGlow })

    self._frame    = frame
    self._track    = track
    self._thumb    = thumb
    self._thumbGlow= thumbGlow
    self._label    = labelText

    -- Click area
    local btn = Utility.Create("TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = frame.ZIndex + 2,
        Parent = frame,
    })

    btn.MouseButton1Click:Connect(function()
        if not self._enabled then return end
        self:SetState(not self._state)
    end)

    -- Hover
    btn.MouseEnter:Connect(function()
        if not self._enabled then return end
        Utility.TweenObject(labelText, { TextColor3 = ThemeManager:GetColor("TextPrimary") }, 0.2)
    end)
    btn.MouseLeave:Connect(function()
        Utility.TweenObject(labelText, { TextColor3 = ThemeManager:GetColor("TextSecondary") }, 0.2)
    end)

    function self:SetState(newState, silent)
        self._state = newState

        -- Animate track
        local trackStroke = track:FindFirstChildOfClass("UIStroke")
        if newState then
            Utility.TweenObject(track, { BackgroundColor3 = ThemeManager:GetColor("ToggleOn") }, 0.25)
            Utility.TweenObject(thumb, { Position = UDim2.new(0, 19, 0.5, -6) }, 0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
            Utility.TweenObject(thumbGlow, { BackgroundTransparency = 0.6 }, 0.25)
            if trackStroke then
                Utility.TweenObject(trackStroke, { Color = ThemeManager:GetColor("Primary") }, 0.25)
            end
        else
            Utility.TweenObject(track, { BackgroundColor3 = ThemeManager:GetColor("ToggleOff") }, 0.25)
            Utility.TweenObject(thumb, { Position = UDim2.new(0, 3, 0.5, -6) }, 0.2)
            Utility.TweenObject(thumbGlow, { BackgroundTransparency = 1 }, 0.2)
            if trackStroke then
                Utility.TweenObject(trackStroke, { Color = ThemeManager:GetColor("Border") }, 0.25)
            end
        end

        if not silent and self._callback then
            task.spawn(self._callback, newState)
        end
    end

    function self:GetState()
        return self._state
    end

    function self:SetEnabled(enabled)
        self._enabled = enabled
        Utility.TweenObject(frame, { }, 0.2) -- just trigger redraw
        labelText.TextTransparency = enabled and 0 or 0.5
    end

    return self
end

--// ============================================================
--// SLIDER WIDGET
--// ============================================================

local Slider = {}
Slider.__index = Slider

function Slider.new(section, text, min, max, default, callback, options)
    local self = setmetatable({}, Slider)
    options = options or {}

    self._min      = min or 0
    self._max      = max or 100
    self._value    = math.clamp(default or min, min, max)
    self._callback = callback
    self._enabled  = true
    self._step     = options.Step     or nil
    self._decimals = options.Decimals or 0
    self._suffix   = options.Suffix   or ""

    -- Outer frame
    local frame = Utility.Create("Frame", {
        Name = "SliderFrame",
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        LayoutOrder = #section.Content:GetChildren(),
        Parent = section.Content,
    })

    -- Label row
    local labelRow = Utility.Create("Frame", {
        Size = UDim2.new(1, 0, 0, 16),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Parent = frame,
    })

    local sliderLabel = Utility.Create("TextLabel", {
        Size = UDim2.new(0.7, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = ThemeManager:GetColor("TextSecondary"),
        TextSize = 11,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = labelRow,
    })

    local valueLabel = Utility.Create("TextLabel", {
        Size = UDim2.new(0.3, 0, 1, 0),
        Position = UDim2.new(0.7, 0, 0, 0),
        BackgroundTransparency = 1,
        Text = tostring(Utility.Round(self._value, self._decimals)) .. self._suffix .. "/" .. tostring(self._max),
        TextColor3 = ThemeManager:GetColor("Primary"),
        TextSize = 10,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = labelRow,
    })

    -- Track background
    local trackBg = Utility.Create("Frame", {
        Name = "TrackBg",
        Size = UDim2.new(1, 0, 0, 8),
        Position = UDim2.new(0, 0, 0, 22),
        BackgroundColor3 = ThemeManager:GetColor("SurfaceHover"),
        BorderSizePixel = 0,
        Parent = frame,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = trackBg })

    -- Fill
    local fillPercent = (self._value - self._min) / (self._max - self._min)

    local fill = Utility.Create("Frame", {
        Name = "Fill",
        Size = UDim2.new(fillPercent, 0, 1, 0),
        BackgroundColor3 = ThemeManager:GetColor("SliderFill"),
        BorderSizePixel = 0,
        Parent = trackBg,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = fill })

    -- Fill glow
    local fillGlow = Utility.Create("Frame", {
        Size = UDim2.new(1, 6, 1, 6),
        Position = UDim2.new(0, -3, 0, -3),
        BackgroundColor3 = ThemeManager:GetColor("Primary"),
        BackgroundTransparency = 0.7,
        BorderSizePixel = 0,
        ZIndex = fill.ZIndex - 1,
        Parent = fill,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = fillGlow })

    -- Thumb
    local thumb = Utility.Create("Frame", {
        Name = "Thumb",
        Size = UDim2.new(0, 14, 0, 14),
        Position = UDim2.new(fillPercent, -7, 0.5, -7),
        BackgroundColor3 = Color3.new(1, 1, 1),
        BorderSizePixel = 0,
        ZIndex = trackBg.ZIndex + 2,
        Parent = trackBg,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = thumb })
    Utility.Create("UIStroke", {
        Color = ThemeManager:GetColor("Primary"),
        Thickness = 2,
        Parent = thumb,
    })

    -- Thumb glow
    local thumbGlow = Utility.Create("Frame", {
        Size = UDim2.new(1, 10, 1, 10),
        Position = UDim2.new(0, -5, 0, -5),
        BackgroundColor3 = ThemeManager:GetColor("Primary"),
        BackgroundTransparency = 0.75,
        BorderSizePixel = 0,
        ZIndex = thumb.ZIndex - 1,
        Parent = thumb,
    })
    Utility.Create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = thumbGlow })

    -- Invisible drag button over track
    local dragBtn = Utility.Create("TextButton", {
        Size = UDim2.new(1, 0, 0, 20),
        Position = UDim2.new(0, 0, 0, 16),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = frame.ZIndex + 5,
        Parent = frame,
    })

    self._frame      = frame
    self._fill       = fill
    self._thumb      = thumb
    self._thumbGlow  = thumbGlow
    self._valueLabel = valueLabel
    self._trackBg    = trackBg

    local dragging = false

    local function updateFromMouse(inputX)
        local trackX      = trackBg.AbsolutePosition.X
        local trackWidth  = trackBg.AbsoluteSize.X
        local relative    = math.clamp((inputX - trackX) / trackWidth, 0, 1)
        local rawValue    = self._min + (self._max - self._min) * relative

        -- Step snapping
        if self._step then
            rawValue = math.floor(rawValue / self._step + 0.5) * self._step
        end

        rawValue = math.clamp(rawValue, self._min, self._max)
        self:SetValue(rawValue)
    end

    dragBtn.MouseButton1Down:Connect(function()
        if not self._enabled then return end
        dragging = true
        updateFromMouse(UserInputService:GetMouseLocation().X)

        -- Thumb pop
        Utility.TweenObject(thumb, { Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(fill.Size.X.Scale, -8, 0.5, -8) }, 0.1)
        Utility.TweenObject(thumbGlow, { BackgroundTransparency = 0.55 }, 0.15)
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateFromMouse(input.Position.X)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
            Utility.TweenObject(thumb, { Size = UDim2.new(0, 14, 0, 14) }, 0.15)
            Utility.TweenObject(thumbGlow, { BackgroundTransparency = 0.75 }, 0.2)
        end
    end)

    -- Hover
    dragBtn.MouseEnter:Connect(function()
        Utility.TweenObject(thumbGlow, { BackgroundTransparency = 0.65 }, 0.2)
    end)
    dragBtn.MouseLeave:Connect(function()
        if not dragging then
            Utility.TweenObject(thumbGlow, { BackgroundTransparency = 0.75 }, 0.2)
        end
    end)

    function self:SetValue(newValue, silent)
        newValue = math.clamp(Utility.Round(newValue, self._decimals), self._min, self._max)
        self._value = newValue

        local pct = (newValue - self._min) / (self._max - self._min)
        Utility.TweenObject(fill, { Size = UDim2.new(pct, 0, 1, 0) }, 0.05)
        thumb.Position = UDim2.new(pct, -7, 0.5, -7)
        valueLabel.Text = tostring(Utility.Round(newValue, self._decimals)) .. self._suffix .. "/" .. tostring(self._max)

        if not silent and self._callback then
            task.spawn(self._callback, newValue)
        end
    end

    function self:GetValue()
        return self._value
    end

    function self:SetEnabled(enabled)
        self._enabled = enabled
        Utility.TweenObject(fill, { BackgroundTransparency = enabled and 0 or 0.5 }, 0.2)
        Utility.TweenObject(sliderLabel, { TextTransparency = enabled and 0 or 0.4 }, 0.2)
    end

    return self
end

