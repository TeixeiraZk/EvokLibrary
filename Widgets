	Utility.MakeStroke(self.Frame, ThemeManager.CurrentTheme.StrokeColor, 1, 0.65)

	self.Title = Utility.CreateInstance("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -70, 1, 0),
		Position = UDim2.new(0, 10, 0, 0),
		Font = Enum.Font.GothamMedium,
		Text = Text or "Keybind",
		TextColor3 = ThemeManager.CurrentTheme.TextColor,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		Parent = self.Frame
	})

	self.KeyButton = Utility.CreateInstance("TextButton", {
		BackgroundColor3 = ThemeManager.CurrentTheme.Background,
		BackgroundTransparency = 0.05,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(56, 20),
		Position = UDim2.new(1, -64, 0.5, -10),
		Font = Enum.Font.GothamMedium,
		Text = self.Key.Name,
		TextColor3 = ThemeManager.CurrentTheme.TextColor,
		TextSize = 11,
		AutoButtonColor = false,
		Parent = self.Frame
	})
	Utility.MakeCorner(self.KeyButton, UDim.new(0, 8))
	Utility.MakeStroke(self.KeyButton, ThemeManager.CurrentTheme.StrokeColor, 1, 0.75)

	self.Listening = false

	self.KeyButton.Activated:Connect(function()
		self.Listening = true
		self.KeyButton.Text = "..."
	end)

	game:GetService("UserInputService").InputBegan:Connect(function(input, gp)
		if gp then return end
		if self.Listening and input.UserInputType == Enum.UserInputType.Keyboard then
			self.Key = input.KeyCode
			self.KeyButton.Text = self.Key.Name
			self.Listening = false
			return
		end
		if input.KeyCode == self.Key then
			if self.Callback then
				task.spawn(self.Callback, self.Key)
			end
		end
	end)

	return self
end

function Keybind:SetKeybind(Key)
	self.Key = Key
	self.KeyButton.Text = Key.Name
end

function Keybind:ListenInput()
	self.Listening = true
	self.KeyButton.Text = "..."
end

function Keybind:SetMode(Mode)
	self.Mode = Mode
end

return Keybind
