function Keybind.Create(Parent, Text, DefaultKey, Callback)
	local self = setmetatable({}, Keybind)

	self.Key = DefaultKey or Enum.KeyCode.RightShift
	self.Callback = Callback
	self.Mode = "Toggle"

	self.Frame = Utility.CreateInstance("Frame", {
		Name = "Keybind",
		BackgroundColor3 = ThemeManager.CurrentTheme.PanelAlt,
		BackgroundTransparency = 0.14,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -4, 0, 34),
		Parent = Parent
	})
