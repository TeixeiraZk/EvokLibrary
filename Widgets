    Utility.Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = listFrame })
    Utility.Create("UIStroke", {
        Color = ThemeManager:GetColor("Border"),
        Thickness = 1,
        Transparency = 0.3,
        Parent = listFrame,
    })

    -- Search bar inside list
    local searchInput = nil
    local listStartY  = 0

    if self._searchable then
        local searchFrame = Utility.Create("Frame", {
            Size = UDim2.new(1, 0, 0, 26),
            BackgroundColor3 = ThemeManager:GetColor("SurfaceHover"),
            BackgroundTransparency = 0.3,
            BorderSizePixel = 0,
            ZIndex = listFrame.ZIndex + 1,
            Parent = listFrame,
        })
        Utility.Create("UICorner", { CornerRadius = UDim.new(0, 5), Parent = searchFrame })

        local searchIcon = Utility.Create("TextLabel", {
            Size = UDim2.new(0, 20, 1, 0),
            BackgroundTransparency = 1,
            Text = "🔍",
            TextSize = 10,
            Font = Enum.Font.Gotham,
            ZIndex = searchFrame.ZIndex + 1,
            Parent = searchFrame,
        })

        searchInput = Utility.Create("TextBox", {
            Size = UDim2.new(1, -22, 1, 0),
            Position = UDim2.new(0, 20, 0, 0),
            BackgroundTransparency = 1,
            Text = "",
            PlaceholderText = "Search...",
            TextColor3 = ThemeManager:GetColor("TextPrimary"),
            PlaceholderColor3 = ThemeManager:GetColor("TextMuted"),
            TextSize = 11,
            Font = Enum.Font.Gotham,
            TextXAlignment = Enum.TextXAlignment.Left,
            ClearTextOnFocus = false,
            ZIndex = searchFrame.ZIndex + 1,
            Parent = searchFrame,
        })
        listStartY = 28
    end

    local scrollFrame = Utility.Create("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, -listStartY),
        Position = UDim2.new(0, 0, 0, listStartY),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = ThemeManager:GetColor("ScrollBar"),
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ZIndex = listFrame.ZIndex + 1,
        Parent = listFrame,
    })

    local listLayout = Utility.Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 2),
        Parent = scrollFrame,
    })

    Utility.Create("UIPadding", {
        PaddingTop    = UDim.new(0, 4),
        PaddingBottom = UDim.new(0, 4),
        PaddingLeft   = UDim.new(0, 4),
        PaddingRight  = UDim.new(0, 4),
        Parent = scrollFrame,
    })

    self._wrapper       = wrapper
    self._btn           = btn
    self._listFrame     = listFrame
    self._scrollFrame   = scrollFrame
    self._selectedLabel = selectedLabel
    self._arrow         = arrow
    self._searchInput   = searchInput
    self._itemHeight    = itemHeight
    self._maxHeight     = maxHeight
    self._listStartY    = listStartY

    -- Build option items
    local function buildItems(filter)
        filter = filter and filter:lower() or ""

        -- Clear existing
        for _, child in ipairs(scrollFrame:GetChildren()) do
            if child:IsA("Frame") then child:Destroy() end
        end

        local visible = 0
        for _, optName in ipairs(self._options) do
            if filter == "" or optName:lower():find(filter, 1, true) then
                visible = visible + 1
                local isSelected = (optName == self._selected)

                local item = Utility.Create("Frame", {
                    Name = "Item_" .. optName,
                    Size = UDim2.new(1, 0, 0, itemHeight),
                    BackgroundColor3 = isSelected
                        and ThemeManager:GetColor("Primary")
                        or  Color3.new(1, 1, 1),
                    BackgroundTransparency = isSelected and 0.15 or 0.95,
                    BorderSizePixel = 0,
                    LayoutOrder = visible,
                    Parent = scrollFrame,
                })
                Utility.Create("UICorner", { CornerRadius = UDim.new(0, 4), Parent = item })

                local itemLabel = Utility.Create("TextLabel", {
                    Size = UDim2.new(1, -8, 1, 0),
                    Position = UDim2.new(0, 8, 0, 0),
                    BackgroundTransparency = 1,
                    Text = optName,
                    TextColor3 = isSelected
                        and Color3.new(0, 0, 0)
                        or  ThemeManager:GetColor("TextSecondary"),
                    TextSize = 11,
                    Font = isSelected and Enum.Font.GothamBold or Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = item.ZIndex + 1,
                    Parent = item,
                })

                local itemBtn = Utility.Create("TextButton", {
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text = "",
                    ZIndex = item.ZIndex + 2,
                    Parent = item,
                })

                itemBtn.MouseEnter:Connect(function()
                    if optName ~= self._selected then
                        Utility.TweenObject(item, { BackgroundTransparency = 0.8 }, 0.15)
                        Utility.TweenObject(itemLabel, { TextColor3 = ThemeManager:GetColor("TextPrimary") }, 0.15)
                    end
                end)

                itemBtn.MouseLeave:Connect(function()
                    if optName ~= self._selected then
                        Utility.TweenObject(item, { BackgroundTransparency = 0.95 }, 0.15)
                        Utility.TweenObject(itemLabel, { TextColor3 = ThemeManager:GetColor("TextSecondary") }, 0.15)
                    end
                end)

                itemBtn.MouseButton1Click:Connect(function()
                    self:SelectOption(optName)
                    self:_Close()
                end)
            end
        end

        return visible
    end

    -- Search filter
    if searchInput then
        searchInput:GetPropertyChangedSignal("Text"):Connect(function()
            local count = buildItems(searchInput.Text)
            local listH = math.min(count * itemHeight + 12, maxHeight) + listStartY
            listFrame.Size = UDim2.new(1, 0, 0, listH)
        end)
    end

    function self:_Open()
        self._open = true
        buildItems("")
        if searchInput then searchInput.Text = "" end

        local itemCount = #self._options
        local listH = math.min(itemCount * itemHeight + 12, maxHeight) + listStartY
        wrapper.Size = UDim2.new(1, 0, 0, 46 + listH + 4)

        listFrame.Visible = true
        listFrame.Size = UDim2.new(1, 0, 0, 0)
        Utility.TweenObject(listFrame, { Size = UDim2.new(1, 0, 0, listH) }, 0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        Utility.TweenObject(arrow, { Rotation = 180 }, 0.25)
    end

    function self:_Close()
        self._open = false
        Utility.TweenObject(listFrame, { Size = UDim2.new(1, 0, 0, 0) }, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
        Utility.TweenObject(arrow, { Rotation = 0 }, 0.2)
        task.delay(0.22, function()
            listFrame.Visible = false
            wrapper.Size = UDim2.new(1, 0, 0, 46)
        end)
    end

    clickBtn.MouseButton1Click:Connect(function()
        if not self._enabled then return end
        if self._open then
            self:_Close()
        else
            self:_Open()
        end
    end)

    -- Hover
    clickBtn.MouseEnter:Connect(function()
        Utility.TweenObject(btn, { BackgroundTransparency = 0.0 }, 0.2)
    end)
    clickBtn.MouseLeave:Connect(function()
        Utility.TweenObject(btn, { BackgroundTransparency = 0.1 }, 0.2)
    end)

    function self:SelectOption(optName, silent)
        self._selected = optName
        selectedLabel.Text      = optName
        selectedLabel.TextColor3 = ThemeManager:GetColor("TextPrimary")
        if not silent and self._callback then
            task.spawn(self._callback, optName)
        end
        buildItems("")
    end

    function self:AddOption(optName)
        table.insert(self._options, optName)
    end

    function self:RemoveOption(optName)
        for i, v in ipairs(self._options) do
            if v == optName then
                table.remove(self._options, i)
                break
            end
        end
        if self._selected == optName then
            self._selected = nil
            selectedLabel.Text = "Select..."
            selectedLabel.TextColor3 = ThemeManager:GetColor("TextMuted")
        end
    end

    function self:SetOptions(newOptions)
        self._options = newOptions
    end

    function self:GetSelected()
        return self._selected
    end

    function self:SetEnabled(enabled)
        self._enabled = enabled
        Utility.TweenObject(btn, { BackgroundTransparency = enabled and 0.1 or 0.5 }, 0.2)
    end

    return self
end

