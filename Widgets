local Utility = require(script.Parent.Parent.Core.Utility)
local ThemeManager = require(script.Parent.Parent.Core.ThemeManager)

local TabSystem = {}
TabSystem.__index = TabSystem

function TabSystem.CreateTabSystem(Window)
	local self = setmetatable({}, TabSystem)

	self.Window = Window
	self.Container = Utility.CreateInstance("Frame", {
		Name = "TabSystem",
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		Parent = Window.Content
	})

	self.TabBar = Utility.CreateInstance("Frame", {
		Name = "TabBar",
		BackgroundColor3 = ThemeManager.CurrentTheme.Panel,
		BackgroundTransparency = 0.15,
		BorderSizePixel = 0,
		Size = UDim2.new(1, -16, 0, 28),
		Position = UDim2.new(0, 8, 0, 8),
		Parent = self.Container
	})
	Utility.MakeCorner(self.TabBar, UDim.new(0, 10))
	Utility.MakeStroke(self.TabBar, ThemeManager.CurrentTheme.StrokeColor, 1, 0.5)

	self.TabHolder = Utility.CreateInstance("Frame", {
		Name = "TabHolder",
		BackgroundTransparency = 1,
		Size = UDim2.new(1, -12, 1, -44),
		Position = UDim2.new(0, 6, 0, 42),
		Parent = self.Container
	})

	self.TabList = {}
	self.Pages = {}
	self.Selected = nil

	self.ListLayout = Utility.MakeListLayout(self.TabBar, 6, Enum.FillDirection.Horizontal, Enum.SortOrder.LayoutOrder)
	self.ListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
	self.InnerPadding = Utility.MakePadding(self.TabBar, 8, 8, 0, 0)

	return self
end

function TabSystem:CreateTab(Name)
	local Tab = {}
	local Button = Utility.CreateInstance("TextButton", {
		Name = Name,
		BackgroundColor3 = ThemeManager.CurrentTheme.PanelAlt,
		BackgroundTransparency = 0.15,
		BorderSizePixel = 0,
		Size = UDim2.fromOffset(92, 20),
		AutoButtonColor = false,
		Text = "",
		Parent = self.TabBar
	})
	Utility.MakeCorner(Button, UDim.new(0, 8))
	Utility.MakeStroke(Button, ThemeManager.CurrentTheme.StrokeColor, 1, 0.7)

	local Label = Utility.CreateInstance("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		Font = Enum.Font.GothamMedium,
		Text = Name,
		TextSize = 12,
		TextColor3 = ThemeManager.CurrentTheme.MutedTextColor,
		Parent = Button
	})

	local Indicator = Utility.CreateInstance("Frame", {
		Name = "Indicator",
		BackgroundColor3 = ThemeManager.CurrentTheme.PrimaryColor,
		BackgroundTransparency = 0.1,
		BorderSizePixel = 0,
		Size = UDim2.new(0, 0, 0, 2),
		Position = UDim2.new(0.5, 0, 1, -2),
		AnchorPoint = Vector2.new(0.5, 1),
		Parent = Button
	})
	Utility.MakeCorner(Indicator, UDim.new(0, 2))

	local Page = Utility.CreateInstance("Frame", {
		Name = Name .. "Page",
		BackgroundTransparency = 1,
		Size = UDim2.new(1, 0, 1, 0),
		Visible = false,
		Parent = self.TabHolder
	})

	Tab.Button = Button
	Tab.Label = Label
	Tab.Indicator = Indicator
	Tab.Page = Page
	Tab.Name = Name

	table.insert(self.TabList, Tab)
	self.Pages[Name] = Tab

	Button.MouseEnter:Connect(function()
		if self.Selected ~= Tab then
			Utility.TweenObject(Button, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				BackgroundTransparency = 0.05
			})
			Utility.TweenObject(Label, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				TextColor3 = ThemeManager.CurrentTheme.TextColor
			})
		end
	end)

	Button.MouseLeave:Connect(function()
		if self.Selected ~= Tab then
			Utility.TweenObject(Button, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				BackgroundTransparency = 0.15
			})
			Utility.TweenObject(Label, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				TextColor3 = ThemeManager.CurrentTheme.MutedTextColor
			})
		end
	end)

	Button.Activated:Connect(function()
		self:SelectTab(Name)
	end)

	if not self.Selected then
		self:SelectTab(Name)
	end

	return Tab
end

function TabSystem:SelectTab(Name)
	local NewTab = self.Pages[Name]
	if not NewTab then
		return
	end

	for _, Tab in ipairs(self.TabList) do
		local Selected = Tab == NewTab
		Tab.Page.Visible = Selected

		if Selected then
			Utility.TweenObject(Tab.Button, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				BackgroundTransparency = 0
			})
			Utility.TweenObject(Tab.Label, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				TextColor3 = ThemeManager.CurrentTheme.TextColor
			})
			Utility.TweenObject(Tab.Indicator, TweenInfo.new(0.24, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				Size = UDim2.new(0.72, 0, 0, 2)
			})
		else
			Utility.TweenObject(Tab.Button, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				BackgroundTransparency = 0.15
			})
			Utility.TweenObject(Tab.Label, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				TextColor3 = ThemeManager.CurrentTheme.MutedTextColor
			})
			Utility.TweenObject(Tab.Indicator, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
				Size = UDim2.new(0, 0, 0, 2)
			})
		end
	end

	self.Selected = NewTab
end

function TabSystem:GetSelected()
	return self.Selected
end

return TabSystem

